# Multi-stage build for BNG Blaster BGP stress testing tool.
# Produces an Ubuntu image with bngblaster, bngblaster-cli, and bgpupdate.
#
# Works on both amd64 and arm64 (Apple Silicon / aarch64).
# libdict is built from source to support any architecture.
#
# Usage:
#   docker buildx build --load -t ze-stress-bb -f Dockerfile.bngblaster .
#   docker buildx build --load --platform linux/amd64 -t ze-stress-bb -f Dockerfile.bngblaster .

FROM ubuntu:24.04 AS builder

RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential cmake git wget ca-certificates \
    libncurses-dev libssl-dev libjansson-dev libpcap-dev \
    && rm -rf /var/lib/apt/lists/*

# Build libdict from source (works on any architecture).
RUN git clone --depth 1 https://github.com/rtbrick/libdict.git /libdict \
    && cd /libdict \
    && mkdir build && cd build \
    && cmake .. -DCMAKE_BUILD_TYPE=Release -DCMAKE_INSTALL_PREFIX=/usr -DLIBDICT_TESTS=OFF -DLIBDICT_TOOLS=OFF \
    && cmake --build . -j$(nproc) \
    && cmake --install .

# Build bngblaster.
RUN git clone --depth 1 https://github.com/rtbrick/bngblaster.git /bngblaster \
    && cd /bngblaster \
    && mkdir build && cd build \
    && cmake .. -DCMAKE_BUILD_TYPE=Release \
    && cmake --build . -j$(nproc)

FROM ubuntu:24.04

RUN apt-get update && apt-get install -y --no-install-recommends \
    libssl3t64 libncurses6 libjansson4 libpcap0.8t64 \
    python3 python3-pip python3-venv \
    jq socat \
    && rm -rf /var/lib/apt/lists/*

# Install scapy for bgpupdate.
RUN pip3 install --break-system-packages scapy

COPY --from=builder /bngblaster/build/code/bngblaster/bngblaster /usr/sbin/bngblaster
COPY --from=builder /bngblaster/code/bngblaster-cli /usr/sbin/bngblaster-cli
COPY --from=builder /bngblaster/code/bgpupdate /usr/bin/bgpupdate

# Install libdict shared library (built from source, arch-native).
COPY --from=builder /usr/lib/libdict.* /usr/lib/
RUN ldconfig

RUN chmod +x /usr/sbin/bngblaster /usr/sbin/bngblaster-cli /usr/bin/bgpupdate

WORKDIR /test
ENTRYPOINT ["/usr/sbin/bngblaster"]
