# Test: daemon quit command dumps goroutines and exits
# VALIDATES: daemon quit RPC dispatches, dumps stacks, daemon exits cleanly
# PREVENTS: quit command broken or daemon hanging after quit

# ze-peer expectations
stdin=peer:terminator=EOF_PEER
option=tcp_connections:value=1
option=timeout:value=15s

# EOR
expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF00170200000000

# After EOR: send SIGTERM to trigger shutdown (quit is tested via plugin dispatch)
action=sigterm:conn=1:seq=2
EOF_PEER

# Python test plugin: dispatches daemon quit
tmpfs=quit-test.run:mode=755:terminator=EOF_RUN
#!/usr/bin/env python3
import sys
import time
from ze_api import API

def dispatch(api, command):
    resp = api._call_engine(
        'ze-plugin-engine:dispatch-command', {'command': command})
    if resp is None:
        return {'status': 'error', 'data': 'engine call returned None'}
    return resp.get('result', {})

def main():
    api = API()
    api.declare_done()
    api.wait_for_config()
    api.capability_done()
    api.wait_for_registry()
    api.ready()
    time.sleep(1.0)

    try:
        result = dispatch(api, 'daemon quit')
        if result.get('status') != 'done':
            print(f'FAIL: quit status={result.get("status")}', file=sys.stderr)
            sys.exit(1)
        print('OK: daemon quit dispatched', file=sys.stderr)
    finally:
        api.wait_for_shutdown()

if __name__ == '__main__':
    main()
EOF_RUN

# ze bgp configuration
tmpfs=ze-bgp.conf:terminator=EOF_CONF
plugin {
	external quit-test {
		run ./quit-test.run
		encoder json
	}
}

bgp {
	peer peer1 {
		connection {
			remote {
				ip 127.0.0.1
			}
			local {
				ip 127.0.0.1
				accept false
			}
		}
		session {
			asn {
				local 1
				remote 1
			}
			router-id 1.2.3.4
			family {
				ipv4/unicast { prefix { maximum 10000; } }
			}
			capability {
				graceful-restart disable
			}
		}
		behavior {
			group-updates disable
		}

		process quit-test {
		}
	}
}
EOF_CONF

# Process orchestration
cmd=background:seq=1:exec=ze-peer --port $PORT:stdin=peer
cmd=foreground:seq=2:exec=ze ze-bgp.conf:timeout=15s
expect=exit:code=0
