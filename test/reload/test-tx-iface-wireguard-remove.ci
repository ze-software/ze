# Test: WireGuard interface removed via SIGHUP-applied transaction
# Initial config has BGP + wireguard wg0 with one peer. Updated config
# drops the wireguard block entirely; Phase 4 reconciliation in
# applyConfig must delete wg0 via DeleteInterface because the netlink
# link type "wireguard" was added to zeManageable in Phase 9. The BGP
# peer connection must hold through the reload.
#
# Wiring test: kernel-level delete may succeed or fail depending on
# test runner privileges; failures are logged at Debug and do not
# crash the daemon.

stdin=peer:terminator=EOF_PEER

expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF00300200000015400101004002004003040A0000014005040000006418C0A801
expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF00170200000000
EOF_PEER

stdin=ze-bgp:terminator=EOF_CONF
bgp {
	peer peer1 {
		connection {
			remote {
				ip 127.0.0.1
				accept false
			}
			local {
				ip 127.0.0.1
			}
		}
		session {
			asn {
				local 1
				remote 1
			}
			router-id 1.2.3.4
			family {
				ipv4/unicast { prefix { maximum 10000; } }
			}
			capability {
				graceful-restart disable
			}
		}
		behavior {
			group-updates disable
		}

		update {
			attribute {
				origin igp
				local-preference 100
				next-hop 10.0.0.1
			}
			nlri {
				ipv4/unicast add 192.168.1.0/24
			}
		}
	}
}

interface {
	wireguard wg0 {
		listen-port 51820
		private-key "AQEBAQEBAQEBAQEBAQEBAQEBAQEBAQEBAQEBAQEBAQE="
		peer site2 {
			public-key "AgICAgICAgICAgICAgICAgICAgICAgICAgICAgICAgI="
			allowed-ips [ 10.0.0.2/32 ]
		}
	}
}
EOF_CONF

# Updated config: BGP only, no wireguard. Phase 4 must delete wg0.
tmpfs=config2.conf:terminator=EOF_CONF2
bgp {
	peer peer1 {
		connection {
			remote {
				ip 127.0.0.1
				accept false
			}
			local {
				ip 127.0.0.1
			}
		}
		session {
			asn {
				local 1
				remote 1
			}
			router-id 1.2.3.4
			family {
				ipv4/unicast { prefix { maximum 10000; } }
			}
			capability {
				graceful-restart disable
			}
		}
		behavior {
			group-updates disable
		}

		update {
			attribute {
				origin igp
				local-preference 100
				next-hop 10.0.0.1
			}
			nlri {
				ipv4/unicast add 192.168.1.0/24
			}
		}
	}
}
EOF_CONF2

tmpfs=trigger.sh:mode=755:terminator=EOF_TRIGGER
#!/bin/sh
while [ ! -f daemon.pid ]; do sleep 0.1; done
while [ ! -f daemon.ready ]; do sleep 0.1; done
sleep 2
cp config2.conf ze-bgp.conf
kill -HUP $(cat daemon.pid)
sleep 2
kill -TERM $(cat daemon.pid)
EOF_TRIGGER

cmd=background:seq=1:exec=ze-peer --port $PORT:stdin=peer
cmd=background:seq=2:exec=sh trigger.sh
cmd=foreground:seq=3:exec=ze -:stdin=ze-bgp:timeout=20s
