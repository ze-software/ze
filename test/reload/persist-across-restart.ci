# Test: bgp-persist plugin replays routes after config reload
# VALIDATES: persist plugin saves API routes and replays after SIGHUP restart
# PREVENTS: routes lost after reload requiring process to re-send

# ze-peer expectations
stdin=peer:terminator=EOF_PEER
option=tcp_connections:value=2
option=timeout:value=20s

# Connection 1: Process sends route (192.168.1.0/24) + EOR
expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF00300200000015400101004002004003040A0000014005040000006418C0A801
expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF00170200000000

# After route received: rewrite config (identical) and SIGHUP to trigger reload
action=rewrite:conn=1:seq=2:source=config2.conf:dest=ze-bgp.conf
action=sighup:conn=1:seq=2

# Connection 2: Persist plugin replays the route on reconnect + EOR
expect=bgp:conn=2:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF00300200000015400101004002004003040A0000014005040000006418C0A801
expect=bgp:conn=2:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF00170200000000
EOF_PEER

# Python plugin script: sends a route then waits
tmpfs=persist-test.run:mode=755:terminator=EOF_RUN
#!/usr/bin/env python3
import time
from ze_api import ready, send, wait_for_shutdown

def main():
    ready()
    send('peer * update text origin igp local-preference 100 nhop 10.0.0.1 nlri ipv4/unicast add 192.168.1.0/24')
    wait_for_shutdown()

if __name__ == '__main__':
    main()
EOF_RUN

# Initial ze bgp configuration (tmpfs so it can be rewritten by action=rewrite)
tmpfs=ze-bgp.conf:terminator=EOF_CONF
plugin {
	external persist-test {
		run ./persist-test.run
		encoder json
	}
	external persist {
		run "ze plugin bgp-persist"
		encoder json
	}
}

environment {
	tcp {
		attempts 3
	}
}

bgp {
	peer 127.0.0.1 {
		router-id 1.2.3.4
		local-address 127.0.0.1
		local-as 1
		peer-as 1
		connection active
		group-updates disable

		family {
			ipv4/unicast
		}
		capability {
			graceful-restart disable
		}
		process persist-test {
			send [ update ]
		}
		process persist {
			send [ update ]
		}
	}
}
EOF_CONF

# Rewritten config (identical -- reload triggers peer restart)
tmpfs=config2.conf:terminator=EOF_CONF2
plugin {
	external persist-test {
		run ./persist-test.run
		encoder json
	}
	external persist {
		run "ze plugin bgp-persist"
		encoder json
	}
}

environment {
	tcp {
		attempts 3
	}
}

bgp {
	peer 127.0.0.1 {
		router-id 1.2.3.4
		local-address 127.0.0.1
		local-as 1
		peer-as 1
		connection active
		group-updates disable

		family {
			ipv4/unicast
		}
		capability {
			graceful-restart disable
		}
		process persist-test {
			send [ update ]
		}
		process persist {
			send [ update ]
		}
	}
}
EOF_CONF2

# Process orchestration
cmd=background:seq=1:exec=ze-peer --port $PORT:stdin=peer
cmd=foreground:seq=2:exec=ze ze-bgp.conf:timeout=20s
