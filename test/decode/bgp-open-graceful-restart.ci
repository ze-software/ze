cmd=foreground:seq=1:exec=ze-test decode --json --plugin bgp-gr --open -:stdin=payload
expect=json:json={"bgp":{"message":{"direction":"received","id":0,"type":"open"},"open":{"asn":65533,"capabilities":[{"code":1,"name":"multiprotocol","value":"ipv4/unicast"},{"code":65,"name":"asn4","value":"65533"},{"code":64,"families":[{"afi":1,"forward-state":true,"safi":1}],"name":"graceful-restart","notification":false,"restart-flags":0,"restart-time":120,"restarting":false}],"router-id":"10.0.0.2","timer":{"hold-time":180}},"peer":{"address":"127.0.0.1","remote":{"as":65533}}},"type":"bgp"}
