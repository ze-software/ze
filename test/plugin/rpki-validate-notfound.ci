# Test: RPKI validation accepts route with no ROA coverage (NotFound)
# VALIDATES: Route with no covering VRP is accepted with state=NotFound (AC-4)
# PREVENTS: RPKI plugin blocking routes when no ROA exists

# ze-peer: send route 192.168.0.0/24 from AS 65001 (VRP only covers 10.0.0.0/8)
stdin=peer:terminator=EOF_PEER
option=tcp_connections:value=1
option=timeout:value=15s
option=update:value=send-route:prefix=192.168.0.0/24:origin-as=65001:next-hop=10.0.0.1
# EOR from ze
expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF00170200000000
EOF_PEER

# Python test plugin: verifies route accepted with NotFound state
tmpfs=rpki-notfound-test.run:mode=755:terminator=EOF_RUN
#!/usr/bin/env python3
import json
import sys
import time
from ze_api import API

def dispatch(api, command):
    resp = api._call_engine(
        'ze-plugin-engine:dispatch-command', {'command': command})
    if resp is None:
        return {'status': 'error', 'data': 'engine call returned None'}
    return resp.get('result', {})

def main():
    api = API()
    api.declare_done()
    api.wait_for_config()
    api.capability_done()
    api.wait_for_registry()
    api.ready()

    time.sleep(4.0)

    try:
        result = dispatch(api, 'rib routes received')
        if result.get('status') != 'done':
            print(f'FAIL: rib routes received status={result.get("status")}', file=sys.stderr)
            sys.exit(1)

        data = result.get('data', '')
        if '192.168.0.0/24' not in data:
            print(f'FAIL: route 192.168.0.0/24 not in adj-rib-in: {data}', file=sys.stderr)
            sys.exit(1)

        # Check validation state is NotFound (2)
        if '"validation-state":2' not in data and '"validation-state": 2' not in data:
            print(f'FAIL: validation-state not 2 (NotFound): {data}', file=sys.stderr)
            sys.exit(1)

        print('OK: route 192.168.0.0/24 accepted with validation-state=NotFound', file=sys.stderr)
    finally:
        dispatch(api, 'daemon shutdown')
        api.wait_for_shutdown()

if __name__ == '__main__':
    main()
EOF_RUN

stdin=ze-bgp:terminator=EOF_CONF
plugin {
	hub {
		listen 127.0.0.1:0;
		secret rpki-test-secret-key-01234567890;
	}
	external rpki-notfound-test {
		run ./rpki-notfound-test.run
		encoder json
	}
	external rpki {
		run "ze plugin bgp-rpki"
		encoder json
	}
	external adj-rib-in {
		run "ze plugin bgp-adj-rib-in"
		encoder json
	}
}

environment {
	tcp {
		attempts 3
	}
}

bgp {
	rpki {
		cache-server 127.0.0.1 {
			port $PORT2
		}
	}
	peer peer1 {
		remote {
			ip 127.0.0.1
			as 1
			accept false
		}
		local {
			as 1
			ip 127.0.0.1
		}
		router-id 1.2.3.4
		group-updates disable

		family {
			ipv4/unicast { prefix { maximum 10000; } }
		}
		capability {
			graceful-restart disable
		}
		process rpki-notfound-test {
		}
		process rpki {
			receive [ update ]
		}
		process adj-rib-in {
			receive [ update state ]
		}
	}
}
EOF_CONF

# VRP: 10.0.0.0/8 maxlen=24 AS=65001 (192.168.0.0/24 not covered = NotFound)
cmd=background:seq=1:exec=ze-rtr-mock --port $PORT2 --vrp 10.0.0.0/8,24,65001
cmd=background:seq=2:exec=ze-peer --port $PORT:stdin=peer
cmd=foreground:seq=3:exec=ze -:stdin=ze-bgp:timeout=20s
expect=exit:code=0
