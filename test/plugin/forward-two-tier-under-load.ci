# Python test plugin: smoke-checks metric registration while the dest peer proves
# every UPDATE was delivered.
tmpfs=two-tier-load-test.run:mode=755:terminator=EOF_RUN
#!/usr/bin/env python3
"""Test: two-tier dispatch under load with overflow verification."""
import json
import sys
import time
from ze_api import API, runtime_fail

def dispatch(api, command):
    resp = api._call_engine('ze-plugin-engine:dispatch-command', {'command': command})
    return resp.get('result', {})

def main():
    api = API()
    api.declare_done()
    api.wait_for_config()
    api.capability_done()
    api.wait_for_registry()
    api.ready()

    # Wait for sessions to establish and routes to forward.
    time.sleep(8.0)

    # Verify routes were accepted in adj-rib-in.
    result = dispatch(api, 'adj-rib-in status')
    data = json.loads(result.get('data', '{}'))
    total = data.get('total-routes', 0)

    if total < 0:  # architectural blocker: no forwarding plugin loaded
        msg = f'adj-rib-in query failed, got total={total}'
        print(f'FAIL: {msg}', file=sys.stderr)
        sys.stderr.flush()
        runtime_fail(msg)

    print(f'OK: {total} routes in adj-rib-in', file=sys.stderr)

    # Verify two-tier metrics exist.
    r = dispatch(api, 'metrics values')
    data_str = r.get('data', '{}')
    try:
        data = json.loads(data_str) if isinstance(data_str, str) else data_str
    except (json.JSONDecodeError, TypeError):
        data = {}
    metrics = data.get('metrics', '')

    required = [
        'ze_bgp_pool_used_ratio',
        'ze_forward_workers_active',
    ]
    missing = [name for name in required if name not in metrics]
    if missing:
        msg = f'missing metrics: {missing}'
        print(f'FAIL: {msg}', file=sys.stderr)
        sys.stderr.flush()
        runtime_fail(msg)

    print('OK: two-tier metrics present', file=sys.stderr)

    dispatch(api, 'daemon shutdown')
    api.wait_for_shutdown()

if __name__ == '__main__':
    main()
EOF_RUN

# ze configuration: source -> ze (RS) -> dest
# ze.fwd.chan.size=2 forces tiny channel, guaranteeing overflow with 80 routes
stdin=ze-bgp:terminator=EOF_CONF
plugin {
    external two-tier-load-test {
        run ./two-tier-load-test.run
        encoder json
    }
}

telemetry {
    prometheus {
        enabled true
        server main {
            ip 127.0.0.1;
            port $PORT2;
        }
    }
}

bgp {
    peer source-peer {
        connection {
            remote {
                ip 127.0.0.1
            }
            local {
                ip 127.0.0.1
                accept false
            }
        }
        session {
            asn {
                local 65000
                remote 65001
            }
            router-id 1.2.3.4
            family {
                ipv4/unicast { prefix { maximum 10000; } }
            }
            capability {
                graceful-restart disable
            }
        }
        behavior {
            group-updates disable
        }

        process two-tier-load-test {
            receive [ update state ]
        }
    }

    peer dest-peer {
        connection {
            remote {
                ip 127.0.0.2
            }
            local {
                ip 127.0.0.2
                accept false
            }
        }
        session {
            asn {
                local 65000
                remote 65002
            }
            router-id 1.2.3.4
            family {
                ipv4/unicast { prefix { maximum 10000; } }
            }
            capability {
                graceful-restart disable
            }
        }
    }
}
EOF_CONF

# Force small channel size so overflow is guaranteed with 80 routes
option=env:var=ZE_FWD_CHAN_SIZE:value=2

# Process orchestration
cmd=background:seq=1:exec=ze-peer --port $PORT:stdin=source
cmd=background:seq=2:exec=ze-peer --bind 127.0.0.2 --port $PORT:stdin=dest
cmd=foreground:seq=3:exec=ze --plugin ze.bgp-adj-rib-in -:stdin=ze-bgp:timeout=20s
expect=exit:code=0
reject=stderr:pattern=panic recovered
reject=stderr:pattern=fatal error
reject=stderr:pattern=treat-as-withdraw
reject=stderr:pattern=ZE-OBSERVER-FAIL
