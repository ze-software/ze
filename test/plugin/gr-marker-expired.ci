# gr-marker-expired - verify expired GR marker produces cold start (R=0)
#
# Flow:
# 1. Shell script creates an expired GR marker (timestamp in the past)
# 2. Ze starts with GR capability (restart-time=120) and filesystem storage
# 3. Ze reads marker, finds it expired, discards it (no RestartUntil set)
# 4. Ze connects to ze-peer, session establishes with R=0 (cold start)
#
# VALIDATES: AC-4 -- startup with expired marker produces R=0, marker removed.
# PREVENTS: Stale marker causing R=1 after restart window expired.

# Shell script to create expired marker before ze starts
tmpfs=create-expired-marker.sh:mode=755:terminator=EOF_MARKER
#!/bin/sh
set -e
mkdir -p meta/bgp
# Past timestamp (September 9, 2001): 1000000000 = 0x000000003B9ACA00
# 8-byte big-endian int64 UNIX seconds (octal: \x not portable in /bin/sh)
printf '\000\000\000\000\073\232\312\000' > meta/bgp/gr-marker
EOF_MARKER

# ze-peer expectations
stdin=peer:terminator=EOF_PEER
option=timeout:value=15s

# Enable GR subsystem logging to confirm marker is NOT detected as valid
option=env:var=ze.log.bgp.gr:value=info

# Session establishes normally (cold start behavior): UPDATE + EOR
expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF00300200000015400101004002004003040A0000014005040000006418C0A801
expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF00170200000000
EOF_PEER

# Marker was expired -- "GR restart marker found" must NOT appear.
# reject= must be outside the peer block (only expect=/action= are parsed inside).
# Uses pattern= (not contains=) because parseReject only supports pattern=.
reject=stderr:pattern=GR restart marker found

# ze bgp configuration (identical to gr-marker-cold-start)
stdin=ze-bgp:terminator=EOF_CONF
plugin {
	external gr {
		use bgp-gr
		encoder json
	}
	external bgp-rib {
		use bgp-rib
		encoder json
	}
}

bgp {
	peer peer1 {
		connection {
			remote {
				ip 127.0.0.1
				accept false
			}
			local {
				ip 127.0.0.1
			}
		}
		session {
			asn {
				local 1
				remote 1
			}
			router-id 1.2.3.4
			family {
				ipv4/unicast { prefix { maximum 10000; } }
			}
			capability {
				graceful-restart {
					restart-time 120
				}
			}
		}
		behavior {
			group-updates disable
		}


		update {
			attribute {
				origin igp
				local-preference 100
				next-hop 10.0.0.1
			}
			nlri {
				ipv4/unicast add 192.168.1.0/24
			}
		}

		process gr {
			send [ update ]
		}
		process bgp-rib {
			send [ update ]
		}
	}
}
EOF_CONF

# Process orchestration:
# 1. Create expired marker file (foreground, completes instantly)
# 2. Start ze-peer (background, waits for connection)
# 3. Start ze with expired marker (foreground, discards marker on startup)
cmd=foreground:seq=1:exec=./create-expired-marker.sh
cmd=background:seq=2:exec=ze-peer --port $PORT:stdin=peer
cmd=foreground:seq=3:exec=ze -:stdin=ze-bgp:timeout=15s
