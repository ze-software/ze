# Test: RIB graph terminal with prefix filter applied before graph
#
# Flow:
# 1. Inject two routes with different prefixes and AS paths
# 2. Run graph with prefix filter to select only one
# 3. Verify filtered graph contains only the matching route's ASNs
#
# VALIDATES: AC-5 "Filters applied before graph construction"
# PREVENTS: Graph ignoring filter stages, showing all routes regardless.

# ze-peer expectations
stdin=peer:terminator=EOF_PEER
option=tcp_connections:value=1
option=timeout:value=15s
EOF_PEER

# Python test plugin
tmpfs=rib-graph-filtered-test.run:mode=755:terminator=EOF_RUN
#!/usr/bin/env python3
"""Test: RIB graph terminal with filters."""

import sys
import time

from ze_api import API, runtime_fail


failures = 0


def dispatch(api, command):
    resp = api._call_engine(
        'ze-plugin-engine:dispatch-command', {'command': command})
    return resp.get('result', {})


def check(label, result, expected_status):
    global failures
    actual = result.get('status')
    if actual != expected_status:
        print(f'FAIL {label}: expected status={expected_status}, got={actual}', file=sys.stderr)
        failures += 1
    else:
        print(f'OK {label}: status={actual}', file=sys.stderr)


def check_contains(label, result, substring):
    global failures
    data = result.get('data', '')
    if substring not in data:
        print(f'FAIL {label}: output does not contain {substring!r}', file=sys.stderr)
        print(f'  got: {data[:200]!r}', file=sys.stderr)
        failures += 1
    else:
        print(f'OK {label}: contains {substring!r}', file=sys.stderr)


def check_not_contains(label, result, substring):
    global failures
    data = result.get('data', '')
    if substring in data:
        print(f'FAIL {label}: output should not contain {substring!r}', file=sys.stderr)
        failures += 1
    else:
        print(f'OK {label}: does not contain {substring!r}', file=sys.stderr)


def main():
    global failures
    api = API()
    api.declare_done()
    api.wait_for_config()
    api.capability_done()
    api.wait_for_registry()
    api.ready()

    time.sleep(1.0)
    for _ in range(20):
        r = dispatch(api, 'bgp rib status')
        if r.get('status') == 'done':
            break
        time.sleep(0.5)
    else:
        print('FAIL: rib plugin did not become ready', file=sys.stderr)
        failures += 1

    # Route 1: 10.10.1.0/24 via AS64501->AS64502
    r = dispatch(api, 'bgp rib inject 10.0.0.1 ipv4/unicast 10.10.1.0/24 aspath 64501,64502')
    check('inject-1', r, 'done')

    # Route 2: 10.20.1.0/24 via AS64601->AS64602 (different prefix space)
    r = dispatch(api, 'bgp rib inject 10.0.0.2 ipv4/unicast 10.20.1.0/24 aspath 64601,64602')
    check('inject-2', r, 'done')

    # Filter to 10.10 prefix and graph
    r = dispatch(api, 'bgp rib show received prefix 10.10 graph')
    check('filtered-graph', r, 'done')

    # Should contain AS64501/64502 from the matching route
    check_contains('filtered-has-64501', r, 'AS64501')
    check_contains('filtered-has-64502', r, 'AS64502')

    # Should NOT contain AS64601/64602 from the non-matching route
    check_not_contains('filtered-no-64601', r, 'AS64601')
    check_not_contains('filtered-no-64602', r, 'AS64602')

    # Shutdown
    if failures > 0:
        msg = f'{failures} filtered-graph assertions failed (see FAIL lines above)'
        print(f'\n{msg}', file=sys.stderr)
        sys.stderr.flush()
        runtime_fail(msg)
    dispatch(api, 'daemon shutdown')
    api.wait_for_shutdown()


if __name__ == '__main__':
    main()
EOF_RUN

# ze bgp configuration
stdin=ze-bgp:terminator=EOF_CONF
plugin {
	external graph-filtered-test {
		run ./rib-graph-filtered-test.run
		encoder json
	}
	external bgp-rib {
		use bgp-rib
		encoder json
	}
}

bgp {
	peer peer1 {
		connection {
			remote {
				ip 127.0.0.1
			}
			local {
				ip 127.0.0.1
				accept false
			}
		}
		session {
			asn {
				local 1
				remote 1
			}
			router-id 1.2.3.4
			family {
				ipv4/unicast { prefix { maximum 10000; } }
			}
			capability {
				graceful-restart disable
			}
		}
		behavior {
			group-updates disable
		}

		process graph-filtered-test {
		}
		process bgp-rib {
			receive [ update sent state ]
			send [ update ]
		}
	}
}
EOF_CONF

# Process orchestration
cmd=background:seq=1:exec=ze-peer --port $PORT:stdin=peer
cmd=foreground:seq=2:exec=ze -:stdin=ze-bgp:timeout=20s
expect=exit:code=0
