# Migrated from test/data/plugin/notification.*

# zebgp-peer expectations
stdin=peer:terminator=EOF_PEER
action=notification:conn=1:seq=1:text=closing session because we can
EOF_PEER

# Python plugin script
tmpfs=notification.run:mode=755:terminator=EOF_RUN
#!/usr/bin/env python3

import time

from zebgp_api import ready, send, wait_for_shutdown


def main() -> None:
    ready()

    try:
        # this will never be received by the peer
        send('update text nhop set 5.6.7.8 nlri ipv4/unicast add 1.2.3.4')
        wait_for_shutdown()
        # This route will never be sent
    except IOError:
        pass


if __name__ == '__main__':
    main()
EOF_RUN

# zebgp configuration
stdin=zebgp:terminator=EOF_CONF
plugin {
	external announce-routes {
		run ./notification.run;
		encoder json;
	}
}
peer 127.0.0.1 {
	router-id 1.2.3.4;
	local-address 127.0.0.1;
	local-as 1;
	peer-as 1;
	group-updates disable;
	capability {
		graceful-restart disable;
	}
	process announce-routes {
	}
}
EOF_CONF

# Process orchestration
cmd=background:seq=1:exec=zebgp-peer --port $PORT:stdin=peer
cmd=foreground:seq=2:exec=zebgp server -:stdin=zebgp:timeout=10s
