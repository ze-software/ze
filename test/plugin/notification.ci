# Migrated from test/data/plugin/notification.*

# ze-peer expectations
stdin=peer:terminator=EOF_PEER
action=notification:conn=1:seq=1:text=closing session because we can
EOF_PEER

# Python plugin script
tmpfs=notification.run:mode=755:terminator=EOF_RUN
#!/usr/bin/env python3

import time

from ze_api import ready, send, wait_for_shutdown


def main() -> None:
    ready()

    try:
        # this will never be received by the peer
        send('peer * update text nhop 5.6.7.8 nlri ipv4/unicast add 1.2.3.4')
        wait_for_shutdown()
        # This route will never be sent
    except IOError:
        pass


if __name__ == '__main__':
    main()
EOF_RUN

# ze bgp configuration
stdin=ze-bgp:terminator=EOF_CONF
plugin {
	external announce-routes {
		run ./notification.run
		encoder json
	}
}
bgp {
	peer peer1 {
		connection {
			remote {
				ip 127.0.0.1
			}
			local {
				ip 127.0.0.1
				accept false
			}
		}
		session {
			asn {
				local 1
				remote 1
			}
			router-id 1.2.3.4
			capability {
				graceful-restart disable
			}
		}
		behavior {
			group-updates disable
		}
		process announce-routes {
		}
	}
}
EOF_CONF

# Process orchestration
cmd=background:seq=1:exec=ze-peer --port $PORT:stdin=peer
cmd=foreground:seq=2:exec=ze -:stdin=ze-bgp:timeout=10s
