# Test: BFD plugin refuses `echo` on a multi-hop session at parse time.
#
# VALIDATES: spec-bfd-6 AC-5 -- multi-hop echo is prohibited by
#            RFC 5883 Section 4, and the parser emits a descriptive
#            error.
# PREVENTS:  accidental enablement of multi-hop echo via config
#            drift.

option=env:var=ze.bfd.test-parallel:value=true

tmpfs=test-bfd-echo-multihop.py:mode=755:terminator=EOF_PY
#!/usr/bin/env python3
"""Drive ze with a multi-hop session inheriting an echo profile."""

import os
import subprocess
import sys
import time
import signal

REQUIRED = ["prohibits multi-hop echo"]

CONFIG = """environment {
}

bfd {
\tenabled true;
\tprofile echo-profile {
\t\tdetect-multiplier 3
\t\tdesired-min-tx-us 100000
\t\trequired-min-rx-us 100000
\t\techo {
\t\t\tdesired-min-echo-tx-us 50000
\t\t}
\t}
\tmulti-hop-session 198.51.100.9 {
\t\tlocal 203.0.113.8
\t\tprofile echo-profile
\t}
}
"""


def main() -> int:
    env = os.environ.copy()
    env["ze.log.bfd"] = "debug"
    env["ze.bfd.test-parallel"] = "true"
    proc = subprocess.Popen(
        ["ze", "-"],
        stdin=subprocess.PIPE,
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
        text=True,
        env=env,
    )
    assert proc.stdin is not None
    proc.stdin.write(CONFIG)
    proc.stdin.close()

    deadline = time.time() + 8.0
    captured = ""
    matched: set[str] = set()
    while time.time() < deadline:
        if proc.stderr is None:
            break
        line = proc.stderr.readline()
        if not line:
            if proc.poll() is not None:
                break
            time.sleep(0.05)
            continue
        captured += line
        sys.stderr.write(line)
        sys.stderr.flush()
        for needle in REQUIRED:
            if needle in line:
                matched.add(needle)
        if len(matched) == len(REQUIRED):
            break

    if proc.poll() is None:
        proc.send_signal(signal.SIGTERM)
        try:
            proc.wait(timeout=3.0)
        except subprocess.TimeoutExpired:
            proc.kill()
            proc.wait(timeout=2.0)

    if proc.stderr is not None:
        try:
            tail = proc.stderr.read()
        except (ValueError, OSError):
            tail = ""
        if tail:
            captured += tail
            sys.stderr.write(tail)
            sys.stderr.flush()

    missing = [n for n in REQUIRED if n not in captured]
    if missing:
        sys.stderr.write(f"FAIL: missing required patterns: {missing}\n")
        return 1
    sys.stderr.write("OK: multi-hop echo rejection observed\n")
    return 0


if __name__ == "__main__":
    sys.exit(main())
EOF_PY

cmd=foreground:seq=1:exec=python3 ./test-bfd-echo-multihop.py:timeout=15s
expect=exit:code=0
expect=stderr:pattern=prohibits multi-hop echo
