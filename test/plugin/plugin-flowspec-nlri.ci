# plugin-flowspec-nlri - verify flowspec plugin NLRI decode
# Tests FlowSpec NLRI decoding via plugin CLI
# Wire: len=08, dest(type=01, len=18(24), prefix=0a0000), protocol(type=03, op=81(end,eq), value=06)

cmd=foreground:seq=1:exec=ze plugin bgp-nlri-flowspec --nlri 0801180a0000038106
expect=exit:code=0
expect=stdout:contains=destination
expect=stdout:contains=protocol
