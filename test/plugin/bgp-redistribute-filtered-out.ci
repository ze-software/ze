# Test: bgp-redistribute -- batch with no matching import rule produces no UPDATE.
# VALIDATES: AC-4 / AC-5 -- evaluator rejects entries whose family or source is
#            not in any import rule.
# PREVENTS: Routes leaking through when redistribute is misconfigured.

# ze-peer expectations: ONE EOR allowed (session start), nothing else.
stdin=peer:terminator=EOF_PEER
option=tcp_connections:value=1
option=timeout:value=15s
# Session-end EOR is fine; no UPDATE is the assertion this test enforces.
expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF00170200000000
EOF_PEER

# Python observer: emit fakeredist event for ipv6/unicast (rule covers ipv4/unicast only).
tmpfs=filtered-test.run:mode=755:terminator=EOF_RUN
#!/usr/bin/env python3
import time
from ze_api import API, runtime_fail


def dispatch(api, command):
    return api._call_engine('ze-plugin-engine:dispatch-command', {'command': command}) or {}


def main():
    api = API()
    api.declare_done()
    api.wait_for_config()
    api.capability_done()
    api.wait_for_registry()
    api.ready()

    time.sleep(2.0)

    # ipv6/unicast prefix; the import rule restricts fakeredist to ipv4/unicast.
    resp = dispatch(api, 'fakeredist emit add ipv6/unicast 2001:db8::1/128')
    result = resp.get('result', {})
    if result.get('status') != 'done':
        runtime_fail(f'fakeredist emit failed: {result}')
        return

    time.sleep(2.0)
    dispatch(api, 'daemon shutdown')
    api.wait_for_shutdown()


if __name__ == '__main__':
    main()
EOF_RUN

stdin=ze-bgp:terminator=EOF_CONF
plugin {
	external filtered-test {
		run ./filtered-test.run
		encoder json
	}
	external bgp-redistribute-egress {
		use bgp-redistribute-egress
		encoder json
	}
	external fakeredist {
		use fakeredist
		encoder json
	}
}

redistribute {
	import fakeredist {
		family [ ipv4/unicast ];
	}
}

bgp {
	peer peer1 {
		connection {
			remote {
				ip 127.0.0.1
			}
			local {
				ip 127.0.0.1
				accept false
			}
		}
		session {
			asn {
				local 65533
				remote 65533
			}
			router-id 1.2.3.4
			family {
				ipv4/unicast { prefix { maximum 10000; } }
			}
			capability {
				graceful-restart disable
			}
		}
		behavior {
			group-updates disable
		}
	}
}
EOF_CONF

cmd=background:seq=1:exec=ze-peer --port $PORT:stdin=peer
cmd=foreground:seq=2:exec=ze -:stdin=ze-bgp:timeout=15s
expect=exit:code=0
