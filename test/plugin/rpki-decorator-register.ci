# Test: rpki-decorator registers update-rpki event type dynamically
# VALIDATES: AC-1: update-rpki accepted by subscribe-events after decorator registers it
# VALIDATES: AC-8: dynamic event type registration is wired into startup
# PREVENTS: Plugin-registered event types rejected as unknown

# ze-peer: simple peer, sends one route then waits
stdin=peer:terminator=EOF_PEER
option=tcp_connections:value=1
option=timeout:value=15s
option=update:value=send-route:prefix=10.0.0.0/24:origin-as=65001:next-hop=10.0.0.1
# EOR from ze
expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF00170200000000
EOF_PEER

# Python test plugin: subscribes to update-rpki, verifies subscription accepted
tmpfs=rpki-reg-test.run:mode=755:terminator=EOF_RUN
#!/usr/bin/env python3
import json
import sys
import time
from ze_api import API

def dispatch(api, command):
    resp = api._call_engine(
        'ze-plugin-engine:dispatch-command', {'command': command})
    if resp is None:
        return {'status': 'error', 'data': 'engine call returned None'}
    return resp.get('result', {})

def main():
    api = API()
    api.declare_done()
    api.wait_for_config()
    api.capability_done()
    api.wait_for_registry()

    # Subscribe to update-rpki events -- this is the key test.
    # If dynamic event registration failed, this subscription would be rejected.
    # Events delivered via config: receive [ update-rpki ]
    api.ready()

    # Wait for UPDATE to arrive and decorator to process it
    time.sleep(3.0)

    try:
        # Collect any update-rpki events (at least one expected from the decorator)
        found = False
        for _ in range(20):
            event_str = api.read_line(timeout=0.5)
            if event_str is None:
                continue
            try:
                evt = json.loads(event_str)
            except (json.JSONDecodeError, TypeError):
                continue
            bgp = evt.get('bgp', {})
            msg = bgp.get('message', {})
            if msg.get('type') == 'update-rpki':
                found = True
                break

        if not found:
            print('FAIL: no update-rpki events received -- registration may have failed', file=sys.stderr)
            sys.exit(1)

        print('OK: update-rpki event received -- dynamic event type registration works', file=sys.stderr)

    finally:
        dispatch(api, 'daemon shutdown')
        api.wait_for_shutdown()

if __name__ == '__main__':
    main()
EOF_RUN

stdin=ze-bgp:terminator=EOF_CONF
plugin {
	hub {
		listen 127.0.0.1:0;
		secret rpki-reg-test-secret-0123456789abcdef;
	}
	external rpki-reg-test {
		run ./rpki-reg-test.run
		encoder json
	}
	external rpki {
		run "ze plugin bgp-rpki"
		encoder json
	}
	external rpki-decorator {
		run "ze plugin bgp-rpki-decorator"
		encoder json
	}
	external adj-rib-in {
		run "ze plugin bgp-adj-rib-in"
		encoder json
	}
}

environment {
	tcp {
		attempts 3
	}
}

bgp {
	rpki {
		cache-server 127.0.0.1 {
			port $PORT2
		}
	}
	peer peer1 {
		remote {
			ip 127.0.0.1
			as 1
		}
		local {
			as 1
			ip 127.0.0.1
		}
		router-id 1.2.3.4
		connection active
		group-updates disable

		family {
			ipv4/unicast { prefix { maximum 10000; } }
		}
		capability {
			graceful-restart disable
		}
		process rpki-reg-test {
			receive [ update-rpki ]
		}
		process rpki {
			receive [ update ]
		}
		process rpki-decorator {
			receive [ update rpki ]
		}
		process adj-rib-in {
			receive [ update state ]
		}
	}
}
EOF_CONF

# RTR mock with one VRP so rpki plugin has data
cmd=background:seq=1:exec=ze-rtr-mock --port $PORT2 --vrp 10.0.0.0/8,32,65001
cmd=background:seq=2:exec=ze-peer --port $PORT:stdin=peer
cmd=foreground:seq=3:exec=ze -:stdin=ze-bgp:timeout=20s
expect=exit:code=0
