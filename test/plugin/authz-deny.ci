# Test: authorization denies restricted user for non-matching commands
#
# Flow:
# 1. Daemon starts with SSH + authz config (restricted profile: default deny)
# 2. Shell script connects via SSH as operator user
# 3. Commands not matching any allow entry are denied
# 4. Stderr contains "unauthorized" error message
#
# VALIDATES: AC-3 -- restricted profile denies commands not in allow entries.
# PREVENTS: Authorization check bypassed -- all commands pass through unchecked.

# Test script: restricted user denied for non-matching commands
tmpfs=test-authz-deny.sh:mode=755:terminator=EOF_SH
#!/bin/sh
set -e

# Signal test runner readiness
touch daemon.ready

# Generate config with SSH on port 0 (OS-assigned)
cat > authz-deny.conf << 'ZECONF'
bgp {
	peer 127.0.0.1 {
		local-address 127.0.0.1
		local-as 65533
		peer-as 65533
		connection active
	}
}

system {
	authentication {
		user operator {
			password "$2a$04$MdupNBXL8iUHgRUDfsFl0ue/.FEH3db8U.LPd/XtMhiBmd4MoRM0m"
			profile [ restricted ]
		}
	}
	authorization {
		profile restricted {
			run {
				default-action deny
				entry 10 {
					action allow
					match "bgp peer list"
				}
			}
			edit {
				default-action deny
			}
		}
	}
	ssh {
		listen 127.0.0.1:0
	}
}
ZECONF

# Use a PID-derived high port for BGP to avoid needing root for port 179
export ze_bgp_tcp_port=$((10000 + ($$ % 50000)))

# Start daemon, capture stderr to parse SSH port
ze authz-deny.conf 2>daemon.log &
DAEMON_PID=$!
trap 'kill $DAEMON_PID 2>/dev/null; wait $DAEMON_PID 2>/dev/null' EXIT

# Wait for SSH server to report its listening address
SSH_PORT=""
for i in $(seq 1 50); do
	SSH_PORT=$(grep -o '127\.0\.0\.1:[0-9]*' daemon.log 2>/dev/null | head -1 | cut -d: -f2 || true)
	if [ -n "$SSH_PORT" ]; then
		break
	fi
	sleep 0.2
done

if [ -z "$SSH_PORT" ]; then
	echo "FAIL: SSH server did not start (no address in daemon.log)" >&2
	cat daemon.log >&2
	exit 1
fi
echo "SSH port: $SSH_PORT" >&2

# Brief delay for postStartFunc to wire authorizer
sleep 0.5

# Set up operator credentials
OP_DIR=$(mktemp -d)
trap 'rm -rf "$OP_DIR"; kill $DAEMON_PID 2>/dev/null; wait $DAEMON_PID 2>/dev/null' EXIT
printf 'operator\noppass\n127.0.0.1\n%s\n' "$SSH_PORT" | ZE_CONFIG_DIR="$OP_DIR" ze init >/dev/null

# Test 1: restricted user denied for command not in allow list
# "bgp peer detail" is NOT in the restricted profile's allow entries
OUTPUT=$(ZE_CONFIG_DIR="$OP_DIR" ze cli --run "peer detail" 2>&1) && {
	echo "FAIL: operator should be denied 'peer detail' but command succeeded" >&2
	echo "OUTPUT: $OUTPUT" >&2
	exit 1
}
echo "OK: operator denied peer detail (exit non-zero)" >&2

# Verify the error message contains "unauthorized"
case "$OUTPUT" in
	*unauthorized*|*Unauthorized*)
		echo "OK: error message contains 'unauthorized'" >&2
		;;
	*)
		echo "FAIL: expected 'unauthorized' in error, got: $OUTPUT" >&2
		exit 1
		;;
esac

# Test 2: restricted user denied for metrics command (not in allow list)
ZE_CONFIG_DIR="$OP_DIR" ze cli --run "metrics list" 2>/dev/null && {
	echo "FAIL: operator should be denied 'metrics list'" >&2
	exit 1
}
echo "OK: operator denied metrics list" >&2

echo "OK: all deny tests passed" >&2
exit 0
EOF_SH

# Process orchestration
cmd=foreground:seq=1:exec=./test-authz-deny.sh:timeout=15s
expect=exit:code=0
