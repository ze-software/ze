# Test: RR client config parses and peer detail reports it
# VALIDATES: cmd-1 AC-13 -- peer detail shows route-reflector-client and cluster-id
# VALIDATES: cmd-1 AC-6 -- cluster-id configured and visible in peer detail
# PREVENTS: RR config not wired to PeerSettings

stdin=peer:terminator=EOF_PEER
option=tcp_connections:value=1
option=timeout:value=15s

action=send:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF0036020000001B4001010040020602010000FDE94003040A000001400504000000C8180A0100
# Wait for ze's End-of-RIB so the peer does not close TCP before the
# observer can poll for peer state. Without this, ze transitions
# Established -> Idle -> Connecting before the observer's first poll fires.
expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF00170200000000
EOF_PEER

tmpfs=rr-test.run:mode=755:terminator=EOF_RUN
#!/usr/bin/env python3
import json
import sys
import time
from ze_api import API, runtime_fail

def dispatch(api, command):
    resp = api._call_engine(
        'ze-plugin-engine:dispatch-command', {'command': command})
    if resp is None:
        return {'status': 'error', 'data': 'engine call returned None'}
    return resp.get('result', {})

def main():
    api = API()
    api.declare_done()
    api.wait_for_config()
    api.capability_done()
    api.wait_for_registry()
    api.ready()

    # Poll until peer session is established (more robust than sleep)
    for _ in range(20):
        time.sleep(0.3)
        result = dispatch(api, 'peer peer-src detail')
        if result.get('status') == 'done' and 'established' in result.get('data', '').lower():
            break
    else:
        runtime_fail('peer-src never reached established state')

    result = dispatch(api, 'peer peer-src detail')
    if result.get('status') != 'done':
        runtime_fail(f'peer detail failed: {result}')

    detail = result.get('data', '')
    if 'route-reflector-client' not in detail:
        runtime_fail(f'missing route-reflector-client: {detail[:300]}')
    if 'cluster-id' not in detail:
        runtime_fail(f'missing cluster-id: {detail[:300]}')

    # Verify RIB has the route (proves UPDATE was processed, not just config accepted)
    result = dispatch(api, 'bgp rib show best')
    if result.get('status') != 'done':
        runtime_fail(f'rib show best failed: {result}')

    data = result.get('data', '{}')
    parsed = json.loads(data) if isinstance(data, str) else data
    entries = parsed.get('best-path', [])

    found = any(e.get('prefix') == '10.1.0.0/24' for e in entries)
    if not found:
        runtime_fail(f'route 10.1.0.0/24 not in RIB')

    print('OK: RR client and cluster-id visible in peer detail, route in RIB', file=sys.stderr)

    dispatch(api, 'daemon shutdown')
    api.wait_for_shutdown()

if __name__ == '__main__':
    main()
EOF_RUN

stdin=ze-bgp:terminator=EOF_CONF
plugin {
	external rr-test {
		run ./rr-test.run
		encoder json
	}
	external bgp-rib {
		use bgp-rib
		encoder json
	}
}
bgp {
	peer peer-src {
		connection {
			remote {
				ip 127.0.0.1
			}
			local {
				ip 127.0.0.1
				accept false
			}
		}
		session {
			asn {
				local 65000
				remote 65000
			}
			router-id 1.2.3.4
			route-reflector-client true
			cluster-id 10.10.10.10
			family {
				ipv4/unicast { prefix { maximum 10000; } }
			}
			capability {
				graceful-restart disable
			}
		}

		process rr-test {
		}
		process bgp-rib {
			receive [ state ]
			send [ update ]
		}
	}
}
EOF_CONF

cmd=background:seq=1:exec=ze-peer --port $PORT:stdin=peer
cmd=foreground:seq=2:exec=ze -:stdin=ze-bgp:timeout=15s
expect=exit:code=0
reject=stderr:pattern=panic recovered
reject=stderr:pattern=fatal error
reject=stderr:pattern=ZE-OBSERVER-FAIL
