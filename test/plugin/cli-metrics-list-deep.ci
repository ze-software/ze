# Test: bgp metrics list includes deep instrumentation metric names
#
# Flow:
# 1. BGP session establishes with telemetry enabled
# 2. Python plugin dispatches "metrics list" via dispatch-command
# 3. Verifies response names array contains session, wire, config, and pool metrics
# 4. Shuts down daemon
#
# VALIDATES: AC-9 — bgp metrics list includes new deep instrumentation metric names.
# PREVENTS: New metrics not registered in Prometheus registry.

# ze-peer expectations
stdin=peer:terminator=EOF_PEER
option=tcp_connections:value=1
option=timeout:value=15s

# EOR
expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF00170200000000
EOF_PEER

# Python test plugin: verifies deep instrumentation metrics in list output
tmpfs=metrics-list-deep-test.run:mode=755:terminator=EOF_RUN
#!/usr/bin/env python3
"""Test: deep instrumentation metrics appear in metrics list output."""

import json
import sys
import time

from ze_api import API


def dispatch(api, command):
    """Call dispatch-command and return result dict."""
    try:
        resp = api._call_engine(
            'ze-plugin-engine:dispatch-command', {'command': command})
        return resp.get('result', {})
    except RuntimeError as e:
        print(f'WARN: dispatch({command!r}) failed: {e}', file=sys.stderr)
        return {'status': 'error', 'message': str(e)}


def main():
    api = API()
    api.declare_done()
    api.wait_for_config()
    api.capability_done()
    api.wait_for_registry()
    api.ready()

    # Wait for BGP session to establish
    time.sleep(1.0)

    failed = False

    # Test: bgp metrics list should include new metric names
    r = dispatch(api, 'metrics list')
    status = r.get('status')
    if status != 'done':
        print(f'FAIL: expected status=done, got={status}', file=sys.stderr)
        failed = True
    else:
        data_str = r.get('data', '{}')
        try:
            data = json.loads(data_str) if isinstance(data_str, str) else data_str
        except (json.JSONDecodeError, TypeError) as e:
            print(f'WARN: JSON parse failed: {e}, raw={data_str!r}', file=sys.stderr)
            data = {}

        names = data.get('names', [])
        if not isinstance(names, list):
            print(f'FAIL: names not a list, data={data}', file=sys.stderr)
            failed = True
        else:
            # These metrics must appear in the names list.
            # Note: "metrics list" returns names from the registry maps (not
            # Prometheus Gather), so Vec metrics appear even with no observations.
            # Covers all phases of deep instrumentation.
            required = [
                # Session lifecycle (Phase 1)
                'ze_peer_sessions_established_total',
                'ze_peer_session_flaps_total',
                'ze_peer_state_transitions_total',
                'ze_peer_notifications_sent_total',
                'ze_peer_notifications_received_total',
                'ze_peer_session_duration_seconds',
                # Forward pool (Phase 2)
                'ze_forward_congestion_events_total',
                'ze_forward_congestion_resumed_total',
                'ze_bgp_pool_used_ratio',
                'ze_bgp_overflow_items',
                'ze_bgp_overflow_ratio',
                # Config (Phase 4)
                'ze_config_reloads_total',
                'ze_config_reload_errors_total',
                'ze_peers_added_total',
                'ze_peers_removed_total',
                # Wire layer (Phase 5)
                'ze_wire_bytes_received_total',
                'ze_wire_bytes_sent_total',
                'ze_wire_read_errors_total',
                'ze_wire_write_errors_total',
            ]
            missing = [n for n in required if n not in names]

            if missing:
                print(f'FAIL: missing metrics in list: {missing}', file=sys.stderr)
                print(f'Got {len(names)} names: {sorted(names)}', file=sys.stderr)
                failed = True
            else:
                print(f'OK: metrics list contains all {len(required)} deep metrics (total: {len(names)})', file=sys.stderr)

    # Always shutdown daemon
    dispatch(api, 'daemon shutdown')
    api.wait_for_shutdown()

    if failed:
        sys.exit(1)


if __name__ == '__main__':
    main()
EOF_RUN

# ze bgp configuration with telemetry enabled
stdin=ze-bgp:terminator=EOF_CONF
plugin {
	external metrics-list-deep-test {
		run ./metrics-list-deep-test.run
		encoder json
	}
}

environment {
	tcp {
		attempts 3
	}
}

telemetry {
	prometheus {
		port 19277
	}
}

bgp {
	peer peer1 {
		remote {
			ip 127.0.0.1
			as 1
			accept false
		}
		local {
			as 1
			ip 127.0.0.1
		}
		router-id 1.2.3.4
		group-updates disable

		family {
			ipv4/unicast { prefix { maximum 10000; } }
		}
		capability {
			graceful-restart disable
		}
		process metrics-list-deep-test {
		}
	}
}
EOF_CONF

# Process orchestration
cmd=background:seq=1:exec=ze-peer --port $PORT:stdin=peer
cmd=foreground:seq=2:exec=ze -:stdin=ze-bgp:timeout=15s
expect=exit:code=0
