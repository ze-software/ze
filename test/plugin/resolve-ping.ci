# Test: resolve ping dispatches ICMP probe to target
# VALIDATES: cmd-9 AC-4 -- resolve ping 127.0.0.1 returns RTT and status (success)
# PREVENTS: resolve ping handler not wired or crashing

# Python plugin dispatches resolve ping 127.0.0.1 via engine API and verifies
# the response contains success output.

stdin=peer:terminator=EOF_PEER
option=tcp_connections:value=1
option=timeout:value=20s
expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF00170200000000
EOF_PEER

tmpfs=ping-test.run:mode=755:terminator=EOF_RUN
#!/usr/bin/env python3
import json
import sys
import time
from ze_api import API, runtime_fail

def dispatch(api, command):
    resp = api._call_engine(
        'ze-plugin-engine:dispatch-command', {'command': command})
    if resp is None:
        return {'status': 'error', 'data': 'engine call returned None'}
    return resp.get('result', {})

def main():
    api = API()
    api.declare_done()
    api.wait_for_config()
    api.capability_done()
    api.wait_for_registry()
    api.ready()

    # Poll until peer session is established
    for _ in range(20):
        time.sleep(0.3)
        result = dispatch(api, 'peer peer1 detail')
        if result.get('status') == 'done' and 'established' in result.get('data', '').lower():
            break

    try:
        result = dispatch(api, 'resolve ping 127.0.0.1')
        if result.get('status') != 'done':
            runtime_fail(f'resolve ping status={result.get("status")} data={result.get("data")}')

        data = result.get('data', {})
        if isinstance(data, str):
            data = json.loads(data)

        target = data.get('target', '')
        if target != '127.0.0.1':
            runtime_fail(f'expected target 127.0.0.1, got: {target}')

        output = data.get('output', '')
        if not output:
            runtime_fail('ping output is empty')

        # On macOS and Linux, successful ping output contains "bytes from"
        if 'bytes from' not in output.lower() and '0% packet loss' not in output.lower() and '0.0% packet loss' not in output.lower():
            # Some systems format differently; just check no error key
            if 'error' in data:
                runtime_fail(f'ping failed: {data["error"]}')

        print(f'OK: resolve ping 127.0.0.1 succeeded', file=sys.stderr)
    finally:
        dispatch(api, 'daemon shutdown')
        api.wait_for_shutdown()

if __name__ == '__main__':
    main()
EOF_RUN

stdin=ze-bgp:terminator=EOF_CONF
plugin {
	external ping-test {
		run ./ping-test.run
		encoder json
	}
}
bgp {
	peer peer1 {
		connection {
			remote {
				ip 127.0.0.1
			}
			local {
				ip 127.0.0.1
				accept false
			}
		}
		session {
			asn {
				local 65000
				remote 65000
			}
			router-id 1.2.3.4
			family {
				ipv4/unicast { prefix { maximum 10000; } }
			}
			capability {
				graceful-restart disable
			}
		}

		process ping-test {
		}
	}
}
EOF_CONF

cmd=background:seq=1:exec=ze-peer --port $PORT:stdin=peer
cmd=foreground:seq=2:exec=ze -:stdin=ze-bgp:timeout=20s
expect=exit:code=0
reject=stderr:pattern=panic recovered
reject=stderr:pattern=fatal error
reject=stderr:pattern=ZE-OBSERVER-FAIL
