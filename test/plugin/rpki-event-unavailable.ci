# Test: rpki event shows "unavailable" when no RTR cache data
# VALIDATES: Empty ROA cache produces "unavailable" rpki event (AC-6)
# PREVENTS: rpki plugin crashing or sending empty results when cache is empty

# ze-peer: send route
stdin=peer:terminator=EOF_PEER
option=tcp_connections:value=1
option=timeout:value=15s
option=update:value=send-route:prefix=10.0.1.0/24:origin-as=65001:next-hop=10.0.0.1
# EOR from ze
expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF00170200000000
EOF_PEER

# Python test plugin: verifies rpki event shows "unavailable"
tmpfs=rpki-unavail-test.run:mode=755:terminator=EOF_RUN
#!/usr/bin/env python3
import json
import sys
import time
from ze_api import API

def dispatch(api, command):
    resp = api._call_engine(
        'ze-plugin-engine:dispatch-command', {'command': command})
    if resp is None:
        return {'status': 'error', 'data': 'engine call returned None'}
    return resp.get('result', {})

def main():
    api = API()
    api.declare_done()
    api.wait_for_config()
    api.capability_done()
    api.wait_for_registry()
    api.subscribe(['rpki direction received'])
    api.ready()

    # Wait for BGP UPDATE (no RTR server = empty cache)
    time.sleep(4.0)

    try:
        found_unavailable = False
        for _ in range(20):
            event_str = api.read_line(timeout=0.5)
            if event_str is None:
                continue
            try:
                evt = json.loads(event_str)
            except (json.JSONDecodeError, TypeError):
                continue
            bgp = evt.get('bgp', {})
            msg = bgp.get('message', {})
            if msg.get('type') != 'rpki':
                continue
            rpki = bgp.get('rpki', {})
            if isinstance(rpki, dict) and rpki.get('status') == 'unavailable':
                found_unavailable = True
                break

        if not found_unavailable:
            print('FAIL: expected rpki=unavailable, not found', file=sys.stderr)
            sys.exit(1)

        print('OK: rpki event shows unavailable (empty cache)', file=sys.stderr)
    finally:
        dispatch(api, 'daemon shutdown')
        api.wait_for_shutdown()

if __name__ == '__main__':
    main()
EOF_RUN

# Config with rpki plugin but NO RTR server (cache will be empty)
stdin=ze-bgp:terminator=EOF_CONF
plugin {
	hub {
		server local {
			ip 127.0.0.1;
			port 0;
			secret rpki-test-secret-key-01234567890;
		}
	}
	external rpki-unavail-test {
		run ./rpki-unavail-test.run
		encoder json
	}
	external rpki {
		use bgp-rpki
		encoder json
	}
	external adj-rib-in {
		use bgp-adj-rib-in
		encoder json
	}
}

environment {
	tcp {
		attempts 3
	}
}

bgp {
	rpki {
		cache-server 127.0.0.1 {
			port 19999
		}
	}
	peer peer1 {
		connection {
			remote {
				ip 127.0.0.1
				accept false
			}
			local {
				ip 127.0.0.1
			}
		}
		session {
			asn {
				local 1
				remote 1
			}
			router-id 1.2.3.4
			family {
				ipv4/unicast { prefix { maximum 10000; } }
			}
			capability {
				graceful-restart disable
			}
		}
		behavior {
			group-updates disable
		}

		process rpki-unavail-test {
		}
		process rpki {
			receive [ update ]
		}
		process adj-rib-in {
			receive [ update state ]
		}
	}
}
EOF_CONF

# No RTR server -- cache will be empty
cmd=background:seq=1:exec=ze-peer --port $PORT:stdin=peer
cmd=foreground:seq=2:exec=ze -:stdin=ze-bgp:timeout=20s
expect=exit:code=0
