# Test: OTC egress stamping -- route to Customer is re-advertised with OTC
# VALIDATES: RFC 9234 Section 5 egress stamp -- route from Customer forwarded to another Customer with OTC
# PREVENTS: OTC egress stamping not wired, wrong ASN used for stamping, route not reaching destination peer
# NOTE: Two-peer test using --bind for separate loopback addresses

# Source peer (Customer, ASN 65001) on 127.0.0.1
stdin=source:terminator=EOF_SOURCE
option=tcp_connections:value=1
option=timeout:value=20s
# Role capability: drop ze-peer's default (mirrored Provider) then add Customer (0x03).
option=open:value=drop-capability:code=9
option=open:value=add-capability:code=9:hex=03
# Send UPDATE without OTC: ORIGIN=IGP, AS_PATH=[65001], NEXT_HOP=1.1.1.1, NLRI=10.0.0.0/24
action=send:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF002F02000000144001010040020602010000FDE940030401010101180A0000
expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF00170200000000
EOF_SOURCE

# Dest peer (Customer, ASN 65002) on 127.0.0.2 -- expect OTC-stamped UPDATE
stdin=dest:terminator=EOF_DEST
option=tcp_connections:value=1
option=timeout:value=20s
# Role capability: drop default (Provider mirror) then add Customer (0x03).
option=open:value=drop-capability:code=9
option=open:value=add-capability:code=9:hex=03
expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF003A020000001F4001010040020A02020000FDE80000FDE940030401010101C023040000FDE8180A0000
expect=bgp:conn=1:seq=2:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF00170200000000
EOF_DEST

# Python test plugin: keeps the daemon alive while the destination wire
# assertion proves OTC stamping.
tmpfs=test-stamp.run:mode=755:terminator=EOF_RUN
#!/usr/bin/env python3
"""Keep the daemon alive while the dest peer verifies OTC egress stamping."""
import json
import sys
import time
from ze_api import API, runtime_fail

def dispatch(api, command):
    resp = api._call_engine('ze-plugin-engine:dispatch-command', {'command': command})
    return resp.get('result', {})

def main():
    api = API()
    api.declare_done()
    api.wait_for_config()
    api.capability_done()
    api.wait_for_registry()
    api.ready()

    # Wait for both sessions to establish and UPDATE to be processed + forwarded.
    time.sleep(5.0)

    # Verify route was accepted in adj-rib-in from source Customer.
    result = dispatch(api, 'adj-rib-in status')
    data = json.loads(result.get('data', '{}'))
    total = data.get('total-routes', -1)

    if total < 0:  # validation gate + disconnect race, same as community-strip
        msg = f'adj-rib-in query failed, got total={total}'
        print(f'FAIL: {msg}', file=sys.stderr)
        sys.stderr.flush()
        runtime_fail(msg)

    print(f'OK: {total} route(s) in adj-rib-in from source Customer peer', file=sys.stderr)

    # Destination expect=bgp lines are authoritative. Log peer detail only for
    # diagnostics; under parallel runs the destination can still be connecting
    # when the observer wakes up.
    dest_result = dispatch(api, 'peer dest-peer detail')
    dest_data = dest_result.get('data', '')
    print(f'INFO: dest-peer detail while wire assertion runs: {dest_data}', file=sys.stderr)

    print('OK: dest wire assertion verified OTC stamp', file=sys.stderr)
    dispatch(api, 'daemon shutdown')
    api.wait_for_shutdown()

if __name__ == '__main__':
    main()
EOF_RUN

# ze configuration: Provider with two Customer peers on different loopback addresses
stdin=ze-bgp:terminator=EOF_CONF
plugin {
	external test-stamp {
		run ./test-stamp.run
		encoder json
	}
}
bgp {
	peer source-peer {
		connection {
			remote {
				ip 127.0.0.1
			}
			local {
				ip 127.0.0.1
				accept false
			}
		}
		session {
			asn {
				local 65000
				remote 65001
			}
			router-id 1.2.3.4
			family {
				ipv4/unicast { prefix { maximum 10000; } }
			}
		}

		role {
			import provider
			export default
		}
		process test-stamp {
			receive [ update state ]
		}
	}

	peer dest-peer {
		connection {
			remote {
				ip 127.0.0.2
			}
			local {
				ip 127.0.0.2
				accept false
			}
		}
		session {
			asn {
				local 65000
				remote 65002
			}
			router-id 1.2.3.4
			family {
				ipv4/unicast { prefix { maximum 10000; } }
			}
		}

		role {
			import provider
			export default
		}
	}
}
EOF_CONF

# Process orchestration: two ze-peer instances on different loopback addresses
cmd=background:seq=1:exec=ze-peer --port $PORT:stdin=source
cmd=background:seq=2:exec=ze-peer --bind 127.0.0.2 --port $PORT:stdin=dest
cmd=foreground:seq=3:exec=ze --plugin ze.bgp-role --plugin ze.bgp-adj-rib-in -:stdin=ze-bgp:timeout=20s
expect=exit:code=0
reject=stderr:pattern=panic recovered
reject=stderr:pattern=fatal error
reject=stderr:pattern=ZE-OBSERVER-FAIL
