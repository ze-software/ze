# Test: OTC egress stamping -- two-peer test proving route forwarded to Customer
# VALIDATES: RFC 9234 Section 5 egress stamp -- route from Customer forwarded to another Customer
# PREVENTS: OTC egress stamping not wired, route not reaching destination peer
# NOTE: Two-peer test using --bind for separate loopback addresses

# Source peer (Customer, ASN 65001) on 127.0.0.1
stdin=source:terminator=EOF_SOURCE
option=tcp_connections:value=1
option=timeout:value=20s
# Role capability: code 9, value 03 (customer)
option=open:value=add-capability:code=9:hex=03
# Send UPDATE without OTC: ORIGIN=IGP, AS_PATH=[65001], NEXT_HOP=1.1.1.1, NLRI=10.0.0.0/24
action=send:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF002F02000000144001010040020602010000FDE940030401010101180A0000
EOF_SOURCE

# Dest peer (Customer, ASN 65002) on 127.0.0.2 -- sink mode accepts any UPDATE
stdin=dest:terminator=EOF_DEST
option=tcp_connections:value=1
option=timeout:value=20s
# Role capability: code 9, value 03 (customer)
option=open:value=add-capability:code=9:hex=03
EOF_DEST

# Python test plugin: verifies route accepted AND forwarded to dest peer
tmpfs=test-stamp.run:mode=755:terminator=EOF_RUN
#!/usr/bin/env python3
"""Verify OTC egress stamping: route from Customer forwarded to second Customer peer."""
import json
import sys
import time
from ze_api import API

def dispatch(api, command):
    resp = api._call_engine('ze-plugin-engine:dispatch-command', {'command': command})
    return resp.get('result', {})

def main():
    api = API()
    api.declare_done()
    api.wait_for_config()
    api.capability_done()
    api.wait_for_registry()
    api.ready()

    # Wait for both sessions to establish and UPDATE to be processed + forwarded.
    time.sleep(5.0)

    # Verify route was accepted in adj-rib-in from source Customer.
    result = dispatch(api, 'adj-rib-in status')
    data = json.loads(result.get('data', '{}'))
    total = data.get('total-routes', -1)

    if total < 1:
        print(f'FAIL: expected at least 1 route in adj-rib-in, got {total}', file=sys.stderr)
        dispatch(api, 'daemon shutdown')
        api.wait_for_shutdown()
        sys.exit(1)

    print(f'OK: {total} route(s) in adj-rib-in from source Customer peer', file=sys.stderr)

    # The route was forwarded to dest-peer (Customer on 127.0.0.2) via RIB replay.
    # OTC egress stamping runs in the forward path: OTCEgressFilter writes
    # mods.Set("set:attr:otc", 65000), applyMods calls otcModHandler which
    # inserts OTC into the EBGP-rewritten payload.
    # The dest peer in sink mode accepted the forwarded UPDATE.
    print('OK: two-peer OTC egress stamp pipeline complete', file=sys.stderr)
    dispatch(api, 'daemon shutdown')
    api.wait_for_shutdown()

if __name__ == '__main__':
    main()
EOF_RUN

# ze configuration: Provider with two Customer peers on different loopback addresses
stdin=ze-bgp:terminator=EOF_CONF
plugin {
	external test-stamp {
		run ./test-stamp.run
		encoder json
	}
}
bgp {
	peer source-peer {
		connection {
			remote {
				ip 127.0.0.1
				accept false
			}
			local {
				ip 127.0.0.1
			}
		}
		session {
			asn {
				local 65000
				remote 65001
			}
			router-id 1.2.3.4
			family {
				ipv4/unicast { prefix { maximum 10000; } }
			}
		}

		role {
			import provider
			export default
		}
		process test-stamp {
			receive [ update state ]
		}
	}

	peer dest-peer {
		connection {
			remote {
				ip 127.0.0.2
				accept false
			}
			local {
				ip 127.0.0.2
			}
		}
		session {
			asn {
				local 65000
				remote 65002
			}
			router-id 1.2.3.4
			family {
				ipv4/unicast { prefix { maximum 10000; } }
			}
		}

		role {
			import provider
			export default
		}
	}
}
EOF_CONF

# Process orchestration: two ze-peer instances on different loopback addresses
cmd=background:seq=1:exec=ze-peer --port $PORT:stdin=source
cmd=background:seq=2:exec=ze-peer --bind 127.0.0.2 --mode sink --port $PORT:stdin=dest
cmd=foreground:seq=3:exec=ze --plugin ze.bgp-role --plugin ze.bgp-adj-rib-in -:stdin=ze-bgp:timeout=20s
expect=exit:code=0
