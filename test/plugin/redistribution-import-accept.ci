# Test: import filter accepts routes, routes pass through to cache
# VALIDATES: AC-5 -- Import filter returns accept, UPDATE cached and dispatched normally
# PREVENTS: Accept filter blocking routes that should pass through

# ze-peer expectations: peer sends an UPDATE, expects EOR back
stdin=peer:terminator=EOF_PEER
option=tcp_connections:value=1
option=timeout:value=15s
expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF00170200000000
EOF_PEER

# Python test plugin: declares an import filter that accepts everything
tmpfs=filter-accept-test.run:mode=755:terminator=EOF_RUN
#!/usr/bin/env python3
import sys
from ze_api import API

def filter_handler(params):
    """Accept all routes."""
    print(f'filter-update received: filter={params.get("filter")} peer={params.get("peer")}', file=sys.stderr)
    return {'action': 'accept'}

def main():
    api = API()
    api.declare_filter(
        name='accept-all',
        direction='import',
        attributes=['as-path', 'origin'],
        on_error='reject',
    )
    api.on_filter_update(filter_handler)
    api.declare_done()
    api.wait_for_config()
    api.capability_done()
    api.wait_for_registry()
    api.ready()

    print('OK: filter plugin ready, waiting for events', file=sys.stderr)
    api.wait_for_shutdown(timeout=10.0)

if __name__ == '__main__':
    main()
EOF_RUN

# ze bgp configuration
stdin=ze-bgp:terminator=EOF_CONF
plugin {
    external filter-accept-test {
        run ./filter-accept-test.run;
        encoder json;
    }
}
bgp {
    router-id 1.2.3.4;
    local { as 65000; }
    redistribution {
        import [ filter-accept-test:accept-all ];
    }
    peer peer1 {
        remote {
            ip 127.0.0.1;
            as 65001;
            accept false;
        }
        local {
            as 65000;
            ip auto;
        }
        process filter-accept-test {
            receive [ update state ];
        }
    }
}
EOF_CONF

# Run ze with the test plugin
cmd=foreground:seq=2:exec=ze -:stdin=ze-bgp:timeout=15s
expect=exit:code=0
