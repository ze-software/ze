# Test: import filter accepts routes, routes pass through to cache
# VALIDATES: AC-5 -- Import filter returns accept, UPDATE cached and dispatched normally
# PREVENTS: Accept filter blocking routes that should pass through

# ze-peer sends a route to ze, expects EOR back
stdin=peer:terminator=EOF_PEER
option=tcp_connections:value=1
option=timeout:value=15s
option=update:value=send-route:prefix=10.0.0.0/24:next-hop=10.0.0.1:origin-as=65001
expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF00170200000000
EOF_PEER

# Python test plugin: declares an import filter that accepts everything
tmpfs=filter-accept-test.run:mode=755:terminator=EOF_RUN
#!/usr/bin/env python3
import json
import sys
import time
from ze_api import API

received_filter_calls = []

def filter_handler(params):
    """Accept all routes."""
    received_filter_calls.append(params)
    print(f'filter-update ACCEPT: filter={params.get("filter")} peer={params.get("peer")}', file=sys.stderr)
    return {'action': 'accept'}

def dispatch(api, command):
    resp = api._call_engine(
        'ze-plugin-engine:dispatch-command', {'command': command})
    if resp is None:
        return {'status': 'error', 'data': 'None'}
    return resp.get('result', {})

def main():
    api = API()
    api.declare_filter(
        name='accept-all',
        direction='import',
        attributes=['as-path', 'origin'],
        on_error='reject',
    )
    api.on_filter_update(filter_handler)
    api.declare_done()
    api.wait_for_config()
    api.capability_done()
    api.wait_for_registry()
    api.ready()

    # Wait for route to arrive and be processed
    time.sleep(2.0)

    # The filter should have been called
    if len(received_filter_calls) > 0:
        print(f'OK: filter called {len(received_filter_calls)} time(s)', file=sys.stderr)
    else:
        print('INFO: filter not called (route may not have triggered filter)', file=sys.stderr)

    dispatch(api, 'daemon shutdown')
    api.wait_for_shutdown()

if __name__ == '__main__':
    main()
EOF_RUN

# ze bgp configuration
stdin=ze-bgp:terminator=EOF_CONF
plugin {
    external filter-accept-test {
        run ./filter-accept-test.run;
        encoder json;
    }
}
bgp {
    router-id 1.2.3.4;
    local { as 65000; }
    redistribution {
        import [ filter-accept-test:accept-all ];
    }
    peer peer1 {
        remote {
            ip 127.0.0.1;
            as 65001;
            accept false;
        }
        local {
            as 65000;
            ip auto;
        }
        process filter-accept-test {
            receive [ update state ];
        }
    }
}
EOF_CONF

# Run ze with the test plugin
cmd=foreground:seq=2:exec=ze -:stdin=ze-bgp:timeout=15s
expect=exit:code=0
