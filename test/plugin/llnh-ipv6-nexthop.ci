# llnh-ipv6-nexthop - verify LLNH plugin injects capability 77 in OPEN
# Tests: link-local-nexthop capability (code 77, empty payload) appears in OPEN
# when bgp-llnh plugin is loaded and peer has link-local-nexthop enabled.
#
# Capability 77 (0x4D) with zero-length payload: cap-code=4D, cap-len=00
# Expected in OPEN opt params as: param-type(02) + param-len(02) + cap-code(4D) + cap-len(00)

# ze-peer expectations
stdin=peer:terminator=EOF_PEER
option=open:value=inspect-open-message
option=timeout:value=10s

# Full OPEN message (exact hex match):
# marker(16xFF) + len(002D=45) + type(01=OPEN) + version(04) + ASN(0001) + hold(005A=90s)
# + router-id(01020304=1.2.3.4) + opt-params-len(10=16)
# + Bundled caps (RFC 5492): param(02) len(0E=14)
#   MP IPv6/unicast: cap(01) cap-len(04) AFI(0002) res(00) SAFI(01)
#   ASN4: cap(41) cap-len(04) ASN(00000001)
#   LLNH: cap(4D) cap-len(00)
expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF002D01040001005A0102030410020E0104000200014104000000014D00
EOF_PEER

# ze bgp configuration with link-local-nexthop enabled
stdin=ze-bgp:terminator=EOF_CONF
bgp {
	peer peer1 {
		connection {
			remote {
				ip 127.0.0.1
				accept false
			}
			local {
				ip 127.0.0.1
			}
		}
		session {
			asn {
				local 1
				remote 1
			}
			router-id 1.2.3.4
			family {
				ipv6/unicast { prefix { maximum 10000; } }
			}
			capability {
				link-local-nexthop
			}
		}
	}
}
EOF_CONF

cmd=background:seq=1:exec=ze-peer --port $PORT:stdin=peer
cmd=foreground:seq=2:exec=ze --plugin ze.bgp-llnh -:stdin=ze-bgp:timeout=10s
