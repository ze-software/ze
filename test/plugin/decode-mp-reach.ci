# Test: Plugin→engine decode-mp-reach RPC
# Validates plugin can decode MP_REACH_NLRI via engine RPC (Socket A)
# MP_REACH_NLRI: IPv4 unicast, NH=192.168.1.1, NLRI=10.0.0.0/24
# Plugin decodes, validates result, sends EOR as success signal

# ze-peer expectations
stdin=peer:terminator=EOF_PEER
# Plugin sends EOR after successful decode-mp-reach validation
cmd=api:conn=1:seq=1:text=peer * update text nlri ipv4/unicast eor
expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF00170200000000
EOF_PEER

# Python plugin script
tmpfs=decode-mp-reach.run:mode=755:terminator=EOF_RUN
#!/usr/bin/env python3
"""Test decode-mp-reach RPC: plugin calls engine to decode MP_REACH_NLRI."""

import sys
import time
from ze_api import API


def main() -> None:
    api = API()
    api.ready()
    time.sleep(0.1)

    # MP_REACH_NLRI for IPv4 unicast:
    # AFI=1(0001), SAFI=1(01), NHLen=4(04), NH=192.168.1.1(C0A80101),
    # Reserved=0(00), NLRI=10.0.0.0/24(180A0000)
    # RFC 4760 Section 3
    params = {'hex': '00010104C0A8010100180A0000', 'add-path': False}
    resp = api._call_engine('ze-plugin-engine:decode-mp-reach', params)

    result = resp.get('result')
    if result is None:
        print('ERROR: decode-mp-reach returned no result', file=sys.stderr)
        sys.exit(1)

    if result.get('family') != 'ipv4/unicast':
        print(f'ERROR: expected family ipv4/unicast, got {result.get("family")}', file=sys.stderr)
        sys.exit(1)

    if result.get('next-hop') != '192.168.1.1':
        print(f'ERROR: expected next-hop 192.168.1.1, got {result.get("next-hop")}', file=sys.stderr)
        sys.exit(1)

    nlri = result.get('nlri', '')
    if '10.0.0.0/24' not in str(nlri):
        print(f'ERROR: expected 10.0.0.0/24 in nlri, got {nlri}', file=sys.stderr)
        sys.exit(1)

    # Success: send EOR to signal completion
    api.send('peer * update text nlri ipv4/unicast eor')
    time.sleep(0.2)
    api.wait_for_ack(expected_count=1)
    api.wait_for_shutdown()


if __name__ == '__main__':
    main()
EOF_RUN

# ze bgp configuration
stdin=ze-bgp:terminator=EOF_CONF
plugin {
    external decode-test {
        run ./decode-mp-reach.run
        encoder json
    }
}
bgp {
    peer peer1 {
    	connection {
    		remote {
    			ip 127.0.0.1
    		}
    		local {
    			ip 127.0.0.1
    			accept false
    		}
    	}
    	session {
    		asn {
    			local 65000
    			remote 65000
    		}
    		router-id 10.0.0.1
    		family {
    		    ipv4/unicast { prefix { maximum 10000; } }
    		}
    	}
    	behavior {
    		group-updates disable
    	}

        process decode-test {
        }
    }
}
EOF_CONF

# Process orchestration
cmd=background:seq=1:exec=ze-peer --port $PORT:stdin=peer
cmd=foreground:seq=2:exec=ze -:stdin=ze-bgp:timeout=15s
