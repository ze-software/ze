# Test: Graceful restart capability with peer inside group
#
# Same as graceful-restart.ci but uses group-level defaults.
# VALIDATES: GR capability works when peer is inside a group with group-level config.
# PREVENTS: Plugin missing grouped peers in config JSON traversal.

# ze-peer expectations
stdin=peer:terminator=EOF_PEER
option=tcp_connections:value=2
option=timeout:value=15s

# Connection A: Static route + EOR
expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF00300200000015400101004002004003040A0000014005040000006418C0A801
expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF00170200000000
action=notification:conn=1:seq=2:text=Peer Reset

# Connection B: Static route resent + EOR
expect=bgp:conn=2:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF00300200000015400101004002004003040A0000014005040000006418C0A801
expect=bgp:conn=2:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF00170200000000
EOF_PEER

# ze bgp configuration -- peer inside group with group-level defaults
stdin=ze-bgp:terminator=EOF_CONF
plugin {
	external gr {
		use bgp-gr
		encoder json
	}
}

bgp {
	group gr-peers {
		connection {
			remote {
			}
			local {
				accept false
			}
		}
		session {
			family {
				ipv4/unicast { prefix { maximum 10000; } }
			}
			capability {
				graceful-restart {
					restart-time 120
				}
			}
		}
		behavior {
			group-updates disable
		}

		process gr {
			send [ update ]
		}

		peer peer1 {
			connection {
				remote {
					ip 127.0.0.1
				}
				local {
					ip 127.0.0.1
				}
			}
			session {
				asn {
					local 1
					remote 1
				}
				router-id 1.2.3.4
			}
			timer { connect-retry 5; }

			update {
				attribute {
					origin igp
					local-preference 100
					next-hop 10.0.0.1
				}
				nlri {
					ipv4/unicast add 192.168.1.0/24
				}
			}
		}
	}
}
EOF_CONF

# Process orchestration
cmd=background:seq=1:exec=ze-peer --port $PORT:stdin=peer
cmd=foreground:seq=2:exec=ze -:stdin=ze-bgp:timeout=15s
