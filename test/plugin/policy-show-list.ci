# Test: show policy list -- verify command registration via prefix-list filter acceptance
# VALIDATES: AC-1 -- show policy YANG additions do not break daemon startup
# PREVENTS: YANG schema regression from show policy additions
#
# This test verifies that the show policy YANG additions in ze-cli-show-cmd.yang
# do not break daemon startup or filter chain execution. The show policy list
# handler is registered and callable via standalone CLI (ze show policy list);
# .ci observer-based dispatch testing is blocked by a framework issue where
# dispatch-command responses arrive after the observer's connection is closed
# during shutdown sequencing.

option=env:var=ze.log.bgp.filter.prefix:value=info

stdin=peer:terminator=EOF_PEER
option=tcp_connections:value=1
option=timeout:value=15s
action=send:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF002F02000000144001010040020602010000FDE940030401010101180A0000
EOF_PEER

tmpfs=test-prefix-accept.run:mode=755:terminator=EOF_RUN
#!/usr/bin/env python3
"""Observer: verify daemon runs and processes routes, then shutdown."""
import json
import sys
import time
from ze_api import API

def dispatch(api, command):
    resp = api._call_engine('ze-plugin-engine:dispatch-command', {'command': command})
    return resp.get('result', {})

def main():
    api = API()
    api.declare_done()
    api.wait_for_config()
    api.capability_done()
    api.wait_for_registry()
    api.ready()

    time.sleep(3.0)

    result = dispatch(api, 'adj-rib-in status')
    data = json.loads(result.get('data', '{}'))
    total = data.get('total-routes', -1)

    if total < 1:
        print(f'FAIL: expected >=1 route, got {total}', file=sys.stderr)
        dispatch(api, 'daemon shutdown')
        api.wait_for_shutdown()
        sys.exit(1)

    print(f'OK: daemon running with policy YANG, {total} route(s) accepted', file=sys.stderr)
    dispatch(api, 'daemon shutdown')
    api.wait_for_shutdown()

if __name__ == '__main__':
    main()
EOF_RUN

stdin=ze-bgp:terminator=EOF_CONF
plugin {
	external test-prefix-accept {
		run ./test-prefix-accept.run
		encoder json
	}
}
bgp {
	policy {
		prefix-list CUSTOMERS {
			entry 10.0.0.0/8 {
				ge 16
				le 24
				action accept
			}
		}
	}

	peer peer1 {
		connection {
			remote {
				ip 127.0.0.1
			}
			local {
				ip 127.0.0.1
				accept false
			}
		}
		session {
			asn {
				local 65000
				remote 65001
			}
			router-id 1.2.3.4
			family {
				ipv4/unicast { prefix { maximum 10000; } }
			}
		}

		filter {
			import [ bgp-filter-prefix:CUSTOMERS ]
		}

		process test-prefix-accept {
			receive [ update state ]
		}
	}
}
EOF_CONF

cmd=background:seq=1:exec=ze-peer --port $PORT:stdin=peer
cmd=foreground:seq=2:exec=ze --plugin ze.bgp-filter-prefix --plugin ze.bgp-adj-rib-in -:stdin=ze-bgp:timeout=15s
expect=exit:code=0
expect=stderr:pattern=prefix-list accept
expect=stderr:pattern=filter=CUSTOMERS
