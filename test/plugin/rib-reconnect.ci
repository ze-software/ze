# Migrated from test/data/plugin/rib-reconnect.*

# ze-peer expectations
stdin=peer:terminator=EOF_PEER
option=tcp_connections:value=2
option=timeout:value=15s

# Test: RIB replays routes on reconnection
#
# Flow:
# 1. Connection A: Plugin sends route -> RIB stores -> peer receives
# 2. Peer sends NOTIFICATION -> ZeBGP disconnects
# 3. Connection B: ZeBGP reconnects -> RIB replays route

# Connection A: Initial route announcement
# UPDATE: origin=IGP, as-path=[], next-hop=10.0.0.1, local-pref=100, nlri=192.168.1.0/24
expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF00300200000015400101004002004003040A0000014005040000006418C0A801
# EOR (End of RIB)
expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF00170200000000
# Peer disconnects with NOTIFICATION
action=notification:conn=1:seq=2:text=Peer Reset

# Connection B: After reconnect, RIB replays the stored route
# UPDATE: same route replayed by RIB
expect=bgp:conn=2:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF00300200000015400101004002004003040A0000014005040000006418C0A801
# EOR
expect=bgp:conn=2:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF00170200000000
EOF_PEER

# Python plugin script
tmpfs=rib-reconnect.run:mode=755:terminator=EOF_RUN
#!/usr/bin/env python3
"""
Test: RIB replays routes on reconnection + route-refresh

Flow:
1. ZeBGP connects to test peer
2. This script sends route via API -> RIB stores in ribOut
3. Test peer receives route + EOR, sends NOTIFICATION
4. ZeBGP reconnects
5. RIB replays the route automatically (peer state "up")
6. Test peer receives route again + EOR
7. Test peer sends ROUTE-REFRESH
8. RIB responds with BoRR + route + EoRR
"""

import time

from ze_bgp_api import ready, send, wait_for_ack, wait_for_shutdown


def main() -> None:
    ready()

    # Send one route - RIB will store it and replay on reconnect
    send('bgp peer * update text nhop set 10.0.0.1 nlri ipv4/unicast add 192.168.1.0/24')
    time.sleep(0.5)

    # Wait for ACK
    wait_for_ack(expected_count=1)

    # Test peer will:
    # 1. Receive route + EOR
    # 2. Send NOTIFICATION -> ZeBGP disconnects
    # 3. ZeBGP reconnects
    # 4. RIB replays the route
    # 5. Send ROUTE-REFRESH
    # 6. RIB responds with BoRR + route + EoRR
    wait_for_shutdown()


if __name__ == '__main__':
    main()
EOF_RUN

# ze bgp configuration
stdin=ze-bgp:terminator=EOF_CONF
plugin {
	external announce-routes {
		run ./rib-reconnect.run;
		encoder json;
	}
	external rib {
		run "ze bgp plugin rib";
		encoder json;
	}
}

environment {
	tcp {
		attempts 3;
	}
}

bgp {
	peer 127.0.0.1 {
		router-id 1.2.3.4;
		local-address 127.0.0.1;
		local-as 1;
		peer-as 1;
		group-updates disable;
	
		family {
			ipv4/unicast;
		}
		capability {
			route-refresh;
			graceful-restart disable;
		}
		process announce-routes {
		}
		process rib {
			send { update; borr; eorr; }
		}
	}
}
EOF_CONF

# Process orchestration
cmd=background:seq=1:exec=ze-peer --port $PORT:stdin=peer
cmd=foreground:seq=2:exec=ze -:stdin=ze-bgp:timeout=20s
