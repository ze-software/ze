# Test: show errors returns notification-sent entry after ze sends a NOTIFICATION
# AC: spec-report-bus AC-9 (notification-sent producer)
# Exercises: peer teardown command -> session_write.go onNotifSent ->
# Peer.IncrNotificationSent -> raiseNotificationError -> report bus ->
# handleShowErrors via dispatch-command -> JSON response with the entry pinned
# to peer 127.0.0.1, code=6, subcode=4 (Cease / Administrative Reset).

# ze-peer: accept connection, expect NOTIFICATION code 6 subcode 4
# (Cease / Administrative Reset, RFC 4486 + RFC 8203 shutdown communication).
# The hex matches teardown-cmd.ci's NOTIFICATION expectation.
stdin=peer:terminator=EOF_PEER
expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF002A0306041441646D696E697374726174697665205265736574
EOF_PEER

# Python test plugin: trigger teardown, then poll "show errors".
tmpfs=show-errors-sent-test.run:mode=755:terminator=EOF_RUN
#!/usr/bin/env python3
import json
import sys
import time
from ze_api import API

def dispatch(api, command):
    resp = api._call_engine(
        'ze-plugin-engine:dispatch-command', {'command': command})
    if resp is None:
        return {'status': 'error', 'data': 'engine call returned None'}
    return resp.get('result', {})

def poll_for_match(api, match_fn, timeout=5.0):
    """Poll `show errors` until at least one entry matches match_fn or timeout."""
    deadline = time.time() + timeout
    while time.time() < deadline:
        result = dispatch(api, 'show errors')
        if result.get('status') == 'done':
            data = result.get('data', {})
            if isinstance(data, str):
                data = json.loads(data)
            errors = data.get('errors', [])
            if any(match_fn(e) for e in errors):
                return data
        time.sleep(0.1)
    return None

def main():
    api = API()
    api.declare_done()
    api.wait_for_config()
    api.capability_done()
    api.wait_for_registry()
    api.ready()
    # Wait for the BGP session to reach Established before tearing it down.
    time.sleep(1.0)

    try:
        # Send teardown 4 (Administrative Reset) -> ze sends NOTIFICATION code=6 subcode=4.
        td = dispatch(api, 'peer 127.0.0.1 teardown 4')
        if td.get('status') != 'done':
            print(f'FAIL: teardown status={td.get("status")} data={td.get("data")}', file=sys.stderr)
            sys.exit(1)

        # Poll for the notification-sent entry instead of a fixed sleep.
        data = poll_for_match(api, lambda e:
            e.get('source') == 'bgp' and
            e.get('code') == 'notification-sent' and
            e.get('subject') == '127.0.0.1')

        if data is None:
            print('FAIL: timed out waiting for bgp/notification-sent entry', file=sys.stderr)
            sys.exit(1)

        errors = data.get('errors', [])

        # Exactly one matching entry per teardown command. Other entries
        # may be present (session-dropped is suppressed because the flag
        # is set, but other unrelated bgp errors might appear).
        matches = [e for e in errors
                   if e.get('source') == 'bgp'
                   and e.get('code') == 'notification-sent'
                   and e.get('subject') == '127.0.0.1']
        if len(matches) != 1:
            print(f'FAIL: expected exactly 1 matching entry, got {len(matches)}: {matches}', file=sys.stderr)
            sys.exit(1)

        e = matches[0]
        if e.get('severity') != 'error':
            print(f'FAIL: severity != error: {e}', file=sys.stderr)
            sys.exit(1)
        detail = e.get('detail', {})
        if detail.get('direction') != 'sent':
            print(f'FAIL: detail.direction != sent: {e}', file=sys.stderr)
            sys.exit(1)
        # teardown 4 -> Cease (6) / Administrative Reset (4) per RFC 4486 + 8203.
        if int(detail.get('code', -1)) != 6:
            print(f'FAIL: detail.code != 6: {e}', file=sys.stderr)
            sys.exit(1)
        if int(detail.get('subcode', -1)) != 4:
            print(f'FAIL: detail.subcode != 4: {e}', file=sys.stderr)
            sys.exit(1)

        print(f'OK: show errors returned {len(errors)} entry(s); 1 matching notification-sent', file=sys.stderr)
        dispatch(api, 'daemon shutdown')
        api.wait_for_shutdown()
    except SystemExit:
        raise
    except Exception as e:
        print(f'FAIL: unexpected error: {e}', file=sys.stderr)
        sys.exit(1)

if __name__ == '__main__':
    main()
EOF_RUN

# ze bgp configuration
stdin=ze-bgp:terminator=EOF_CONF
plugin {
	external show-errors-sent-test {
		run ./show-errors-sent-test.run
		encoder json
	}
}

bgp {
	peer peer1 {
		connection {
			remote {
				ip 127.0.0.1
				accept false
			}
			local {
				ip 127.0.0.1
			}
		}
		session {
			asn {
				local 65000
				remote 65001
			}
			router-id 1.2.3.4
			family {
				ipv4/unicast {
					prefix {
						maximum 10000
					}
				}
			}
			capability {
				graceful-restart disable
			}
		}
		behavior {
			group-updates disable
		}


		process show-errors-sent-test {
		}
	}
}
EOF_CONF

# Process orchestration
cmd=background:seq=1:exec=ze-peer --port $PORT:stdin=peer
cmd=foreground:seq=2:exec=ze -:stdin=ze-bgp:timeout=15s
expect=exit:code=0
