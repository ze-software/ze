# Test: as-path-list and prefix-list compose in a filter chain
# VALIDATES: AC-8 -- composable in chain with other filters
# PREVENTS: AS-path filter breaks prefix-list filter or vice versa in chain
#
# Flow:
# 1. ze-peer sends UPDATE: ORIGIN=IGP, AS_PATH=[65001], NEXT_HOP=1.1.1.1, NLRI=10.0.0.0/24
# 2. Import chain: [as-path-list:ALLOW-AS, bgp-filter-prefix:ALLOW-PREFIX]
# 3. AS-path filter: "65001" matches "^65001" -> accept, pass to next filter
# 4. Prefix filter: 10.0.0.0/24 matches 10.0.0.0/8 ge 16 le 24 -> accept
# 5. Assertions on stderr confirm both filters accepted.

option=env:var=ze.log.bgp.filter.aspath:value=info
option=env:var=ze.log.bgp.filter.prefix:value=info

stdin=peer:terminator=EOF_PEER
option=tcp_connections:value=1
option=timeout:value=15s
action=send:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF002F02000000144001010040020602010000FDE940030401010101180A0000
EOF_PEER

# Observer: wait for filter dispatch then clean shutdown
tmpfs=test-aspath-chain.run:mode=755:terminator=EOF_RUN
#!/usr/bin/env python3
"""Observer for chain composition test: clean shutdown after filter dispatch."""
import time
from ze_api import API

def dispatch(api, command):
    resp = api._call_engine('ze-plugin-engine:dispatch-command', {'command': command})
    return resp.get('result', {})

def main():
    api = API()
    api.declare_done()
    api.wait_for_config()
    api.capability_done()
    api.wait_for_registry()
    api.ready()

    time.sleep(3.0)

    dispatch(api, 'daemon shutdown')
    api.wait_for_shutdown()

if __name__ == '__main__':
    main()
EOF_RUN

stdin=ze-bgp:terminator=EOF_CONF
plugin {
	external test-aspath-chain {
		run ./test-aspath-chain.run
		encoder json
	}
}
bgp {
	policy {
		as-path-list ALLOW-AS {
			entry "^65001" {
				action accept
			}
		}
		prefix-list ALLOW-PREFIX {
			entry 10.0.0.0/8 {
				ge 16
				le 24
				action accept
			}
		}
	}

	peer peer1 {
		connection {
			remote {
				ip 127.0.0.1
			}
			local {
				ip 127.0.0.1
				accept false
			}
		}
		session {
			asn {
				local 65000
				remote 65001
			}
			router-id 1.2.3.4
			family {
				ipv4/unicast { prefix { maximum 10000; } }
			}
		}

		filter {
			import [ as-path-list:ALLOW-AS bgp-filter-prefix:ALLOW-PREFIX ]
		}

		process test-aspath-chain {
			receive [ update state ]
		}
	}
}
EOF_CONF

cmd=background:seq=1:exec=ze-peer --port $PORT:stdin=peer
cmd=foreground:seq=2:exec=ze --plugin ze.bgp-filter-aspath --plugin ze.bgp-filter-prefix --plugin ze.bgp-adj-rib-in -:stdin=ze-bgp:timeout=15s
expect=exit:code=0
# Both filters must have accepted.
expect=stderr:pattern=as-path-list accept
expect=stderr:pattern=prefix-list accept
reject=stderr:pattern=as-path-list reject
reject=stderr:pattern=prefix-list reject
