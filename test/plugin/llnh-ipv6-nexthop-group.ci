# llnh-ipv6-nexthop-group - verify LLNH plugin works with grouped peers
#
# Same as llnh-ipv6-nexthop.ci but peer is inside a group.
# VALIDATES: LLNH capability (code 77) appears in OPEN for grouped peers.
# PREVENTS: Plugin missing grouped peers in config JSON traversal.

# ze-peer expectations
stdin=peer:terminator=EOF_PEER
option=open:value=inspect-open-message
option=timeout:value=10s

# Same expected OPEN as standalone test
expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF002D01040001005A0102030410020E0104000200014104000000014D00
EOF_PEER

# ze bgp configuration -- peer inside group
stdin=ze-bgp:terminator=EOF_CONF
bgp {
	group llnh-peers {
		remote {
			accept false
		}
		family {
			ipv6/unicast { prefix { maximum 10000; } }
		}
		capability {
			link-local-nexthop
		}

		peer peer1 {
			remote {
				ip 127.0.0.1
				as 1
			}
			local {
				as 1
				ip 127.0.0.1
			}
			router-id 1.2.3.4
		}
	}
}
EOF_CONF

cmd=background:seq=1:exec=ze-peer --port $PORT:stdin=peer
cmd=foreground:seq=2:exec=ze --plugin ze.bgp-llnh -:stdin=ze-bgp:timeout=10s
