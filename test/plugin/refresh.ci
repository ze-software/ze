# Migrated from test/data/plugin/refresh.*

# ze-peer expectations
stdin=peer:terminator=EOF_PEER
option:timeout:value=10s

# Step 1: Receive initial route announcement and EoR from ze bgp
expect:bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF00300200000015400101004002004003040A0000014005040000006418C0A801
expect:bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF00170200000000

# Step 2: Send ROUTE-REFRESH (type 5) for IPv4/unicast (AFI=1, Subtype=0, SAFI=1)
# Wire format: AFI(2) + Subtype(1) + SAFI(1) = 00010001
action:send:conn=1:seq=2:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF00170500010001

# Step 3: Expect BoRR, route re-announcement, EoRR
# BoRR: ROUTE-REFRESH with Subtype=1 (RFC 7313)
expect:bgp:conn=1:seq=3:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF00170500010101
# Route re-announcement (same as step 1)
expect:bgp:conn=1:seq=3:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF00300200000015400101004002004003040A0000014005040000006418C0A801
# EoRR: ROUTE-REFRESH with Subtype=2 (RFC 7313)
expect:bgp:conn=1:seq=3:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF00170500010201
EOF_PEER

# Python plugin script
tmpfs=refresh.run:mode=755:terminator=EOF_RUN
#!/usr/bin/env python3
"""
Plugin that waits for peer UP, then sends a route.
Uses buffered line reader to avoid losing data.
"""

import json
import sys
import os
import select
import time


# Global line buffer for proper multi-line handling
line_buffer = []


def flush_write(msg: str) -> None:
    """Write message to stdout and flush."""
    sys.stdout.write(msg + '\n')
    sys.stdout.flush()


def read_line_with_timeout(fd: int, timeout: float) -> str | None:
    """Read a line from fd with timeout, using buffer for multi-line reads."""
    global line_buffer

    # Return buffered line if available
    if line_buffer:
        return line_buffer.pop(0)

    # Read new data
    ready, _, _ = select.select([fd], [], [], timeout)
    if ready:
        data = os.read(fd, 4096).decode('utf-8', errors='replace')
        if data:
            lines = data.strip().split('\n')
            if lines:
                # Return first line, buffer the rest
                result = lines[0]
                line_buffer.extend(lines[1:])
                return result
    return None


def wait_for(fd: int, expected: str, timeout: float = 5.0) -> bool:
    """Wait for a specific line from fd."""
    start = time.time()
    while time.time() - start < timeout:
        line = read_line_with_timeout(fd, 0.1)
        if line and expected in line:
            return True
    return False


def log(msg: str) -> None:
    """Write to debug file."""
    with open('/tmp/refresh-debug.log', 'a') as f:
        f.write(msg + '\n')


def main() -> None:
    stdin_fd = sys.stdin.fileno()

    log("main started")

    # Stage 1: declare done
    flush_write('declare done')
    log("declare done sent")

    # Stage 2: wait for config done
    found = wait_for(stdin_fd, 'config done')
    log(f"config done found={found}")

    # Stage 3: capability done
    flush_write('capability done')
    log("capability done sent")

    # Stage 4: wait for registry done
    found = wait_for(stdin_fd, 'registry done')
    log(f"registry done found={found}")

    # Subscribe BEFORE ready
    flush_write('subscribe bgp event state')
    log("subscribe sent")

    # Stage 5: ready
    flush_write('ready')
    log("ready sent")

    # Wait for state=up event
    start = time.time()
    while time.time() - start < 5:
        line = read_line_with_timeout(stdin_fd, 0.5)
        if line is None:
            continue
        log(f"received: {line[:100]}")

        # Parse JSON
        try:
            event = json.loads(line)
        except (json.JSONDecodeError, TypeError):
            continue

        # Check for state=up
        bgp = event.get('bgp', {})
        if bgp.get('type') == 'state' and bgp.get('state') == 'up':
            log("state=up received, sending route")
            # Send route with all required attributes matching expected hex
            # Expected: ORIGIN IGP, empty AS_PATH, NEXT_HOP 10.0.0.1, LOCAL_PREF 100, NLRI 192.168.1.0/24
            flush_write('bgp peer * update text origin set igp local-preference set 100 nhop set 10.0.0.1 nlri ipv4/unicast add 192.168.1.0/24')
            break

    log("waiting for shutdown")
    # Wait for shutdown or parent death
    start = time.time()
    while os.getppid() != 1 and time.time() - start < 5:
        line = read_line_with_timeout(stdin_fd, 0.5)
        if line and 'shutdown' in line:
            break
    log("exiting")


if __name__ == '__main__':
    main()
EOF_RUN

# ze bgp configuration
stdin=ze-bgp:terminator=EOF_CONF
plugin {
	external announce-routes {
		run ./refresh.run;
		encoder json;
	}
	external rib {
		run "ze bgp plugin rib";
		encoder json;
	}
}
bgp {
	peer 127.0.0.1 {
		router-id 1.2.3.4;
		local-address 127.0.0.1;
		local-as 1;
		peer-as 1;
		group-updates disable;
	
		family {
			ipv4/unicast;
		}
		capability {
			route-refresh;
		}
		process announce-routes {
		}
		process rib {
			send { update; borr; eorr; }
		}
	}
}
EOF_CONF

# Process orchestration
cmd:background:seq=1:exec=ze-peer --port $PORT:stdin=peer
cmd:foreground:seq=2:exec=ze -:stdin=ze-bgp:timeout=20s
