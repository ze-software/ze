# Migrated from test/data/plugin/refresh.*

# ze-peer expectations
stdin=peer:terminator=EOF_PEER
option=timeout:value=10s

# Step 1: Receive initial route announcement and EoR from ze bgp
expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF00300200000015400101004002004003040A0000014005040000006418C0A801
expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF00170200000000

# Step 2: Send ROUTE-REFRESH (type 5) for IPv4/unicast (AFI=1, Subtype=0, SAFI=1)
# Wire format: AFI(2) + Subtype(1) + SAFI(1) = 00010001
action=send:conn=1:seq=2:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF00170500010001

# Step 3: Expect BoRR, route re-announcement, EoRR
# BoRR: ROUTE-REFRESH with Subtype=1 (RFC 7313)
expect=bgp:conn=1:seq=3:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF00170500010101
# Route re-announcement (same as step 1)
expect=bgp:conn=1:seq=3:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF00300200000015400101004002004003040A0000014005040000006418C0A801
# EoRR: ROUTE-REFRESH with Subtype=2 (RFC 7313)
expect=bgp:conn=1:seq=3:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF00170500010201
EOF_PEER

# Python plugin script
tmpfs=refresh.run:mode=755:terminator=EOF_RUN
#!/usr/bin/env python3
"""
Plugin that waits for peer UP, then sends a route.
Uses ze_api library for YANG RPC communication.
"""

import json
import sys
import time

from ze_api import API


def main() -> None:
    api = API()

    # Stage 1: Empty declaration
    api.declare_done()

    # Stage 2: Receive config
    api.wait_for_config(timeout=10.0)

    # Stage 3: No capabilities
    api.capability_done()

    # Stage 4: Receive registry
    api.wait_for_registry(timeout=10.0)

    # Subscribe to state events atomically with ready
    api.subscribe(['state'])

    # Stage 5: Ready (includes subscription)
    api.ready()

    # Wait for state=up event
    start = time.time()
    while time.time() - start < 5:
        line = api.read_line(0.5)
        if line is None:
            continue

        # Parse JSON event
        try:
            event = json.loads(line)
        except (json.JSONDecodeError, TypeError):
            continue

        # Check for state=up (bgp.message.type = "state", bgp.state = "up")
        bgp = event.get('bgp', {})
        msg = bgp.get('message', {})
        if msg.get('type') == 'state' and bgp.get('state') == 'up':
            # Send route with all required attributes matching expected hex
            api.send('peer * update text origin igp local-preference 100 nhop 10.0.0.1 nlri ipv4/unicast add 192.168.1.0/24')
            break

    # Wait for shutdown
    api.wait_for_shutdown()


if __name__ == '__main__':
    main()
EOF_RUN

# ze bgp configuration
stdin=ze-bgp:terminator=EOF_CONF
plugin {
	external announce-routes {
		run ./refresh.run
		encoder json
	}
	external rib {
		run "ze plugin bgp-rib"
		encoder json
	}
}
bgp {
	peer peer1 {
		connection {
			remote {
				ip 127.0.0.1
				accept false
			}
			local {
				ip 127.0.0.1
			}
		}
		session {
			asn {
				local 1
				remote 1
			}
			router-id 1.2.3.4
			family {
				ipv4/unicast { prefix { maximum 10000; } }
			}
			capability {
				route-refresh
			}
		}
		behavior {
			group-updates disable
		}
	
		process announce-routes {
		}
		process rib {
			send [ update refresh enhanced-refresh ]
		}
	}
}
EOF_CONF

# Process orchestration
cmd=background:seq=1:exec=ze-peer --port $PORT:stdin=peer
cmd=foreground:seq=2:exec=ze -:stdin=ze-bgp:timeout=20s
