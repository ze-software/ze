# Test: commit start then end flushes queued routes
# VALIDATES: commit start/end dispatches through engine with done status
# PREVENTS: commit workflow handler broken or transaction manager unavailable

# ze-peer expectations
stdin=peer:terminator=EOF_PEER
option=tcp_connections:value=1
option=timeout:value=15s
expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF00170200000000
EOF_PEER

# Python test plugin: exercises dispatch-command for commit workflow
tmpfs=commit-workflow-test.run:mode=755:terminator=EOF_RUN
#!/usr/bin/env python3
import sys
import time
from ze_api import API

def dispatch(api, command):
    resp = api._call_engine(
        'ze-plugin-engine:dispatch-command', {'command': command})
    if resp is None:
        return {'status': 'error', 'data': 'engine call returned None'}
    return resp.get('result', {})

def main():
    api = API()
    api.declare_done()
    api.wait_for_config()
    api.capability_done()
    api.wait_for_registry()
    api.ready()
    time.sleep(1.0)

    try:
        # Start a named commit
        result = dispatch(api, 'commit test-commit start')
        if result.get('status') != 'done':
            print(f'FAIL: commit start status={result.get("status")} data={result.get("data")}', file=sys.stderr)
            sys.exit(1)

        # Show queued count
        result = dispatch(api, 'commit test-commit show')
        if result.get('status') != 'done':
            print(f'FAIL: commit show status={result.get("status")}', file=sys.stderr)
            sys.exit(1)

        # End commit (flush)
        result = dispatch(api, 'commit test-commit end')
        if result.get('status') != 'done':
            print(f'FAIL: commit end status={result.get("status")}', file=sys.stderr)
            sys.exit(1)

        print('OK: commit start/show/end workflow completed', file=sys.stderr)
    finally:
        dispatch(api, 'daemon shutdown')
        api.wait_for_shutdown()

if __name__ == '__main__':
    main()
EOF_RUN

# ze bgp configuration
stdin=ze-bgp:terminator=EOF_CONF
plugin {
	external commit-workflow-test {
		run ./commit-workflow-test.run
		encoder json
	}
}

environment {
	tcp {
		attempts 3
	}
}

bgp {
	peer peer1 {
		remote {
			ip 127.0.0.1
			as 1
		}
		local {
			as 1
			ip 127.0.0.1
		}
		router-id 1.2.3.4
		connection active
		group-updates disable

		family {
			ipv4/unicast { prefix { maximum 10000; } }
		}
		capability {
			graceful-restart disable
		}
		process commit-workflow-test {
			send [ update ]
		}
	}
}
EOF_CONF

# Process orchestration
cmd=background:seq=1:exec=ze-peer --port $PORT:stdin=peer
cmd=foreground:seq=2:exec=ze -:stdin=ze-bgp:timeout=15s
expect=exit:code=0
