# Test: prefix-list filter partial modify (per-prefix NLRI rewrite)
# VALIDATES: dest-3 -- mixed-prefix UPDATE triggers action=modify with a
#            rewritten NLRI section containing only the accepted prefixes.
# VALIDATES: cmd-4 phase 2 -- strict whole-update mode gives way to per-
#            prefix partition when some prefixes are accepted and others
#            rejected.
# PREVENTS: regression where a 3-prefix UPDATE with 2 accepts + 1 reject
#           turns into a whole-update reject (cmd-4 v1 strict behaviour).
#
# Flow:
# 1. ze-peer sends UPDATE with three prefixes: 10.0.1.0/24 (accept),
#    10.0.2.0/24 (accept), 192.168.1.0/24 (reject).
# 2. bgp-filter-prefix partitions into accepted/rejected and returns
#    action=modify with delta nlri = "ipv4/unicast add 10.0.1.0/24 10.0.2.0/24".
# 3. Engine's extractLegacyNLRIOverride computes the wire NLRI bytes for the
#    accepted subset and passes them to buildModifiedPayload.
# 4. The resulting UPDATE carries only the accepted prefixes.
# 5. Assertions on stderr logs: the "prefix-list modify" decision line with
#    accepted=2 / rejected=1 counts.

option=env:var=ze.log.bgp.filter.prefix:value=info

# Source peer sends one UPDATE carrying three prefixes.
stdin=peer:terminator=EOF_PEER
option=tcp_connections:value=1
option=timeout:value=15s
# Marker(16) + Len=0037(55) + Type=02 + WdLen=0000 + AttrLen=0014(20)
#   ORIGIN: 40010100 (IGP)
#   AS_PATH: 40020602010000FDE9 (AS_SEQ [65001])
#   NEXT_HOP: 40030401010101
#   NLRI: 180A0001 180A0002 18C0A801 (10.0.1.0/24 10.0.2.0/24 192.168.1.0/24)
action=send:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF003702000000144001010040020602010000FDE940030401010101180A0001180A000218C0A801
EOF_PEER

# Minimal observer: waits for the UPDATE to be processed then dispatches
# `daemon shutdown` so ze exits cleanly inside the 15s window. Verification
# is done via `expect=stderr:pattern=` assertions on production logs rather
# than observer introspection (dest-1 antipattern).
tmpfs=test-modify-partial.run:mode=755:terminator=EOF_RUN
#!/usr/bin/env python3
"""Shutdown observer for per-prefix modify test."""
import time
from ze_api import API

def main():
    api = API()
    api.declare_done()
    api.wait_for_config()
    api.capability_done()
    api.wait_for_registry()
    api.ready()
    time.sleep(3.0)
    api._call_engine('ze-plugin-engine:dispatch-command', {'command': 'daemon shutdown'})
    api.wait_for_shutdown()

if __name__ == '__main__':
    main()
EOF_RUN

# ze configuration: prefix-list that accepts 10.0.0.0/8 in /16..24 range.
stdin=ze-bgp:terminator=EOF_CONF
plugin {
	external test-modify-partial {
		run ./test-modify-partial.run
		encoder json
	}
}
bgp {
	policy {
		prefix-list CUSTOMERS {
			entry 10.0.0.0/8 {
				ge 16
				le 24
				action accept
			}
		}
	}

	peer peer1 {
		connection {
			remote {
				ip 127.0.0.1
				accept false
			}
			local {
				ip 127.0.0.1
			}
		}
		session {
			asn {
				local 65000
				remote 65001
			}
			router-id 1.2.3.4
			family {
				ipv4/unicast { prefix { maximum 10000; } }
			}
		}

		filter {
			import [ bgp-filter-prefix:CUSTOMERS ]
		}
	}
}
EOF_CONF

# Process orchestration
cmd=background:seq=1:exec=ze-peer --port $PORT:stdin=peer
cmd=foreground:seq=2:exec=ze --plugin ze.bgp-filter-prefix --plugin ze.bgp-adj-rib-in -:stdin=ze-bgp:timeout=15s
expect=exit:code=0
# The filter must have emitted the modify decision with the expected counts.
# A whole-update reject or accept would miss these patterns.
expect=stderr:pattern=prefix-list modify
expect=stderr:pattern=accepted=2
expect=stderr:pattern=rejected=1
expect=stderr:pattern=filter=CUSTOMERS
