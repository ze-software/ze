# Test: RPKI validates multiple prefixes independently
# VALIDATES: Each prefix in UPDATE gets independent accept/reject (AC-7)
# PREVENTS: RPKI plugin applying same validation result to all prefixes

# ze-peer: send 3 routes -- valid, invalid, notfound
stdin=peer:terminator=EOF_PEER
option=tcp_connections:value=1
option=timeout:value=15s
option=update:value=send-route:prefix=10.0.1.0/24:origin-as=65001:next-hop=10.0.0.1
option=update:value=send-route:prefix=10.0.2.0/24:origin-as=65999:next-hop=10.0.0.1
option=update:value=send-route:prefix=192.168.1.0/24:origin-as=65001:next-hop=10.0.0.1
# EOR from ze
expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF00170200000000
EOF_PEER

tmpfs=rpki-multi-test.run:mode=755:terminator=EOF_RUN
#!/usr/bin/env python3
import json
import sys
import time
from ze_api import API

def dispatch(api, command):
    resp = api._call_engine(
        'ze-plugin-engine:dispatch-command', {'command': command})
    if resp is None:
        return {'status': 'error', 'data': 'engine call returned None'}
    return resp.get('result', {})

def main():
    api = API()
    api.declare_done()
    api.wait_for_config()
    api.capability_done()
    api.wait_for_registry()
    api.ready()

    time.sleep(5.0)

    try:
        result = dispatch(api, 'rib routes received')
        if result.get('status') != 'done':
            print(f'FAIL: rib routes received status={result.get("status")}', file=sys.stderr)
            sys.exit(1)

        data = result.get('data', '')

        # 10.0.1.0/24 from AS 65001: Valid (VRP covers, AS matches) -> accepted
        if '10.0.1.0/24' not in data:
            print(f'FAIL: valid route 10.0.1.0/24 not in RIB: {data}', file=sys.stderr)
            sys.exit(1)

        # 10.0.2.0/24 from AS 65999: Invalid (VRP covers, AS mismatch) -> rejected
        if '10.0.2.0/24' in data:
            print(f'FAIL: invalid route 10.0.2.0/24 should be rejected: {data}', file=sys.stderr)
            sys.exit(1)

        # 192.168.1.0/24 from AS 65001: NotFound (no VRP coverage) -> accepted
        if '192.168.1.0/24' not in data:
            print(f'FAIL: notfound route 192.168.1.0/24 not in RIB: {data}', file=sys.stderr)
            sys.exit(1)

        print('OK: 2 routes accepted, 1 rejected (multi-prefix validation)', file=sys.stderr)
    finally:
        dispatch(api, 'daemon shutdown')
        api.wait_for_shutdown()

if __name__ == '__main__':
    main()
EOF_RUN

stdin=ze-bgp:terminator=EOF_CONF
plugin {
	hub {
		listen 127.0.0.1:0;
		secret rpki-test-secret-key-01234567890;
	}
	external rpki-multi-test {
		run ./rpki-multi-test.run
		encoder json
	}
	external rpki {
		run "ze plugin bgp-rpki"
		encoder json
	}
	external adj-rib-in {
		run "ze plugin bgp-adj-rib-in"
		encoder json
	}
}

environment {
	tcp {
		attempts 3
	}
}

bgp {
	rpki {
		cache-server 127.0.0.1 {
			port $PORT2
		}
	}
	peer peer1 {
		remote {
			ip 127.0.0.1
			as 1
		}
		local {
			as 1
			ip 127.0.0.1
		}
		router-id 1.2.3.4
		connection active
		group-updates disable

		family {
			ipv4/unicast
		}
		capability {
			graceful-restart disable
		}
		process rpki-multi-test {
		}
		process rpki {
			receive [ update ]
		}
		process adj-rib-in {
			receive [ update state ]
		}
	}
}
EOF_CONF

# VRP: 10.0.0.0/8 maxlen=24 AS=65001
cmd=background:seq=1:exec=ze-rtr-mock --port $PORT2 --vrp 10.0.0.0/8,24,65001
cmd=background:seq=2:exec=ze-peer --port $PORT:stdin=peer
cmd=foreground:seq=3:exec=ze -:stdin=ze-bgp:timeout=20s
expect=exit:code=0
