# bgp-rs-reactor-fastpath-fallback -- fallback to plugin dispatch (rs-gap-1)
#
# VALIDATES: peers without rs-fast-path enable still receive UPDATEs through
# the normal bgp-rs ForwardCached plugin dispatch chain. The reactor fast path
# skips peers that lack the flag, and bgp-rs picks them up via ForwardCached.
#
# PREVENTS: regression where disabling rs-fast-path causes UPDATEs to be lost
# entirely (neither fast path nor plugin path forwards them).
#
# Two eBGP peers: source (65001) sends one UPDATE, receiver (65002) has
# rs-fast-path DISABLED (the default). The UPDATE must still arrive at the
# receiver via the normal plugin dispatch chain.

stdin=peer:terminator=EOF_PEER
option=tcp_connections:value=2
option=timeout:value=15s
option=bind:value=0.0.0.0

# Source peer (conn=1): send one UPDATE with NLRI 10.0.0.0/24.
# ORIGIN=IGP, AS_PATH=[65001] (4-byte), NEXT_HOP=1.1.1.1, LOCAL_PREF=100
action=send:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF0036020000001B4001010040020602010000FDE94003040101010140050400000064180A0000

# Receiver peer (conn=2): expect the forwarded UPDATE containing NLRI 10.0.0.0/24.
# Forwarded via plugin dispatch (not fast path), with AS 65000 prepended.
# Use contains= to match the NLRI bytes (180A0000 = /24 10.0.0.0).
expect=bgp:conn=2:seq=1:contains=180A0000

# Both peers receive EOR.
expect=bgp:conn=1:seq=2:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF00170200000000
expect=bgp:conn=2:seq=2:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF00170200000000
EOF_PEER

# Observer: shut down cleanly after forwarding completes.
tmpfs=shutdown-after-up.run:mode=755:terminator=EOF_RUN
#!/usr/bin/env python3
import time
from ze_api import API

def main():
    api = API()
    api.declare_done()
    api.wait_for_config()
    api.capability_done()
    api.wait_for_registry()
    api.ready()
    time.sleep(2.0)
    api._call_engine('ze-plugin-engine:dispatch-command', {'command': 'daemon shutdown'})
    api.wait_for_shutdown()

if __name__ == '__main__':
    main()
EOF_RUN

stdin=ze-bgp:terminator=EOF_CONF
plugin {
	external rs {
		use bgp-rs
	}
	external shutdown-after-up {
		run ./shutdown-after-up.run
		encoder json
	}
}
bgp {
	peer source-peer {
		connection {
			remote {
				ip 127.0.0.1
			}
			local {
				ip 127.0.0.1
				accept false
			}
		}
		session {
			asn {
				local 65000
				remote 65001
			}
			router-id 1.2.3.4
			family {
				ipv4/unicast { prefix { maximum 10000; } }
			}
			capability {
				graceful-restart disable
			}
		}
		behavior {
			group-updates disable
			rs-fast-path enable
		}
	}
	peer receiver-peer {
		connection {
			remote {
				ip 127.0.0.2
			}
			local {
				ip 127.0.0.2
				accept false
			}
		}
		session {
			asn {
				local 65000
				remote 65002
			}
			router-id 1.2.3.4
			family {
				ipv4/unicast { prefix { maximum 10000; } }
			}
			capability {
				graceful-restart disable
			}
		}
		behavior {
			group-updates disable
		}
	}
}
EOF_CONF

cmd=background:seq=1:exec=ze-peer --port $PORT:stdin=peer
cmd=foreground:seq=2:exec=ze -:stdin=ze-bgp:timeout=15s
expect=exit:code=0
reject=stderr:pattern=panic
reject=stderr:pattern=fatal error
reject=stderr:pattern=release-cached failed
reject=stderr:pattern=BUG: ForwardUpdatesDirect
