# Test: ze signal stop sends stop command via SSH
#
# Flow:
# 1. BGP daemon starts with SSH configured
# 2. Plugin sends stop via dispatch-command
# 3. Daemon shuts down cleanly
#
# VALIDATES: AC-6 — stop command via SSH triggers daemon shutdown.
# PREVENTS: Signal command not reaching daemon through SSH.

# ze-peer expectations
stdin=peer:terminator=EOF_PEER
option=tcp_connections:value=1
option=timeout:value=15s

# EOR
expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF00170200000000
EOF_PEER

# Python test plugin: sends stop via dispatch-command
tmpfs=signal-stop-test.run:mode=755:terminator=EOF_RUN
#!/usr/bin/env python3
"""Test: daemon stop via dispatch-command."""

import sys
import time
from ze_api import API


def main():
    api = API()
    api.declare_done()
    api.wait_for_config()
    api.capability_done()
    api.wait_for_registry()
    api.ready()

    # Wait for BGP session
    time.sleep(1.0)

    # Send shutdown command
    resp = api._call_engine(
        'ze-plugin-engine:dispatch-command', {'command': 'daemon shutdown'})
    status = resp.get('result', {}).get('status')
    if status != 'done':
        print(f'FAIL: shutdown status={status}', file=sys.stderr)
        sys.exit(1)

    print('OK: daemon shutdown dispatched', file=sys.stderr)
    api.wait_for_shutdown()


if __name__ == '__main__':
    main()
EOF_RUN

# ze bgp configuration with SSH
stdin=ze-bgp:terminator=EOF_CONF
plugin {
	external signal-stop-test {
		run ./signal-stop-test.run
		encoder json
	}
}

system {
	authentication {
		user admin {
			password "$2a$10$abcdefghijklmnopqrstuuABCDEFGHIJKLMNOPQRSTUVWXYZ0123"
		}
	}
}

environment {
	ssh {
		enabled true
		server main {
			ip 127.0.0.1;
			port 0;
		}
	}
}

bgp {
	peer peer1 {
		connection {
			remote {
				ip 127.0.0.1
				accept false
			}
			local {
				ip 127.0.0.1
			}
		}
		session {
			asn {
				local 1
				remote 1
			}
			router-id 1.2.3.4
			family {
				ipv4/unicast { prefix { maximum 10000; } }
			}
			capability {
				graceful-restart disable
			}
		}
		behavior {
			group-updates disable
		}

		process signal-stop-test {
		}
	}
}
EOF_CONF

cmd=background:seq=1:exec=ze-peer --port $PORT:stdin=peer
cmd=foreground:seq=2:exec=ze -:stdin=ze-bgp:timeout=15s
expect=exit:code=0
