# Test: Withdrawn routes not replayed on reconnect
#
# Flow:
# 1. Connection A: Plugin sends route -> RIB stores -> peer receives
# 2. Plugin withdraws route -> RIB removes from ribOut
# 3. Peer sends NOTIFICATION -> ZeBGP disconnects
# 4. Connection B: ZeBGP reconnects -> RIB replays ONLY remaining routes (none)
#
# VALIDATES: Withdrawn routes are removed from Adj-RIB-Out.
# PREVENTS: Stale routes being replayed after withdrawal.

# ze-peer expectations
stdin=peer:terminator=EOF_PEER
option=tcp_connections:value=2
option=timeout:value=15s

# Connection A: Route announcement + withdrawal + EOR
# Both announce and withdrawal are queued pre-session (Python plugin sends
# during startup, before peers connect). sendInitialRoutes drains both from
# the opQueue before sending EOR.
expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF00300200000015400101004002004003040A0000014005040000006418C0A801
expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF001B02000418C0A8010000
expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF00170200000000
action=notification:conn=1:seq=2:text=Peer Reset

# Connection B: After reconnect, only EOR (no routes - all withdrawn)
expect=bgp:conn=2:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF00170200000000
EOF_PEER

# Python plugin script
tmpfs=rib-withdrawal.run:mode=755:terminator=EOF_RUN
#!/usr/bin/env python3
"""
Test: Withdrawn routes not replayed on reconnect

Flow:
1. Send route via API -> RIB stores in ribOut
2. Withdraw route via API -> RIB removes from ribOut
3. Test peer disconnects
4. ZeBGP reconnects
5. RIB replays nothing (route was withdrawn)
"""

import time

from ze_api import ready, send, wait_for_ack, wait_for_shutdown


def main() -> None:
    ready()

    # Send one route
    send('peer * update text nhop 10.0.0.1 nlri ipv4/unicast add 192.168.1.0/24')
    time.sleep(1.0)
    wait_for_ack(expected_count=1)

    # Withdraw the route
    send('peer * update text nlri ipv4/unicast del 192.168.1.0/24')
    time.sleep(1.0)
    wait_for_ack(expected_count=1)

    # Wait for reconnect cycle to complete
    wait_for_shutdown()


if __name__ == '__main__':
    main()
EOF_RUN

# ze bgp configuration
stdin=ze-bgp:terminator=EOF_CONF
plugin {
	external announce-routes {
		run ./rib-withdrawal.run
		encoder json
	}
	external bgp-rib {
		use bgp-rib
		encoder json
	}
}

bgp {
	peer peer1 {
		connection {
			remote {
				ip 127.0.0.1
				accept false
			}
			local {
				ip 127.0.0.1
			}
		}
		session {
			asn {
				local 1
				remote 1
			}
			router-id 1.2.3.4
			family {
				ipv4/unicast { prefix { maximum 10000; } }
			}
			capability {
				graceful-restart disable
			}
		}
		behavior {
			group-updates disable
		}
		timer { connect-retry 5; }
	
		process announce-routes {
		}
		process bgp-rib {
			receive [ sent state ]
			send [ update ]
		}
	}
}
EOF_CONF

# Process orchestration
cmd=background:seq=1:exec=ze-peer --port $PORT:stdin=peer
cmd=foreground:seq=2:exec=ze -:stdin=ze-bgp:timeout=20s
