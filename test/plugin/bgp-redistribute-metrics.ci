# Test: bgp-redistribute -- known event sequence drives the consumer through
#       all metric-incrementing branches without runtime errors.
# VALIDATES: AC-14 (functional half) -- the consumer dispatches accepted adds,
#            accepted removes, rule-rejected adds, and BGP-skipped batches in
#            the same daemon process without crashing or hanging. Counter
#            cadence itself is asserted in the Go unit test
#            `TestMetricsCadence`; no daemon-side `metrics show` query is
#            available, so this .ci verifies the runtime path only.
# PREVENTS: A regression in any of the four counter-increment branches that
#           does not surface in unit-mocked dispatch.

stdin=peer:terminator=EOF_PEER
option=tcp_connections:value=1
option=timeout:value=20s
expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF00170200000000
EOF_PEER

tmpfs=metrics-test.run:mode=755:terminator=EOF_RUN
#!/usr/bin/env python3
import time
from ze_api import API, runtime_fail


def dispatch(api, command):
    return api._call_engine('ze-plugin-engine:dispatch-command', {'command': command}) or {}


def main():
    api = API()
    api.declare_done()
    api.wait_for_config()
    api.capability_done()
    api.wait_for_registry()
    api.ready()

    time.sleep(2.0)

    sequence = [
        'fakeredist emit add ipv4/unicast 10.0.0.1/32',     # accepted add
        'fakeredist emit add ipv4/unicast 10.0.0.2/32',     # accepted add
        'fakeredist emit add ipv4/unicast 10.0.0.3/32',     # accepted add
        'fakeredist emit remove ipv4/unicast 10.0.0.1/32',  # accepted remove
        'fakeredist emit add ipv6/unicast 2001:db8::1/128', # rule-rejected (family)
    ]
    for cmd in sequence:
        resp = dispatch(api, cmd)
        result = resp.get('result', {})
        if result.get('status') != 'done':
            runtime_fail(f'{cmd}: status={result.get("status")} data={result.get("data")}')
            return
        time.sleep(0.2)

    time.sleep(2.0)
    dispatch(api, 'daemon shutdown')
    api.wait_for_shutdown()


if __name__ == '__main__':
    main()
EOF_RUN

stdin=ze-bgp:terminator=EOF_CONF
plugin {
	external metrics-test {
		run ./metrics-test.run
		encoder json
	}
	external bgp-redistribute-egress {
		use bgp-redistribute-egress
		encoder json
	}
	external fakeredist {
		use fakeredist
		encoder json
	}
}

redistribute {
	import fakeredist {
		family [ ipv4/unicast ];
	}
}

bgp {
	peer peer1 {
		connection {
			remote {
				ip 127.0.0.1
			}
			local {
				ip 127.0.0.1
				accept false
			}
		}
		session {
			asn {
				local 65533
				remote 65533
			}
			router-id 1.2.3.4
			family {
				ipv4/unicast { prefix { maximum 10000; } }
			}
			capability {
				graceful-restart disable
			}
		}
		behavior {
			group-updates disable
		}
	}
}
EOF_CONF

cmd=background:seq=1:exec=ze-peer --port $PORT:stdin=peer
cmd=foreground:seq=2:exec=ze -:stdin=ze-bgp:timeout=20s
expect=exit:code=0
