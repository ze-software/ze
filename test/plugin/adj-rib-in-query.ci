# Test: adj-rib-in plugin stores received routes queryable via API
# VALIDATES: routes received from peer stored in adj-rib-in, queryable via rib routes
# PREVENTS: adj-rib-in not storing received routes or query returning empty

# ze-peer expectations
stdin=peer:terminator=EOF_PEER
option=tcp_connections:value=1
option=timeout:value=15s
option=update:value=send-default-route
# EOR from ze
expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF00170200000000
EOF_PEER

# Python test plugin: waits for route from peer, then queries adj-rib-in
tmpfs=adj-rib-query-test.run:mode=755:terminator=EOF_RUN
#!/usr/bin/env python3
import json
import sys
import time
from ze_api import API

def dispatch(api, command):
    resp = api._call_engine(
        'ze-plugin-engine:dispatch-command', {'command': command})
    if resp is None:
        return {'status': 'error', 'data': 'engine call returned None'}
    return resp.get('result', {})

def main():
    api = API()
    api.declare_done()
    api.wait_for_config()
    api.capability_done()
    api.wait_for_registry()
    api.ready()

    # Wait for session + route from ze-peer (send-default-route option)
    time.sleep(2.0)

    try:
        # Query adj-rib-in for received routes
        result = dispatch(api, 'rib routes received')
        if result.get('status') != 'done':
            print(f'FAIL: rib show-in status={result.get("status")} data={result.get("data")}', file=sys.stderr)
            sys.exit(1)

        print('OK: adj-rib-in query returned done', file=sys.stderr)
    finally:
        dispatch(api, 'daemon shutdown')
        api.wait_for_shutdown()

if __name__ == '__main__':
    main()
EOF_RUN

# ze bgp configuration with adj-rib-in plugin
stdin=ze-bgp:terminator=EOF_CONF
plugin {
	external adj-rib-query-test {
		run ./adj-rib-query-test.run
		encoder json
	}
	external rib {
		run "ze plugin bgp-rib"
		encoder json
	}
	external adj-rib-in {
		run "ze plugin bgp-adj-rib-in"
		encoder json
	}
}

environment {
	tcp {
		attempts 3
	}
}

bgp {
	peer 127.0.0.1 {
		router-id 1.2.3.4
		local-address 127.0.0.1
		local-as 1
		peer-as 1
		connection active
		group-updates disable

		family {
			ipv4/unicast
		}
		capability {
			graceful-restart disable
		}
		process adj-rib-query-test {
		}
		process rib {
			receive [ state ]
			send [ update ]
		}
		process adj-rib-in {
			receive [ update state ]
		}
	}
}
EOF_CONF

# Process orchestration
cmd=background:seq=1:exec=ze-peer --port $PORT:stdin=peer
cmd=foreground:seq=2:exec=ze -:stdin=ze-bgp:timeout=15s
expect=exit:code=0
