# Test: BMP sender emits Route Mirroring with verbatim BGP messages.
# VALIDATES: AC-4 -- Route Mirroring sent for UPDATE with TLV type 0
#            containing complete BGP PDU (marker + length + type + body).
# VALIDATES: AC-12 -- Route Mirroring only sent when route-mirroring true.
# PREVENTS:  Route Mirroring wrapping body-only bytes without BGP header,
#            or sending mirrored messages when the feature is disabled.
#
# Flow:
# 1. Start a Python BMP collector listener on $PORT2.
# 2. Start ze as BMP sender with route-mirroring true, peered with ze-peer.
# 3. ze-peer sends an UPDATE; ze sends both Route Monitoring and Route
#    Mirroring to the collector.
# 4. Collector validates Route Mirroring: TLV type 0, embedded BGP PDU
#    has valid marker + length + type.
# 5. Test matches the sentinel on stderr.

option=env:var=ze.log.bgp.bmp:value=info
option=timeout:value=20s

tmpfs=bmp-shutdown.run:mode=755:terminator=EOF_OBS
#!/usr/bin/env python3
"""Observer: wait for the bmp-collector to signal via the .collector-done
marker file, then dispatch daemon shutdown."""
import os
import time
from ze_api import API


MARKER = '.collector-done'
DEADLINE_SECONDS = 15.0


def dispatch(api, command):
    api._call_engine('ze-plugin-engine:dispatch-command', {'command': command})


def main():
    api = API()
    api.declare_done()
    api.wait_for_config()
    api.capability_done()
    api.wait_for_registry()
    api.ready()

    deadline = time.time() + DEADLINE_SECONDS
    while time.time() < deadline:
        if os.path.exists(MARKER):
            break
        time.sleep(0.1)
    time.sleep(0.3)

    dispatch(api, 'daemon shutdown')
    api.wait_for_shutdown()


if __name__ == '__main__':
    main()
EOF_OBS

tmpfs=bmp-collector.py:mode=755:terminator=EOF_COLLECTOR
#!/usr/bin/env python3
"""BMP collector: accept one ze connection, validate Route Mirroring PDUs."""
import socket
import struct
import sys
import time

BMP_PORT = $PORT2
VALID_SENTINEL = "BMP-COLLECTOR: valid-route-mirroring"
INVALID_SENTINEL = "BMP-COLLECTOR: invalid-pdu"
DONE_SENTINEL = "BMP-COLLECTOR: done"

MSG_ROUTE_MONITORING = 0
MSG_ROUTE_MIRRORING = 6
MSG_INITIATION = 4
MSG_PEER_UP = 3

MIRROR_TLV_BGP_MSG = 0
BGP_MARKER = b"\xff" * 16


def log(msg):
    print(msg, file=sys.stderr, flush=True)


def read_exact(sock, n):
    buf = b""
    while len(buf) < n:
        chunk = sock.recv(n - len(buf))
        if not chunk:
            return None
        buf += chunk
    return buf


def validate_route_mirroring(payload):
    """Validate Route Mirroring: PeerHeader(42) + TLV(type=0, BGP PDU)."""
    if len(payload) < 42 + 4:
        log(f"{INVALID_SENTINEL}: mirroring payload too short ({len(payload)} bytes)")
        return False

    off = 42  # skip PeerHeader
    tlv_type = struct.unpack("!H", payload[off:off + 2])[0]
    tlv_len = struct.unpack("!H", payload[off + 2:off + 4])[0]
    off += 4

    if tlv_type != MIRROR_TLV_BGP_MSG:
        log(f"{INVALID_SENTINEL}: TLV type={tlv_type} (want {MIRROR_TLV_BGP_MSG})")
        return False

    if len(payload) < off + tlv_len:
        log(f"{INVALID_SENTINEL}: TLV value truncated")
        return False

    pdu = payload[off:off + tlv_len]
    if len(pdu) < 19:
        log(f"{INVALID_SENTINEL}: BGP PDU too short ({len(pdu)} bytes)")
        return False
    if pdu[:16] != BGP_MARKER:
        log(f"{INVALID_SENTINEL}: BGP marker mismatch")
        return False
    bgp_len = struct.unpack("!H", pdu[16:18])[0]
    if bgp_len != len(pdu):
        log(f"{INVALID_SENTINEL}: BGP length={bgp_len} but PDU has {len(pdu)} bytes")
        return False
    log(f"{VALID_SENTINEL}: type={pdu[18]} len={bgp_len}")
    return True


def main():
    srv = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
    srv.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)
    srv.bind(("127.0.0.1", BMP_PORT))
    srv.listen(1)
    srv.settimeout(15.0)
    log(f"BMP-COLLECTOR: listening on {BMP_PORT}")

    try:
        conn, _ = srv.accept()
    except socket.timeout:
        log(f"{INVALID_SENTINEL}: no connection accepted before timeout")
        sys.exit(1)

    conn.settimeout(10.0)
    got_valid_mirror = False
    deadline = time.time() + 10.0
    while time.time() < deadline:
        header = read_exact(conn, 6)
        if header is None:
            break
        version, length, msg_type = struct.unpack("!BIB", header)
        if version != 3:
            log(f"{INVALID_SENTINEL}: BMP version={version}")
            break
        if length < 6 or length > 65535:
            log(f"{INVALID_SENTINEL}: BMP length={length}")
            break
        payload = read_exact(conn, length - 6)
        if payload is None:
            break
        if msg_type == MSG_ROUTE_MIRRORING:
            if validate_route_mirroring(payload):
                got_valid_mirror = True
                break

    log(DONE_SENTINEL)
    conn.close()
    srv.close()
    try:
        with open(".collector-done", "w") as f:
            f.write("1\n")
    except OSError as e:
        log(f"BMP-COLLECTOR: marker write failed: {e}")
    sys.exit(0 if got_valid_mirror else 1)


if __name__ == "__main__":
    main()
EOF_COLLECTOR

stdin=peer:terminator=EOF_PEER
option=tcp_connections:value=1
option=update:value=send-route:prefix=10.20.30.0/24:origin-as=65001:next-hop=101.1.101.1
expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF00170200000000
EOF_PEER

stdin=ze-bgp:terminator=EOF_CONF
environment {
    bmp {
        enabled true;
    }
}
bgp {
    router-id 1.2.3.5;
    bmp {
        sender {
            collector test-collector {
                address 127.0.0.1;
                port $PORT2;
            }
            route-monitoring-policy all;
            route-mirroring true;
        }
    }
    peer test-peer {
        connection {
            remote {
                ip 127.0.0.1
            }
            local {
                ip 127.0.0.1
                accept false
            }
        }
        session {
            asn {
                local 65000;
                remote 65001;
            }
            router-id 1.2.3.5;
            family {
                ipv4/unicast { prefix { maximum 10000; } }
            }
        }
        behavior {
            group-updates disable;
        }
    }
}
plugin {
    external bmp-shutdown {
        run ./bmp-shutdown.run;
        encoder json;
    }
}
EOF_CONF

cmd=background:seq=1:exec=python3 ./bmp-collector.py
cmd=background:seq=2:exec=ze-peer --port $PORT:stdin=peer
cmd=foreground:seq=3:exec=ze --plugin ze.bgp-bmp -:stdin=ze-bgp
expect=exit:code=0
expect=stderr:pattern=BMP-COLLECTOR: listening on
expect=stderr:pattern=BMP-COLLECTOR: valid-route-mirroring
reject=stderr:pattern=BMP-COLLECTOR: invalid-pdu
