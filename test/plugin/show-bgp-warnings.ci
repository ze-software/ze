# Test: show bgp warnings returns stale prefix data warning
# Exercises the full CLI path: dispatch-command -> ze-show:bgp-warnings -> HandleBgpWarnings

# ze-peer: accepts connection, receives EOR
stdin=peer:terminator=EOF_PEER
option=tcp_connections:value=1
option=timeout:value=15s
option=asn:value=65001
expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF00170200000000
EOF_PEER

# Python test plugin: issues "show bgp warnings" and checks the response
tmpfs=show-warnings-test.run:mode=755:terminator=EOF_RUN
#!/usr/bin/env python3
import json
import sys
import time
from ze_api import API

def dispatch(api, command):
    resp = api._call_engine(
        'ze-plugin-engine:dispatch-command', {'command': command})
    if resp is None:
        return {'status': 'error', 'data': 'engine call returned None'}
    return resp.get('result', {})

def main():
    api = API()
    api.declare_done()
    api.wait_for_config()
    api.capability_done()
    api.wait_for_registry()
    api.ready()
    time.sleep(1.0)

    try:
        result = dispatch(api, 'show bgp warnings')
        status = result.get('status')
        if status != 'done':
            print(f'FAIL: status={status} data={result.get("data")}', file=sys.stderr)
            sys.exit(1)

        data = result.get('data', {})
        if isinstance(data, str):
            data = json.loads(data)

        count = data.get('count', 0)
        if count < 1:
            print(f'FAIL: expected at least 1 warning, got {count}', file=sys.stderr)
            sys.exit(1)

        warnings = data.get('warnings', [])
        found_stale = False
        for w in warnings:
            if w.get('type') == 'stale-data':
                found_stale = True
                if '2024-01-01' not in w.get('message', ''):
                    print(f'FAIL: stale warning missing date: {w}', file=sys.stderr)
                    sys.exit(1)

        if not found_stale:
            print(f'FAIL: no stale-data warning in {warnings}', file=sys.stderr)
            sys.exit(1)

        print(f'OK: show bgp warnings returned {count} warning(s)', file=sys.stderr)
        dispatch(api, 'daemon shutdown')
        api.wait_for_shutdown()
    except SystemExit:
        raise
    except Exception as e:
        print(f'FAIL: unexpected error: {e}', file=sys.stderr)
        sys.exit(1)

if __name__ == '__main__':
    main()
EOF_RUN

# ze bgp configuration: peer1 has stale prefix data (2024-01-01)
stdin=ze-bgp:terminator=EOF_CONF
environment {
	tcp {
		attempts 3
	}
}

plugin {
	external show-warnings-test {
		run ./show-warnings-test.run
		encoder json
	}
}

bgp {
	peer peer1 {
		connection {
			remote {
				ip 127.0.0.1
				accept false
			}
			local {
				ip 127.0.0.1
			}
		}
		session {
			asn {
				local 65000
				remote 65001
			}
			router-id 1.2.3.4
			family {
				ipv4/unicast {
					prefix {
						maximum 10000
						updated 2024-01-01
					}
				}
			}
			capability {
				graceful-restart disable
			}
		}
		behavior {
			group-updates disable
		}


		process show-warnings-test {
		}
	}
}
EOF_CONF

# Process orchestration
cmd=background:seq=1:exec=ze-peer --port $PORT:stdin=peer
cmd=foreground:seq=2:exec=ze -:stdin=ze-bgp:timeout=15s
expect=exit:code=0
