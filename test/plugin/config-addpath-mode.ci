# Test: add-path send config negotiates ADD-PATH capability
# VALIDATES: ADD-PATH capability negotiated, verified via peer capabilities
# PREVENTS: ADD-PATH config silently ignored, no capability negotiated

# ze-peer expectations
stdin=peer:terminator=EOF_PEER
option=tcp_connections:value=1
option=timeout:value=15s
# EOR (session established with ADD-PATH negotiated)
expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF00170200000000
EOF_PEER

# Python test plugin: verifies ADD-PATH capability negotiated
tmpfs=addpath-test.run:mode=755:terminator=EOF_RUN
#!/usr/bin/env python3
import json
import sys
import time
from ze_api import API

def dispatch(api, command):
    resp = api._call_engine(
        'ze-plugin-engine:dispatch-command', {'command': command})
    if resp is None:
        return {'status': 'error', 'data': 'engine call returned None'}
    return resp.get('result', {})

def main():
    api = API()
    api.declare_done()
    api.wait_for_config()
    api.capability_done()
    api.wait_for_registry()
    api.ready()
    time.sleep(1.0)

    try:
        result = dispatch(api, 'peer 127.0.0.1 capabilities')
        if result.get('status') != 'done':
            print(f'FAIL: capabilities status={result.get("status")}', file=sys.stderr)
            sys.exit(1)

        data = result.get('data', {})
        if isinstance(data, str):
            data = json.loads(data)

        # Single peer returns flat object
        negotiated = data.get('negotiated', {})
        if 'add-path' not in negotiated:
            print(f'FAIL: no add-path in negotiated capabilities: {list(negotiated.keys())}', file=sys.stderr)
            sys.exit(1)

        print(f'OK: add-path capability negotiated: {negotiated["add-path"]}', file=sys.stderr)
    finally:
        dispatch(api, 'daemon shutdown')
        api.wait_for_shutdown()

if __name__ == '__main__':
    main()
EOF_RUN

# ze bgp configuration with add-path send
stdin=ze-bgp:terminator=EOF_CONF
plugin {
	external addpath-test {
		run ./addpath-test.run
		encoder json
	}
}

environment {
	tcp {
		attempts 3
	}
}

bgp {
	peer 127.0.0.1 {
		router-id 1.2.3.4
		local-address 127.0.0.1
		local-as 1
		peer-as 1
		connection active
		group-updates disable

		family {
			ipv4/unicast
		}
		capability {
			add-path send/receive
			graceful-restart disable
		}
		add-path {
			ipv4/unicast
		}
		process addpath-test {
		}
	}
}
EOF_CONF

# Process orchestration
cmd=background:seq=1:exec=ze-peer --port $PORT:stdin=peer
cmd=foreground:seq=2:exec=ze -:stdin=ze-bgp:timeout=15s
expect=exit:code=0
