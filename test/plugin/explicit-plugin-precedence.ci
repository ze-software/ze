# Test: Explicit plugin via --plugin flag prevents auto-loading
#
# Scenario:
# - Config has `family { ipv4/flow; }` which would normally auto-load ze.bgp-nlri-flowspec
# - User explicitly loads ze.bgp-nlri-flowspec via --plugin flag
# - Expected: Only one flowspec instance, no conflict from duplicate auto-loading
#
# Key verification:
# - If auto-load happened despite explicit --plugin, there would be a family conflict
# - Family conflicts abort startup, so test passing = no conflict = no auto-load
#
# Note: Config family block overrides plugin decode families in OPEN
# So OPEN contains only ipv4/flow (from config), not all 4 flowspec families

# ze-peer expectations
stdin=peer:terminator=EOF_PEER
option=open:value=inspect-open-message
# Expect OPEN with:
# - ASN=1 (0x0001), hold=90s (0x005A), router-id=1.2.3.4 (0x01020304)
# - Opt params (14 bytes = 0x0E), bundled in single type-2 param (RFC 5492):
#   - 02 0C (param type 2, len 12)
#     Multiprotocol ipv4/flow: 01 04 00 01 00 85
#     ASN4: 41 04 00 00 00 01
expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF002B01040001005A010203040E020C010400010085410400000001
EOF_PEER

# ze bgp configuration
# Config has family block - would normally trigger auto-load of ze.bgp-nlri-flowspec
# But --plugin ze.bgp-nlri-flowspec is explicit, so auto-load is skipped
stdin=ze-bgp:terminator=EOF_CONF
bgp {
    peer peer1 {
    	connection {
    		remote {
    			ip 127.0.0.1
    		}
    		local {
    			ip 127.0.0.1
    			accept false
    		}
    	}
    	session {
    		asn {
    			local 1
    			remote 1
    		}
    		router-id 1.2.3.4
    		family {
    		    ipv4/flow { prefix { maximum 10000; } }
    		}
    	}

    }
}
EOF_CONF

# Process orchestration
# --plugin ze.bgp-nlri-flowspec is explicit - prevents auto-loading
cmd=background:seq=1:exec=ze-peer --port $PORT:stdin=peer
cmd=foreground:seq=2:exec=ze --plugin ze.bgp-nlri-flowspec -:stdin=ze-bgp:timeout=10s
