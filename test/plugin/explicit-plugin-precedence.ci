# Test: Explicit plugin via --plugin flag prevents auto-loading
#
# Scenario:
# - Config has `family { ipv4/flow; }` which would normally auto-load ze.bgp-flowspec
# - User explicitly loads ze.bgp-flowspec via --plugin flag
# - Expected: Only one flowspec instance, no conflict from duplicate auto-loading
#
# Key verification:
# - If auto-load happened despite explicit --plugin, there would be a family conflict
# - Family conflicts abort startup, so test passing = no conflict = no auto-load
#
# Note: Config family block overrides plugin decode families in OPEN
# So OPEN contains only ipv4/flow (from config), not all 4 flowspec families

# ze-peer expectations
stdin=peer:terminator=EOF_PEER
option=open:value=inspect-open-message
# Expect OPEN with:
# - ASN=1 (0x0001), hold=90s (0x005A), router-id=1.2.3.4 (0x01020304)
# - Opt params (16 bytes = 0x10):
#   - Multiprotocol ipv4/flow: 02 06 01 04 00 01 00 85
#   - ASN4: 02 06 41 04 00 00 00 01
expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF002D01040001005A010203041002060104000100850206410400000001
EOF_PEER

# ze bgp configuration
# Config has family block - would normally trigger auto-load of ze.bgp-flowspec
# But --plugin ze.bgp-flowspec is explicit, so auto-load is skipped
stdin=ze-bgp:terminator=EOF_CONF
bgp {
    peer 127.0.0.1 {
        router-id 1.2.3.4;
        local-address 127.0.0.1;
        local-as 1;
        peer-as 1;

        family {
            ipv4/flow;
        }
    }
}
EOF_CONF

# Process orchestration
# --plugin ze.bgp-flowspec is explicit - prevents auto-loading
cmd=background:seq=1:exec=ze-peer --port $PORT:stdin=peer
cmd=foreground:seq=2:exec=ze --plugin ze.bgp-flowspec -:stdin=ze-bgp:timeout=10s
