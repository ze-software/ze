# Test: BFD Stage 2 transport hardening wiring is live
#
# VALIDATES: spec-bfd-2-transport-hardening -- a pinned single-hop session
#            drives loopFor into the real UDP transport, the loop starts
#            (logging "bfd loop started" with a vrf label), the engine
#            FSM is reachable from a real bound socket, and the plugin
#            stays up until SIGTERM.
# PREVENTS:  regression where Stage 2 wiring drops a pinned session on the
#            floor, the loop does not bind, or the Stage 1 "VRF not yet
#            supported" error path re-appears.
#
# Method: a Python orchestrator launches ze with a config containing one
# pinned single-hop session + one pinned multi-hop session, captures
# stderr for the Stage 2 lifecycle log lines, then SIGTERMs cleanly. The
# test uses VRF=default (no CAP_NET_RAW required) and does not bind to a
# specific interface so the runner environment does not need SO_BINDTODEVICE
# permissions. The unit tests in
# internal/plugins/bfd/transport/udp_device_linux_test.go cover the
# bind-to-device paths that do require privilege.

tmpfs=test-bfd-stage2.py:mode=755:terminator=EOF_PY
#!/usr/bin/env python3
"""Drive ze with pinned BFD sessions and assert Stage 2 wiring."""

import os
import signal
import subprocess
import sys
import time

REQUIRED = [
    "bfd plugin starting",
    "bfd plugin configured",
    "bfd loop started",
    "bfd pinned session created",
    "mode=single-hop",
    "mode=multi-hop",
]

CONFIG = """environment {
}

bfd {
\tenabled true;
\tprofile fast {
\t\tdetect-multiplier 3
\t\tdesired-min-tx-us 50000
\t\trequired-min-rx-us 50000
\t}
\tsingle-hop-session 203.0.113.9 {
\t\tprofile fast
\t}
\tmulti-hop-session 198.51.100.9 {
\t\tlocal 203.0.113.8
\t\tmin-ttl 250
\t\tprofile fast
\t}
}
"""


def main() -> int:
    env = os.environ.copy()
    env["ze.log.bfd"] = "debug"

    proc = subprocess.Popen(
        ["ze", "-"],
        stdin=subprocess.PIPE,
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
        text=True,
        env=env,
    )
    assert proc.stdin is not None
    proc.stdin.write(CONFIG)
    proc.stdin.close()

    deadline = time.time() + 10.0
    captured = ""
    matched: set[str] = set()
    while time.time() < deadline:
        if proc.stderr is None:
            break
        line = proc.stderr.readline()
        if not line:
            if proc.poll() is not None:
                break
            time.sleep(0.05)
            continue
        captured += line
        sys.stderr.write(line)
        sys.stderr.flush()
        for needle in REQUIRED:
            if needle in line:
                matched.add(needle)
        if len(matched) == len(REQUIRED):
            break

    if proc.poll() is None:
        proc.send_signal(signal.SIGTERM)
        try:
            proc.wait(timeout=3.0)
        except subprocess.TimeoutExpired:
            proc.kill()
            proc.wait(timeout=2.0)

    if proc.stderr is not None:
        try:
            tail = proc.stderr.read()
        except (ValueError, OSError):
            tail = ""
        if tail:
            captured += tail
            sys.stderr.write(tail)
            sys.stderr.flush()

    missing = [needle for needle in REQUIRED if needle not in captured]
    if missing:
        sys.stderr.write(f"FAIL: missing required patterns: {missing}\n")
        return 1

    sys.stderr.write("OK: all bfd Stage 2 lifecycle patterns observed\n")
    return 0


if __name__ == "__main__":
    sys.exit(main())
EOF_PY

cmd=foreground:seq=1:exec=python3 ./test-bfd-stage2.py:timeout=20s
expect=exit:code=0
expect=stderr:pattern=bfd plugin starting
expect=stderr:pattern=bfd loop started
expect=stderr:pattern=bfd pinned session created
expect=stderr:pattern=mode=single-hop
expect=stderr:pattern=mode=multi-hop
