# Test: role strict sends NOTIFICATION when peer lacks role capability
# VALIDATES: role strict config causes NOTIFICATION to peer without role
# PREVENTS: role strict silently accepting peers without role capability

# ze-peer expectations
stdin=peer:terminator=EOF_PEER
option=tcp_connections:value=1
option=timeout:value=10s
# Drop role capability (code 9) from ze-peer's OPEN response
option=open:value=drop-capability:code=9
# Expect NOTIFICATION: OPEN Message Error (code 2), Role Mismatch (subcode 11/0x0B, RFC 9234)
expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF001503020B
EOF_PEER

# ze bgp configuration with role strict (peer-level container, not in capability)
stdin=ze-bgp:terminator=EOF_CONF
bgp {
	peer peer1 {
		connection {
			remote {
				ip 127.0.0.1
				accept false
			}
			local {
				ip 127.0.0.1
			}
		}
		session {
			asn {
				local 1
				remote 1
			}
			router-id 1.2.3.4
			family {
				ipv4/unicast { prefix { maximum 10000; } }
			}
		}

		role {
			import provider
			strict true
		}
	}
}
EOF_CONF

# Process orchestration
cmd=background:seq=1:exec=ze-peer --port $PORT:stdin=peer
cmd=foreground:seq=2:exec=ze --plugin ze.bgp-role -:stdin=ze-bgp:timeout=10s
