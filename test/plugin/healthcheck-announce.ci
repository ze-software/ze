# Healthcheck: probe success triggers watchdog announce with UP metric (MED 100).
# Config: probe runs "true" (always succeeds), rise=1 for fast UP, withdraw-on-down true.
# The watchdog route has withdraw=true, so not sent initially. After healthcheck
# transitions to UP, it dispatches "watchdog announce hc-dns med 100".

# ze-peer expectations
stdin=peer:terminator=EOF_PEER
# EOR (no routes initially -- watchdog has withdraw=true)
expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF00170200000000
# After probe succeeds (rise=1), healthcheck dispatches watchdog announce med 100.
# UPDATE: origin igp, as-path [], nhop 1.2.3.4, med 100, local-pref 100, nlri 10.0.0.0/24
cmd=api:conn=1:seq=1:text=healthcheck probe UP triggers announce med 100
expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF0037020000001C40010100400200400304010203048004040000006440050400000064180A0000
EOF_PEER

# ze bgp configuration
stdin=ze-bgp:terminator=EOF_CONF
bgp {
	healthcheck {
		probe dns {
			command "true"
			group hc-dns
			interval 1
			rise 1
			fall 1
			withdraw-on-down true
			up-metric 100
		}
	}
	peer peer1 {
		connection {
			remote {
				ip 127.0.0.1
			}
			local {
				ip 127.0.0.1
				accept false
			}
		}
		session {
			asn {
				local 65533
				remote 65533
			}
			router-id 10.0.0.10
			family {
				ipv4/unicast { prefix { maximum 10000; } }
			}
		}

		update {
			attribute {
				origin igp
				local-preference 100
				next-hop 1.2.3.4
			}
			nlri {
				ipv4/unicast add 10.0.0.0/24
			}
			watchdog {
				name hc-dns
				withdraw true
			}
		}
	}
}
EOF_CONF

# Process orchestration
cmd=background:seq=1:exec=ze-peer --port $PORT:stdin=peer
cmd=foreground:seq=2:exec=ze --plugin ze.bgp-healthcheck --plugin ze.bgp-watchdog -:stdin=ze-bgp:timeout=15s
