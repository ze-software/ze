# Healthcheck: probe success triggers watchdog announce with UP metric.
# Config: probe runs "true" (always succeeds), rise=1 for fast UP, withdraw-on-down true.

# ze-peer expectations
stdin=peer:terminator=EOF_PEER
# Initial config route (watchdog dnsr with withdraw=true, not sent initially)
expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF00170200000000
# After probe succeeds (rise=1 -> immediate UP), watchdog announce with med 100
cmd=api:conn=1:seq=1:text=healthcheck probe UP triggers watchdog announce
expect=json:conn=1:seq=1:json={"meta":{"version":"1.0.0","format":"ze-bgp"},"message":{"type":"update"},"peer":{"address":"127.0.0.1","remote":{"as":65533}},"direction":"in","local-preference":100,"med":100,"origin":"igp","ipv4/unicast":[{"action":"add","nlri":["10.0.0.0/24"],"next-hop":"1.2.3.4"}]}
EOF_PEER

# ze bgp configuration
stdin=ze-bgp:terminator=EOF_CONF
bgp {
	healthcheck {
		probe dns {
			command "true"
			group hc-dns
			interval 1
			rise 1
			fall 1
			withdraw-on-down true
			up-metric 100
		}
	}
	peer peer1 {
		connection {
			remote {
				ip 127.0.0.1
				accept false
			}
			local {
				ip 127.0.0.1
			}
		}
		session {
			asn {
				local 65533
				remote 65533
			}
			router-id 10.0.0.10
			family {
				ipv4/unicast { prefix { maximum 10000; } }
			}
		}

		update {
			attribute {
				origin igp
				local-preference 100
				next-hop 1.2.3.4
			}
			nlri {
				ipv4/unicast add 10.0.0.0/24
			}
			watchdog {
				name hc-dns
				withdraw true
			}
		}
	}
}
EOF_CONF

# Process orchestration
cmd=background:seq=1:exec=ze-peer --port $PORT:stdin=peer
cmd=foreground:seq=2:exec=ze --plugin ze.bgp-healthcheck --plugin ze.bgp-watchdog -:stdin=ze-bgp:timeout=15s
