# Test: modify filter sets local-preference on import
# VALIDATES: AC-1 -- local-preference set on ingress routes
# VALIDATES: AC-7 -- only declared attributes modified
# PREVENTS: Modify filter not dispatched or delta not applied
#
# Flow:
# 1. ze-peer sends UPDATE: ORIGIN=IGP, AS_PATH=[65001], NEXT_HOP=1.1.1.1, NLRI=10.0.0.0/24
# 2. Filter chain calls bgp-filter-modify:PREFER-LOCAL
# 3. Plugin returns action=modify delta="local-preference 200"
# 4. Engine merges delta and applies wire-level modification
# 5. Plugin log confirms "modify apply filter=PREFER-LOCAL"

option=env:var=ze.log.bgp.filter.modify:value=info

stdin=peer:terminator=EOF_PEER
option=tcp_connections:value=1
option=timeout:value=15s
# UPDATE: ORIGIN=IGP, AS_PATH=[65001], NEXT_HOP=1.1.1.1, NLRI=10.0.0.0/24
action=send:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF002F02000000144001010040020602010000FDE940030401010101180A0000
EOF_PEER

tmpfs=test-modify-lp.run:mode=755:terminator=EOF_RUN
#!/usr/bin/env python3
"""Observer for modify local-preference test: clean shutdown."""
import time
from ze_api import API

def dispatch(api, command):
    resp = api._call_engine('ze-plugin-engine:dispatch-command', {'command': command})
    return resp.get('result', {})

def main():
    api = API()
    api.declare_done()
    api.wait_for_config()
    api.capability_done()
    api.wait_for_registry()
    api.ready()
    time.sleep(3.0)
    dispatch(api, 'daemon shutdown')
    api.wait_for_shutdown()

if __name__ == '__main__':
    main()
EOF_RUN

stdin=ze-bgp:terminator=EOF_CONF
plugin {
	external test-modify-lp {
		run ./test-modify-lp.run
		encoder json
	}
}
bgp {
	policy {
		modify PREFER-LOCAL {
			set {
				local-preference 200
			}
		}
	}

	peer peer1 {
		connection {
			remote {
				ip 127.0.0.1
				accept false
			}
			local {
				ip 127.0.0.1
			}
		}
		session {
			asn {
				local 65000
				remote 65001
			}
			router-id 1.2.3.4
			family {
				ipv4/unicast { prefix { maximum 10000; } }
			}
		}

		filter {
			import [ modify:PREFER-LOCAL ]
		}

		process test-modify-lp {
			receive [ update state ]
		}
	}
}
EOF_CONF

cmd=background:seq=1:exec=ze-peer --port $PORT:stdin=peer
cmd=foreground:seq=2:exec=ze --plugin ze.bgp-filter-modify --plugin ze.bgp-adj-rib-in -:stdin=ze-bgp:timeout=15s
expect=exit:code=0
# The modify filter must have been invoked with the correct delta.
expect=stderr:pattern=modify apply
expect=stderr:pattern=filter=PREFER-LOCAL
expect=stderr:pattern=local-preference 200
