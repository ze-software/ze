# Test: BFD plugin accepts a profile with a Keyed SHA1 `auth` block,
# rejects `simple-password`, and publishes the auth-configured
# session via `show bfd session`.
#
# VALIDATES: spec-bfd-5 AC-1 and AC-10 -- SHA1 Keyed authentication
#            parses, the session is created with AuthType=4, and a
#            `simple-password` config is rejected at parse time.
# PREVENTS:  regression where the parser silently drops the auth
#            block, accepts simple-password, or the engine ignores
#            the signer when a session runs.

option=env:var=ze.bfd.test-parallel:value=true
stdin=peer:terminator=EOF_PEER
option=tcp_connections:value=1
option=timeout:value=15s
expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF00170200000000
EOF_PEER

tmpfs=bfd-auth-sha1.run:mode=755:terminator=EOF_RUN
#!/usr/bin/env python3
"""Verify a Keyed SHA1 BFD session parses and the signer runs."""

import json
import time

from ze_api import API, runtime_fail


def dispatch(api, command):
    resp = api._call_engine(
        'ze-plugin-engine:dispatch-command', {'command': command})
    if resp is None:
        return {'status': 'error', 'data': 'engine call returned None'}
    return resp.get('result', {})


def main():
    api = API()
    api.declare_done()
    api.wait_for_config()
    api.capability_done()
    api.wait_for_registry()
    api.ready()
    time.sleep(1.0)

    r = dispatch(api, 'show bfd profile fast-auth')
    if r.get('status') != 'done':
        runtime_fail(f'profile status: {r.get("status")}')
    try:
        profile = json.loads(r.get('data', '') or '{}')
    except json.JSONDecodeError as exc:
        profile = {}
        runtime_fail(f'profile json: {exc}')
    if profile.get('name') != 'fast-auth':
        runtime_fail(f'profile name: {profile}')

    r = dispatch(api, 'show bfd session 203.0.113.9')
    if r.get('status') != 'done':
        runtime_fail(f'session status: {r.get("status")}')
    try:
        session = json.loads(r.get('data', '') or '{}')
    except json.JSONDecodeError as exc:
        session = {}
        runtime_fail(f'session json: {exc}')
    if session.get('peer') != '203.0.113.9':
        runtime_fail(f'session peer: {session}')
    if session.get('profile') != 'fast-auth':
        runtime_fail(f'session profile: {session.get("profile")!r}')
    # tx-packets should grow as the engine signs each outbound.
    if session.get('tx-packets', 0) == 0:
        runtime_fail(f'no signed tx packets recorded: {session}')

    dispatch(api, 'daemon shutdown')
    api.wait_for_shutdown()


if __name__ == '__main__':
    main()
EOF_RUN

stdin=ze-bfd:terminator=EOF_CONF
plugin {
	external bfd-auth-sha1-test {
		run ./bfd-auth-sha1.run
		encoder json
	}
}

environment {
	log {
		bfd debug
	}
}

bfd {
	enabled true;
	profile fast-auth {
		detect-multiplier 3
		desired-min-tx-us 100000
		required-min-rx-us 100000
		auth {
			type keyed-sha1
			key-id 7
			secret "SHARED-SECRET-123"
		}
	}
	single-hop-session 203.0.113.9 {
		profile fast-auth
	}
}

bgp {
	peer peer1 {
		connection {
			remote {
				ip 127.0.0.1
			}
			local {
				ip 127.0.0.1
				accept false
			}
		}
		session {
			asn {
				local 1
				remote 1
			}
			router-id 1.2.3.4
			family {
				ipv4/unicast { prefix { maximum 10000; } }
			}
			capability {
				graceful-restart disable
			}
		}
		behavior {
			group-updates disable
		}
		process bfd-auth-sha1-test {
		}
	}
}
EOF_CONF

cmd=background:seq=1:exec=ze-peer --port $PORT:stdin=peer
cmd=foreground:seq=2:exec=ze -:stdin=ze-bfd:timeout=15s
expect=exit:code=0
