# RFC 8203: teardown with user-provided shutdown message

# ze-peer expectations
stdin=peer:terminator=EOF_PEER
# Route announcement (1.1.0.0/16 next-hop 1.1.1.1)
expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF002F0200000015400101004002004003040101010140050400000064100101
# EOR for IPv4 unicast
expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF00170200000000
# NOTIFICATION: Cease (06) Administrative Shutdown (02) with message "test" (04 74657374)
expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF001A0306020474657374
EOF_PEER

# Python plugin script
tmpfs=teardown-msg.run:mode=755:terminator=EOF_RUN
#!/usr/bin/env python3

from ze_api import ready, send, wait_for_ack, wait_for_shutdown


def main() -> None:
    ready()

    # Send a route first
    send('peer * update text nhop 1.1.1.1 nlri ipv4/unicast add 1.1.0.0/16')

    # Wait for route to be processed
    wait_for_ack(expected_count=1)

    # RFC 8203: teardown with shutdown communication message
    send('peer 127.0.0.1 teardown 2 test')

    # The connection will close after teardown, script exits
    try:
        wait_for_shutdown()
    except IOError:
        # Expected - connection closed by teardown
        pass


if __name__ == '__main__':
    main()
EOF_RUN

# ze bgp configuration
stdin=ze-bgp:terminator=EOF_CONF
plugin {
	external teardown-msg-test {
		run ./teardown-msg.run
		encoder json
	}
}
bgp {
	peer peer1 {
		connection {
			remote {
				ip 127.0.0.1
			}
			local {
				ip 127.0.0.1
				accept false
			}
		}
		session {
			asn {
				local 1
				remote 1
			}
			router-id 1.2.3.4
			family {
				ipv4/unicast { prefix { maximum 10000; } }
			}
			capability {
				graceful-restart disable
			}
		}
		behavior {
			group-updates disable
		}

		process teardown-msg-test {
		}
	}
}
EOF_CONF

# Process orchestration
cmd=background:seq=1:exec=ze-peer --port $PORT:stdin=peer
cmd=foreground:seq=2:exec=ze -:stdin=ze-bgp:timeout=10s
