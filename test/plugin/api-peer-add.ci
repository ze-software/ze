# Test: bgp peer add dynamically adds a peer
# VALIDATES: peer add creates peer, verified by subsequent peer list
# PREVENTS: peer add silently failing or not persisting

# ze-peer expectations
stdin=peer:terminator=EOF_PEER
option=tcp_connections:value=1
option=timeout:value=15s
expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF00170200000000
EOF_PEER

# Python test plugin: exercises dispatch-command for peer add
tmpfs=peer-add-test.run:mode=755:terminator=EOF_RUN
#!/usr/bin/env python3
import json
import sys
import time
from ze_api import API

def dispatch(api, command):
    resp = api._call_engine(
        'ze-plugin-engine:dispatch-command', {'command': command})
    if resp is None:
        return {'status': 'error', 'data': 'engine call returned None'}
    return resp.get('result', {})

def main():
    api = API()
    api.declare_done()
    api.wait_for_config()
    api.capability_done()
    api.wait_for_registry()
    api.ready()
    time.sleep(1.0)

    try:
        result = dispatch(api, 'set bgp peer 10.0.0.1 with remote as 2 local as 1')
        if result.get('status') != 'done':
            print(f'FAIL: add status={result.get("status")} data={result.get("data")}', file=sys.stderr)
            sys.exit(1)

        # Verify the peer appears in the list
        result = dispatch(api, 'peer * list')
        data = result.get('data', {})
        if isinstance(data, str):
            data = json.loads(data)
        peers = data.get('peers', {})
        if '10.0.0.1' not in peers:
            print(f'FAIL: 10.0.0.1 not in peers after add: {list(peers.keys())}', file=sys.stderr)
            sys.exit(1)

        print('OK: peer add verified in list', file=sys.stderr)
    finally:
        dispatch(api, 'daemon shutdown')
        api.wait_for_shutdown()

if __name__ == '__main__':
    main()
EOF_RUN

# ze bgp configuration
stdin=ze-bgp:terminator=EOF_CONF
plugin {
	external peer-add-test {
		run ./peer-add-test.run
		encoder json
	}
}

bgp {
	peer peer1 {
		connection {
			remote {
				ip 127.0.0.1
			}
			local {
				ip 127.0.0.1
				accept false
			}
		}
		session {
			asn {
				local 1
				remote 1
			}
			router-id 1.2.3.4
			family {
				ipv4/unicast { prefix { maximum 10000; } }
			}
			capability {
				graceful-restart disable
			}
		}
		behavior {
			group-updates disable
		}

		process peer-add-test {
		}
	}
}
EOF_CONF

# Process orchestration
cmd=background:seq=1:exec=ze-peer --port $PORT:stdin=peer
cmd=foreground:seq=2:exec=ze -:stdin=ze-bgp:timeout=15s
expect=exit:code=0
