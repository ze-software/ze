# Test: RPKI validation timeout promotes route (fail-open)
# VALIDATES: Route promoted after timeout when RPKI plugin cannot validate (AC-9)
# PREVENTS: Routes stuck in pending state forever when RTR server unreachable

# ze-peer: send route (no RTR server -> RPKI has no VRPs -> validation hangs in pending)
stdin=peer:terminator=EOF_PEER
option=tcp_connections:value=1
option=timeout:value=45s
option=update:value=send-route:prefix=10.0.1.0/24:origin-as=65001:next-hop=10.0.0.1
# EOR from ze
expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF00170200000000
EOF_PEER

tmpfs=rpki-timeout-test.run:mode=755:terminator=EOF_RUN
#!/usr/bin/env python3
import json
import sys
import time
from ze_api import API

def dispatch(api, command):
    resp = api._call_engine(
        'ze-plugin-engine:dispatch-command', {'command': command})
    if resp is None:
        return {'status': 'error', 'data': 'engine call returned None'}
    return resp.get('result', {})

def main():
    api = API()
    api.declare_done()
    api.wait_for_config()
    api.capability_done()
    api.wait_for_registry()
    api.ready()

    # Wait for BGP UPDATE to arrive + adj-rib-in sweep timeout (5s sweep interval)
    # Route should be pending initially, then promoted after validation timeout
    time.sleep(12.0)

    try:
        result = dispatch(api, 'rib routes received')
        if result.get('status') != 'done':
            print(f'FAIL: rib routes received status={result.get("status")}', file=sys.stderr)
            sys.exit(1)

        data = result.get('data', '')
        # Route should be promoted after timeout (fail-open)
        if '10.0.1.0/24' not in data:
            print(f'FAIL: route 10.0.1.0/24 not promoted after timeout: {data}', file=sys.stderr)
            sys.exit(1)

        print('OK: route 10.0.1.0/24 promoted after timeout (fail-open)', file=sys.stderr)
    finally:
        dispatch(api, 'daemon shutdown')
        api.wait_for_shutdown()

if __name__ == '__main__':
    main()
EOF_RUN

# Use short validation timeout (5s) for testing
stdin=ze-bgp:terminator=EOF_CONF
plugin {
	hub {
		server local {
			host 127.0.0.1;
			port 0;
			secret rpki-test-secret-key-01234567890;
		}
	}
	external rpki-timeout-test {
		run ./rpki-timeout-test.run
		encoder json
	}
	external rpki {
		run "ze plugin bgp-rpki"
		encoder json
	}
	external adj-rib-in {
		run "ze plugin bgp-adj-rib-in"
		encoder json
	}
}

environment {
	tcp {
		attempts 3
	}
}

bgp {
	rpki {
		cache-server 127.0.0.1 {
			port 19999
		}
		validation-timeout 5
	}
	peer peer1 {
		remote {
			ip 127.0.0.1
			as 1
			accept false
		}
		local {
			as 1
			ip 127.0.0.1
		}
		router-id 1.2.3.4
		group-updates disable

		family {
			ipv4/unicast { prefix { maximum 10000; } }
		}
		capability {
			graceful-restart disable
		}
		process rpki-timeout-test {
		}
		process rpki {
			receive [ update ]
		}
		process adj-rib-in {
			receive [ update state ]
		}
	}
}
EOF_CONF

# NO ze-rtr-mock: RPKI plugin has no cache, validation cannot complete
cmd=background:seq=1:exec=ze-peer --port $PORT:stdin=peer
cmd=foreground:seq=2:exec=ze -:stdin=ze-bgp:timeout=40s
expect=exit:code=0
