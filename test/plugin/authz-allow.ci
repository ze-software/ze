# Test: authorization allows admin and permitted restricted commands
#
# Flow:
# 1. Daemon starts with SSH + authz config (admin + restricted profiles)
# 2. Shell script creates per-user SSH credentials via ze init
# 3. Admin user can run any command (default-action allow)
# 4. Restricted user can run permitted command (entry match)
#
# VALIDATES: AC-1 -- admin profile allows all commands via SSH.
# VALIDATES: AC-2 -- restricted profile allows entry-matched commands.
# PREVENTS: Authorization wiring missing -- authz store not set on dispatcher.

# Test script: admin + restricted allowed commands via SSH
tmpfs=test-authz-allow.sh:mode=755:terminator=EOF_SH
#!/bin/sh
set -e

# Signal test runner readiness
touch daemon.ready

# Generate config with SSH on port 0 (OS-assigned)
cat > authz-allow.conf << 'ZECONF'
bgp {
	peer peer1 {
		connection {
			remote {
				ip 127.0.0.1
				accept false
			}
			local {
				ip 127.0.0.1
			}
		}
		session {
			asn {
				local 65533
				remote 65533
			}
		}
	}
}

system {
	authentication {
		user admin {
			password "$2a$04$UlwuiuH82Unfsq.XEMPGJeDkXwbm3KW.nvVaVXOd/JeFK8VjMjrQO"
			profile [ admin ]
		}
		user operator {
			password "$2a$04$MdupNBXL8iUHgRUDfsFl0ue/.FEH3db8U.LPd/XtMhiBmd4MoRM0m"
			profile [ restricted ]
		}
	}
	authorization {
		profile admin {
			run {
				default-action allow
			}
			edit {
				default-action allow
			}
		}
		profile restricted {
			run {
				default-action deny
				entry 10 {
					action allow
					match "peer list"
				}
				entry 20 {
					action allow
					match "summary"
				}
			}
			edit {
				default-action deny
			}
		}
	}
}

environment {
	ssh {
		listen 127.0.0.1:0
	}
}
ZECONF

# Use a PID-derived high port for BGP to avoid needing root for port 179
export ze_bgp_tcp_port=$((10000 + ($$ % 50000)))

# Start daemon, capture stderr to parse SSH port
ze authz-allow.conf 2>daemon.log &
DAEMON_PID=$!
trap 'kill $DAEMON_PID 2>/dev/null; wait $DAEMON_PID 2>/dev/null' EXIT

# Wait for SSH server to report its listening address
SSH_PORT=""
for i in $(seq 1 50); do
	SSH_PORT=$(grep -o '127\.0\.0\.1:[0-9]*' daemon.log 2>/dev/null | head -1 | cut -d: -f2 || true)
	if [ -n "$SSH_PORT" ]; then
		break
	fi
	sleep 0.2
done

if [ -z "$SSH_PORT" ]; then
	echo "FAIL: SSH server did not start (no address in daemon.log)" >&2
	cat daemon.log >&2
	exit 1
fi
echo "SSH port: $SSH_PORT" >&2

# Brief delay for postStartFunc to wire authorizer
sleep 0.5

# Set up admin credentials
ADMIN_DIR=$(mktemp -d)
trap 'rm -rf "$ADMIN_DIR"; kill $DAEMON_PID 2>/dev/null; wait $DAEMON_PID 2>/dev/null' EXIT
printf 'admin\ntestpass\n127.0.0.1\n%s\n' "$SSH_PORT" | ZE_CONFIG_DIR="$ADMIN_DIR" ze init >/dev/null

# Test 1: admin can run read-only command
OUTPUT=$(ZE_CONFIG_DIR="$ADMIN_DIR" ZE_SSH_PASSWORD="testpass" ze cli -c "peer list" 2>&1) || {
	echo "FAIL: admin should be allowed to run 'peer list'" >&2
	echo "OUTPUT: $OUTPUT" >&2
	exit 1
}
echo "OK: admin allowed peer list" >&2

# Set up operator credentials
OP_DIR=$(mktemp -d)
trap 'rm -rf "$ADMIN_DIR" "$OP_DIR"; kill $DAEMON_PID 2>/dev/null; wait $DAEMON_PID 2>/dev/null' EXIT
printf 'operator\noppass\n127.0.0.1\n%s\n' "$SSH_PORT" | ZE_CONFIG_DIR="$OP_DIR" ze init >/dev/null

# ... "peer list")
OUTPUT=$(ZE_CONFIG_DIR="$OP_DIR" ZE_SSH_PASSWORD="oppass" ze cli -c "peer list" 2>&1) || {
	echo "FAIL: operator should be allowed to run 'peer list' (entry 10)" >&2
	echo "OUTPUT: $OUTPUT" >&2
	exit 1
}
echo "OK: operator allowed peer list (entry match)" >&2

# ... "summary")
OUTPUT=$(ZE_CONFIG_DIR="$OP_DIR" ZE_SSH_PASSWORD="oppass" ze cli -c "summary" 2>&1) || {
	echo "FAIL: operator should be allowed to run 'summary' (entry 20)" >&2
	echo "OUTPUT: $OUTPUT" >&2
	exit 1
}
echo "OK: operator allowed summary (entry match)" >&2

echo "OK: all allow tests passed" >&2
exit 0
EOF_SH

# Process orchestration
cmd=foreground:seq=1:exec=./test-authz-allow.sh:timeout=15s
expect=exit:code=0
