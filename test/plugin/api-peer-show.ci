# Test: bgp peer detail returns peer state and config
# VALIDATES: peer detail returns data with state and ASN for the peer
# PREVENTS: peer detail returning empty or missing key fields

# ze-peer expectations
stdin=peer:terminator=EOF_PEER
option=tcp_connections:value=1
option=timeout:value=15s
expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF00170200000000
EOF_PEER

# Python test plugin: exercises dispatch-command for peer detail
tmpfs=peer-show-test.run:mode=755:terminator=EOF_RUN
#!/usr/bin/env python3
import json
import sys
import time
from ze_api import API

def dispatch(api, command):
    resp = api._call_engine(
        'ze-plugin-engine:dispatch-command', {'command': command})
    if resp is None:
        return {'status': 'error', 'data': 'engine call returned None'}
    return resp.get('result', {})

def main():
    api = API()
    api.declare_done()
    api.wait_for_config()
    api.capability_done()
    api.wait_for_registry()
    api.ready()
    time.sleep(1.0)

    try:
        result = dispatch(api, 'peer peer1 detail')
        if result.get('status') != 'done':
            print(f'FAIL: detail status={result.get("status")}', file=sys.stderr)
            sys.exit(1)

        data = result.get('data', {})
        if isinstance(data, str):
            data = json.loads(data)

        peers = data.get('peers', {})
        if '127.0.0.1' not in peers:
            print(f'FAIL: 127.0.0.1 not in detail response', file=sys.stderr)
            sys.exit(1)

        peer = peers['127.0.0.1']
        if 'state' not in peer:
            print(f'FAIL: no state in peer detail', file=sys.stderr)
            sys.exit(1)
        if 'remote-as' not in peer:
            print(f'FAIL: no remote-as in peer detail', file=sys.stderr)
            sys.exit(1)

        print(f'OK: peer detail has state={peer["state"]} remote-as={peer["remote-as"]}', file=sys.stderr)
    finally:
        dispatch(api, 'daemon shutdown')
        api.wait_for_shutdown()

if __name__ == '__main__':
    main()
EOF_RUN

# ze bgp configuration
stdin=ze-bgp:terminator=EOF_CONF
plugin {
	external peer-show-test {
		run ./peer-show-test.run
		encoder json
	}
}

environment {
	tcp {
		attempts 3
	}
}

bgp {
	peer peer1 {
		remote {
			ip 127.0.0.1
			as 1
		}
		local {
			as 1
			ip 127.0.0.1
		}
		router-id 1.2.3.4
		connection active
		group-updates disable

		family {
			ipv4/unicast { prefix { maximum 10000; } }
		}
		capability {
			graceful-restart disable
		}
		process peer-show-test {
		}
	}
}
EOF_CONF

# Process orchestration
cmd=background:seq=1:exec=ze-peer --port $PORT:stdin=peer
cmd=foreground:seq=2:exec=ze -:stdin=ze-bgp:timeout=15s
expect=exit:code=0
