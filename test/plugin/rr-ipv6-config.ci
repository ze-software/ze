# Test: IPv6 route reflection config acceptance
# VALIDATES: IPv6 RR client config parses with route-reflector-client + next-hop self
# VALIDATES: cmd-1 AC-13 -- peer detail shows route-reflector-client and next-hop
# PREVENTS: IPv6 RR config not parsed, next-hop self not wired for IPv6 peers
#
# NOTE: Wire-level forwarding verification (ORIGINATOR_ID in forwarded UPDATE)
# requires two peers on different IPs which is blocked by the single-ze-peer
# multi-IP timing issue. Unit tests verify the wire attribute modification.

stdin=peer:terminator=EOF_PEER
option=tcp_connections:value=1
option=timeout:value=15s

# Send IPv6 UPDATE with MP_REACH_NLRI
# ORIGIN=IGP, AS_PATH=65001, LOCAL_PREF=200, MP_REACH: AFI=2 SAFI=1 NH=2001:db8::1 NLRI=2001:db8:1::/48
action=send:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF004B02000000344001010040020602010000FDE9400504000000C8900E001C0002011020010DB8000000000000000000000001003020010DB80001
EOF_PEER

tmpfs=rr-ipv6-test.run:mode=755:terminator=EOF_RUN
#!/usr/bin/env python3
import json
import sys
import time
from ze_api import API, runtime_fail

def dispatch(api, command):
    resp = api._call_engine(
        'ze-plugin-engine:dispatch-command', {'command': command})
    if resp is None:
        return {'status': 'error', 'data': 'engine call returned None'}
    return resp.get('result', {})

def main():
    api = API()
    api.declare_done()
    api.wait_for_config()
    api.capability_done()
    api.wait_for_registry()
    api.ready()

    # Poll until peer session is established
    for _ in range(20):
        time.sleep(0.3)
        result = dispatch(api, 'peer peer-src detail')
        if result.get('status') == 'done' and 'established' in result.get('data', '').lower():
            break
    else:
        runtime_fail('peer-src never reached established state')

    result = dispatch(api, 'peer peer-src detail')
    if result.get('status') != 'done':
        runtime_fail(f'peer detail failed: {result}')

    detail = result.get('data', '')
    if 'route-reflector-client' not in detail:
        runtime_fail(f'missing route-reflector-client: {detail[:300]}')

    print('OK: IPv6 RR client config accepted, peer detail shows RR fields', file=sys.stderr)

    dispatch(api, 'daemon shutdown')
    api.wait_for_shutdown()

if __name__ == '__main__':
    main()
EOF_RUN

stdin=ze-bgp:terminator=EOF_CONF
plugin {
	external rr-ipv6-test {
		run ./rr-ipv6-test.run
		encoder json
	}
}
bgp {
	peer peer-src {
		connection {
			remote {
				ip 127.0.0.1
				accept false
			}
			local {
				ip 127.0.0.1
			}
		}
		session {
			asn {
				local 65000
				remote 65000
			}
			router-id 1.2.3.4
			route-reflector-client true
			next-hop self
			family {
				ipv6/unicast { prefix { maximum 10000; } }
			}
			capability {
				graceful-restart disable
			}
		}

		process rr-ipv6-test {
		}
	}
}
EOF_CONF

cmd=background:seq=1:exec=ze-peer --port $PORT:stdin=peer
cmd=foreground:seq=2:exec=ze -:stdin=ze-bgp:timeout=15s
expect=exit:code=0
reject=stderr:pattern=panic recovered
reject=stderr:pattern=fatal error
reject=stderr:pattern=ZE-OBSERVER-FAIL
