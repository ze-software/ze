# Test: RTR cache VRP update affects subsequent validation
# VALIDATES: Updated VRPs from RTR cache are used for validation (AC-6)
# PREVENTS: ROA cache not being populated from RTR session data

# ze-peer: send route after RTR sync
stdin=peer:terminator=EOF_PEER
option=tcp_connections:value=1
option=timeout:value=15s
option=update:value=send-route:prefix=10.0.1.0/24:origin-as=65001:next-hop=10.0.0.1
# EOR from ze
expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF00170200000000
EOF_PEER

tmpfs=rpki-update-test.run:mode=755:terminator=EOF_RUN
#!/usr/bin/env python3
import json
import sys
import time
from ze_api import API

def dispatch(api, command):
    resp = api._call_engine(
        'ze-plugin-engine:dispatch-command', {'command': command})
    if resp is None:
        return {'status': 'error', 'data': 'engine call returned None'}
    return resp.get('result', {})

def main():
    api = API()
    api.declare_done()
    api.wait_for_config()
    api.capability_done()
    api.wait_for_registry()
    api.ready()

    # Wait for RTR sync and BGP processing
    time.sleep(4.0)

    try:
        # Verify VRPs loaded via rpki roa command
        result = dispatch(api, 'rpki roa')
        if result.get('status') != 'done':
            print(f'FAIL: rpki roa status={result.get("status")}', file=sys.stderr)
            sys.exit(1)

        data = json.loads(result.get('data', '{}'))
        total = data.get('total-vrps', 0)
        if total < 1:
            print(f'FAIL: total-vrps={total}, expected >= 1', file=sys.stderr)
            sys.exit(1)

        # Verify route was accepted (VRP covers 10.0.1.0/24 from AS 65001)
        result = dispatch(api, 'rib routes received')
        if result.get('status') != 'done':
            print(f'FAIL: rib routes received status={result.get("status")}', file=sys.stderr)
            sys.exit(1)

        data_str = result.get('data', '')
        if '10.0.1.0/24' not in data_str:
            print(f'FAIL: route 10.0.1.0/24 not in adj-rib-in: {data_str}', file=sys.stderr)
            sys.exit(1)

        print(f'OK: RTR cache updated, route validated (total-vrps={total})', file=sys.stderr)
    finally:
        dispatch(api, 'daemon shutdown')
        api.wait_for_shutdown()

if __name__ == '__main__':
    main()
EOF_RUN

stdin=ze-bgp:terminator=EOF_CONF
plugin {
	hub {
		server local {
			host 127.0.0.1;
			port 0;
			secret rpki-test-secret-key-01234567890;
		}
	}
	external rpki-update-test {
		run ./rpki-update-test.run
		encoder json
	}
	external rpki {
		run "ze plugin bgp-rpki"
		encoder json
	}
	external adj-rib-in {
		run "ze plugin bgp-adj-rib-in"
		encoder json
	}
}

environment {
	tcp {
		attempts 3
	}
}

bgp {
	rpki {
		cache-server 127.0.0.1 {
			port $PORT2
		}
	}
	peer peer1 {
		remote {
			ip 127.0.0.1
			as 1
			accept false
		}
		local {
			as 1
			ip 127.0.0.1
		}
		router-id 1.2.3.4
		group-updates disable

		family {
			ipv4/unicast { prefix { maximum 10000; } }
		}
		capability {
			graceful-restart disable
		}
		process rpki-update-test {
		}
		process rpki {
			receive [ update ]
		}
		process adj-rib-in {
			receive [ update state ]
		}
	}
}
EOF_CONF

# VRP: 10.0.0.0/8 maxlen=24 AS=65001
cmd=background:seq=1:exec=ze-test rtr-mock --port $PORT2 --vrp 10.0.0.0/8,24,65001
cmd=background:seq=2:exec=ze-peer --port $PORT:stdin=peer
cmd=foreground:seq=3:exec=ze -:stdin=ze-bgp:timeout=20s
expect=exit:code=0
