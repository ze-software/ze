# Test: Routes flow through unchanged without RPKI plugin
# VALIDATES: No RPKI plugin loaded means routes stored immediately (AC-5)
# PREVENTS: RPKI infrastructure blocking routes when plugin not configured

# ze-peer: send default route
stdin=peer:terminator=EOF_PEER
option=tcp_connections:value=1
option=timeout:value=15s
option=update:value=send-default-route
# EOR from ze
expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF00170200000000
EOF_PEER

# Python test plugin: verifies route stored in adj-rib-in without validation
tmpfs=rpki-passthrough-test.run:mode=755:terminator=EOF_RUN
#!/usr/bin/env python3
import json
import sys
import time
from ze_api import API

def dispatch(api, command):
    resp = api._call_engine(
        'ze-plugin-engine:dispatch-command', {'command': command})
    if resp is None:
        return {'status': 'error', 'data': 'engine call returned None'}
    return resp.get('result', {})

def main():
    api = API()
    api.declare_done()
    api.wait_for_config()
    api.capability_done()
    api.wait_for_registry()
    api.ready()

    time.sleep(2.0)

    try:
        result = dispatch(api, 'bgp rib routes received')
        if result.get('status') != 'done':
            print(f'FAIL: rib routes received status={result.get("status")}', file=sys.stderr)
            sys.exit(1)

        data = result.get('data', '')
        if '0.0.0.0' not in data:
            print(f'FAIL: default route not in adj-rib-in: {data}', file=sys.stderr)
            sys.exit(1)

        # Validation state should be 0 (NotValidated) since no RPKI plugin
        if '"validation-state":4' in data or '"validation-state": 4' in data:
            print(f'FAIL: route stuck in pending state without RPKI plugin: {data}', file=sys.stderr)
            sys.exit(1)

        print('OK: route stored immediately without RPKI (passthrough)', file=sys.stderr)
    finally:
        dispatch(api, 'daemon shutdown')
        api.wait_for_shutdown()

if __name__ == '__main__':
    main()
EOF_RUN

# No RPKI plugin loaded -- only adj-rib-in
stdin=ze-bgp:terminator=EOF_CONF
plugin {
	hub {
		server local {
			ip 127.0.0.1;
			port 0;
			secret rpki-test-secret-key-01234567890;
		}
	}
	external rpki-passthrough-test {
		run ./rpki-passthrough-test.run
		encoder json
	}
	external adj-rib-in {
		use bgp-adj-rib-in
		encoder json
	}
}

bgp {
	peer peer1 {
		connection {
			remote {
				ip 127.0.0.1
			}
			local {
				ip 127.0.0.1
				accept false
			}
		}
		session {
			asn {
				local 1
				remote 1
			}
			router-id 1.2.3.4
			family {
				ipv4/unicast { prefix { maximum 10000; } }
			}
			capability {
				graceful-restart disable
			}
		}
		behavior {
			group-updates disable
		}

		process rpki-passthrough-test {
		}
		process adj-rib-in {
			receive [ update state ]
		}
	}
}
EOF_CONF

# No ze-test rtr-mock needed -- no RPKI plugin
cmd=background:seq=1:exec=ze-peer --port $PORT:stdin=peer
cmd=foreground:seq=2:exec=ze -:stdin=ze-bgp:timeout=15s
expect=exit:code=0
