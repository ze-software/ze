# Migrated from test/data/plugin/teardown-cmd.*

# ze-peer expectations
stdin=peer:terminator=EOF_PEER
# Route announcement (1.1.0.0/16 next-hop 1.1.1.1)
expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF002F0200000015400101004002004003040101010140050400000064100101
# EOR for IPv4 unicast
expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF00170200000000
# NOTIFICATION: Cease (06) Administrative Reset (04) with message "Administrative Reset"
expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF002A0306041441646D696E697374726174697665205265736574
EOF_PEER

# Python plugin script
tmpfs=teardown-cmd.run:mode=755:terminator=EOF_RUN
#!/usr/bin/env python3

from ze_api import ready, send, wait_for_ack, wait_for_shutdown


def main() -> None:
    ready()

    # Send a route first
    send('bgp peer * update text nhop set 1.1.1.1 nlri ipv4/unicast add 1.1.0.0/16')

    # Wait for route to be processed
    wait_for_ack(expected_count=1)

    # Send teardown command - ZeBGP should send NOTIFICATION to peer
    # Step 5: neighbor prefix changed to bgp peer
    send('bgp peer 127.0.0.1 teardown 4')

    # The connection will close after teardown, script exits
    try:
        wait_for_shutdown()
    except IOError:
        # Expected - connection closed by teardown
        pass


if __name__ == '__main__':
    main()
EOF_RUN

# ze bgp configuration
stdin=ze-bgp:terminator=EOF_CONF
plugin {
	external teardown-test {
		run ./teardown-cmd.run;
		encoder json;
	}
}
bgp {
	peer 127.0.0.1 {
		router-id 1.2.3.4;
		local-address 127.0.0.1;
		local-as 1;
		peer-as 1;
		connection active;
		group-updates disable;
	
		family {
			ipv4/unicast;
		}
		capability {
			graceful-restart disable;
		}
		process teardown-test {
		}
	}
}
EOF_CONF

# Process orchestration
cmd=background:seq=1:exec=ze-peer --port $PORT:stdin=peer
cmd=foreground:seq=2:exec=ze -:stdin=ze-bgp:timeout=10s
