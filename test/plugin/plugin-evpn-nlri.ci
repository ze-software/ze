# plugin-evpn-nlri - verify evpn plugin --nlri decode
# Tests: ze bgp plugin evpn --nlri <hex> outputs correct JSON
# EVPN Type 2 (MAC/IP): minimal valid structure
# Wire: type=02, len=33, rd, esi, eth-tag, mac-len, mac, ip-len, ip, label
cmd=foreground:seq=1:exec=ze bgp plugin evpn --nlri 02210001252C373700010001FC15B47878787800000000000000010804C0A80101
expect=exit:code=0
expect=stdout:contains="code":2
