# Test: rpki-decorator auto-loaded when consumer subscribes to update-rpki
# VALIDATES: AC-6: Decorator auto-loaded when config references update-rpki event type
# PREVENTS: Consumers forced to explicitly configure decorator plugin

# ze-peer: send one route
stdin=peer:terminator=EOF_PEER
option=tcp_connections:value=1
option=timeout:value=20s
option=update:value=send-route:prefix=10.0.0.0/24:origin-as=65001:next-hop=10.0.0.1
# EOR from ze
expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF00170200000000
EOF_PEER

# Python test plugin: subscribes to update-rpki, verifies decorator was auto-loaded
tmpfs=rpki-auto-test.run:mode=755:terminator=EOF_RUN
#!/usr/bin/env python3
import json
import sys
import time
from ze_api import API

def dispatch(api, command):
    resp = api._call_engine(
        'ze-plugin-engine:dispatch-command', {'command': command})
    if resp is None:
        return {'status': 'error', 'data': 'engine call returned None'}
    return resp.get('result', {})

def main():
    api = API()
    api.declare_done()
    api.wait_for_config()
    api.capability_done()
    api.wait_for_registry()

    # Subscribe to update-rpki events
    # The decorator plugin is NOT in the config -- it must be auto-loaded
    api.ready()

    # Wait for auto-load + UPDATE + decorator merge + timeout
    time.sleep(6.0)

    try:
        # Collect update-rpki events
        found = False
        for _ in range(20):
            event_str = api.read_line(timeout=0.5)
            if event_str is None:
                continue
            try:
                evt = json.loads(event_str)
            except (json.JSONDecodeError, TypeError):
                continue
            bgp = evt.get('bgp', {})
            msg = bgp.get('message', {})
            if msg.get('type') == 'update-rpki':
                found = True
                break

        if not found:
            print('FAIL: no update-rpki events -- decorator may not have been auto-loaded', file=sys.stderr)
            sys.exit(1)

        print('OK: update-rpki event received -- decorator was auto-loaded', file=sys.stderr)

    finally:
        dispatch(api, 'daemon shutdown')
        api.wait_for_shutdown()

if __name__ == '__main__':
    main()
EOF_RUN

stdin=ze-bgp:terminator=EOF_CONF
plugin {
	hub {
		listen 127.0.0.1:0;
		secret rpki-autoload-test-secret-0123456789abcdef;
	}
	# NOTE: No explicit rpki, rpki-decorator, or adj-rib-in plugins!
	# The engine should auto-load bgp-rpki-decorator (and its dependency bgp-rpki)
	# because rpki-auto-test has receive [ update-rpki ].
	external rpki-auto-test {
		run ./rpki-auto-test.run
		encoder json
	}
}

environment {
	tcp {
		attempts 3
	}
}

bgp {
	peer peer1 {
		remote {
			ip 127.0.0.1
			as 1
			accept false
		}
		local {
			as 1
			ip 127.0.0.1
		}
		router-id 1.2.3.4
		group-updates disable

		family {
			ipv4/unicast { prefix { maximum 10000; } }
		}
		capability {
			graceful-restart disable
		}
		process rpki-auto-test {
			receive [ update-rpki ]
		}
	}
}
EOF_CONF

# No RTR mock -- decorator will timeout and emit UPDATE without rpki section
cmd=background:seq=1:exec=ze-peer --port $PORT:stdin=peer
cmd=foreground:seq=2:exec=ze -:stdin=ze-bgp:timeout=20s
expect=exit:code=0
