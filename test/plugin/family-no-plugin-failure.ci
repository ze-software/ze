# Family with no plugin failure test
# Verifies: Config loading fails when a family is configured but doesn't exist
#
# This tests config validation:
# - Config specifies ipv4/fake-safi (not a real address family)
# - ParseFamily rejects it as unknown
# - Startup should fail with "unknown address family" error

# ze-peer expectations (won't be reached - ze fails to start)
stdin=peer:terminator=EOF_PEER
EOF_PEER

# ze bgp configuration with unknown family
stdin=ze-bgp:terminator=EOF_CONF
bgp {
	peer peer1 {
		connection {
			remote {
				ip 127.0.0.1
				accept false
			}
			local {
				ip 127.0.0.1
			}
		}
		session {
			asn {
				local 1
				remote 1
			}
			router-id 1.2.3.4
			family {
				# fake-safi - not a real SAFI, should be rejected
				ipv4/fake-safi { prefix { maximum 10000; } }
			}
		}

	}
}
EOF_CONF

# Process orchestration - expect startup failure
cmd=background:seq=1:exec=ze-peer --port $PORT:stdin=peer
cmd=foreground:seq=2:exec=ze -:stdin=ze-bgp:timeout=5s
expect=exit:code=1
expect=stderr:contains=unknown address family
