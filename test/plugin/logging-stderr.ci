# Migrated from test/data/plugin/logging-stderr.*

# ze-peer expectations
stdin=peer:terminator=EOF_PEER
option=timeout:value=10s

# Enable server subsystem logging
option=env:var=ze.bgp.log.server:value=debug

# Test: Engine subsystem logging to stderr
# Verifies ze.bgp.log.server=debug produces server logs in stderr

# Static route UPDATE
expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF00300200000015400101004002004003040A0000014005040000006418C0A801
# EOR
expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF00170200000000

# Verify server subsystem logs appear in stderr
expect=stderr:pattern=subsystem=server
expect=stderr:pattern=stageTransition|deliverConfig|handleRegistrationLine
EOF_PEER

# ze bgp configuration
stdin=ze-bgp:terminator=EOF_CONF
# Test: Engine subsystem logging to stderr
# Verifies that ze.bgp.log.server=debug produces log output

plugin {
    external gr {
        use bgp-gr
        encoder json
    }
}

bgp {
	peer peer1 {
		connection {
			remote {
				ip 127.0.0.1
				accept false
			}
			local {
				ip 127.0.0.1
			}
		}
		session {
			asn {
				local 1
				remote 1
			}
			router-id 1.2.3.4
			family {
			    ipv4/unicast { prefix { maximum 10000; } }
			}
			capability {
			    graceful-restart {
			        restart-time 120
			    }
			}
		}
		behavior {
			group-updates disable
		}
	
	
	
	    update {
	        attribute {
	            origin igp
	            local-preference 100
	            next-hop 10.0.0.1
	        }
	        nlri {
	            ipv4/unicast add 192.168.1.0/24
	        }
	    }
	
	    process gr {
	        send [ update ]
	    }
	}
}
EOF_CONF

# Process orchestration
cmd=background:seq=1:exec=ze-peer --port $PORT:stdin=peer
cmd=foreground:seq=2:exec=ze -:stdin=ze-bgp:timeout=10s
