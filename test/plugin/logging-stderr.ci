# Migrated from test/data/plugin/logging-stderr.*

# Enable bgp.server subsystem logging at DEBUG.
# Convention is ze.log.<subsystem> per slogutil.go.
# Must live OUTSIDE the stdin=peer block: option=env is consumed by the
# test runner, not ze-peer.
option=env:var=ze.log.bgp.server:value=debug

# ze-peer expectations
stdin=peer:terminator=EOF_PEER
option=timeout:value=10s

# Test: Engine subsystem logging to stderr
# Verifies ze.log.bgp.server=debug produces server logs in stderr

# Static route UPDATE
expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF00300200000015400101004002004003040A0000014005040000006418C0A801
# EOR
expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF00170200000000

# Verify bgp.server subsystem DEBUG logs appear in stderr.
# The subsystem tag in slog output is the literal "bgp.server" so the
# regex escapes the dot.
expect=stderr:pattern=subsystem=bgp\.server
# At least one DEBUG-level callback fired by the server lifecycle -- these
# only appear when ze.log.bgp.server=debug actually takes effect.
expect=stderr:pattern=OnMessageReceived|OnPeerStateChange|OnMessageSent
EOF_PEER

# ze bgp configuration
stdin=ze-bgp:terminator=EOF_CONF
# Test: Engine subsystem logging to stderr
# Verifies that ze.bgp.log.server=debug produces log output

plugin {
    external gr {
        use bgp-gr
        encoder json
    }
}

bgp {
	peer peer1 {
		connection {
			remote {
				ip 127.0.0.1
			}
			local {
				ip 127.0.0.1
				accept false
			}
		}
		session {
			asn {
				local 1
				remote 1
			}
			router-id 1.2.3.4
			family {
			    ipv4/unicast { prefix { maximum 10000; } }
			}
			capability {
			    graceful-restart {
			        restart-time 120
			    }
			}
		}
		behavior {
			group-updates disable
		}
	
	
	
	    update {
	        attribute {
	            origin igp
	            local-preference 100
	            next-hop 10.0.0.1
	        }
	        nlri {
	            ipv4/unicast add 192.168.1.0/24
	        }
	    }
	
	    process gr {
	        send [ update ]
	    }
	}
}
EOF_CONF

# Process orchestration
cmd=background:seq=1:exec=ze-peer --port $PORT:stdin=peer
cmd=foreground:seq=2:exec=ze -:stdin=ze-bgp:timeout=10s
