# FlowSpec OPEN capability injection test
# Verifies that loading the flowspec plugin auto-adds Multiprotocol capabilities to OPEN
# WITHOUT explicit family configuration - the engine infers from plugin decode declarations

# ze-peer expectations
# The OPEN message should contain Multiprotocol capabilities for FlowSpec families:
# - IPv4 FlowSpec: AFI=1 (0x0001), SAFI=133 (0x85) → cap bytes: 01 04 00 01 00 85
# - IPv6 FlowSpec: AFI=2 (0x0002), SAFI=133 (0x85) → cap bytes: 01 04 00 02 00 85
# - IPv4 FlowSpec VPN: AFI=1, SAFI=134 (0x86) → cap bytes: 01 04 00 01 00 86
# - IPv6 FlowSpec VPN: AFI=2, SAFI=134 (0x86) → cap bytes: 01 04 00 02 00 86
stdin=peer:terminator=EOF_PEER
option=open:value=inspect-open-message
# Expected OPEN with FlowSpec Multiprotocol capabilities (no explicit family config)
# Structure: marker(16) + len(2) + type(1=OPEN) + version(1) + ASN(2) + hold(2) + router-id(4) + opt-params-len(1) + opt-params
# ASN=1 (0x0001), hold=90s (0x005A default), router-id=1.2.3.4 (0x01020304)
# Opt params (32 bytes = 0x20): bundled in single type-2 param (RFC 5492)
# 02 1E (param type 2, len 30): 4 Multiprotocol caps + ASN4
# Each Multiprotocol: cap-code(01) + cap-len(04) + AFI(2) + reserved(1) + SAFI(1)
# ASN4: cap-code(41) + cap-len(04) + ASN(4)
expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF003D01040001005A0102030420021E010400010085010400010086010400020085010400020086410400000001
EOF_PEER

# ze bgp configuration - NO explicit family block!
# Plugin declares decode for flowspec families, engine should auto-add Multiprotocol caps
stdin=ze-bgp:terminator=EOF_CONF
bgp {
	peer peer1 {
		connection {
			remote {
				ip 127.0.0.1
			}
			local {
				ip 127.0.0.1
				accept false
			}
		}
		session {
			asn {
				local 1
				remote 1
			}
			router-id 1.2.3.4
		}

		# NOTE: No explicit family block - relying on plugin to inject capabilities
	}
}
EOF_CONF

# Process orchestration
cmd=background:seq=1:exec=ze-peer --port $PORT:stdin=peer
cmd=foreground:seq=2:exec=ze --plugin ze.bgp-nlri-flowspec -:stdin=ze-bgp:timeout=10s
