# Test: RPKI validation rejects route with mismatched origin AS (Invalid)
# VALIDATES: Route with origin AS not matching VRP is rejected (AC-3)
# PREVENTS: RPKI plugin accepting routes with wrong origin AS

# ze-peer: send route 10.0.1.0/24 from AS 65999 (VRP has AS 65001)
stdin=peer:terminator=EOF_PEER
option=tcp_connections:value=1
option=timeout:value=15s
option=update:value=send-route:prefix=10.0.1.0/24:origin-as=65999:next-hop=10.0.0.1
# EOR from ze
expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF00170200000000
EOF_PEER

# Python test plugin: verifies route NOT in adj-rib-in (rejected)
tmpfs=rpki-reject-test.run:mode=755:terminator=EOF_RUN
#!/usr/bin/env python3
import json
import sys
import time
from ze_api import API

def dispatch(api, command):
    resp = api._call_engine(
        'ze-plugin-engine:dispatch-command', {'command': command})
    if resp is None:
        return {'status': 'error', 'data': 'engine call returned None'}
    return resp.get('result', {})

def main():
    api = API()
    api.declare_done()
    api.wait_for_config()
    api.capability_done()
    api.wait_for_registry()
    api.ready()

    # Wait for RTR sync + BGP UPDATE + validation processing
    time.sleep(4.0)

    try:
        # Query adj-rib-in for received routes
        result = dispatch(api, 'bgp rib routes received')
        if result.get('status') != 'done':
            print(f'FAIL: rib routes received status={result.get("status")}', file=sys.stderr)
            sys.exit(1)

        data = result.get('data', '')
        # Route should NOT be in installed RIB (rejected by RPKI)
        if '10.0.1.0/24' in data:
            print(f'FAIL: route 10.0.1.0/24 should have been rejected: {data}', file=sys.stderr)
            sys.exit(1)

        print('OK: route 10.0.1.0/24 correctly rejected (Invalid)', file=sys.stderr)
    finally:
        dispatch(api, 'daemon shutdown')
        api.wait_for_shutdown()

if __name__ == '__main__':
    main()
EOF_RUN

stdin=ze-bgp:terminator=EOF_CONF
plugin {
	hub {
		server local {
			ip 127.0.0.1;
			port 0;
			secret rpki-test-secret-key-01234567890;
		}
	}
	external rpki-reject-test {
		run ./rpki-reject-test.run
		encoder json
	}
	external rpki {
		use bgp-rpki
		encoder json
	}
	external adj-rib-in {
		use bgp-adj-rib-in
		encoder json
	}
}

bgp {
	rpki {
		cache-server 127.0.0.1 {
			port $PORT2
		}
	}
	peer peer1 {
		connection {
			remote {
				ip 127.0.0.1
			}
			local {
				ip 127.0.0.1
				accept false
			}
		}
		session {
			asn {
				local 1
				remote 1
			}
			router-id 1.2.3.4
			family {
				ipv4/unicast { prefix { maximum 10000; } }
			}
			capability {
				graceful-restart disable
			}
		}
		behavior {
			group-updates disable
		}

		process rpki-reject-test {
		}
		process rpki {
			receive [ update ]
		}
		process adj-rib-in {
			receive [ update state ]
		}
	}
}
EOF_CONF

# VRP: 10.0.0.0/8 maxlen=24 AS=65001 (route from AS 65999 = Invalid)
cmd=background:seq=1:exec=ze-test rtr-mock --port $PORT2 --vrp 10.0.0.0/8,24,65001
cmd=background:seq=2:exec=ze-peer --port $PORT:stdin=peer
cmd=foreground:seq=3:exec=ze -:stdin=ze-bgp:timeout=20s
expect=exit:code=0
