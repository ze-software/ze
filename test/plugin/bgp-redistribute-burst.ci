# Test: bgp-redistribute -- emit-burst N=500 add events drives 500 distinct UPDATEs.
# VALIDATES: AC-13 -- consumer/producer paths sustain 500 sequential emissions
#            without dropping events or exceeding the UpdateRoute timeout.
# PREVENTS: Pool sizing bug or per-event allocation hot path causing drops.

stdin=peer:terminator=EOF_PEER
option=tcp_connections:value=1
option=timeout:value=30s
# Burst arrives as 500 distinct prefixes; assert we observe the first and last
# (full enumeration would balloon the .ci file). Receiving both proves the
# burst stream completes in order.
expect=json:conn=1:seq=1:json={"meta":{"version":"1.0.0","format":"ze-bgp"},"message":{"type":"update"},"peer":{"address":"127.0.0.1","remote":{"as":65533}},"direction":"in","origin":"incomplete","ipv4/unicast":[{"action":"add","nlri":["10.0.0.0/32"],"next-hop":"127.0.0.1"}]}
expect=json:conn=1:seq=1:contains=10.0.1.243/32
EOF_PEER

tmpfs=burst-test.run:mode=755:terminator=EOF_RUN
#!/usr/bin/env python3
import time
from ze_api import API, runtime_fail


def dispatch(api, command):
    return api._call_engine('ze-plugin-engine:dispatch-command', {'command': command}) or {}


def main():
    api = API()
    api.declare_done()
    api.wait_for_config()
    api.capability_done()
    api.wait_for_registry()
    api.ready()

    time.sleep(2.0)

    resp = dispatch(api, 'fakeredist emit-burst 500 add ipv4/unicast 10.0.0.0/32')
    result = resp.get('result', {})
    if result.get('status') != 'done':
        runtime_fail(f'emit-burst failed: {result}')
        return

    time.sleep(5.0)
    dispatch(api, 'daemon shutdown')
    api.wait_for_shutdown()


if __name__ == '__main__':
    main()
EOF_RUN

stdin=ze-bgp:terminator=EOF_CONF
plugin {
	external burst-test {
		run ./burst-test.run
		encoder json
	}
	external bgp-redistribute-egress {
		use bgp-redistribute-egress
		encoder json
	}
	external fakeredist {
		use fakeredist
		encoder json
	}
}

redistribute {
	import fakeredist {
		family [ ipv4/unicast ];
	}
}

bgp {
	peer peer1 {
		connection {
			remote {
				ip 127.0.0.1
			}
			local {
				ip 127.0.0.1
				accept false
			}
		}
		session {
			asn {
				local 65533
				remote 65533
			}
			router-id 1.2.3.4
			family {
				ipv4/unicast { prefix { maximum 10000; } }
			}
			capability {
				graceful-restart disable
			}
		}
		behavior {
			group-updates disable
		}
	}
}
EOF_CONF

cmd=background:seq=1:exec=ze-peer --port $PORT:stdin=peer
cmd=foreground:seq=2:exec=ze -:stdin=ze-bgp:timeout=30s
expect=exit:code=0
