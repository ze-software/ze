# Test: TACACS+ per-command authorization PASS_ADD and FAIL
#
# Flow:
# 1. Mock accepts admin:testpass:15 and denies any AUTHOR REQUEST whose cmd
#    contains "configure"
# 2. Daemon enables TACACS+ authorization (`authorization true`)
# 3. ze cli -c "summary" succeeds (mock replies PASS_ADD)
# 4. ze cli -c "configure" fails (mock replies FAIL; daemon emits "authorization denied")
#
# VALIDATES: AC-9  -- TACACS+ AUTHOR REQUEST sent, PASS_ADD reply lets command run.
# VALIDATES: AC-10 -- TACACS+ AUTHOR REQUEST sent, FAIL reply blocks the command.
# PREVENTS: TACACS+ authorization wired but dispatcher never consults it (or always
#           ignores the FAIL status), letting denied commands run anyway.

option=env:var=ze.log.hub.infra:value=info

tmpfs=test-tacacs-author.sh:mode=755:terminator=EOF_SH
#!/bin/sh
set -e

touch daemon.ready

ze-test tacacs-mock --port 0 --key ze-mock-key \
	--user admin:testpass:15 \
	--author-deny configure \
	--addr-file mock.addr 2>mock.log &
MOCK_PID=$!
trap 'kill $MOCK_PID 2>/dev/null || true; wait $MOCK_PID 2>/dev/null || true' EXIT

MOCK_ADDR=""
for i in $(seq 1 30); do
	if [ -s mock.addr ]; then
		MOCK_ADDR=$(cat mock.addr)
		break
	fi
	sleep 0.1
done
if [ -z "$MOCK_ADDR" ]; then
	echo "FAIL: mock did not report address" >&2
	cat mock.log >&2
	exit 1
fi
MOCK_IP=$(echo "$MOCK_ADDR" | cut -d: -f1)
MOCK_PORT=$(echo "$MOCK_ADDR" | cut -d: -f2)
echo "mock at $MOCK_ADDR" >&2

cat > tacacs-author.conf <<ZECONF
bgp {
	peer peer1 {
		connection {
			remote { ip 127.0.0.1; }
			local  { ip 127.0.0.1; accept false; }
		}
		session { asn { local 65533; remote 65533; } }
	}
}

system {
	authentication {
		tacacs {
			server ${MOCK_IP} { port ${MOCK_PORT}; key "ze-mock-key"; }
			timeout 2;
			authorization true;
		}
		tacacs-profile 15 { profile [ admin ]; }
	}
	authorization {
		profile admin { run { default-action allow; } edit { default-action allow; } }
	}
}

environment {
	ssh {
		enabled true
		server main { ip 127.0.0.1; port 0; }
	}
}
ZECONF

export ze_test_bgp_port=$((10000 + ($$ % 50000)))

ze tacacs-author.conf 2>daemon.log &
DAEMON_PID=$!
trap 'kill $DAEMON_PID 2>/dev/null || true; wait $DAEMON_PID 2>/dev/null || true; kill $MOCK_PID 2>/dev/null || true; wait $MOCK_PID 2>/dev/null || true' EXIT

SSH_PORT=""
for i in $(seq 1 50); do
	SSH_PORT=$(grep -o '127\.0\.0\.1:[0-9]*' daemon.log 2>/dev/null | head -1 | cut -d: -f2 || true)
	if [ -n "$SSH_PORT" ]; then
		break
	fi
	sleep 0.2
done
if [ -z "$SSH_PORT" ]; then
	echo "FAIL: SSH server did not start" >&2
	cat daemon.log >&2
	exit 1
fi
echo "ssh on :$SSH_PORT" >&2

sleep 0.5

ADMIN_DIR=$(mktemp -d)
trap 'rm -rf "$ADMIN_DIR"; kill $DAEMON_PID 2>/dev/null || true; wait $DAEMON_PID 2>/dev/null || true; kill $MOCK_PID 2>/dev/null || true; wait $MOCK_PID 2>/dev/null || true' EXIT
printf 'admin\ntestpass\n127.0.0.1\n%s\n' "$SSH_PORT" | ZE_CONFIG_DIR="$ADMIN_DIR" ze init >/dev/null

# AC-9: summary is NOT in the deny list -- mock replies PASS_ADD, command runs.
OUTPUT=$(ZE_CONFIG_DIR="$ADMIN_DIR" ZE_SSH_PASSWORD="testpass" ze cli -c "summary" 2>&1) || {
	echo "FAIL: 'summary' should have been authorized by TACACS+" >&2
	echo "OUTPUT: $OUTPUT" >&2
	echo "--- daemon log ---" >&2
	cat daemon.log >&2
	echo "--- mock log ---" >&2
	cat mock.log >&2
	exit 1
}
echo "OK: 'summary' authorized" >&2

# AC-10: 'configure' contains the deny substring -- mock replies FAIL, command blocked.
if OUTPUT=$(ZE_CONFIG_DIR="$ADMIN_DIR" ZE_SSH_PASSWORD="testpass" ze cli -c "configure" 2>&1); then
	echo "FAIL: 'configure' should have been blocked by TACACS+ authorization" >&2
	echo "OUTPUT: $OUTPUT" >&2
	exit 1
fi
echo "OK: 'configure' blocked: $OUTPUT" >&2

sleep 0.3
cat daemon.log >&2
cat mock.log >&2

exit 0
EOF_SH

cmd=foreground:seq=1:exec=./test-tacacs-author.sh:timeout=20s
expect=exit:code=0
# AC-9: AUTHOR REQUEST issued for 'summary' AND mock replied PASS_ADD.
expect=stderr:pattern=tacacs-mock: AUTHOR cmd="summary" reply=PASS_ADD
# AC-10: AUTHOR REQUEST issued for 'configure' AND mock replied FAIL.
expect=stderr:pattern=tacacs-mock: AUTHOR cmd="configure" reply=FAIL
# Script-side proof that the daemon actually blocked 'configure' (exits 1
# inside the script if 'ze cli -c configure' returned 0, i.e. authorization
# was ignored). Combined with the FAIL mock reply above, this proves the
# dispatcher consumed the FAIL status rather than silently letting the
# command run.
expect=stderr:pattern=OK: 'configure' blocked
