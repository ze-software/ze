# Test: cache list returns cache entries
# VALIDATES: cache list dispatches through engine and returns done
# PREVENTS: cache command handler broken or not wired

# ze-peer expectations
stdin=peer:terminator=EOF_PEER
option=tcp_connections:value=1
option=timeout:value=15s
expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF00170200000000
EOF_PEER

# Python test plugin: exercises dispatch-command for cache operations
tmpfs=cache-ops-test.run:mode=755:terminator=EOF_RUN
#!/usr/bin/env python3
import sys
import time
from ze_api import API

def dispatch(api, command):
    resp = api._call_engine(
        'ze-plugin-engine:dispatch-command', {'command': command})
    if resp is None:
        return {'status': 'error', 'data': 'engine call returned None'}
    return resp.get('result', {})

def main():
    api = API()
    api.declare_done()
    api.wait_for_config()
    api.capability_done()
    api.wait_for_registry()
    api.ready()
    time.sleep(1.0)

    try:
        result = dispatch(api, 'cache list')
        if result.get('status') != 'done':
            print(f'FAIL: cache list status={result.get("status")} data={result.get("data")}', file=sys.stderr)
            sys.exit(1)
        print('OK: cache list dispatched', file=sys.stderr)
    finally:
        dispatch(api, 'daemon shutdown')
        api.wait_for_shutdown()

if __name__ == '__main__':
    main()
EOF_RUN

# ze bgp configuration
stdin=ze-bgp:terminator=EOF_CONF
plugin {
	external cache-ops-test {
		run ./cache-ops-test.run
		encoder json
	}
}

environment {
	tcp {
		attempts 3
	}
}

bgp {
	peer peer1 {
		remote {
			ip 127.0.0.1
			as 1
		}
		local {
			as 1
			ip 127.0.0.1
		}
		router-id 1.2.3.4
		connection active
		group-updates disable

		family {
			ipv4/unicast { prefix { maximum 10000; } }
		}
		capability {
			graceful-restart disable
		}
		process cache-ops-test {
		}
	}
}
EOF_CONF

# Process orchestration
cmd=background:seq=1:exec=ze-peer --port $PORT:stdin=peer
cmd=foreground:seq=2:exec=ze -:stdin=ze-bgp:timeout=15s
expect=exit:code=0
