# Test: plugin-owned metrics appear in metrics list
#
# Flow:
# 1. BGP session establishes with telemetry enabled
# 2. Python plugin dispatches "metrics list" via dispatch-command
# 3. Verifies plugin-owned metric prefixes appear (ze_rib_, ze_gr_)
# 4. Shuts down daemon
#
# VALIDATES: AC-1 — ConfigureMetrics callback called during plugin startup.
# VALIDATES: AC-2 — Plugin metrics appear in Prometheus scrape output.
# VALIDATES: AC-8 — Plugin metrics use ze_{pluginname}_ prefix.
# PREVENTS: ConfigureMetrics not wired, plugin metrics not registered.

# ze-peer expectations
stdin=peer:terminator=EOF_PEER
option=tcp_connections:value=1
option=timeout:value=15s

# EOR
expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF00170200000000
EOF_PEER

# Python test plugin: exercises dispatch-command for bgp metrics list
tmpfs=metrics-list-test.run:mode=755:terminator=EOF_RUN
#!/usr/bin/env python3
"""Test: bgp metrics list via dispatch-command."""

import json
import sys
import time

from ze_api import API


def dispatch(api, command):
    """Call dispatch-command and return result dict."""
    resp = api._call_engine(
        'ze-plugin-engine:dispatch-command', {'command': command})
    return resp.get('result', {})


def main():
    api = API()
    api.declare_done()
    api.wait_for_config()
    api.capability_done()
    api.wait_for_registry()
    api.ready()

    # Wait for BGP session to establish
    time.sleep(1.0)

    # Test: bgp metrics list should return metric names
    r = dispatch(api, 'metrics list')
    status = r.get('status')
    if status != 'done':
        print(f'FAIL: expected status=done, got={status}', file=sys.stderr)
        sys.exit(1)

    data_str = r.get('data', '{}')
    try:
        data = json.loads(data_str) if isinstance(data_str, str) else data_str
    except (json.JSONDecodeError, TypeError):
        data = {}

    names = data.get('names', [])
    if not isinstance(names, list):
        print(f'FAIL: names not a list, data={data}', file=sys.stderr)
        sys.exit(1)

    count = data.get('count', 0)
    if count != len(names):
        print(f'FAIL: count mismatch: {count} != {len(names)}', file=sys.stderr)
        sys.exit(1)

    print(f'OK: metrics list returned {count} names', file=sys.stderr)

    # Verify plugin-owned metrics are registered.
    # bgp-rib and bgp-gr auto-load with any BGP peer.
    failures = []
    for prefix in ['ze_rib_', 'ze_gr_']:
        found = any(n.startswith(prefix) for n in names)
        if not found:
            failures.append(prefix)
            print(f'FAIL: no {prefix}* metrics in list', file=sys.stderr)
        else:
            print(f'OK: {prefix}* metrics present', file=sys.stderr)

    # Always shutdown before exiting
    dispatch(api, 'daemon shutdown')
    api.wait_for_shutdown()

    if failures:
        sys.exit(1)


if __name__ == '__main__':
    main()
EOF_RUN

# ze bgp configuration with telemetry enabled
stdin=ze-bgp:terminator=EOF_CONF
plugin {
	external metrics-list-test {
		run ./metrics-list-test.run
		encoder json
	}
}

telemetry {
	prometheus {
		enabled true
		server main {
			ip 127.0.0.1;
			port $PORT2;
		}
	}
}

bgp {
	peer peer1 {
		connection {
			remote {
				ip 127.0.0.1
			}
			local {
				ip 127.0.0.1
				accept false
			}
		}
		session {
			asn {
				local 1
				remote 1
			}
			router-id 1.2.3.4
			family {
				ipv4/unicast { prefix { maximum 10000; } }
			}
			capability {
				graceful-restart disable
			}
		}
		behavior {
			group-updates disable
		}

		process metrics-list-test {
		}
	}
}
EOF_CONF

# Process orchestration
cmd=background:seq=1:exec=ze-peer --port $PORT:stdin=peer
cmd=foreground:seq=2:exec=ze -:stdin=ze-bgp:timeout=15s
expect=exit:code=0
