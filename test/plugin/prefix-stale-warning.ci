# Test: Stale prefix data triggers warning at startup
# AC-5: Peer with old updated timestamp -> slog WARN at startup.
# AC-6: Peer without updated timestamp -> no staleness warning.

# ze-peer: accepts connection, expects EOR
stdin=peer:terminator=EOF_PEER
option=tcp_connections:value=1
option=timeout:value=15s
option=asn:value=65001
expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF00170200000000
EOF_PEER

# ze bgp configuration: peer1 has stale updated timestamp (2024-01-01)
stdin=ze-bgp:terminator=EOF_CONF
environment {
	tcp {
		attempts 3
	}
}

bgp {
	peer peer1 {
		remote {
			ip 127.0.0.1
			as 65001
		}
		local {
			as 65000
			ip 127.0.0.1
		}
		router-id 10.0.0.1
		connection active

		prefix {
			updated 2024-01-01
		}

		family {
			ipv4/unicast {
				prefix {
					maximum 10000
				}
			}
		}
	}
}
EOF_CONF

# Process orchestration
cmd=background:seq=1:exec=ze-peer --port $PORT:stdin=peer
cmd=foreground:seq=2:exec=ze -:stdin=ze-bgp:timeout=10s
# Verify staleness warning in ze stderr
expect=stderr:contains=prefix data is stale
