# Migrated from test/data/plugin/logging-level-filter.*

# ze-peer expectations
stdin=peer:terminator=EOF_PEER
option=timeout:value=10s

# Set server logging to INFO level (should filter out DEBUG)
option=env:var=ze.bgp.log.server:value=info

# Test: Level filtering
# Verifies ze.bgp.log.server=info filters out DEBUG messages

# Static route UPDATE
expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF00300200000015400101004002004003040A0000014005040000006418C0A801
# EOR
expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF00170200000000

# DEBUG messages should NOT appear (server subsystem logs at DEBUG level)
reject=stderr:pattern=level=DEBUG
EOF_PEER

# ze bgp configuration
stdin=ze-bgp:terminator=EOF_CONF
# Test: Level filtering
# Verifies that ze.bgp.log.server=info filters out DEBUG messages

plugin {
    external gr {
        run "ze plugin bgp-gr"
        encoder json
    }
}

bgp {
	peer peer1 {
		remote {
			ip 127.0.0.1
			as 1
			accept false
		}
		local {
			as 1
			ip 127.0.0.1
		}
	    router-id 1.2.3.4
	    group-updates disable
	
	    family {
	        ipv4/unicast { prefix { maximum 10000; } }
	    }
	
	    capability {
	        graceful-restart {
	            restart-time 120
	        }
	    }
	
	    update {
	        attribute {
	            origin igp
	            local-preference 100
	            next-hop 10.0.0.1
	        }
	        nlri {
	            ipv4/unicast add 192.168.1.0/24
	        }
	    }
	
	    process gr {
	        send [ update ]
	    }
	}
}
EOF_CONF

# Process orchestration
cmd=background:seq=1:exec=ze-peer --port $PORT:stdin=peer
cmd=foreground:seq=2:exec=ze -:stdin=ze-bgp:timeout=10s
