# Test: SIGHUP reload applies a changed `shared-secret` to the
#       running subsystem's effective config.
#
# VALIDATES: spec-l2tp-7 AC-14 -- shared-secret is hot-applied by
#            Subsystem.Reload and surfaces as "<set>" / "<unset>"
#            through EffectiveConfig. `show l2tp config` must not
#            leak the actual secret; the redaction must respond to
#            reload-time changes.
# PREVENTS:  regression where a reload parses the new secret but
#            does not update the redacted indicator (operators would
#            believe the old state still applies), and regression
#            where the reload silently no-ops when the secret flips.

option=env:var=ze.l2tp.skip-kernel-probe:value=true
stdin=peer:terminator=EOF_PEER
option=tcp_connections:value=1
option=timeout:value=20s
expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF00170200000000
EOF_PEER

tmpfs=reload-shared-secret.run:mode=755:terminator=EOF_RUN
#!/usr/bin/env python3
"""Verify `shared-secret` transitions `<unset>` -> `<set>` across SIGHUP.

Uses the `<unset>` -> `<set>` transition (rather than `<set>` -> `<set>`)
so the redaction-aware CLI surface shows a user-visible change. The
trigger.sh handshake serializes observer reads and config swap.
"""

import json
import os
import time

from ze_api import API, runtime_fail


def dispatch(api, command):
    resp = api._call_engine(
        'ze-plugin-engine:dispatch-command', {'command': command})
    if resp is None:
        return {'status': 'error', 'data': 'engine call returned None'}
    return resp.get('result', {})


def read_secret(api, label):
    r = None
    for _ in range(40):
        r = dispatch(api, 'show l2tp config')
        if r.get('status') == 'done':
            break
        time.sleep(0.1)
    if r is None or r.get('status') != 'done':
        runtime_fail(f'{label}: show l2tp config: status={r.get("status") if r else "nil"}')
    try:
        cfg = json.loads(r.get('data', '') or '{}')
    except json.JSONDecodeError as exc:
        runtime_fail(f'{label}: json: {exc}')
        return ''
    return cfg.get('shared-secret')


def main():
    api = API()
    api.declare_done()
    api.wait_for_config()
    api.capability_done()
    api.wait_for_registry()
    api.ready()
    time.sleep(1.0)

    before = read_secret(api, 'before')
    if before != '<unset>':
        runtime_fail(f'before SIGHUP: shared-secret={before!r} want "<unset>"')

    with open('observer.initial-ok', 'w') as f:
        f.write('ok')

    for _ in range(100):
        if os.path.exists('reload.done'):
            break
        time.sleep(0.1)
    else:
        runtime_fail('trigger.sh never created reload.done marker')

    after = None
    for _ in range(50):
        after = read_secret(api, 'after')
        if after == '<set>':
            break
        time.sleep(0.1)
    if after != '<set>':
        runtime_fail(f'after SIGHUP: shared-secret={after!r} want "<set>"')

    dispatch(api, 'daemon shutdown')
    api.wait_for_shutdown()


if __name__ == '__main__':
    main()
EOF_RUN

# Post-SIGHUP config: adds the shared-secret. Everything else unchanged.
tmpfs=config2.conf:terminator=EOF_CONF2
plugin {
	external reload-shared-secret-test {
		run ./reload-shared-secret.run
		encoder json
	}
}

environment {
	log {
		l2tp debug
	}
	l2tp {
		server main {
			ip 127.0.0.1
			port $PORT2
		}
	}
}

l2tp {
	enabled true
	shared-secret reload-secret-v2
}

bgp {
	peer peer1 {
		connection {
			remote {
				ip 127.0.0.1
				accept false
			}
			local {
				ip 127.0.0.1
			}
		}
		session {
			asn {
				local 1
				remote 1
			}
			router-id 1.2.3.4
			family {
				ipv4/unicast { prefix { maximum 10000; } }
			}
			capability {
				graceful-restart disable
			}
		}
		behavior {
			group-updates disable
		}
		process reload-shared-secret-test {
		}
	}
}
EOF_CONF2

tmpfs=trigger.sh:mode=755:terminator=EOF_TRIGGER
#!/bin/sh
while [ ! -f daemon.pid ]; do sleep 0.1; done
while [ ! -f daemon.ready ]; do sleep 0.1; done
while [ ! -f observer.initial-ok ]; do sleep 0.1; done
cp config2.conf ze-bgp.conf
kill -HUP $(cat daemon.pid)
touch reload.done
EOF_TRIGGER

stdin=ze-conf:terminator=EOF_CONF
plugin {
	external reload-shared-secret-test {
		run ./reload-shared-secret.run
		encoder json
	}
}

environment {
	log {
		l2tp debug
	}
	l2tp {
		server main {
			ip 127.0.0.1
			port $PORT2
		}
	}
}

l2tp {
	enabled true
}

bgp {
	peer peer1 {
		connection {
			remote {
				ip 127.0.0.1
				accept false
			}
			local {
				ip 127.0.0.1
			}
		}
		session {
			asn {
				local 1
				remote 1
			}
			router-id 1.2.3.4
			family {
				ipv4/unicast { prefix { maximum 10000; } }
			}
			capability {
				graceful-restart disable
			}
		}
		behavior {
			group-updates disable
		}
		process reload-shared-secret-test {
		}
	}
}
EOF_CONF

cmd=background:seq=1:exec=ze-peer --port $PORT:stdin=peer
cmd=background:seq=2:exec=sh trigger.sh
cmd=foreground:seq=3:exec=ze -:stdin=ze-conf:timeout=20s
expect=exit:code=0
expect=stderr:contains=l2tp reload: shared-secret updated
