# Test: ze config edit without daemon starts ephemeral daemon
#
# This test validates the ephemeral daemon concept by verifying
# ze init works as a bootstrap step for the config editor.
# Full interactive TUI testing is not possible in .ci format.
#
# VALIDATES: AC-5 -- ze init bootstraps credentials for editor.
# PREVENTS: Editor failing silently when daemon not available.

# Test script
tmpfs=test-config-edit.sh:mode=755:terminator=EOF_SH
#!/bin/sh
set -e

# Signal test runner readiness
touch daemon.ready

# Create a temp directory for the database
INIT_DIR=$(mktemp -d)
trap 'rm -rf "$INIT_DIR"' EXIT

# Verify ze init works (pre-daemon bootstrap)
printf 'admin\nsecret123\n127.0.0.1\n2222\n' | ZE_CONFIG_DIR="$INIT_DIR" ze init

# Verify database was created
if [ ! -f "$INIT_DIR/database.zefs" ]; then
	echo "FAIL: database.zefs not created" >&2
	exit 1
fi

echo "OK: ze init created database for editor bootstrap" >&2
exit 0
EOF_SH

cmd=foreground:seq=1:exec=./test-config-edit.sh:timeout=10s
expect=exit:code=0
