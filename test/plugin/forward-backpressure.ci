# Test: forward backpressure congestion events are subscribable
# VALIDATES: congested/resumed event types registered in BGP namespace
# PREVENTS: congestion events not wired into subscription system

# ze-peer expectations
stdin=peer:terminator=EOF_PEER
option=tcp_connections:value=1
option=timeout:value=15s
expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF00170200000000
EOF_PEER

# Python test plugin: subscribes to congested and resumed events
tmpfs=backpressure-test.run:mode=755:terminator=EOF_RUN
#!/usr/bin/env python3
import json
import sys
import time
from ze_api import API

def dispatch(api, command):
    resp = api._call_engine(
        'ze-plugin-engine:dispatch-command', {'command': command})
    if resp is None:
        return {'status': 'error', 'data': 'engine call returned None'}
    return resp.get('result', {})

def main():
    api = API()
    api.declare_done()
    api.wait_for_config()
    api.capability_done()
    api.wait_for_registry()
    api.ready()
    time.sleep(1.0)

    try:
        # Subscribe to congested events -- proves the event type is registered
        result = dispatch(api, 'subscribe bgp event congested')
        if result.get('status') != 'done':
            print(f'FAIL: subscribe congested status={result.get("status")} data={result.get("data")}', file=sys.stderr)
            sys.exit(1)

        data = result.get('data', {})
        if isinstance(data, str):
            data = json.loads(data)
        ns = data.get('namespace', '')
        ev = data.get('event', '')
        if ns != 'bgp' or ev != 'congested':
            print(f'FAIL: expected bgp/congested, got {ns}/{ev}', file=sys.stderr)
            sys.exit(1)
        print(f'OK: subscribed to {ns} event {ev}', file=sys.stderr)

        # Subscribe to resumed events -- proves the event type is registered
        result = dispatch(api, 'subscribe bgp event resumed')
        if result.get('status') != 'done':
            print(f'FAIL: subscribe resumed status={result.get("status")} data={result.get("data")}', file=sys.stderr)
            sys.exit(1)

        data = result.get('data', {})
        if isinstance(data, str):
            data = json.loads(data)
        ns = data.get('namespace', '')
        ev = data.get('event', '')
        if ns != 'bgp' or ev != 'resumed':
            print(f'FAIL: expected bgp/resumed, got {ns}/{ev}', file=sys.stderr)
            sys.exit(1)
        print(f'OK: subscribed to {ns} event {ev}', file=sys.stderr)

        print('OK: both congestion events subscribable', file=sys.stderr)
    finally:
        dispatch(api, 'daemon shutdown')
        api.wait_for_shutdown()

if __name__ == '__main__':
    main()
EOF_RUN

# ze bgp configuration
stdin=ze-bgp:terminator=EOF_CONF
plugin {
	external backpressure-test {
		run ./backpressure-test.run
		encoder json
	}
}

environment {
	tcp {
		attempts 3
	}
}

bgp {
	peer peer1 {
		remote {
			ip 127.0.0.1
			as 1
			accept false
		}
		local {
			as 1
			ip 127.0.0.1
		}
		router-id 1.2.3.4
		group-updates disable

		family {
			ipv4/unicast { prefix { maximum 10000; } }
		}
		capability {
			graceful-restart disable
		}
		process backpressure-test {
		}
	}
}
EOF_CONF

# Process orchestration
cmd=background:seq=1:exec=ze-peer --port $PORT:stdin=peer
cmd=foreground:seq=2:exec=ze -:stdin=ze-bgp:timeout=15s
expect=exit:code=0
