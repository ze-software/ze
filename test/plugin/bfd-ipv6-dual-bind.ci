# Test: BFD plugin opens an IPv6 companion socket when
# `bfd { bind-v6 true }` is set and an IPv6 single-hop session is
# pinned.
#
# VALIDATES: spec-bfd-2b-ipv6-transport -- the transport.Dual
#            wrapper pairs an IPv4 UDP with an IPv6 UDP, both
#            bound to the canonical RFC port, and the BFD plugin
#            routes an IPv6 peer's Send to the IPv6 inner.
# PREVENTS:  regression where the YANG `bind-v6` leaf is ignored
#            or the Dual path silently falls back to IPv4 only.
#
# Method: a Python orchestrator launches ze with a v6 single-hop
# session and a top-level `bfd { bind-v6 true }` leaf, waits for
# the lifecycle log lines (including the new ipv6=true field), and
# SIGTERMs cleanly. Rings v4/v6 port conflict is avoided because
# each test gets its own ze.bfd.test-parallel=true (SO_REUSEPORT).

option=env:var=ze.bfd.test-parallel:value=true

tmpfs=test-bfd-ipv6.py:mode=755:terminator=EOF_PY
#!/usr/bin/env python3
"""Drive ze with a v6 pinned session and assert the dual-bind path."""

import os
import signal
import subprocess
import sys
import time

REQUIRED = [
    "bfd plugin starting",
    "bfd pinned session created",
    "ipv6=true",
    "bfd plugin running",
]

CONFIG = """environment {
}

bfd {
\tenabled true;
\tbind-v6 true;
\tprofile fast {
\t\tdetect-multiplier 3
\t\tdesired-min-tx-us 100000
\t\trequired-min-rx-us 100000
\t}
\tsingle-hop-session 2001:db8::9 {
\t\tprofile fast
\t}
}
"""


def main() -> int:
    env = os.environ.copy()
    env["ze.log.bfd"] = "debug"
    env["ze.bfd.test-parallel"] = "true"

    proc = subprocess.Popen(
        ["ze", "-"],
        stdin=subprocess.PIPE,
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
        text=True,
        env=env,
    )
    assert proc.stdin is not None
    proc.stdin.write(CONFIG)
    proc.stdin.close()

    deadline = time.time() + 8.0
    captured = ""
    matched: set[str] = set()
    while time.time() < deadline:
        if proc.stderr is None:
            break
        line = proc.stderr.readline()
        if not line:
            if proc.poll() is not None:
                break
            time.sleep(0.05)
            continue
        captured += line
        sys.stderr.write(line)
        sys.stderr.flush()
        for needle in REQUIRED:
            if needle in line:
                matched.add(needle)
        if len(matched) == len(REQUIRED):
            break

    if proc.poll() is None:
        proc.send_signal(signal.SIGTERM)
        try:
            proc.wait(timeout=3.0)
        except subprocess.TimeoutExpired:
            proc.kill()
            proc.wait(timeout=2.0)

    if proc.stderr is not None:
        try:
            tail = proc.stderr.read()
        except (ValueError, OSError):
            tail = ""
        if tail:
            captured += tail
            sys.stderr.write(tail)
            sys.stderr.flush()

    missing = [n for n in REQUIRED if n not in captured]
    if missing:
        sys.stderr.write(f"FAIL: missing required patterns: {missing}\n")
        return 1
    sys.stderr.write("OK: bfd dual-bind v6 lifecycle observed\n")
    return 0


if __name__ == "__main__":
    sys.exit(main())
EOF_PY

cmd=foreground:seq=1:exec=python3 ./test-bfd-ipv6.py:timeout=15s
expect=exit:code=0
expect=stderr:pattern=bfd plugin running
expect=stderr:pattern=ipv6=true
