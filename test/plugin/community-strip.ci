# Test: Community filter egress stripping
# VALIDATES: blocked -- this file is harness wiring only; it does not prove AC-7
# STATUS: blocked -- no plugin in this config calls ForwardUpdate or
#         ForwardUpdatesDirect, so the configured dest-peer egress filter never runs
# PREVENTS: false reviewer confidence that community stripping is covered end-to-end
#
# Flow:
# 1. Source peer sends UPDATE with community 65000:200
# 2. Test proves source/dest session orchestration and observer RPC health only
# 3. No forwarding plugin is loaded, so the dest peer is not evidence for strip behavior

# Source peer (ASN 65001) on 127.0.0.1
option=env:var=ze.log.bgp.filter.community:value=info
option=env:var=ze.log.bgp.adj-rib-in:value=info
option=env:var=ze.log.bgp.reactor.session:value=debug
stdin=source:terminator=EOF_SOURCE
option=tcp_connections:value=1
option=timeout:value=20s
# Send UPDATE with COMMUNITY 65000:200: ORIGIN=IGP, AS_PATH=[65001], NEXT_HOP=1.1.1.1,
#   COMMUNITY=65000:200 (0xFDE800C8), NLRI=10.0.0.0/24
# Attrs: ORIGIN(4) + AS_PATH(9) + NEXT_HOP(7) + COMMUNITY(7) = 27 = 0x1B
# Total msg: 16(marker)+2(len)+1(type)+2(wdLen)+2(attrLen)+27(attrs)+4(NLRI) = 54 = 0x36
# COMMUNITY attr (non-extended length): C0 08 04 FDE800C8 (Optional Transitive code=8 len=4 val=65000:200)
action=send:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF0036020000001B4001010040020602010000FDE940030401010101C00804FDE800C8180A0000
EOF_SOURCE

# Dest peer (ASN 65002) on 127.0.0.2 -- sink mode accepts any UPDATE
stdin=dest:terminator=EOF_DEST
option=tcp_connections:value=1
option=timeout:value=20s
EOF_DEST

# Python test plugin: verify harness wiring only. Real strip proof needs a
# forwarding plugin plus a dest-peer wire assertion.
tmpfs=test-strip.run:mode=755:terminator=EOF_RUN
#!/usr/bin/env python3
"""Verify observer wiring only; this file does not prove egress stripping."""
import json
import sys
import time
from ze_api import API, runtime_fail

def dispatch(api, command):
    resp = api._call_engine('ze-plugin-engine:dispatch-command', {'command': command})
    return resp.get('result', {})

def main():
    api = API()
    api.declare_done()
    api.wait_for_config()
    api.capability_done()
    api.wait_for_registry()
    api.ready()

    # Wait for both sessions to establish and route to be forwarded.
    time.sleep(5.0)

    # Query adj-rib-in for diagnostic info. The rpki validation gate (auto-
    # enabled by bgp-rpki) holds routes in pending; the strip verification
    # itself is via the production log assertion at the bottom of this file.
    result = dispatch(api, 'adj-rib-in status')
    data = json.loads(result.get('data', '{}'))
    total = data.get('total-routes', -1)

    if total < 0:
        msg = f'adj-rib-in query failed, got total={total}'
        print(f'FAIL: {msg}', file=sys.stderr)
        sys.stderr.flush()
        runtime_fail(msg)

    print(f'INFO: adj-rib-in total={total} (no egress-strip assertion in this file)', file=sys.stderr)

    # Verify dest-peer session is established (proves ze connected to second peer).
    dest_result = dispatch(api, 'peer dest-peer detail')
    dest_data = dest_result.get('data', '')
    if 'established' not in dest_data.lower():
        msg = f'dest-peer session not established: {dest_data}'
        print(f'FAIL: {msg}', file=sys.stderr)
        sys.stderr.flush()
        runtime_fail(msg)

    print('OK: session wiring stayed healthy; egress strip remains blocked in this file', file=sys.stderr)
    dispatch(api, 'daemon shutdown')
    api.wait_for_shutdown()

if __name__ == '__main__':
    main()
EOF_RUN

# ze configuration: two peers, egress strip on dest peer
stdin=ze-bgp:terminator=EOF_CONF
plugin {
	external test-strip {
		run ./test-strip.run
		encoder json
	}
}
bgp {
	community {
		standard unwanted {
			value 65000:200
		}
	}

	peer source-peer {
		connection {
			remote {
				ip 127.0.0.1
			}
			local {
				ip 127.0.0.1
				accept false
			}
		}
		session {
			asn {
				local 65000
				remote 65001
			}
			router-id 1.2.3.4
			family {
				ipv4/unicast { prefix { maximum 10000; } }
			}
		}

		process test-strip {
			receive [ update state ]
		}
	}

	peer dest-peer {
		connection {
			remote {
				ip 127.0.0.2
			}
			local {
				ip 127.0.0.2
				accept false
			}
		}
		session {
			asn {
				local 65000
				remote 65002
			}
			router-id 1.2.3.4
			family {
				ipv4/unicast { prefix { maximum 10000; } }
			}
		}

		filter {
			egress {
				community {
					strip unwanted
				}
			}
		}
	}
}
EOF_CONF

# Process orchestration
cmd=background:seq=1:exec=ze-peer --port $PORT:stdin=source
cmd=background:seq=2:exec=ze-peer --bind 127.0.0.2 --mode sink --port $PORT:stdin=dest
cmd=foreground:seq=3:exec=ze --plugin ze.bgp-filter-community --plugin ze.bgp-adj-rib-in -:stdin=ze-bgp:timeout=20s
expect=exit:code=0
# This file intentionally makes no AC-7 claim. With no forwarding plugin
# (for example bgp-rs) the dest-peer egress filter never executes, so the
# session checks below are only harness health signals.
reject=stderr:pattern=panic recovered
reject=stderr:pattern=fatal error
reject=stderr:pattern=treat-as-withdraw
reject=stderr:pattern=ZE-OBSERVER-FAIL
