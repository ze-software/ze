# Test: Community filter egress stripping
# VALIDATES: AC-7 -- dest peer receives the re-advertised UPDATE without the stripped community
# PREVENTS: egress community stripping being configured but not applied on the wire

# Source peer (ASN 65001) on 127.0.0.1
option=env:var=ze.log.bgp.filter.community:value=info
option=env:var=ze.log.bgp.adj-rib-in:value=info
option=env:var=ze.log.bgp.reactor.session:value=debug
stdin=source:terminator=EOF_SOURCE
option=tcp_connections:value=1
option=timeout:value=20s
# Send UPDATE with COMMUNITY 65000:200: ORIGIN=IGP, AS_PATH=[65001], NEXT_HOP=1.1.1.1,
#   COMMUNITY=65000:200 (0xFDE800C8), NLRI=10.0.0.0/24
# Attrs: ORIGIN(4) + AS_PATH(9) + NEXT_HOP(7) + COMMUNITY(7) = 27 = 0x1B
# Total msg: 16(marker)+2(len)+1(type)+2(wdLen)+2(attrLen)+27(attrs)+4(NLRI) = 54 = 0x36
# COMMUNITY attr (non-extended length): C0 08 04 FDE800C8 (Optional Transitive code=8 len=4 val=65000:200)
action=send:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF0036020000001B4001010040020602010000FDE940030401010101C00804FDE800C8180A0000
# Hold the source session open long enough for the forwarding plugin to
# re-advertise the route and send EOR.
expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF00170200000000
EOF_SOURCE

# Dest peer (ASN 65002) on 127.0.0.2 -- expect stripped re-advertisement
stdin=dest:terminator=EOF_DEST
option=tcp_connections:value=1
option=timeout:value=20s
expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF003302000000184001010040020A02020000FDE80000FDE940030401010101180A0000
expect=bgp:conn=1:seq=2:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF00170200000000
EOF_DEST

# Python test plugin: keep the daemon alive long enough for the destination wire
# assertion below to complete. The dest-peer `expect=bgp` lines are the proof.
tmpfs=test-strip.run:mode=755:terminator=EOF_RUN
#!/usr/bin/env python3
"""Keep the daemon alive while the dest peer proves egress stripping on the wire."""
import json
import sys
import time
from ze_api import API, runtime_fail

def dispatch(api, command):
    resp = api._call_engine('ze-plugin-engine:dispatch-command', {'command': command})
    return resp.get('result', {})

def main():
    api = API()
    api.declare_done()
    api.wait_for_config()
    api.capability_done()
    api.wait_for_registry()
    api.ready()

    # Wait for both sessions to establish and route to be forwarded.
    time.sleep(5.0)

    # Query adj-rib-in for diagnostic context only. The strip proof is the
    # destination peer wire assertion at the bottom of this file.
    result = dispatch(api, 'adj-rib-in status')
    data = json.loads(result.get('data', '{}'))
    total = data.get('total-routes', -1)

    if total < 0:
        msg = f'adj-rib-in query failed, got total={total}'
        print(f'FAIL: {msg}', file=sys.stderr)
        sys.stderr.flush()
        runtime_fail(msg)

    print(f'INFO: adj-rib-in total={total}', file=sys.stderr)

    # Verify dest-peer session is established (proves ze connected to second peer).
    dest_result = dispatch(api, 'peer dest-peer detail')
    dest_data = dest_result.get('data', '')
    if 'established' not in dest_data.lower():
        msg = f'dest-peer session not established: {dest_data}'
        print(f'FAIL: {msg}', file=sys.stderr)
        sys.stderr.flush()
        runtime_fail(msg)

    print('OK: session wiring stayed healthy while dest peer verified stripped wire output', file=sys.stderr)
    dispatch(api, 'daemon shutdown')
    api.wait_for_shutdown()

if __name__ == '__main__':
    main()
EOF_RUN

# ze configuration: two peers, egress strip on dest peer
stdin=ze-bgp:terminator=EOF_CONF
plugin {
	external test-strip {
		run ./test-strip.run
		encoder json
	}
}
bgp {
	community {
		standard unwanted {
			value 65000:200
		}
	}

	peer source-peer {
		connection {
			remote {
				ip 127.0.0.1
			}
			local {
				ip 127.0.0.1
				accept false
			}
		}
		session {
			asn {
				local 65000
				remote 65001
			}
			router-id 1.2.3.4
			family {
				ipv4/unicast { prefix { maximum 10000; } }
			}
		}

		process test-strip {
			receive [ update state ]
		}
	}

	peer dest-peer {
		connection {
			remote {
				ip 127.0.0.2
			}
			local {
				ip 127.0.0.2
				accept false
			}
		}
		session {
			asn {
				local 65000
				remote 65002
			}
			router-id 1.2.3.4
			family {
				ipv4/unicast { prefix { maximum 10000; } }
			}
		}

		filter {
			egress {
				community {
					strip unwanted
				}
			}
		}
	}
}
EOF_CONF

# Process orchestration
cmd=background:seq=1:exec=ze-peer --port $PORT:stdin=source
cmd=background:seq=2:exec=ze-peer --bind 127.0.0.2 --port $PORT:stdin=dest
cmd=foreground:seq=3:exec=ze --plugin ze.bgp-filter-community --plugin ze.bgp-adj-rib-in -:stdin=ze-bgp:timeout=20s
expect=exit:code=0
reject=stderr:pattern=panic recovered
reject=stderr:pattern=fatal error
reject=stderr:pattern=treat-as-withdraw
reject=stderr:pattern=ZE-OBSERVER-FAIL
