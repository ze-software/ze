# Test: `show bfd session <peer>` returns one session's detail.
#
# VALIDATES: spec-bfd-4 AC-2 and AC-3 -- handleShowSession returns
#            the SessionState struct when the peer matches a pinned
#            session, and a "no session for peer" StatusError when
#            the peer is unknown.
# PREVENTS:  regression where the lookup ignores the peer argument
#            or drops the not-found path.

option=env:var=ze.bfd.test-parallel:value=true
stdin=peer:terminator=EOF_PEER
option=tcp_connections:value=1
option=timeout:value=15s
expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF00170200000000
EOF_PEER

tmpfs=bfd-show-session.run:mode=755:terminator=EOF_RUN
#!/usr/bin/env python3
"""Exercise `show bfd session <peer>` for known and unknown peers."""

import json
import time

from ze_api import API, runtime_fail


def dispatch(api, command):
    resp = api._call_engine(
        'ze-plugin-engine:dispatch-command', {'command': command})
    if resp is None:
        return {'status': 'error', 'data': 'engine call returned None'}
    return resp.get('result', {})


def main():
    api = API()
    api.declare_done()
    api.wait_for_config()
    api.capability_done()
    api.wait_for_registry()
    api.ready()
    time.sleep(1.0)

    # AC-2: known peer
    r = None
    for _ in range(20):
        r = dispatch(api, 'show bfd session 203.0.113.9')
        if r.get('status') == 'done':
            break
        time.sleep(0.25)
    if r is None or r.get('status') != 'done':
        runtime_fail(f'known peer: status={r.get("status") if r else "nil"}')

    try:
        detail = json.loads(r.get('data', '') or '{}')
    except json.JSONDecodeError as exc:
        detail = {}
        runtime_fail(f'known peer json: {exc}')
    if detail.get('peer') != '203.0.113.9':
        runtime_fail(f'known peer payload: {detail}')
    if detail.get('mode') != 'single-hop':
        runtime_fail(f'known mode: {detail.get("mode")}')

    # AC-3: unknown peer
    r = dispatch(api, 'show bfd session 198.51.100.200')
    if r.get('status') != 'error':
        runtime_fail(f'unknown status: {r.get("status")} data={r.get("data", "")[:200]}')
    else:
        msg = r.get('data', '')
        if 'no session for peer' not in msg:
            runtime_fail(f'unknown message: {msg}')

    dispatch(api, 'daemon shutdown')
    api.wait_for_shutdown()


if __name__ == '__main__':
    main()
EOF_RUN

stdin=ze-bfd:terminator=EOF_CONF
plugin {
	external bfd-show-session-test {
		run ./bfd-show-session.run
		encoder json
	}
}

environment {
	log {
		bfd debug
	}
}

bfd {
	enabled true;
	profile fast {
		detect-multiplier 3
		desired-min-tx-us 50000
		required-min-rx-us 50000
	}
	single-hop-session 203.0.113.9 {
		profile fast
	}
}

bgp {
	peer peer1 {
		connection {
			remote {
				ip 127.0.0.1
				accept false
			}
			local {
				ip 127.0.0.1
			}
		}
		session {
			asn {
				local 1
				remote 1
			}
			router-id 1.2.3.4
			family {
				ipv4/unicast { prefix { maximum 10000; } }
			}
			capability {
				graceful-restart disable
			}
		}
		behavior {
			group-updates disable
		}
		process bfd-show-session-test {
		}
	}
}
EOF_CONF

cmd=background:seq=1:exec=ze-peer --port $PORT:stdin=peer
cmd=foreground:seq=2:exec=ze -:stdin=ze-bfd:timeout=15s
expect=exit:code=0
