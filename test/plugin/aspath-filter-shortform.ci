# Test: as-path-list filter works with short-form reference
# VALIDATES: AC-1 -- filter works via as-path-list:NAME reference (short form)
# VALIDATES: AC-8 -- composable (standalone chain with short-form reference)
# PREVENTS: Short-form reference "as-path-list:NAME" not resolved to plugin
#
# Flow:
# 1. ze-peer sends UPDATE: ORIGIN=IGP, AS_PATH=[65001], NEXT_HOP=1.1.1.1, NLRI=10.0.0.0/24
# 2. Filter chain resolves short-form "as-path-list:CUSTOMERS" to bgp-filter-aspath:CUSTOMERS
# 3. Regex "65001" matches "65001" -> accept
# 4. Assertions on stderr confirm the decision log.

option=env:var=ze.log.bgp.filter.aspath:value=info

stdin=peer:terminator=EOF_PEER
option=tcp_connections:value=1
option=timeout:value=15s
action=send:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF002F02000000144001010040020602010000FDE940030401010101180A0000
EOF_PEER

# Observer: wait for filter dispatch then clean shutdown
tmpfs=test-aspath-short.run:mode=755:terminator=EOF_RUN
#!/usr/bin/env python3
"""Observer for as-path-list short-form test: clean shutdown after filter dispatch."""
import time
from ze_api import API

def dispatch(api, command):
    resp = api._call_engine('ze-plugin-engine:dispatch-command', {'command': command})
    return resp.get('result', {})

def main():
    api = API()
    api.declare_done()
    api.wait_for_config()
    api.capability_done()
    api.wait_for_registry()
    api.ready()

    time.sleep(3.0)

    dispatch(api, 'daemon shutdown')
    api.wait_for_shutdown()

if __name__ == '__main__':
    main()
EOF_RUN

stdin=ze-bgp:terminator=EOF_CONF
plugin {
	external test-aspath-short {
		run ./test-aspath-short.run
		encoder json
	}
}
bgp {
	policy {
		as-path-list CUSTOMERS {
			entry "65001" {
				action accept
			}
		}
	}

	peer peer1 {
		connection {
			remote {
				ip 127.0.0.1
			}
			local {
				ip 127.0.0.1
				accept false
			}
		}
		session {
			asn {
				local 65000
				remote 65001
			}
			router-id 1.2.3.4
			family {
				ipv4/unicast { prefix { maximum 10000; } }
			}
		}

		filter {
			import [ as-path-list:CUSTOMERS ]
		}

		process test-aspath-short {
			receive [ update state ]
		}
	}
}
EOF_CONF

cmd=background:seq=1:exec=ze-peer --port $PORT:stdin=peer
cmd=foreground:seq=2:exec=ze --plugin ze.bgp-filter-aspath --plugin ze.bgp-adj-rib-in -:stdin=ze-bgp:timeout=15s
expect=exit:code=0
expect=stderr:pattern=as-path-list accept
expect=stderr:pattern=filter=CUSTOMERS
reject=stderr:pattern=as-path-list reject
