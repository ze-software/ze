# Test: `show l2tp config` reflects non-default runtime configuration.
#
# VALIDATES: spec-l2tp-7 AC-7 -- EffectiveConfig surfaces enabled,
#            max-tunnels, max-sessions, hello-interval, shared-secret
#            (redacted as "<set>"), and listeners in registration
#            order. Proves non-default values flow through
#            ExtractParameters -> Subsystem.params -> handleConfig
#            and into the JSON payload the CLI consumer sees.
# PREVENTS:  silent drop of any l2tp{} leaf between parsing and the
#            CLI surface (e.g., hello-interval read but not stored,
#            max-sessions ignored, shared-secret leaked).
#
# Runs under test/plugin/ so the TLS plugin hub is configured by the
# BGP peer's `process ...` directive; an L2TP-only test cannot
# trigger hub setup by itself (see plan/learned/620-l2tp-7-subsystem.md
# "Gotchas" -- BFD-as-plugin precedent).

option=env:var=ze.l2tp.skip-kernel-probe:value=true
stdin=peer:terminator=EOF_PEER
option=tcp_connections:value=1
option=timeout:value=15s
expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF00170200000000
EOF_PEER

tmpfs=show-l2tp-config.run:mode=755:terminator=EOF_RUN
#!/usr/bin/env python3
"""Dispatch `show l2tp config` and assert non-default values round-trip."""

import json
import time

from ze_api import API, runtime_fail


def dispatch(api, command):
    resp = api._call_engine(
        'ze-plugin-engine:dispatch-command', {'command': command})
    if resp is None:
        return {'status': 'error', 'data': 'engine call returned None'}
    return resp.get('result', {})


def main():
    api = API()
    api.declare_done()
    api.wait_for_config()
    api.capability_done()
    api.wait_for_registry()
    api.ready()
    time.sleep(1.0)

    r = None
    for _ in range(20):
        r = dispatch(api, 'show l2tp config')
        if r.get('status') == 'done':
            break
        time.sleep(0.25)
    if r is None or r.get('status') != 'done':
        status = r.get('status') if r else 'nil'
        data = r.get('data', '') if r else ''
        runtime_fail(f'show l2tp config: status={status} data={data[:200]}')

    try:
        cfg = json.loads(r.get('data', '') or '{}')
    except json.JSONDecodeError as exc:
        runtime_fail(f'show l2tp config json: {exc}: {r.get("data", "")[:200]}')
        cfg = {}

    # Non-default values set by the config block below.
    checks = [
        ('enabled', True),
        ('max-tunnels', 50),
        ('max-sessions', 75),
        ('hello-interval', 45),
        ('shared-secret', '<set>'),
    ]
    for key, want in checks:
        got = cfg.get(key)
        if got != want:
            runtime_fail(f'show l2tp config: {key}={got!r} want {want!r}')

    listeners = cfg.get('listeners')
    if not isinstance(listeners, list) or len(listeners) != 1:
        runtime_fail(f'show l2tp config listeners unexpected: {listeners!r}')
    if '127.0.0.1:' not in listeners[0]:
        runtime_fail(f'show l2tp config listeners[0]={listeners[0]!r}')

    dispatch(api, 'daemon shutdown')
    api.wait_for_shutdown()


if __name__ == '__main__':
    main()
EOF_RUN

stdin=ze-conf:terminator=EOF_CONF
plugin {
	external show-l2tp-config-test {
		run ./show-l2tp-config.run
		encoder json
	}
}

environment {
	log {
		l2tp debug
	}
	l2tp {
		server main {
			ip 127.0.0.1
			port $PORT2
		}
	}
}

l2tp {
	enabled true
	shared-secret s3cr3t
	hello-interval 45
	max-tunnels 50
	max-sessions 75
}

bgp {
	peer peer1 {
		connection {
			remote {
				ip 127.0.0.1
			}
			local {
				ip 127.0.0.1
				accept false
			}
		}
		session {
			asn {
				local 1
				remote 1
			}
			router-id 1.2.3.4
			family {
				ipv4/unicast { prefix { maximum 10000; } }
			}
			capability {
				graceful-restart disable
			}
		}
		behavior {
			group-updates disable
		}
		process show-l2tp-config-test {
		}
	}
}
EOF_CONF

cmd=background:seq=1:exec=ze-peer --port $PORT:stdin=peer
cmd=foreground:seq=2:exec=ze -:stdin=ze-conf:timeout=15s
expect=exit:code=0
