# Test: prefix-list filter chain ref using plain (unprefixed) filter name
# VALIDATES: ISSUE 6 fix -- user can write `filter import [ CUSTOMERS ]`
#   with no `<type>:` or `<plugin>:` prefix; the framework resolves plain
#   names via the FilterRegistry + FilterTypes map at parse time.
# PREVENTS: Regression where plain names are silently rejected or dispatched
#   to a non-existent plugin.

option=env:var=ze.log.bgp.filter.prefix:value=info

stdin=peer:terminator=EOF_PEER
option=tcp_connections:value=1
option=timeout:value=15s
action=send:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF002F02000000144001010040020602010000FDE940030401010101180A0000
EOF_PEER

# Observer: sleep briefly so the filter fires, then dispatch daemon shutdown.
tmpfs=test-plain.run:mode=755:terminator=EOF_RUN
#!/usr/bin/env python3
import time
from ze_api import API

def main():
    api = API()
    api.declare_done()
    api.wait_for_config()
    api.capability_done()
    api.wait_for_registry()
    api.ready()
    time.sleep(2.0)
    api._call_engine('ze-plugin-engine:dispatch-command', {'command': 'daemon shutdown'})
    api.wait_for_shutdown()

if __name__ == '__main__':
    main()
EOF_RUN

stdin=ze-bgp:terminator=EOF_CONF
plugin {
	external test-plain {
		run ./test-plain.run
		encoder json
	}
}
bgp {
	policy {
		prefix-list GLOBALLY_UNIQUE_NAME {
			entry 10.0.0.0/8 {
				ge 16
				le 24
				action accept
			}
		}
	}

	peer peer1 {
		connection {
			remote {
				ip 127.0.0.1
				accept false
			}
			local {
				ip 127.0.0.1
			}
		}
		session {
			asn {
				local 65000
				remote 65001
			}
			router-id 1.2.3.4
			family {
				ipv4/unicast { prefix { maximum 10000; } }
			}
		}

		# Plain name -- no `<type>:` or `<plugin>:` prefix. The framework
		# resolves GLOBALLY_UNIQUE_NAME via BuildFilterRegistry to type
		# "prefix-list", then via FilterTypes map to plugin "bgp-filter-prefix",
		# and rewrites the ref to "bgp-filter-prefix:GLOBALLY_UNIQUE_NAME"
		# before runtime dispatch.
		filter {
			import [ GLOBALLY_UNIQUE_NAME ]
		}
	}
}
EOF_CONF

cmd=background:seq=1:exec=ze-peer --port $PORT:stdin=peer
cmd=foreground:seq=2:exec=ze --plugin ze.bgp-filter-prefix -:stdin=ze-bgp:timeout=15s
expect=exit:code=0
# Plain name resolved and filter invoked with the right filter-name.
expect=stderr:pattern=prefix-list accept
expect=stderr:pattern=filter=GLOBALLY_UNIQUE_NAME
reject=stderr:pattern=unknown plugin
