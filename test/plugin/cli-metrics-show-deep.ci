# Test: bgp metrics values includes deep instrumentation metric names
#
# Flow:
# 1. BGP session establishes with telemetry enabled
# 2. Python plugin dispatches "metrics values" via dispatch-command
# 3. Verifies response contains session lifecycle, wire, config, and GR metric names
# 4. Shuts down daemon
#
# VALIDATES: AC-9 — bgp metrics show includes new deep instrumentation metrics.
# PREVENTS: New metrics not registered or not reachable via dispatch chain.

# ze-peer expectations
stdin=peer:terminator=EOF_PEER
option=tcp_connections:value=1
option=timeout:value=15s

# EOR
expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF00170200000000
EOF_PEER

# Python test plugin: verifies deep instrumentation metrics in values output
tmpfs=metrics-show-deep-test.run:mode=755:terminator=EOF_RUN
#!/usr/bin/env python3
"""Test: deep instrumentation metrics visible in metrics values output."""

import json
import sys
import time

from ze_api import API


def dispatch(api, command):
    """Call dispatch-command and return result dict."""
    try:
        resp = api._call_engine(
            'ze-plugin-engine:dispatch-command', {'command': command})
        return resp.get('result', {})
    except RuntimeError as e:
        print(f'WARN: dispatch({command!r}) failed: {e}', file=sys.stderr)
        return {'status': 'error', 'message': str(e)}


def main():
    api = API()
    api.declare_done()
    api.wait_for_config()
    api.capability_done()
    api.wait_for_registry()
    api.ready()

    # Wait for BGP session to establish
    time.sleep(1.0)

    failed = False

    # Test: metrics values should contain deep instrumentation metrics
    r = dispatch(api, 'metrics values')
    status = r.get('status')
    if status != 'done':
        print(f'FAIL: expected status=done, got={status}', file=sys.stderr)
        failed = True
    else:
        data_str = r.get('data', '{}')
        try:
            data = json.loads(data_str) if isinstance(data_str, str) else data_str
        except (json.JSONDecodeError, TypeError) as e:
            print(f'WARN: JSON parse failed: {e}, raw={data_str!r}', file=sys.stderr)
            data = {}

        metrics_text = data.get('metrics', '')
        if not metrics_text:
            print(f'FAIL: empty metrics text, data={data}', file=sys.stderr)
            failed = True
        else:
            # Scalar gauges and counters: always registered, present with default values.
            # Vec metrics with peer labels only appear after a session produces them.
            required = [
                # Session lifecycle (Phase 1) - Vec metrics appear after session up
                'ze_peer_sessions_established_total',
                'ze_peer_state_transitions_total',
                # Forward pool (Phase 2)
                'ze_bgp_pool_used_ratio',
                # Config (Phase 4)
                'ze_config_reloads_total',
                'ze_peers_added_total',
                'ze_peers_removed_total',
                # Wire layer (Phase 5) - Vec metrics appear after session I/O
                'ze_wire_bytes_received_total',
                'ze_wire_bytes_sent_total',
                # Pre-existing
                'ze_uptime_seconds',
                'ze_peers_configured',
            ]
            missing = []
            for name in required:
                if name not in metrics_text:
                    missing.append(name)

            if missing:
                print(f'FAIL: missing metrics: {missing}', file=sys.stderr)
                print(f'Got metrics text ({len(metrics_text)} bytes):', file=sys.stderr)
                for line in metrics_text.split('\n'):
                    if 'ze_' in line and not line.startswith('#'):
                        print(f'  {line}', file=sys.stderr)
                failed = True
            else:
                print(f'OK: deep instrumentation metrics present in {len(metrics_text)} bytes', file=sys.stderr)

    # Always shutdown daemon
    dispatch(api, 'daemon shutdown')
    api.wait_for_shutdown()

    if failed:
        sys.exit(1)


if __name__ == '__main__':
    main()
EOF_RUN

# ze bgp configuration with telemetry enabled
stdin=ze-bgp:terminator=EOF_CONF
plugin {
	external metrics-show-deep-test {
		run ./metrics-show-deep-test.run
		encoder json
	}
}

telemetry {
	prometheus {
		enabled true
		server main {
			ip 127.0.0.1;
			port $PORT2;
		}
	}
}

bgp {
	peer peer1 {
		connection {
			remote {
				ip 127.0.0.1
			}
			local {
				ip 127.0.0.1
				accept false
			}
		}
		session {
			asn {
				local 1
				remote 1
			}
			router-id 1.2.3.4
			family {
				ipv4/unicast { prefix { maximum 10000; } }
			}
			capability {
				graceful-restart disable
			}
		}
		behavior {
			group-updates disable
		}

		process metrics-show-deep-test {
		}
	}
}
EOF_CONF

# Process orchestration
cmd=background:seq=1:exec=ze-peer --port $PORT:stdin=peer
cmd=foreground:seq=2:exec=ze -:stdin=ze-bgp:timeout=15s
expect=exit:code=0
