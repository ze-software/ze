# Test: RIB show pipeline dispatch wiring
#
# Flow:
# 1. BGP session establishes, rib plugin sends EOR
# 2. Python test plugin dispatches rib show commands with pipeline args
# 3. Verifies community, path, family filters reach rib pipeline correctly
# 4. Verifies unknown pipeline keyword returns error status
# 5. Shuts down daemon via dispatch-command
#
# VALIDATES: Pipeline parameters are dispatched through the full command chain
#   (dispatch-command → tokenizer → longest-match → execute-command → parsePipelineArgs).
# PREVENTS: Pipeline args silently dropped or command routing broken.

# ze-peer expectations
stdin=peer:terminator=EOF_PEER
option=tcp_connections:value=1
option=timeout:value=15s

# ze sends EOR after session setup (no static routes configured)
expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF00170200000000
EOF_PEER

# Python test plugin: exercises dispatch-command with filter args
tmpfs=rib-filter-test.run:mode=755:terminator=EOF_RUN
#!/usr/bin/env python3
"""
Test: RIB show pipeline dispatch wiring

Verifies dispatch-command with pipeline filter args (community, path, family)
reaches the rib plugin pipeline handler and returns valid responses.
Empty RIB is expected — the test proves wiring, not filtering logic
(unit tests cover filtering).
"""

import sys
import time

from ze_api import API


def dispatch(api, command):
    """Call dispatch-command and return result dict."""
    resp = api._call_engine(
        'ze-plugin-engine:dispatch-command', {'command': command})
    return resp.get('result', {})


def check(label, result, expected_status, expect_error=False):
    """Assert result status matches expected, exit on failure."""
    actual = result.get('status')
    if actual != expected_status:
        sys.exit(1)
    if expect_error:
        data = result.get('data', '')
        if '"error"' not in data:
            sys.exit(1)


def main():
    api = API()
    api.declare_done()
    api.wait_for_config()
    api.capability_done()
    api.wait_for_registry()
    api.ready()

    # Wait for BGP session to establish and rib plugin to be ready
    time.sleep(2.0)

    # Community filter on empty RIB via pipeline — done (not error)
    check('community', dispatch(api, 'rib show received community 65000:100'), 'done')

    # Path filter on empty RIB — done (not error)
    check('path', dispatch(api, 'rib show received path 64501'), 'done')

    # Count terminal on empty RIB — done
    check('count', dispatch(api, 'rib show count'), 'done')

    # Combined family + community filter — done
    check('family+community', dispatch(api, 'rib show received family ipv4/unicast community 65000:100'), 'done')

    # Unknown pipeline keyword — status is done but data contains error JSON
    check('unknown-keyword', dispatch(api, 'rib show bogus'), 'done', expect_error=True)

    # All passed — shutdown daemon
    dispatch(api, 'daemon shutdown')
    api.wait_for_shutdown()


if __name__ == '__main__':
    main()
EOF_RUN

# ze bgp configuration
stdin=ze-bgp:terminator=EOF_CONF
plugin {
	external filter-test {
		run ./rib-filter-test.run
		encoder json
	}
	external rib {
		run "ze plugin bgp-rib"
		encoder json
	}
}

environment {
	tcp {
		attempts 3
	}
}

bgp {
	peer peer1 {
		remote {
			ip 127.0.0.1
			as 1
		}
		local {
			as 1
			ip 127.0.0.1
		}
		router-id 1.2.3.4
		connection active
		group-updates disable

		family {
			ipv4/unicast
		}
		capability {
			graceful-restart disable
		}
		process filter-test {
		}
		process rib {
			receive [ state ]
			send [ update ]
		}
	}
}
EOF_CONF

# Process orchestration
cmd=background:seq=1:exec=ze-peer --port $PORT:stdin=peer
cmd=foreground:seq=2:exec=ze -:stdin=ze-bgp:timeout=20s
expect=exit:code=0
