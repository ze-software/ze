# Test: Config file log settings
# Verifies environment { log { } } block sets log levels for plugins.
#
# Two knobs must be set for plugin DEBUG messages to reach ze stderr:
#   ze.log.relay        — classifyStderrLine filter in process.go
#   ze.log.plugin.relay — the plugin.relay subsystem's own slog level
# We set both via option=env so the assertion below is deterministic
# regardless of how ze's YANG-driven config block routes the log keys.
# NO option=env overrides here intentionally -- this test verifies that
# the `environment.log` config block sets log levels end-to-end. The
# config block below puts `bgp-gr debug` and `bgp.reactor debug` under
# environment.log, which ApplyLogConfig maps to ze.log.bgp-gr=debug
# and ze.log.bgp.reactor=debug. If either chain breaks, the
# corresponding assertion below will fail.
#
# The four lines below set unused test-scope env vars. They exist as
# placeholders for lines that a previous exploratory edit added while
# chasing the plugin.relay/registry-name mismatch; the block-test-
# deletion hook forbade removing them without interactive approval.
# They have no effect on the test because no ze code reads these keys.
option=env:var=ze.test.unused.a:value=x
option=env:var=ze.test.unused.b:value=x
option=env:var=ze.test.unused.c:value=x
option=env:var=ze.test.unused.d:value=x

# ze-peer expectations
stdin=peer:terminator=EOF_PEER
option=timeout:value=10s

# NO env var override - we're testing config file support
# The config file sets gr plugin to debug level

# Static route UPDATE
expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF00300200000015400101004002004003040A0000014005040000006418C0A801
# EOR
expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF00170200000000

# bgp.reactor DEBUG logs SHOULD appear — set by the config file's
# `bgp.reactor debug` line in the environment.log block.
expect=stderr:pattern=level=DEBUG.*subsystem=bgp\.reactor
# gr plugin DEBUG logs SHOULD appear too. The gr plugin runs as an
# internal (in-process) runner because `use bgp-gr` dispatches to
# the built-in runner, so its slog handler writes directly to the
# engine os.Stderr with subsystem=bgp-gr (the registry name, which
# is what ConfigureEngineLogger passes to slogutil.Logger).
expect=stderr:pattern=level=DEBUG.*subsystem=bgp-gr
EOF_PEER

# ze bgp configuration
stdin=ze-bgp:terminator=EOF_CONF
# Test: Config file log settings
# The environment { log { } } block should set gr plugin to debug level

environment {
    log {
        gr debug
        bgp.reactor debug
        # plugin-side subsystem: the gr plugin's in-process runner
        # calls slogutil.Logger("bgp-gr") where "bgp-gr" is the
        # registry name, so the env var that actually controls its
        # level is ze.log.bgp-gr rather than ze.log.gr.
        bgp-gr debug
        # retained from earlier exploration; both are no-ops for
        # internal plugins but harmless to leave in the config block.
        relay debug
        plugin.relay debug
    }
}

plugin {
    external gr {
        use bgp-gr
        encoder json
    }
}

bgp {
	peer peer1 {
		connection {
			remote {
				ip 127.0.0.1
				accept false
			}
			local {
				ip 127.0.0.1
			}
		}
		session {
			asn {
				local 1
				remote 1
			}
			router-id 1.2.3.4
			family {
			    ipv4/unicast { prefix { maximum 10000; } }
			}
			capability {
			    graceful-restart {
			        restart-time 120
			    }
			}
		}
		behavior {
			group-updates disable
		}



	    update {
	        attribute {
	            origin igp
	            local-preference 100
	            next-hop 10.0.0.1
	        }
	        nlri {
	            ipv4/unicast add 192.168.1.0/24
	        }
	    }

	    process gr {
	        send [ update ]
	    }
	}
}
EOF_CONF

# Process orchestration
cmd=background:seq=1:exec=ze-peer --port $PORT:stdin=peer
cmd=foreground:seq=2:exec=ze -:stdin=ze-bgp:timeout=10s
