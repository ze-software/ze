# Test: Config file log settings
#
# Verifies `environment.log { ... }` sets per-subsystem log levels.
# Two paths are exercised end-to-end:
#   1. Engine-side: `bgp.reactor debug` -> ze.log.bgp.reactor=debug
#      -> bgp.reactor.* loggers emit DEBUG messages in ze stderr.
#   2. Plugin-side (in-process runner): `bgp.gr debug`
#      -> ze.log.bgp.gr=debug -> gr plugin's engine logger emits
#      DEBUG messages in ze stderr tagged subsystem=bgp.gr.
#
# The plugin-side path is made possible by inprocess.go transforming
# the plugin registry name ("bgp-gr", hyphen) to the canonical
# dot-separated subsystem name ("bgp.gr") before calling the
# plugin's ConfigureEngineLogger callback. Without that transform,
# the plugin would register under `subsystem=bgp-gr` and the
# config-file key would have to be the unintuitive `bgp-gr debug`.

# ze-peer expectations
stdin=peer:terminator=EOF_PEER
option=timeout:value=10s

# Static route UPDATE
expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF00300200000015400101004002004003040A0000014005040000006418C0A801
# EOR
expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF00170200000000

# Engine-side subsystem: config sets bgp.reactor debug, so
# bgp.reactor.* DEBUG messages appear in ze stderr.
expect=stderr:pattern=level=DEBUG.*subsystem=bgp\.reactor
# Plugin-side subsystem: config sets bgp.gr debug, so the gr
# plugin's engine logger fires DEBUG messages tagged subsystem=bgp.gr.
expect=stderr:pattern=level=DEBUG.*subsystem=bgp\.gr
EOF_PEER

# ze bgp configuration
stdin=ze-bgp:terminator=EOF_CONF
environment {
    log {
        bgp.reactor debug
        bgp.gr debug
    }
}

plugin {
    external gr {
        use bgp-gr
        encoder json
    }
}

bgp {
	peer peer1 {
		connection {
			remote {
				ip 127.0.0.1
			}
			local {
				ip 127.0.0.1
				accept false
			}
		}
		session {
			asn {
				local 1
				remote 1
			}
			router-id 1.2.3.4
			family {
			    ipv4/unicast { prefix { maximum 10000; } }
			}
			capability {
			    graceful-restart {
			        restart-time 120
			    }
			}
		}
		behavior {
			group-updates disable
		}

	    update {
	        attribute {
	            origin igp
	            local-preference 100
	            next-hop 10.0.0.1
	        }
	        nlri {
	            ipv4/unicast add 192.168.1.0/24
	        }
	    }

	    process gr {
	        send [ update ]
	    }
	}
}
EOF_CONF

# Process orchestration
cmd=background:seq=1:exec=ze-peer --port $PORT:stdin=peer
cmd=foreground:seq=2:exec=ze -:stdin=ze-bgp:timeout=10s
