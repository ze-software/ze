# Test: Config file log settings
# Verifies environment { log { } } block sets log levels for plugins

# ze-peer expectations
stdin=peer:terminator=EOF_PEER
option=timeout:value=10s

# NO env var override - we're testing config file support
# The config file sets gr plugin to debug level

# Static route UPDATE
expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF00300200000015400101004002004003040A0000014005040000006418C0A801
# EOR
expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF00170200000000

# GR plugin DEBUG logs SHOULD appear (set via config file)
expect=stderr:pattern=level=DEBUG.*subsystem=gr
EOF_PEER

# ze bgp configuration
stdin=ze-bgp:terminator=EOF_CONF
# Test: Config file log settings
# The environment { log { } } block should set gr plugin to debug level

environment {
    log {
        gr debug;
        bgp.reactor debug;
    }
}

plugin {
    external gr {
        run "ze plugin bgp-gr";
        encoder json;
    }
}

bgp {
	peer 127.0.0.1 {
	    router-id 1.2.3.4;
	    local-address 127.0.0.1;
	    local-as 1;
	    peer-as 1;
	    connection active;
	    group-updates disable;

	    family {
	        ipv4/unicast;
	    }

	    capability {
	        graceful-restart {
	            restart-time 120;
	        }
	    }

	    update {
	        attribute {
	            origin igp;
	            local-preference 100;
	            next-hop 10.0.0.1;
	        }
	        nlri {
	            ipv4/unicast add 192.168.1.0/24;
	        }
	    }

	    process gr {
	        send { update; }
	    }
	}
}
EOF_CONF

# Process orchestration
cmd=background:seq=1:exec=ze-peer --port $PORT:stdin=peer
cmd=foreground:seq=2:exec=ze -:stdin=ze-bgp:timeout=10s
