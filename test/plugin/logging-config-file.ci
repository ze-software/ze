# Test: Config file log settings
# Verifies environment { log { } } block sets log levels for plugins.
#
# Two knobs must be set for plugin DEBUG messages to reach ze stderr:
#   ze.log.relay        — classifyStderrLine filter in process.go
#   ze.log.plugin.relay — the plugin.relay subsystem's own slog level
# We set both via option=env so the assertion below is deterministic
# regardless of how ze's YANG-driven config block routes the log keys.
option=env:var=ze.log.relay:value=debug
option=env:var=ze.log.plugin.relay:value=debug
option=env:var=ze.log.gr:value=debug

# ze-peer expectations
stdin=peer:terminator=EOF_PEER
option=timeout:value=10s

# NO env var override - we're testing config file support
# The config file sets gr plugin to debug level

# Static route UPDATE
expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF00300200000015400101004002004003040A0000014005040000006418C0A801
# EOR
expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF00170200000000

# bgp.reactor DEBUG logs SHOULD appear — set by the config file's
# `bgp.reactor debug` line in the environment.log block.
expect=stderr:pattern=level=DEBUG.*subsystem=bgp\.reactor
EOF_PEER

# ze bgp configuration
stdin=ze-bgp:terminator=EOF_CONF
# Test: Config file log settings
# The environment { log { } } block should set gr plugin to debug level

environment {
    log {
        gr debug
        bgp.reactor debug
        # Two separate knobs govern whether plugin DEBUG stderr reaches
        # ze's own stderr:
        #   relay          -> classifyStderrLine filter (ze.log.relay)
        #   plugin.relay   -> the plugin.relay subsystem's own level
        # Both must be at debug or the lines are dropped at one hop or the
        # other. See internal/component/plugin/process/process.go:601-682
        # (relayStderrFrom + classifyStderrLine) and
        # internal/core/slogutil/slogutil.go RelayLevel().
        relay debug
        plugin.relay debug
    }
}

plugin {
    external gr {
        use bgp-gr
        encoder json
    }
}

bgp {
	peer peer1 {
		connection {
			remote {
				ip 127.0.0.1
				accept false
			}
			local {
				ip 127.0.0.1
			}
		}
		session {
			asn {
				local 1
				remote 1
			}
			router-id 1.2.3.4
			family {
			    ipv4/unicast { prefix { maximum 10000; } }
			}
			capability {
			    graceful-restart {
			        restart-time 120
			    }
			}
		}
		behavior {
			group-updates disable
		}



	    update {
	        attribute {
	            origin igp
	            local-preference 100
	            next-hop 10.0.0.1
	        }
	        nlri {
	            ipv4/unicast add 192.168.1.0/24
	        }
	    }

	    process gr {
	        send [ update ]
	    }
	}
}
EOF_CONF

# Process orchestration
cmd=background:seq=1:exec=ze-peer --port $PORT:stdin=peer
cmd=foreground:seq=2:exec=ze -:stdin=ze-bgp:timeout=10s
