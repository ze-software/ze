# Test: bgp peer capabilities shows negotiated capabilities
# VALIDATES: capabilities returns negotiated data with families for the peer
# PREVENTS: capabilities returning empty or flat-format mismatch

# ze-peer expectations
stdin=peer:terminator=EOF_PEER
option=tcp_connections:value=1
option=timeout:value=15s
expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF00170200000000
EOF_PEER

# Python test plugin: exercises dispatch-command for peer capabilities
tmpfs=peer-caps-test.run:mode=755:terminator=EOF_RUN
#!/usr/bin/env python3
import json
import sys
import time
from ze_api import API

def dispatch(api, command):
    resp = api._call_engine(
        'ze-plugin-engine:dispatch-command', {'command': command})
    if resp is None:
        return {'status': 'error', 'data': 'engine call returned None'}
    return resp.get('result', {})

def main():
    api = API()
    api.declare_done()
    api.wait_for_config()
    api.capability_done()
    api.wait_for_registry()
    api.ready()
    time.sleep(1.0)

    try:
        result = dispatch(api, 'peer 127.0.0.1 capabilities')
        if result.get('status') != 'done':
            print(f'FAIL: capabilities status={result.get("status")}', file=sys.stderr)
            sys.exit(1)

        data = result.get('data', {})
        if isinstance(data, str):
            data = json.loads(data)

        # Single peer returns flat object with "peer" key
        if data.get('peer') != '127.0.0.1':
            print(f'FAIL: expected peer=127.0.0.1, got {data.get("peer")}', file=sys.stderr)
            sys.exit(1)

        negotiated = data.get('negotiated', {})
        if not isinstance(negotiated, dict) or len(negotiated) == 0:
            print(f'FAIL: empty negotiated capabilities', file=sys.stderr)
            sys.exit(1)

        print(f'OK: capabilities has {len(negotiated)} entries for 127.0.0.1', file=sys.stderr)
    finally:
        dispatch(api, 'daemon shutdown')
        api.wait_for_shutdown()

if __name__ == '__main__':
    main()
EOF_RUN

# ze bgp configuration
stdin=ze-bgp:terminator=EOF_CONF
plugin {
	external peer-caps-test {
		run ./peer-caps-test.run
		encoder json
	}
}

environment {
	tcp {
		attempts 3
	}
}

bgp {
	peer 127.0.0.1 {
		router-id 1.2.3.4
		local-address 127.0.0.1
		local-as 1
		peer-as 1
		connection active
		group-updates disable

		family {
			ipv4/unicast
		}
		capability {
			graceful-restart disable
		}
		process peer-caps-test {
		}
	}
}
EOF_CONF

# Process orchestration
cmd=background:seq=1:exec=ze-peer --port $PORT:stdin=peer
cmd=foreground:seq=2:exec=ze -:stdin=ze-bgp:timeout=15s
expect=exit:code=0
