# Test: peer raw sends raw bytes to peer
# VALIDATES: raw command sends exact KEEPALIVE bytes verified at wire level
# PREVENTS: raw command handler broken or bytes not reaching peer

# ze-peer expectations
stdin=peer:terminator=EOF_PEER
option=tcp_connections:value=1
option=timeout:value=15s
# EOR
expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF00170200000000
# KEEPALIVE: marker(16) + length(0013=19) + type(04)
expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF001304
EOF_PEER

# Python test plugin: exercises dispatch-command for peer raw
tmpfs=raw-test.run:mode=755:terminator=EOF_RUN
#!/usr/bin/env python3
import sys
import time
from ze_api import API

def dispatch(api, command):
    resp = api._call_engine(
        'ze-plugin-engine:dispatch-command', {'command': command})
    if resp is None:
        return {'status': 'error', 'data': 'engine call returned None'}
    return resp.get('result', {})

def main():
    api = API()
    api.declare_done()
    api.wait_for_config()
    api.capability_done()
    api.wait_for_registry()
    api.ready()
    time.sleep(1.0)

    try:
        # Send a KEEPALIVE via raw (full packet mode: marker + length + type)
        result = dispatch(api, 'peer peer1 raw hex FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF001304')
        if result.get('status') != 'done':
            print(f'FAIL: raw status={result.get("status")} data={result.get("data")}', file=sys.stderr)
            sys.exit(1)
        print('OK: raw keepalive sent', file=sys.stderr)
        time.sleep(1.0)
    finally:
        dispatch(api, 'daemon shutdown')
        api.wait_for_shutdown()

if __name__ == '__main__':
    main()
EOF_RUN

# ze bgp configuration
stdin=ze-bgp:terminator=EOF_CONF
plugin {
	external raw-test {
		run ./raw-test.run
		encoder json
	}
}

bgp {
	peer peer1 {
		connection {
			remote {
				ip 127.0.0.1
			}
			local {
				ip 127.0.0.1
				accept false
			}
		}
		session {
			asn {
				local 1
				remote 1
			}
			router-id 1.2.3.4
			family {
				ipv4/unicast { prefix { maximum 10000; } }
			}
			capability {
				graceful-restart disable
			}
		}
		behavior {
			group-updates disable
		}

		process raw-test {
		}
	}
}
EOF_CONF

# Process orchestration
cmd=background:seq=1:exec=ze-peer --port $PORT:stdin=peer
cmd=foreground:seq=2:exec=ze -:stdin=ze-bgp:timeout=15s
expect=exit:code=0
