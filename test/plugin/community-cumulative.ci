# Test: Community filter cumulative tag accumulation
# VALIDATES: AC-8 -- tag lists accumulate across bgp/group/peer levels via ze:cumulative
# STATUS: Phase 4 (spec-ci-observer-per-test-audit) -- runtime_fail wired;
#         AC-8 verified via the `community ingress applied` production log
#         with tag list asserted to include BOTH global-mark and peer-mark.
# PREVENTS: Most-specific level replacing less-specific tag list
#
# Flow:
# 1. Config has BGP-level tag + peer-level tag (both should apply)
# 2. ze-peer sends UPDATE without communities
# 3. Community filter adds BOTH communities on ingress
# 4. Production log asserts tag=[global-mark peer-mark] -- both accumulated

# Source peer (ASN 65001) on 127.0.0.1
option=env:var=ze.log.bgp.filter.community:value=info
option=env:var=ze.log.bgp.reactor.session:value=debug
stdin=peer:terminator=EOF_PEER
option=tcp_connections:value=1
option=timeout:value=15s
# Send UPDATE: ORIGIN=IGP, AS_PATH=[65001], NEXT_HOP=1.1.1.1, NLRI=10.0.0.0/24
action=send:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF002F02000000144001010040020602010000FDE940030401010101180A0000
EOF_PEER

# Python test plugin: verify both communities present
tmpfs=test-cumulative.run:mode=755:terminator=EOF_RUN
#!/usr/bin/env python3
"""Verify cumulative community tagging: both BGP-level and peer-level tags applied."""
import json
import sys
import time
from ze_api import API, runtime_fail

def dispatch(api, command):
    resp = api._call_engine('ze-plugin-engine:dispatch-command', {'command': command})
    return resp.get('result', {})

def main():
    api = API()
    api.declare_done()
    api.wait_for_config()
    api.capability_done()
    api.wait_for_registry()
    api.ready()

    time.sleep(3.0)

    # Verify route accepted.
    result = dispatch(api, 'adj-rib-in status')
    data = json.loads(result.get('data', '{}'))
    total = data.get('total-routes', -1)

    if total < 0:  # rpki validation gate may hold route; count is unreliable
        msg = f'adj-rib-in query failed, got total={total}'
        print(f'FAIL: {msg}', file=sys.stderr)
        sys.stderr.flush()
        runtime_fail(msg)

    # Verify RPC path works for both communities; the actual tag list is
    # asserted via the production log at the bottom of this file.
    for community in ['65000:1', '65000:2']:
        result = dispatch(api, f'bgp rib show received community {community}')
        if result.get('status') not in ('done', 'error'):
            msg = f'rib show community {community} rpc failed: {result.get("status")}'
            print(f'FAIL: {msg}', file=sys.stderr)
            sys.stderr.flush()
            runtime_fail(msg)

    print('OK: both cumulative communities tagged on ingress', file=sys.stderr)
    dispatch(api, 'daemon shutdown')
    api.wait_for_shutdown()

if __name__ == '__main__':
    main()
EOF_RUN

# ze configuration: BGP-level tag + peer-level tag (cumulative)
stdin=ze-bgp:terminator=EOF_CONF
plugin {
	external test-cumulative {
		run ./test-cumulative.run
		encoder json
	}
	external bgp-rib {
		use bgp-rib
		encoder json
	}
}
bgp {
	community {
		standard global-mark {
			value 65000:1
		}
		standard peer-mark {
			value 65000:2
		}
	}

	# BGP-level tag (applies to all peers)
	filter {
		ingress {
			community {
				tag global-mark
			}
		}
	}

	peer peer1 {
		connection {
			remote {
				ip 127.0.0.1
				accept false
			}
			local {
				ip 127.0.0.1
			}
		}
		session {
			asn {
				local 65000
				remote 65001
			}
			router-id 1.2.3.4
			family {
				ipv4/unicast { prefix { maximum 10000; } }
			}
			capability {
				graceful-restart disable
			}
		}
		behavior {
			group-updates disable
		}

		# Peer-level tag (accumulates with BGP-level)
		filter {
			ingress {
				community {
					tag peer-mark
				}
			}
		}
		process test-cumulative {
			receive [ update state ]
		}
		process bgp-rib {
			receive [ state ]
			send [ update ]
		}
	}
}
EOF_CONF

# Process orchestration
cmd=background:seq=1:exec=ze-peer --port $PORT:stdin=peer
cmd=foreground:seq=2:exec=ze --plugin ze.bgp-filter-community --plugin ze.bgp-adj-rib-in -:stdin=ze-bgp:timeout=15s
expect=exit:code=0
# AC-8 verification: the cumulative merge of BGP-level `global-mark` and
# peer-level `peer-mark` must produce a two-element tag list. The
# production log shows `tag=[global-mark peer-mark]` in cumulative order.
# A bug where peer-level replaces bgp-level would emit `tag=[peer-mark]`
# and break the assertion.
expect=stderr:pattern=community ingress applied
expect=stderr:pattern=peer=peer1
expect=stderr:pattern=tag="\[global-mark peer-mark\]"
# Negative regressions:
reject=stderr:pattern=panic recovered
reject=stderr:pattern=fatal error
reject=stderr:pattern=treat-as-withdraw
reject=stderr:pattern=ZE-OBSERVER-FAIL
