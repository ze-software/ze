# Test: unassigned user is denied when other user assignments exist (fail closed)
#
# Flow:
# 1. Daemon starts with SSH + authz config (profiles exist but user not assigned)
# 2. Shell script connects via SSH as unknown user (no profile assignment)
# 3. Unknown user has no profile assignment + other users exist -> fail closed -> deny
#
# VALIDATES: P1-2 -- unassigned users are denied when assignments are configured.
# PREVENTS: Unassigned users silently becoming admin-equivalent.

# Test script: unassigned user gets denied
tmpfs=test-authz-default.sh:mode=755:terminator=EOF_SH
#!/bin/sh
set -e

# Signal test runner readiness
touch daemon.ready

# Generate config with SSH on port 0 (OS-assigned)
cat > authz-default.conf << 'ZECONF'
bgp {
	peer peer1 {
		connection {
			remote {
				ip 127.0.0.1
			}
			local {
				ip 127.0.0.1
				accept false
			}
		}
		session {
			asn {
				local 65533
				remote 65533
			}
		}
	}
}

system {
	authentication {
		user operator {
			password "$2a$04$MdupNBXL8iUHgRUDfsFl0ue/.FEH3db8U.LPd/XtMhiBmd4MoRM0m"
			profile [ restricted ]
		}
		user unknown {
			password "$2a$04$UlwuiuH82Unfsq.XEMPGJeDkXwbm3KW.nvVaVXOd/JeFK8VjMjrQO"
		}
	}
	authorization {
		profile restricted {
			run {
				default-action deny
				entry 10 {
					action allow
					match "peer list"
				}
			}
			edit {
				default-action deny
			}
		}
	}
}

environment {
	ssh {
		enabled true
		server main {
			ip 127.0.0.1;
			port 0;
		}
	}
}
ZECONF

# Use a PID-derived high port for BGP to avoid needing root for port 179
export ze_test_bgp_port=$((10000 + ($$ % 50000)))

# Start daemon, capture stderr to parse SSH port
ze authz-default.conf 2>daemon.log &
DAEMON_PID=$!
trap 'kill $DAEMON_PID 2>/dev/null; wait $DAEMON_PID 2>/dev/null' EXIT

# Wait for SSH server to report its listening address
SSH_PORT=""
for i in $(seq 1 50); do
	SSH_PORT=$(grep -o '127\.0\.0\.1:[0-9]*' daemon.log 2>/dev/null | head -1 | cut -d: -f2 || true)
	if [ -n "$SSH_PORT" ]; then
		break
	fi
	sleep 0.2
done

if [ -z "$SSH_PORT" ]; then
	echo "FAIL: SSH server did not start (no address in daemon.log)" >&2
	cat daemon.log >&2
	exit 1
fi
echo "SSH port: $SSH_PORT" >&2

# Brief delay for postStartFunc to wire authorizer
sleep 0.5

# Set up unknown user credentials (has auth entry but no profile assignment)
UNK_DIR=$(mktemp -d)
trap 'rm -rf "$UNK_DIR"; kill $DAEMON_PID 2>/dev/null; wait $DAEMON_PID 2>/dev/null' EXIT
printf 'unknown\ntestpass\n127.0.0.1\n%s\n' "$SSH_PORT" | ZE_CONFIG_DIR="$UNK_DIR" ze init >/dev/null

# Test 1: unknown user (no profile assignment) is DENIED when other assignments exist
# Store.Authorize returns Deny for unassigned users when assignments are configured (fail closed)
OUTPUT=$(ZE_CONFIG_DIR="$UNK_DIR" ZE_SSH_PASSWORD="testpass" ze cli -c "peer list" 2>&1) && {
	echo "FAIL: unknown user should be denied (fail closed) but was allowed" >&2
	echo "OUTPUT: $OUTPUT" >&2
	exit 1
}
echo "OK: unknown user denied peer list (fail closed)" >&2

# Test 2: unknown user also denied on other commands
OUTPUT=$(ZE_CONFIG_DIR="$UNK_DIR" ZE_SSH_PASSWORD="testpass" ze cli -c "peer detail" 2>&1) && {
	echo "FAIL: unknown user should be denied but was allowed" >&2
	echo "OUTPUT: $OUTPUT" >&2
	exit 1
}
echo "OK: unknown user denied peer detail (fail closed)" >&2

echo "OK: all fail-closed authz tests passed" >&2
exit 0
EOF_SH

# Process orchestration
cmd=foreground:seq=1:exec=./test-authz-default.sh:timeout=15s
expect=exit:code=0
