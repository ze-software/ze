# Test: BFD plugin wires Prometheus metrics into the telemetry server.
#
# VALIDATES: spec-bfd-4 AC-6 -- ze_bfd_sessions gauge is populated
#            from Snapshot after a scrape. The telemetry HTTP server
#            is enabled, the plugin calls bindMetricsRegistry at
#            startup, and an external scraper sees the ze_bfd_sessions
#            metric family.
# PREVENTS:  regression where the metrics pointer is not wired or the
#            gauge refresh is never called.

option=env:var=ze.bfd.test-parallel:value=true
stdin=peer:terminator=EOF_PEER
option=tcp_connections:value=1
option=timeout:value=15s
expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF00170200000000
EOF_PEER

tmpfs=bfd-metrics.run:mode=755:terminator=EOF_RUN
#!/usr/bin/env python3
"""Scrape the telemetry endpoint and assert ze_bfd_sessions appears."""

import time
import urllib.request

from ze_api import API, runtime_fail


def dispatch(api, command):
    resp = api._call_engine(
        'ze-plugin-engine:dispatch-command', {'command': command})
    if resp is None:
        return {'status': 'error', 'data': 'engine call returned None'}
    return resp.get('result', {})


def main():
    api = API()
    api.declare_done()
    api.wait_for_config()
    api.capability_done()
    api.wait_for_registry()
    api.ready()
    time.sleep(0.5)

    # Trigger Snapshot so refreshSessionsGauge runs and sets the gauge
    # for at least one (state, mode, vrf) bucket.
    r = dispatch(api, 'show bfd sessions')
    if r.get('status') != 'done':
        runtime_fail(f'priming: status={r.get("status")}')

    # Scrape the metrics endpoint. Retry briefly to absorb any late
    # registry rebinding done by the plugin's OnStarted hook.
    body = ''
    last = None
    for _ in range(20):
        try:
            with urllib.request.urlopen('http://127.0.0.1:19273/metrics', timeout=1.0) as resp:
                body = resp.read().decode('utf-8', 'replace')
                if 'ze_bfd_sessions' in body:
                    break
        except (OSError, ValueError) as exc:
            last = exc
        time.sleep(0.25)
    if body == '':
        runtime_fail(f'scrape: {last}')

    # ze_bfd_sessions is the only metric guaranteed to have a sample
    # without any state transitions; refreshSessionsGauge sets it
    # from Snapshot on every dispatch. Counters like
    # ze_bfd_transitions_total only appear once at least one sample
    # has been recorded, so we do not assert on them here.
    if 'ze_bfd_sessions' not in body:
        runtime_fail('missing ze_bfd_sessions in scrape body')

    dispatch(api, 'daemon shutdown')
    api.wait_for_shutdown()


if __name__ == '__main__':
    main()
EOF_RUN

stdin=ze-bfd:terminator=EOF_CONF
plugin {
	external bfd-metrics-test {
		run ./bfd-metrics.run
		encoder json
	}
}

environment {
	log {
		bfd debug
	}
}

telemetry {
	prometheus {
		enabled true
		server primary {
			ip 127.0.0.1
			port 19273
		}
	}
}

bfd {
	enabled true;
	profile fast {
		detect-multiplier 3
		desired-min-tx-us 50000
		required-min-rx-us 50000
	}
	single-hop-session 203.0.113.9 {
		profile fast
	}
}

bgp {
	peer peer1 {
		connection {
			remote {
				ip 127.0.0.1
				accept false
			}
			local {
				ip 127.0.0.1
			}
		}
		session {
			asn {
				local 1
				remote 1
			}
			router-id 1.2.3.4
			family {
				ipv4/unicast { prefix { maximum 10000; } }
			}
			capability {
				graceful-restart disable
			}
		}
		behavior {
			group-updates disable
		}
		process bfd-metrics-test {
		}
	}
}
EOF_CONF

cmd=background:seq=1:exec=ze-peer --port $PORT:stdin=peer
cmd=foreground:seq=2:exec=ze -:stdin=ze-bfd:timeout=15s
expect=exit:code=0
