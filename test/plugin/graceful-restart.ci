# Migrated from test/data/plugin/graceful-restart.*

# ze-peer expectations
stdin=peer:terminator=EOF_PEER
option=tcp_connections:value=2
option=timeout:value=15s

# Test: Route preservation across restart (GR-like behavior)
#
# This test verifies that routes are preserved when a peer disconnects
# and reconnects. The RIB plugin stores routes and replays them on reconnect.
#
# NOTE: GR capability is parsed from config but NOT yet sent in OPEN.
# This test validates the route preservation behavior that GR would use.
#
# Flow:
# 1. Connection A: Static route sent, stored in RIB
# 2. Notification -> disconnect
# 3. Connection B: RIB replays stored route + static route resent

# Connection A: Initial route announcement
# Static route UPDATE
expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF00300200000015400101004002004003040A0000014005040000006418C0A801
# EOR
expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF00170200000000
# Trigger restart with notification
action=notification:conn=1:seq=2:text=Peer Reset

# Connection B: Routes preserved and replayed
# Static route (from sendInitialRoutes)
expect=bgp:conn=2:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF00300200000015400101004002004003040A0000014005040000006418C0A801
# RIB replay (same route, no dedup)
expect=bgp:conn=2:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF00300200000015400101004002004003040A0000014005040000006418C0A801
# EOR
expect=bgp:conn=2:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF00170200000000
EOF_PEER

# ze bgp configuration
stdin=ze-bgp:terminator=EOF_CONF
plugin {
	external gr {
		run "ze bgp plugin gr";
		encoder json;
	}
	external rib {
		run "ze bgp plugin rib";
		encoder json;
	}
}


environment {
	tcp {
		attempts 3;
	}
}

bgp {
	peer 127.0.0.1 {
		router-id 1.2.3.4;
		local-address 127.0.0.1;
		local-as 1;
		peer-as 1;
		group-updates disable;
	
		family {
			ipv4/unicast;
		}
		capability {
			graceful-restart {
				restart-time 120;
			}
		}
	
		static {
			route 192.168.1.0/24 next-hop 10.0.0.1;
		}
	
		process rib {
			receive { sent; state; }
			send { update; }
		}
	}
}
EOF_CONF

# Process orchestration
cmd=background:seq=1:exec=ze-peer --port $PORT:stdin=peer
cmd=foreground:seq=2:exec=ze bgp server -:stdin=ze-bgp:timeout=20s
