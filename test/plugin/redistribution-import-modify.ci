# Test: import filter modifies attributes
# VALIDATES: AC-7 -- Import filter returns modify with changed local-pref
# PREVENTS: Modify response ignored, attributes not updated

# ze-peer sends a route to ze
stdin=peer:terminator=EOF_PEER
option=tcp_connections:value=1
option=timeout:value=15s
option=update:value=send-route:prefix=10.0.0.0/24:next-hop=10.0.0.1:origin-as=65001
expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF00170200000000
EOF_PEER

# Python test plugin: import filter that modifies local-preference
tmpfs=filter-modify-test.run:mode=755:terminator=EOF_RUN
#!/usr/bin/env python3
import sys
import time
from ze_api import API

modified_count = 0

def filter_handler(params):
    """Modify local-preference to 200."""
    global modified_count
    modified_count += 1
    print(f'filter-update MODIFY: filter={params.get("filter")} peer={params.get("peer")}', file=sys.stderr)
    return {'action': 'modify', 'update': 'local-preference 200'}

def dispatch(api, command):
    resp = api._call_engine(
        'ze-plugin-engine:dispatch-command', {'command': command})
    if resp is None:
        return {'status': 'error', 'data': 'None'}
    return resp.get('result', {})

def main():
    api = API()
    api.declare_filter(
        name='set-localpref',
        direction='import',
        attributes=['local-preference'],
        on_error='reject',
    )
    api.on_filter_update(filter_handler)
    api.declare_done()
    api.wait_for_config()
    api.capability_done()
    api.wait_for_registry()
    api.ready()

    time.sleep(2.0)

    if modified_count > 0:
        print(f'OK: filter modified {modified_count} route(s)', file=sys.stderr)
    else:
        print('INFO: filter not called', file=sys.stderr)

    dispatch(api, 'daemon shutdown')
    api.wait_for_shutdown()

if __name__ == '__main__':
    main()
EOF_RUN

# ze bgp configuration
stdin=ze-bgp:terminator=EOF_CONF
plugin {
    external filter-modify-test {
        run ./filter-modify-test.run;
        encoder json;
    }
}
bgp {
    router-id 1.2.3.4;
    local { as 65000; }
    redistribution {
        import [ filter-modify-test:set-localpref ];
    }
    peer peer1 {
        remote {
            ip 127.0.0.1;
            as 65001;
            accept false;
        }
        local {
            as 65000;
            ip auto;
        }
        process filter-modify-test {
            receive [ update state ];
        }
    }
}
EOF_CONF

cmd=foreground:seq=2:exec=ze -:stdin=ze-bgp:timeout=15s
expect=exit:code=0
