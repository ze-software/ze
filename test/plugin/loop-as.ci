# Test: AS loop detection (RFC 4271 Section 9)
# AC-2: iBGP UPDATE with local ASN in AS_PATH -> route treated as withdrawn.
#
# ze-peer sends a route with ASN 65000 (ze's local AS) in the AS_PATH.
# Ze detects the loop and silently drops the route (treat-as-withdraw).

stdin=peer:terminator=EOF_PEER
option=tcp_connections:value=1
option=timeout:value=15s
option=asn:value=65000
option=update:value=send-route:prefix=10.0.0.0/24:next-hop=10.0.0.1:as-path=65002,65000,65003
# Accept EOR from ze on session establishment.
expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF00170200000000
EOF_PEER

# ze bgp configuration: iBGP (local AS = remote AS = 65000)
stdin=ze-bgp:terminator=EOF_CONF
environment {
	log {
		level debug
	}
	tcp {
		attempts 3
	}
}

bgp {
	peer peer1 {
		connection {
			remote {
				ip 127.0.0.1
				accept false
			}
			local {
				ip 127.0.0.1
			}
		}
		session {
			asn {
				local 65000
				remote 65000
			}
			router-id 1.2.3.4
			family {
				ipv4/unicast { prefix { maximum 10000; } }
			}
		}

	}
}
EOF_CONF

# Process orchestration
cmd=background:seq=1:exec=ze-peer --port $PORT:stdin=peer
cmd=foreground:seq=2:exec=ze -:stdin=ze-bgp:timeout=10s
expect=stderr:contains=AS loop detected
