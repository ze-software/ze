# Test: community-match filter accepts routes with matching community
# VALIDATES: AC-1 -- standard community match triggers accept
# VALIDATES: AC-4 -- accept action on match
# PREVENTS: Route dropped when community-match should allow it
#
# Flow:
# 1. ze-peer sends UPDATE with COMMUNITY=65001:100, NLRI=10.0.0.0/24
# 2. Filter chain calls bgp-filter-community-match:ALLOW-CUSTOMER
# 3. community-match ALLOW-CUSTOMER has entry "65001:100" type standard action accept
# 4. Community 65001:100 found in route -> accept
# 5. Assertions on stderr confirm the decision log.

option=env:var=ze.log.bgp.filter.community.match:value=info

stdin=peer:terminator=EOF_PEER
option=tcp_connections:value=1
option=timeout:value=15s
# UPDATE: ORIGIN=IGP, AS_PATH=[65001], NEXT_HOP=1.1.1.1, COMMUNITY=65001:100, NLRI=10.0.0.0/24
action=send:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF0036020000001B4001010040020602010000FDE940030401010101C00804FDE90064180A0000
EOF_PEER

tmpfs=test-cm-accept.run:mode=755:terminator=EOF_RUN
#!/usr/bin/env python3
"""Observer for community-match accept test: clean shutdown."""
import time
from ze_api import API

def dispatch(api, command):
    resp = api._call_engine('ze-plugin-engine:dispatch-command', {'command': command})
    return resp.get('result', {})

def main():
    api = API()
    api.declare_done()
    api.wait_for_config()
    api.capability_done()
    api.wait_for_registry()
    api.ready()
    time.sleep(3.0)
    dispatch(api, 'daemon shutdown')
    api.wait_for_shutdown()

if __name__ == '__main__':
    main()
EOF_RUN

stdin=ze-bgp:terminator=EOF_CONF
plugin {
	external test-cm-accept {
		run ./test-cm-accept.run
		encoder json
	}
}
bgp {
	policy {
		community-match ALLOW-CUSTOMER {
			entry 65001:100 {
				type standard
				action accept
			}
		}
	}

	peer peer1 {
		connection {
			remote {
				ip 127.0.0.1
			}
			local {
				ip 127.0.0.1
				accept false
			}
		}
		session {
			asn {
				local 65000
				remote 65001
			}
			router-id 1.2.3.4
			family {
				ipv4/unicast { prefix { maximum 10000; } }
			}
		}

		filter {
			import [ community-match:ALLOW-CUSTOMER ]
		}

		process test-cm-accept {
			receive [ update state ]
		}
	}
}
EOF_CONF

cmd=background:seq=1:exec=ze-peer --port $PORT:stdin=peer
cmd=foreground:seq=2:exec=ze --plugin ze.bgp-filter-community-match --plugin ze.bgp-adj-rib-in -:stdin=ze-bgp:timeout=15s
expect=exit:code=0
expect=stderr:pattern=community-match accept
expect=stderr:pattern=filter=ALLOW-CUSTOMER
reject=stderr:pattern=community-match reject
