# Test: RIB best graph terminal renders AS path topology for best paths
#
# Flow:
# 1. Inject routes with AS paths via rib inject
# 2. Run "rib show best graph"
# 3. Verify output contains box-drawing characters and ASN labels
#
# VALIDATES: AC-6 "rib show best graph works with best-path pipeline"
# PREVENTS: Graph terminal only working with show, not best.

# ze-peer expectations
stdin=peer:terminator=EOF_PEER
option=tcp_connections:value=1
option=timeout:value=15s
EOF_PEER

# Python test plugin
tmpfs=rib-graph-best-test.run:mode=755:terminator=EOF_RUN
#!/usr/bin/env python3
"""Test: RIB best graph terminal."""

import sys
import time

from ze_api import API, runtime_fail


failures = 0


def dispatch(api, command):
    resp = api._call_engine(
        'ze-plugin-engine:dispatch-command', {'command': command})
    return resp.get('result', {})


def check(label, result, expected_status):
    global failures
    actual = result.get('status')
    if actual != expected_status:
        print(f'FAIL {label}: expected status={expected_status}, got={actual}', file=sys.stderr)
        failures += 1
    else:
        print(f'OK {label}: status={actual}', file=sys.stderr)


def check_contains(label, result, substring):
    global failures
    data = result.get('data', '')
    if substring not in data:
        print(f'FAIL {label}: output does not contain {substring!r}', file=sys.stderr)
        print(f'  got: {data[:200]!r}', file=sys.stderr)
        failures += 1
    else:
        print(f'OK {label}: contains {substring!r}', file=sys.stderr)


def main():
    global failures
    api = API()
    api.declare_done()
    api.wait_for_config()
    api.capability_done()
    api.wait_for_registry()
    api.ready()

    time.sleep(1.0)
    for _ in range(20):
        r = dispatch(api, 'bgp rib status')
        if r.get('status') == 'done':
            break
        time.sleep(0.5)
    else:
        print('FAIL: rib plugin did not become ready', file=sys.stderr)
        failures += 1

    # Inject a route with AS path
    r = dispatch(api, 'bgp rib inject 10.0.0.1 ipv4/unicast 10.10.1.0/24 aspath 64501,64502')
    check('inject', r, 'done')

    # rib show best graph
    r = dispatch(api, 'bgp rib show best graph')
    check('best-graph', r, 'done')

    # Output should contain ASN labels
    check_contains('best-graph-as64501', r, 'AS64501')
    check_contains('best-graph-as64502', r, 'AS64502')

    # Output should contain box-drawing
    check_contains('best-graph-box', r, '\u250c')  # ┌

    # Shutdown
    if failures > 0:
        msg = f'{failures} best-graph assertions failed (see FAIL lines above)'
        print(f'\n{msg}', file=sys.stderr)
        sys.stderr.flush()
        runtime_fail(msg)
    dispatch(api, 'daemon shutdown')
    api.wait_for_shutdown()


if __name__ == '__main__':
    main()
EOF_RUN

# ze bgp configuration
stdin=ze-bgp:terminator=EOF_CONF
plugin {
	external graph-best-test {
		run ./rib-graph-best-test.run
		encoder json
	}
	external bgp-rib {
		use bgp-rib
		encoder json
	}
}

environment {
	tcp {
		attempts 3
	}
}

bgp {
	peer peer1 {
		connection {
			remote {
				ip 127.0.0.1
				accept false
			}
			local {
				ip 127.0.0.1
			}
		}
		session {
			asn {
				local 1
				remote 1
			}
			router-id 1.2.3.4
			family {
				ipv4/unicast { prefix { maximum 10000; } }
			}
			capability {
				graceful-restart disable
			}
		}
		behavior {
			group-updates disable
		}

		process graph-best-test {
		}
		process bgp-rib {
			receive [ update sent state ]
			send [ update ]
		}
	}
}
EOF_CONF

# Process orchestration
cmd=background:seq=1:exec=ze-peer --port $PORT:stdin=peer
cmd=foreground:seq=2:exec=ze -:stdin=ze-bgp:timeout=20s
expect=exit:code=0
