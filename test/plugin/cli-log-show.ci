# Test: bgp log show returns subsystem levels via dispatch-command
#
# Flow:
# 1. BGP session establishes
# 2. Python plugin dispatches "bgp log show" via dispatch-command
# 3. Verifies response contains levels map with subsystem entries
# 4. Shuts down daemon
#
# VALIDATES: AC-1 — bgp log show returns JSON map of subsystem names to levels.
# PREVENTS: Log show handler not wired into dispatch chain.

# ze-peer expectations
stdin=peer:terminator=EOF_PEER
option=tcp_connections:value=1
option=timeout:value=15s

# EOR
expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF00170200000000
EOF_PEER

# Python test plugin: exercises dispatch-command for bgp log show
tmpfs=log-show-test.run:mode=755:terminator=EOF_RUN
#!/usr/bin/env python3
"""Test: bgp log show via dispatch-command."""

import json
import sys
import time

from ze_api import API


def dispatch(api, command):
    """Call dispatch-command and return result dict."""
    resp = api._call_engine(
        'ze-plugin-engine:dispatch-command', {'command': command})
    return resp.get('result', {})


def main():
    api = API()
    api.declare_done()
    api.wait_for_config()
    api.capability_done()
    api.wait_for_registry()
    api.ready()

    # Wait for BGP session to establish
    time.sleep(1.0)

    # Test: bgp log show should return subsystem levels
    r = dispatch(api, 'bgp log show')
    status = r.get('status')
    if status != 'done':
        print(f'FAIL: expected status=done, got={status}', file=sys.stderr)
        sys.exit(1)

    data_str = r.get('data', '{}')
    try:
        data = json.loads(data_str) if isinstance(data_str, str) else data_str
    except (json.JSONDecodeError, TypeError):
        data = {}

    levels = data.get('levels', {})
    if not isinstance(levels, dict):
        print(f'FAIL: levels not a dict, data={data}', file=sys.stderr)
        sys.exit(1)

    count = data.get('count', 0)
    if count < 1:
        print(f'FAIL: expected at least 1 subsystem, got count={count}', file=sys.stderr)
        sys.exit(1)

    print(f'OK: log show returned {count} subsystems', file=sys.stderr)

    # Shutdown daemon
    dispatch(api, 'daemon shutdown')
    api.wait_for_shutdown()


if __name__ == '__main__':
    main()
EOF_RUN

# ze bgp configuration
stdin=ze-bgp:terminator=EOF_CONF
plugin {
	external log-show-test {
		run ./log-show-test.run;
		encoder json;
	}
}

environment {
	tcp {
		attempts 3;
	}
}

bgp {
	peer 127.0.0.1 {
		router-id 1.2.3.4;
		local-address 127.0.0.1;
		local-as 1;
		peer-as 1;
		connection active;
		group-updates disable;

		family {
			ipv4/unicast;
		}
		capability {
			graceful-restart disable;
		}
		process log-show-test {
		}
	}
}
EOF_CONF

# Process orchestration
cmd=background:seq=1:exec=ze-peer --port $PORT:stdin=peer
cmd=foreground:seq=2:exec=ze -:stdin=ze-bgp:timeout=15s
expect=exit:code=0
