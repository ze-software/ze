cmd=api:conn=1:seq=1:text=announce ipv6/unicast ::1/128 next-hop ::1 origin igp local-preference 100
expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF004E02000000374001010040020040050400000064800E260002011000000000000000000000000000000001008000000000000000000000000000000001
