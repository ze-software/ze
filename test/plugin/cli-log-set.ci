# Test: bgp log set changes subsystem level via dispatch-command
#
# Flow:
# 1. BGP session establishes
# 2. Python plugin dispatches "log levels" to see initial levels
# 3. Dispatches "log set <subsystem> debug" to change a level
# 4. Dispatches "log levels" again to verify the change
# 5. Shuts down daemon
#
# VALIDATES: AC-2 — bgp log set changes subsystem to specified level.
# PREVENTS: Log set handler not wired or level change not taking effect.

# ze-peer expectations
stdin=peer:terminator=EOF_PEER
option=tcp_connections:value=1
option=timeout:value=15s

# EOR
expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF00170200000000
EOF_PEER

# Python test plugin: exercises dispatch-command for bgp log set
tmpfs=log-set-test.run:mode=755:terminator=EOF_RUN
#!/usr/bin/env python3
"""Test: bgp log set via dispatch-command."""

import json
import sys
import time

from ze_api import API


def dispatch(api, command):
    """Call dispatch-command and return result dict."""
    resp = api._call_engine(
        'ze-plugin-engine:dispatch-command', {'command': command})
    return resp.get('result', {})


def parse_data(result):
    """Parse result data as JSON, return dict."""
    data_str = result.get('data', '{}')
    try:
        return json.loads(data_str) if isinstance(data_str, str) else data_str
    except (json.JSONDecodeError, TypeError):
        return {}


def main():
    api = API()
    api.declare_done()
    api.wait_for_config()
    api.capability_done()
    api.wait_for_registry()
    api.ready()

    # Wait for BGP session to establish
    time.sleep(1.0)

    # Get initial levels to find a subsystem to modify
    r = dispatch(api, 'log levels')
    data = parse_data(r)
    levels = data.get('levels', {})

    if not levels:
        print('FAIL: no subsystems in log levels', file=sys.stderr)
        sys.exit(1)

    # Pick the first subsystem and change it to debug
    subsystem = sorted(levels.keys())[0]
    original_level = levels[subsystem]
    print(f'INFO: changing {subsystem} from {original_level} to debug', file=sys.stderr)

    # Set level to debug
    r = dispatch(api, f'log set {subsystem} debug')
    status = r.get('status')
    if status != 'done':
        print(f'FAIL: set returned status={status}', file=sys.stderr)
        sys.exit(1)

    # Verify the change via log levels
    r = dispatch(api, 'log levels')
    data = parse_data(r)
    new_levels = data.get('levels', {})

    if new_levels.get(subsystem) != 'debug':
        print(f'FAIL: {subsystem} level is {new_levels.get(subsystem)}, expected debug', file=sys.stderr)
        sys.exit(1)

    print(f'OK: {subsystem} level changed to debug', file=sys.stderr)

    # Test error case: unknown subsystem
    r = dispatch(api, 'log set nonexistent info')
    if r.get('status') != 'error':
        print(f'FAIL: expected error for unknown subsystem', file=sys.stderr)
        sys.exit(1)

    print('OK: unknown subsystem returns error', file=sys.stderr)

    # Shutdown daemon
    dispatch(api, 'daemon shutdown')
    api.wait_for_shutdown()


if __name__ == '__main__':
    main()
EOF_RUN

# ze bgp configuration
stdin=ze-bgp:terminator=EOF_CONF
plugin {
	external log-set-test {
		run ./log-set-test.run
		encoder json
	}
}

environment {
	tcp {
		attempts 3
	}
}

bgp {
	peer peer1 {
		connection {
			remote {
				ip 127.0.0.1
				accept false
			}
			local {
				ip 127.0.0.1
			}
		}
		session {
			asn {
				local 1
				remote 1
			}
			router-id 1.2.3.4
			family {
				ipv4/unicast { prefix { maximum 10000; } }
			}
			capability {
				graceful-restart disable
			}
		}
		behavior {
			group-updates disable
		}

		process log-set-test {
		}
	}
}
EOF_CONF

# Process orchestration
cmd=background:seq=1:exec=ze-peer --port $PORT:stdin=peer
cmd=foreground:seq=2:exec=ze -:stdin=ze-bgp:timeout=15s
expect=exit:code=0
