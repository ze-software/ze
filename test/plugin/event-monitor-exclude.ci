# Test: event monitor with exclude filter via dispatch-command
# VALIDATES: AC-3 -- exclude filter parsed and returned in response
# PREVENTS: exclude keyword not recognized by event monitor handler

# ze-peer expectations
stdin=peer:terminator=EOF_PEER
option=tcp_connections:value=1
option=timeout:value=15s
expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF00170200000000
EOF_PEER

# Python test plugin: exercises dispatch-command for event monitor exclude
tmpfs=event-monitor-exclude-test.run:mode=755:terminator=EOF_RUN
#!/usr/bin/env python3
import json
import sys
import time
from ze_api import API

def dispatch(api, command):
    resp = api._call_engine(
        'ze-plugin-engine:dispatch-command', {'command': command})
    if resp is None:
        return {'status': 'error', 'data': 'engine call returned None'}
    return resp.get('result', {})

def main():
    api = API()
    api.declare_done()
    api.wait_for_config()
    api.capability_done()
    api.wait_for_registry()
    api.ready()
    time.sleep(1.0)

    try:
        result = dispatch(api, 'event monitor exclude keepalive')
        if result.get('status') != 'done':
            print(f'FAIL: status={result.get("status")} data={result.get("data")}', file=sys.stderr)
            sys.exit(1)

        data = result.get('data', {})
        if isinstance(data, str):
            data = json.loads(data)

        exclude = data.get('exclude', [])
        if 'keepalive' not in exclude:
            print(f'FAIL: expected exclude=[keepalive], got {exclude}', file=sys.stderr)
            sys.exit(1)

        print(f'OK: event monitor exclude filter parsed: {exclude}', file=sys.stderr)
    finally:
        dispatch(api, 'daemon shutdown')
        api.wait_for_shutdown()

if __name__ == '__main__':
    main()
EOF_RUN

# ze bgp configuration
stdin=ze-bgp:terminator=EOF_CONF
plugin {
	external event-monitor-exclude-test {
		run ./event-monitor-exclude-test.run
		encoder json
	}
}

environment {
	tcp {
		attempts 3
	}
}

bgp {
	peer peer1 {
		remote {
			ip 127.0.0.1
			as 1
			accept false
		}
		local {
			as 1
			ip 127.0.0.1
		}
		router-id 1.2.3.4
		group-updates disable

		family {
			ipv4/unicast { prefix { maximum 10000; } }
		}
		capability {
			graceful-restart disable
		}
		process event-monitor-exclude-test {
			receive [ update ]
		}
	}
}
EOF_CONF

# Process orchestration
cmd=background:seq=1:exec=ze-peer --port $PORT:stdin=peer
cmd=foreground:seq=2:exec=ze -:stdin=ze-bgp:timeout=15s
expect=exit:code=0
