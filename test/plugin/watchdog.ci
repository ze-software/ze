# Python plugin script
tmpfs=watchdog.run:mode=755:terminator=EOF_RUN
#!/usr/bin/env python3

import os
import time

from ze_bgp_api import ready, send


def main() -> None:
    ready()

    while os.getppid() != 1:
        send('watchdog announce dnsr')
        time.sleep(0.2)

        send('watchdog withdraw dnsr')
        time.sleep(0.2)

    time.sleep(1)  # time for configuration routes to pass


if __name__ == '__main__':
    main()
EOF_RUN

# ze bgp configuration
stdin=ze-bgp:terminator=EOF_CONF
plugin {
	external service-watchdog {
		run ./watchdog.run;
		encoder json;
	}
}
peer 127.0.0.1 {
	router-id 10.0.0.10;
	local-address 127.0.0.1;
	local-as 65533;
	peer-as 65533;

	family {
		ipv4/unicast;
	}
	announce {
		ipv4 {
			unicast 100.100.100.100 next-hop 192.168.1.100;
			unicast 66.66.66.66 next-hop 1.2.3.4;
			unicast 77.77.77.77 next-hop 1.2.3.4 watchdog dnsr withdraw true;
			unicast 88.88.88.88 next-hop 1.2.3.4;
		}
	}
	process service-watchdog {
	}
}
EOF_CONF

# Process orchestration
cmd=background:seq=1:exec=ze-peer --port $PORT:stdin=peer
cmd=foreground:seq=2:exec=ze bgp server -:stdin=ze-bgp:timeout=10s
