# Python plugin script
tmpfs=watchdog.run:mode=755:terminator=EOF_RUN
#!/usr/bin/env python3

from ze_api import API, runtime_fail


def main() -> None:
    api = API()
    api.declare_done()
    api.wait_for_config()
    api.capability_done()
    api.wait_for_registry()
    api.ready()
    if not api.wait_for_post_startup():
        runtime_fail('watchdog: post-startup callback not received')

    # Drain startup routes before watchdog commands, so watchdog state changes
    # are sent as separate UPDATEs instead of being folded into the config batch.
    api.wait_for_ack(expected_count=3)

    for _ in range(3):
        api.send('watchdog announce dnsr')
        api.wait_for_ack()

        api.send('watchdog withdraw dnsr')
        api.wait_for_ack()

    api.wait_for_shutdown()


if __name__ == '__main__':
    main()
EOF_RUN

# ze bgp configuration
stdin=ze-bgp:terminator=EOF_CONF
plugin {
	external service-watchdog {
		run ./watchdog.run
		encoder json
	}
}
bgp {
	peer peer1 {
		connection {
			remote {
				ip 127.0.0.1
			}
			local {
				ip 127.0.0.1
				accept false
			}
		}
		session {
			asn {
				local 65533
				remote 65533
			}
			router-id 10.0.0.10
			family {
				ipv4/unicast { prefix { maximum 10000; } }
			}
		}
	
		update {
			attribute {
				origin igp
				local-preference 100
				next-hop 192.168.1.100
			}
			nlri {
				ipv4/unicast add 100.100.100.100/32
			}
		}
		update {
			attribute {
				origin igp
				local-preference 100
				next-hop 1.2.3.4
			}
			nlri {
				ipv4/unicast add 66.66.66.66/32
				ipv4/unicast add 88.88.88.88/32
			}
		}
		update {
			attribute {
				origin igp
				local-preference 100
				next-hop 1.2.3.4
			}
			nlri {
				ipv4/unicast add 77.77.77.77/32
			}
			watchdog {
				name dnsr
				withdraw true
			}
		}
		process service-watchdog {
		}
	}
}
EOF_CONF

# Process orchestration
cmd=background:seq=1:exec=ze-peer --port $PORT:stdin=peer
cmd=foreground:seq=2:exec=ze --plugin ze.bgp-watchdog -:stdin=ze-bgp:timeout=10s
