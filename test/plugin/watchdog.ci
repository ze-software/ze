# Python plugin script
tmpfs=watchdog.run:mode=755:terminator=EOF_RUN
#!/usr/bin/env python3

import os
import time

from ze_api import ready, send


def main() -> None:
    ready()

    # Wait for BGP session to establish and config routes to be sent.
    # Without this, watchdog commands may arrive before the session is up,
    # setting state to "announced" prematurely — causing the route to be
    # sent with the initial config batch instead of as a separate UPDATE.
    time.sleep(1)

    while os.getppid() != 1:
        send('watchdog announce dnsr')
        time.sleep(0.2)

        send('watchdog withdraw dnsr')
        time.sleep(0.2)

    time.sleep(1)  # time for configuration routes to pass


if __name__ == '__main__':
    main()
EOF_RUN

# ze bgp configuration
stdin=ze-bgp:terminator=EOF_CONF
plugin {
	external service-watchdog {
		run ./watchdog.run
		encoder json
	}
}
bgp {
	peer peer1 {
		remote {
			ip 127.0.0.1
			as 65533
		}
		local {
			as 65533
			ip 127.0.0.1
		}
		router-id 10.0.0.10
		connection active
	
		family {
			ipv4/unicast { prefix { maximum 10000; } }
		}
		update {
			attribute {
				origin igp
				local-preference 100
				next-hop 192.168.1.100
			}
			nlri {
				ipv4/unicast add 100.100.100.100/32
			}
		}
		update {
			attribute {
				origin igp
				local-preference 100
				next-hop 1.2.3.4
			}
			nlri {
				ipv4/unicast add 66.66.66.66/32
				ipv4/unicast add 88.88.88.88/32
			}
		}
		update {
			attribute {
				origin igp
				local-preference 100
				next-hop 1.2.3.4
			}
			nlri {
				ipv4/unicast add 77.77.77.77/32
			}
			watchdog {
				name dnsr
				withdraw true
			}
		}
		process service-watchdog {
		}
	}
}
EOF_CONF

# Process orchestration
cmd=background:seq=1:exec=ze-peer --port $PORT:stdin=peer
cmd=foreground:seq=2:exec=ze --plugin ze.bgp-watchdog -:stdin=ze-bgp:timeout=10s
