# Test: bgp-redistribute -- accepted add event from fakeredist becomes a BGP UPDATE.
# VALIDATES: AC-2 -- batch with `add` action and matching import rule produces an
#            UPDATE on the wire whose attributes / NLRI match the canonical
#            `update text origin incomplete nhop self nlri ipv4/unicast add 10.0.0.1/32` shape.
# VALIDATES: auto-load via ConfigRoots -- this scenario deliberately omits an
#            explicit `external bgp-redistribute-egress { use bgp-redistribute-egress }`
#            block, so the only way the consumer runs is via the auto-load
#            triggered by the `redistribute {}` config root.
# PREVENTS: bgp-redistribute consumer not wired to UpdateRoute, or fakeredist event
#           not reaching the consumer, or auto-load regression silently dropping
#           the egress path.

# ze-peer expectations
stdin=peer:terminator=EOF_PEER
option=tcp_connections:value=1
option=timeout:value=15s
# UPDATE for 10.0.0.1/32 with NEXT_HOP=127.0.0.1 (peer's local session address)
expect=json:conn=1:seq=1:json={"meta":{"version":"1.0.0","format":"ze-bgp"},"message":{"type":"update"},"peer":{"address":"127.0.0.1","remote":{"as":65533}},"direction":"in","origin":"incomplete","ipv4/unicast":[{"action":"add","nlri":["10.0.0.1/32"],"next-hop":"127.0.0.1"}]}
EOF_PEER

# Python observer plugin: drive `fakeredist emit add` via dispatch-command, then exit.
tmpfs=announce-test.run:mode=755:terminator=EOF_RUN
#!/usr/bin/env python3
import time
from ze_api import API, runtime_fail


def dispatch(api, command):
    return api._call_engine('ze-plugin-engine:dispatch-command', {'command': command}) or {}


def main():
    api = API()
    api.declare_done()
    api.wait_for_config()
    api.capability_done()
    api.wait_for_registry()
    api.ready()

    # Wait for BGP session up so the UPDATE has a destination peer.
    time.sleep(2.0)

    resp = dispatch(api, 'fakeredist emit add ipv4/unicast 10.0.0.1/32')
    result = resp.get('result', {})
    if result.get('status') != 'done':
        runtime_fail(f'fakeredist emit failed: {result}')
        return

    # Give the consumer + reactor time to dispatch the UPDATE.
    time.sleep(2.0)
    dispatch(api, 'daemon shutdown')
    api.wait_for_shutdown()


if __name__ == '__main__':
    main()
EOF_RUN

# ze configuration
stdin=ze-bgp:terminator=EOF_CONF
plugin {
	external announce-test {
		run ./announce-test.run
		encoder json
	}
	# bgp-redistribute-egress is intentionally NOT listed here. The
	# `redistribute {}` block below carries `ConfigRoots: ["redistribute"]`,
	# which auto-loads the egress consumer. This validates the auto-load
	# wiring -- if the consumer fails to start, no UPDATE reaches the peer
	# and the test times out.
	external fakeredist {
		use fakeredist
		encoder json
	}
}

redistribute {
	import fakeredist {
		family [ ipv4/unicast ];
	}
}

bgp {
	peer peer1 {
		connection {
			remote {
				ip 127.0.0.1
			}
			local {
				ip 127.0.0.1
				accept false
			}
		}
		session {
			asn {
				local 65533
				remote 65533
			}
			router-id 1.2.3.4
			family {
				ipv4/unicast { prefix { maximum 10000; } }
			}
			capability {
				graceful-restart disable
			}
		}
		behavior {
			group-updates disable
		}
	}
}
EOF_CONF

# Process orchestration
cmd=background:seq=1:exec=ze-peer --port $PORT:stdin=peer
cmd=foreground:seq=2:exec=ze -:stdin=ze-bgp:timeout=15s
expect=exit:code=0
