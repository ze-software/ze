# Test: rpki plugin emits validation event with per-prefix states
# VALIDATES: rpki event emitted for valid prefix (AC-1, AC-9)
# PREVENTS: rpki plugin not emitting events after validation

# ze-peer: send route 10.0.1.0/24 from AS 65001
stdin=peer:terminator=EOF_PEER
option=tcp_connections:value=1
option=timeout:value=15s
option=update:value=send-route:prefix=10.0.1.0/24:origin-as=65001:next-hop=10.0.0.1
# EOR from ze
expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF00170200000000
EOF_PEER

# Python test plugin: subscribes to rpki events, verifies validation event received
tmpfs=rpki-event-test.run:mode=755:terminator=EOF_RUN
#!/usr/bin/env python3
import json
import sys
import time
from ze_api import API

def dispatch(api, command):
    resp = api._call_engine(
        'ze-plugin-engine:dispatch-command', {'command': command})
    if resp is None:
        return {'status': 'error', 'data': 'engine call returned None'}
    return resp.get('result', {})

def main():
    api = API()
    api.declare_done()
    api.wait_for_config()
    api.capability_done()
    api.wait_for_registry()

    # Subscribe to rpki events before ready
    api.subscribe(['rpki direction received'])
    api.ready()

    # Wait for RTR sync + BGP UPDATE + rpki event emission
    time.sleep(4.0)

    try:
        # Poll for rpki events
        found_valid = False
        for _ in range(20):
            event_str = api.read_line(timeout=0.5)
            if event_str is None:
                continue
            try:
                evt = json.loads(event_str)
            except (json.JSONDecodeError, TypeError):
                continue
            bgp = evt.get('bgp', {})
            msg = bgp.get('message', {})
            if msg.get('type') != 'rpki':
                continue
            rpki = bgp.get('rpki', {})
            if not isinstance(rpki, dict) or rpki.get('status') == 'unavailable':
                # Cache not ready yet, skip
                continue
            family = rpki.get('ipv4/unicast', {})
            state = family.get('10.0.1.0/24')
            if state == 'valid':
                found_valid = True
                break
            print(f'INFO: rpki event state={state} rpki={rpki}', file=sys.stderr)

        if not found_valid:
            print('FAIL: no rpki event with valid state for 10.0.1.0/24', file=sys.stderr)
            sys.exit(1)

        print('OK: rpki event has 10.0.1.0/24=valid', file=sys.stderr)
    finally:
        dispatch(api, 'daemon shutdown')
        api.wait_for_shutdown()

if __name__ == '__main__':
    main()
EOF_RUN

stdin=ze-bgp:terminator=EOF_CONF
plugin {
	hub {
		server local {
			host 127.0.0.1;
			port 0;
			secret rpki-test-secret-key-01234567890;
		}
	}
	external rpki-event-test {
		run ./rpki-event-test.run
		encoder json
	}
	external rpki {
		run "ze plugin bgp-rpki"
		encoder json
	}
	external adj-rib-in {
		run "ze plugin bgp-adj-rib-in"
		encoder json
	}
}

environment {
	tcp {
		attempts 3
	}
}

bgp {
	rpki {
		cache-server 127.0.0.1 {
			port $PORT2
		}
	}
	peer peer1 {
		connection {
			remote {
				ip 127.0.0.1
				accept false
			}
			local {
				ip 127.0.0.1
			}
		}
		session {
			asn {
				local 1
				remote 1
			}
			router-id 1.2.3.4
			family {
				ipv4/unicast { prefix { maximum 10000; } }
			}
			capability {
				graceful-restart disable
			}
		}
		behavior {
			group-updates disable
		}

		process rpki-event-test {
		}
		process rpki {
			receive [ update ]
		}
		process adj-rib-in {
			receive [ update state ]
		}
	}
}
EOF_CONF

# VRP: 10.0.0.0/8 maxlen=24 AS=65001
cmd=background:seq=1:exec=ze-test rtr-mock --port $PORT2 --vrp 10.0.0.0/8,24,65001
cmd=background:seq=2:exec=ze-peer --port $PORT:stdin=peer
cmd=foreground:seq=3:exec=ze -:stdin=ze-bgp:timeout=20s
expect=exit:code=0
