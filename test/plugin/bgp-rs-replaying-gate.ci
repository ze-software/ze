# bgp-rs-replaying-gate -- Replaying-peer handling through ForwardCached (rs-fastpath-3)
#
# VALIDATES: rs-fastpath-3 preserves the pre-existing decision that replaying
# peers are INCLUDED in forward targets (not excluded). BGP UPDATE duplicates
# are idempotent at the receiver; excluding replaying peers would risk route
# loss during peer-up races. See TestReplayingPeerIncludedInForwardTargets
# (internal/component/bgp/plugins/rs/server_test.go) for the in-process check.
#
# PREVENTS: regression where the fast path changes forwarding semantics
# beyond the transport swap (text RPC -> typed SDK call).

stdin=source:terminator=EOF_SOURCE
option=tcp_connections:value=1
option=timeout:value=10s

action=send:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF00300200000015400101004002004003040101010140050400000064180A0000
EOF_SOURCE

stdin=ze-bgp:terminator=EOF_CONF
plugin {
	external rs {
		use bgp-rs
	}
}
bgp {
	peer source-peer {
		connection {
			remote {
				ip 127.0.0.1
			}
			local {
				ip 127.0.0.1
				accept false
			}
		}
		session {
			asn {
				local 65000
				remote 65000
			}
			router-id 1.2.3.4
			family {
				ipv4/unicast { prefix { maximum 10000; } }
			}
			capability {
				graceful-restart disable
			}
		}
		behavior {
			group-updates disable
		}
	}
}
EOF_CONF

cmd=background:seq=1:exec=ze-peer --port $PORT:stdin=source
cmd=foreground:seq=2:exec=ze -:stdin=ze-bgp:timeout=10s
expect=exit:code=0
reject=stderr:pattern=panic
reject=stderr:pattern=fatal error
reject=stderr:pattern=cache .* forward
reject=stderr:pattern=forward-cached failed
reject=stderr:pattern=release-cached failed
reject=stderr:pattern=BUG: ForwardUpdatesDirect
