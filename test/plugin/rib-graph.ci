# Test: RIB graph terminal renders AS path topology as box-drawing art
#
# Flow:
# 1. Python test plugin injects routes with known AS paths via rib inject
# 2. Dispatches "rib show received graph" command
# 3. Verifies output contains box-drawing characters and ASN labels
#
# VALIDATES: AC-1 "Output contains box-drawing characters and both ASN labels"
#   AC-2 "Graph shows columns (layers), left-to-right flow"
#   AC-4 "Consecutive duplicates collapsed"
#   AC-7 "No routes match filters -- no crash"
# PREVENTS: Graph terminal not wired into pipeline, empty output.

# ze-peer expectations
stdin=peer:terminator=EOF_PEER
option=tcp_connections:value=1
option=timeout:value=15s

# No wire expectations from ze-peer (routes injected via API)
EOF_PEER

# Python test plugin
tmpfs=rib-graph-test.run:mode=755:terminator=EOF_RUN
#!/usr/bin/env python3
"""Test: RIB graph terminal."""

import sys
import time

from ze_api import API


failures = 0


def dispatch(api, command):
    resp = api._call_engine(
        'ze-plugin-engine:dispatch-command', {'command': command})
    return resp.get('result', {})


def check(label, result, expected_status):
    global failures
    actual = result.get('status')
    if actual != expected_status:
        print(f'FAIL {label}: expected status={expected_status}, got={actual}', file=sys.stderr)
        failures += 1
    else:
        print(f'OK {label}: status={actual}', file=sys.stderr)


def check_contains(label, result, substring):
    global failures
    data = result.get('data', '')
    if substring not in data:
        print(f'FAIL {label}: output does not contain {substring!r}', file=sys.stderr)
        print(f'  got: {data[:200]!r}', file=sys.stderr)
        failures += 1
    else:
        print(f'OK {label}: contains {substring!r}', file=sys.stderr)


def main():
    global failures
    api = API()
    api.declare_done()
    api.wait_for_config()
    api.capability_done()
    api.wait_for_registry()
    api.ready()

    # Wait for rib plugin
    time.sleep(1.0)
    for _ in range(20):
        r = dispatch(api, 'rib status')
        if r.get('status') == 'done':
            break
        time.sleep(0.5)
    else:
        print('FAIL: rib plugin did not become ready', file=sys.stderr)
        failures += 1

    # Inject routes with AS paths
    # Route 1: AS64501 -> AS64502 -> AS64503
    r = dispatch(api, 'rib inject 10.0.0.1 ipv4/unicast 10.10.1.0/24 aspath 64501,64502,64503')
    check('inject-1', r, 'done')

    # Route 2: AS64504 -> AS64502 -> AS64503 (diamond: shares AS64502 and AS64503)
    r = dispatch(api, 'rib inject 10.0.0.2 ipv4/unicast 10.10.2.0/24 aspath 64504,64502,64503')
    check('inject-2', r, 'done')

    # --- graph terminal ---
    r = dispatch(api, 'rib show received graph')
    check('graph', r, 'done')

    # Output should contain ASN labels
    check_contains('graph-as64501', r, 'AS64501')
    check_contains('graph-as64502', r, 'AS64502')
    check_contains('graph-as64503', r, 'AS64503')
    check_contains('graph-as64504', r, 'AS64504')

    # Output should contain box-drawing characters
    check_contains('graph-box', r, '\u250c')  # ┌

    # --- empty graph (no matching routes) ---
    r = dispatch(api, 'rib show received cidr 99.99.99.0/24 graph')
    check('empty-graph', r, 'done')

    # Shutdown
    if failures > 0:
        print(f'\n{failures} failures', file=sys.stderr)
    dispatch(api, 'daemon shutdown')
    api.wait_for_shutdown()

    if failures > 0:
        sys.exit(1)


if __name__ == '__main__':
    main()
EOF_RUN

# ze bgp configuration
stdin=ze-bgp:terminator=EOF_CONF
plugin {
	external graph-test {
		run ./rib-graph-test.run
		encoder json
	}
	external rib {
		run "ze plugin bgp-rib"
		encoder json
	}
}

environment {
	tcp {
		attempts 3
	}
}

bgp {
	peer peer1 {
		connection {
			remote {
				ip 127.0.0.1
				accept false
			}
			local {
				ip 127.0.0.1
			}
		}
		session {
			asn {
				local 1
				remote 1
			}
			router-id 1.2.3.4
			family {
				ipv4/unicast { prefix { maximum 10000; } }
			}
			capability {
				graceful-restart disable
			}
		}
		behavior {
			group-updates disable
		}

		process graph-test {
		}
		process rib {
			receive [ update sent state ]
			send [ update ]
		}
	}
}
EOF_CONF

# Process orchestration
cmd=background:seq=1:exec=ze-peer --port $PORT:stdin=peer
cmd=foreground:seq=2:exec=ze -:stdin=ze-bgp:timeout=20s
expect=exit:code=0
