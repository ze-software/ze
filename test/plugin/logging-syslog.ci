# Migrated from test/data/plugin/logging-syslog.*

# ze-peer expectations
stdin=peer:terminator=EOF_PEER
option=timeout:value=10s

# Enable server subsystem logging (syslog backend set automatically by runner)
option=env:var=ze.bgp.log.server:value=debug

# Test: Syslog backend
# Verifies ze.bgp.log.backend=syslog sends logs to test-syslog server

# Static route UPDATE
expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF00300200000015400101004002004003040A0000014005040000006418C0A801
# EOR
expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF00170200000000

# Verify server subsystem logs arrive at syslog server
expect=syslog:pattern=subsystem=server
EOF_PEER

# ze bgp configuration
stdin=ze-bgp:terminator=EOF_CONF
# Test: Syslog backend
# Verifies that ze.bgp.log.backend=syslog sends logs to syslog server

plugin {
    external gr {
        run "ze plugin bgp-gr";
        encoder json;
    }
}

bgp {
	peer 127.0.0.1 {
	    router-id 1.2.3.4;
	    local-address 127.0.0.1;
	    local-as 1;
	    peer-as 1;
	    group-updates disable;
	
	    family {
	        ipv4/unicast;
	    }
	
	    capability {
	        graceful-restart {
	            restart-time 120;
	        }
	    }
	
	    update {
	        attribute {
	            origin igp;
	            local-preference 100;
	            next-hop 10.0.0.1;
	        }
	        nlri {
	            ipv4/unicast add 192.168.1.0/24;
	        }
	    }
	
	    process gr {
	        send { update; }
	    }
	}
}
EOF_CONF

# Process orchestration
cmd=background:seq=1:exec=ze-peer --port $PORT:stdin=peer
cmd=foreground:seq=2:exec=ze -:stdin=ze-bgp:timeout=10s
