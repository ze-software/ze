# Test: bgp summary returns valid dashboard data via dispatch-command
# VALIDATES: AC-1 — monitor bgp can reach summary data through dispatch-command
# PREVENTS: dashboard wiring broken — summary RPC not reachable

# ze-peer expectations
stdin=peer:terminator=EOF_PEER
option=tcp_connections:value=1
option=timeout:value=15s
expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF00170200000000
EOF_PEER

# Python test plugin: exercises dispatch-command for bgp summary
tmpfs=dashboard-test.run:mode=755:terminator=EOF_RUN
#!/usr/bin/env python3
import json
import sys
import time
from ze_api import API

def dispatch(api, command):
    resp = api._call_engine(
        'ze-plugin-engine:dispatch-command', {'command': command})
    if resp is None:
        return {'status': 'error', 'data': 'engine call returned None'}
    return resp.get('result', {})

def main():
    api = API()
    api.declare_done()
    api.wait_for_config()
    api.capability_done()
    api.wait_for_registry()
    api.ready()
    time.sleep(1.0)

    try:
        result = dispatch(api, 'bgp summary')
        if result.get('status') != 'done':
            print(f'FAIL: summary status={result.get("status")} data={result.get("data")}', file=sys.stderr)
            sys.exit(1)

        data = result.get('data', {})
        if isinstance(data, str):
            data = json.loads(data)

        summary = data.get('summary', {})
        if 'router-id' not in summary:
            print(f'FAIL: summary missing router-id: {json.dumps(data)}', file=sys.stderr)
            sys.exit(1)
        if 'peers' not in summary:
            print(f'FAIL: summary missing peers: {json.dumps(data)}', file=sys.stderr)
            sys.exit(1)
        if 'local-as' not in summary:
            print(f'FAIL: summary missing local-as: {json.dumps(data)}', file=sys.stderr)
            sys.exit(1)

        peers = summary.get('peers', [])
        if not isinstance(peers, list):
            print(f'FAIL: peers is not a list: {type(peers)}', file=sys.stderr)
            sys.exit(1)

        print(f'OK: summary has router-id={summary["router-id"]} local-as={summary["local-as"]} peers={len(peers)}', file=sys.stderr)
    finally:
        dispatch(api, 'daemon shutdown')
        api.wait_for_shutdown()

if __name__ == '__main__':
    main()
EOF_RUN

# ze bgp configuration
stdin=ze-bgp:terminator=EOF_CONF
plugin {
	external dashboard-test {
		run ./dashboard-test.run
		encoder json
	}
}

environment {
	tcp {
		attempts 3
	}
}

bgp {
	peer peer1 {
		connection {
			remote {
				ip 127.0.0.1
				accept false
			}
			local {
				ip 127.0.0.1
			}
		}
		session {
			asn {
				local 1
				remote 1
			}
			router-id 1.2.3.4
			family {
				ipv4/unicast { prefix { maximum 10000; } }
			}
			capability {
				graceful-restart disable
			}
		}
		behavior {
			group-updates disable
		}

		process dashboard-test {
			receive [ update ]
		}
	}
}
EOF_CONF

# Process orchestration
cmd=background:seq=1:exec=ze-peer --port $PORT:stdin=peer
cmd=foreground:seq=2:exec=ze -:stdin=ze-bgp:timeout=15s
expect=exit:code=0
