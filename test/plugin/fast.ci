expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF00170200000000
cmd=api:conn=1:seq=1:text=bgp peer * update text origin set igp local-preference set 100 nhop set 101.1.101.1 nlri ipv4/unicast add 1.1.0.0/25
expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF003102000000154001010040020040030465016501400504000000641901010000
cmd=api:conn=1:seq=1:text=bgp peer * update text nlri ipv4/unicast del 2.2.0.0/25
expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF001C02000519020200000000
cmd=api:conn=1:seq=1:text=bgp peer * update text origin set igp local-preference set 100 nhop set 101.1.101.1 nlri ipv4/unicast add 2.2.0.0/24
expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF0030020000001540010100400200400304650165014005040000006418020200
