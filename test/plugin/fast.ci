# Python plugin script
tmpfs=fast.run:mode=755:terminator=EOF_RUN
#!/usr/bin/env python3
"""Fast test - verifies basic route announcement and withdrawal.

This script sends the exact commands that produce the expected .ci output.
The original ExaBGP version used batching with sleep() which deduplicated
routes internally. ZeBGP sends each command immediately, so we send only
the final expected routes.
"""

import sys
import time
from ze_api import flush, ready, wait_for_shutdown

print("DEBUG: fast.run starting", file=sys.stderr)

def main() -> None:
    print("DEBUG: main() called", file=sys.stderr)
    ready()
    print("DEBUG: after ready", file=sys.stderr)

    # Message 1: Announce 1.1.0.0/25
    # (ExaBGP batched: announce /24, announce /25, withdraw /24, announce /25 → just /25)
    flush('bgp peer * update text nhop set 101.1.101.1 nlri ipv4/unicast add 1.1.0.0/25\n')
    time.sleep(0.1)

    # Message 2: Withdraw 2.2.0.0/25
    # (ExaBGP batched: announce /25, announce /24, withdraw /25 → withdraw /25 + announce /24)
    flush('bgp peer * update text nlri ipv4/unicast del 2.2.0.0/25\n')
    time.sleep(0.1)

    # Message 3: Announce 2.2.0.0/24
    flush('bgp peer * update text nhop set 101.1.101.1 nlri ipv4/unicast add 2.2.0.0/24\n')
    time.sleep(0.1)

    # Message 4: Announce 0.0.0.0/0
    flush('bgp peer * update text nhop set 1.101.1.101 nlri ipv4/unicast add 0.0.0.0/0\n')

    wait_for_shutdown()


if __name__ == '__main__':
    main()
EOF_RUN

# ze bgp configuration
stdin=ze-bgp:terminator=EOF_CONF
plugin {
	external announce-routes {
		run ./fast.run;
		encoder json;
	}
}
bgp {
	peer 127.0.0.1 {
		router-id 1.2.3.4;
		local-address 127.0.0.1;
		local-as 1;
		peer-as 1;
		group-updates disable;
	
		family {
			ipv4/unicast;
		}
		capability {
			graceful-restart;
		}
		process announce-routes {
		}
	}
}
EOF_CONF

# Process orchestration
cmd=background:seq=1:exec=ze-peer --port $PORT:stdin=peer
cmd=foreground:seq=2:exec=ze -:stdin=ze-bgp:timeout=10s
