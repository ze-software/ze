# Test: extended-nexthop capability negotiated via config
# VALIDATES: nexthop config in capability block causes ext-NH capability
# PREVENTS: extended-nexthop config silently ignored

# ze-peer expectations
stdin=peer:terminator=EOF_PEER
option=tcp_connections:value=1
option=timeout:value=15s
# EOR proves session established with ext-NH capability negotiated
expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF00170200000000
EOF_PEER

# Python test plugin: verifies extended-nexthop capability negotiated
tmpfs=ext-nh-test.run:mode=755:terminator=EOF_RUN
#!/usr/bin/env python3
import json
import sys
import time
from ze_api import API

def dispatch(api, command):
    resp = api._call_engine(
        'ze-plugin-engine:dispatch-command', {'command': command})
    if resp is None:
        return {'status': 'error', 'data': 'engine call returned None'}
    return resp.get('result', {})

def main():
    api = API()
    api.declare_done()
    api.wait_for_config()
    api.capability_done()
    api.wait_for_registry()
    api.ready()
    time.sleep(1.0)

    try:
        result = dispatch(api, 'peer 127.0.0.1 capabilities')
        if result.get('status') != 'done':
            print(f'FAIL: capabilities status={result.get("status")}', file=sys.stderr)
            sys.exit(1)

        data = result.get('data', {})
        if isinstance(data, str):
            data = json.loads(data)

        # Single peer returns flat object
        negotiated = data.get('negotiated', {})
        data_str = str(data).lower()
        if 'extended' not in data_str:
            print(f'FAIL: no extended-nexthop in capabilities', file=sys.stderr)
            sys.exit(1)

        print('OK: extended-nexthop capability present', file=sys.stderr)
    finally:
        dispatch(api, 'daemon shutdown')
        api.wait_for_shutdown()

if __name__ == '__main__':
    main()
EOF_RUN

# ze bgp configuration with extended-nexthop via capability nexthop list
stdin=ze-bgp:terminator=EOF_CONF
plugin {
	external ext-nh-test {
		run ./ext-nh-test.run
		encoder json
	}
}

environment {
	tcp {
		attempts 3
	}
}

bgp {
	peer 127.0.0.1 {
		router-id 1.2.3.4
		local-address 127.0.0.1
		local-as 1
		peer-as 1
		connection active
		group-updates disable

		family {
			ipv4/unicast
			ipv6/unicast
		}
		capability {
			graceful-restart disable
			nexthop ipv4/unicast {
				nhafi ipv6
			}
		}
		process ext-nh-test {
		}
	}
}
EOF_CONF

# Process orchestration
cmd=background:seq=1:exec=ze-peer --port $PORT:stdin=peer
cmd=foreground:seq=2:exec=ze -:stdin=ze-bgp:timeout=15s
expect=exit:code=0
