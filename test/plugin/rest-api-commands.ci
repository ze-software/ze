# Test: REST API /api/v1/commands returns command list
# VALIDATES: REST transport wired to engine, commands endpoint reachable
# PREVENTS: REST server not started, engine not connected to dispatcher

# ze-peer expectations
stdin=peer:terminator=EOF_PEER
option=tcp_connections:value=1
option=timeout:value=20s
expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF00170200000000
EOF_PEER

# Python test plugin: starts, waits for REST API, queries /api/v1/commands
tmpfs=rest-test.run:mode=755:terminator=EOF_RUN
#!/usr/bin/env python3
import json
import sys
import time
import urllib.request
import urllib.error
from ze_api import API

REST_PORT = 18081
REST_URL = f'http://127.0.0.1:{REST_PORT}/api/v1/commands'

def wait_for_rest(url, timeout=10):
    """Poll REST endpoint until it responds or timeout."""
    deadline = time.time() + timeout
    while time.time() < deadline:
        try:
            req = urllib.request.Request(url)
            resp = urllib.request.urlopen(req, timeout=2)
            return resp.read()
        except (urllib.error.URLError, ConnectionRefusedError, OSError):
            time.sleep(0.5)
    return None

def dispatch(api, command):
    resp = api._call_engine(
        'ze-plugin-engine:dispatch-command', {'command': command})
    if resp is None:
        return {'status': 'error', 'data': 'engine call returned None'}
    return resp.get('result', {})

def main():
    api = API()
    api.declare_done()
    api.wait_for_config()
    api.capability_done()
    api.wait_for_registry()
    api.ready()
    time.sleep(1.0)

    try:
        data = wait_for_rest(REST_URL)
        if data is None:
            print('FAIL: REST API did not respond within timeout', file=sys.stderr)
            sys.exit(1)

        commands = json.loads(data)
        if not isinstance(commands, list):
            print(f'FAIL: expected list, got {type(commands).__name__}', file=sys.stderr)
            sys.exit(1)

        if len(commands) == 0:
            print('FAIL: empty command list', file=sys.stderr)
            sys.exit(1)

        names = [c.get('Name', '') for c in commands]
        print(f'OK: REST /api/v1/commands returned {len(commands)} commands', file=sys.stderr)

        # Also test execute endpoint
        exec_url = f'http://127.0.0.1:{REST_PORT}/api/v1/execute'
        req = urllib.request.Request(
            exec_url,
            data=json.dumps({'command': 'summary'}).encode(),
            headers={'Content-Type': 'application/json'},
        )
        resp = urllib.request.urlopen(req, timeout=5)
        result = json.loads(resp.read())
        if result.get('status') != 'done':
            print(f'FAIL: execute status={result.get("status")}', file=sys.stderr)
            sys.exit(1)

        print(f'OK: REST /api/v1/execute returned status=done', file=sys.stderr)
    finally:
        dispatch(api, 'daemon shutdown')
        api.wait_for_shutdown()

if __name__ == '__main__':
    main()
EOF_RUN

# ze bgp configuration with REST API enabled
stdin=ze-bgp:terminator=EOF_CONF
plugin {
	external rest-test {
		run ./rest-test.run
		encoder json
	}
}

environment {
	api-server {
		rest {
			enabled true;
			server main {
				ip 127.0.0.1;
				port 18081;
			}
		}
	}
}

bgp {
	peer peer1 {
		connection {
			remote {
				ip 127.0.0.1
			}
			local {
				ip 127.0.0.1
				accept false
			}
		}
		session {
			asn {
				local 1
				remote 1
			}
			router-id 1.2.3.4
			family {
				ipv4/unicast { prefix { maximum 10000; } }
			}
			capability {
				graceful-restart disable
			}
		}
		behavior {
			group-updates disable
		}

		process rest-test {
		}
	}
}
EOF_CONF

# Process orchestration
cmd=background:seq=1:exec=ze-peer --port $PORT:stdin=peer
cmd=foreground:seq=2:exec=ze -:stdin=ze-bgp:timeout=20s
expect=exit:code=0
