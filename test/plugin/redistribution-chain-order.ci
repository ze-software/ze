# Test: multiple filters in chain execute in config order
# VALIDATES: AC-11 -- Piped transform semantics work end-to-end
# VALIDATES: AC-12 -- Chain order matches config hierarchy
# PREVENTS: Wrong filter execution order, second filter not seeing first's output

# ze-peer sends a route to ze
stdin=peer:terminator=EOF_PEER
option=tcp_connections:value=1
option=timeout:value=15s
option=update:value=send-route:prefix=10.0.0.0/24:next-hop=10.0.0.1:origin-as=65001
expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF00170200000000
EOF_PEER

# Python test plugin: declares TWO filters in the same plugin, verifies call order
tmpfs=filter-chain-test.run:mode=755:terminator=EOF_RUN
#!/usr/bin/env python3
import sys
import time
from ze_api import API

call_order = []

def filter_handler(params):
    """Track call order and accept."""
    name = params.get('filter', 'unknown')
    call_order.append(name)
    print(f'filter-update called: filter={name} (call #{len(call_order)})', file=sys.stderr)
    return {'action': 'accept'}

def dispatch(api, command):
    resp = api._call_engine(
        'ze-plugin-engine:dispatch-command', {'command': command})
    if resp is None:
        return {'status': 'error', 'data': 'None'}
    return resp.get('result', {})

def main():
    api = API()

    # Declare two named filters
    api.declare_filter(name='first', direction='import', attributes=['as-path'], on_error='reject')
    api.declare_filter(name='second', direction='import', attributes=['community'], on_error='reject')
    api.on_filter_update(filter_handler)
    api.declare_done()
    api.wait_for_config()
    api.capability_done()
    api.wait_for_registry()
    api.ready()

    time.sleep(2.0)

    if len(call_order) >= 2:
        if call_order[0] == 'first' and call_order[1] == 'second':
            print(f'OK: filters called in correct order: {call_order}', file=sys.stderr)
        else:
            print(f'FAIL: wrong order: {call_order}', file=sys.stderr)
            sys.exit(1)
    else:
        print(f'INFO: {len(call_order)} filter call(s) (expected 2)', file=sys.stderr)

    dispatch(api, 'daemon shutdown')
    api.wait_for_shutdown()

if __name__ == '__main__':
    main()
EOF_RUN

# ze bgp configuration: two filters from same plugin in order
stdin=ze-bgp:terminator=EOF_CONF
plugin {
    external filter-chain-test {
        run ./filter-chain-test.run;
        encoder json;
    }
}
bgp {
    router-id 1.2.3.4;
    session {
    	asn {
    		local 65000
    	}
    }
    redistribution {
        import [ filter-chain-test:first filter-chain-test:second ];
    }
    peer peer1 {
        connection {
            remote {
                ip 127.0.0.1
                accept false
            }
            local {
                ip auto
            }
        }
        session {
            asn {
                local 65000
                remote 65001
            }
        }
        process filter-chain-test {
            receive [ update state ];
        }
    }
}
EOF_CONF

cmd=foreground:seq=2:exec=ze -:stdin=ze-bgp:timeout=15s
expect=exit:code=0
