# bgp-rs-mod-copy -- copy-on-modify through ForwardCached (rs-fastpath-3)
#
# VALIDATES: rs-fastpath-3 wiring -- source with AS-override peer behavior
# exercises the copy-on-modify path via the ForwardCached fast path.
#
# PREVENTS: regression where ForwardCached bypasses buildModifiedPayload.

stdin=source:terminator=EOF_SOURCE
option=tcp_connections:value=1
option=timeout:value=15s

action=send:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF00300200000015400101004002004003040101010140050400000064180A0000
# Hold the connection until rs finishes its replayForPeer goroutine and sends
# EOR. Without this the peer closes immediately after the send, the BGP FSM
# drops to IDLE, and rs's AnnounceEOR fails with "no established peers".
expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF00170200000000
EOF_SOURCE

# Observer: issue `daemon shutdown` after a short settle so ze exits 0 instead
# of being killed by the foreground cmd timeout (which the runner flags as
# StateTimeout). See bgp-rs-fastpath-ebgp-shared.ci for the rationale.
tmpfs=shutdown-after-up.run:mode=755:terminator=EOF_RUN
#!/usr/bin/env python3
import time
from ze_api import API

def main():
    api = API()
    api.declare_done()
    api.wait_for_config()
    api.capability_done()
    api.wait_for_registry()
    api.ready()
    time.sleep(2.0)
    api._call_engine('ze-plugin-engine:dispatch-command', {'command': 'daemon shutdown'})
    api.wait_for_shutdown()

if __name__ == '__main__':
    main()
EOF_RUN

stdin=ze-bgp:terminator=EOF_CONF
plugin {
	external rs {
		use bgp-rs
	}
	external shutdown-after-up {
		run ./shutdown-after-up.run
		encoder json
	}
}
bgp {
	peer source-peer {
		connection {
			remote {
				ip 127.0.0.1
			}
			local {
				ip 127.0.0.1
				accept false
			}
		}
		session {
			asn {
				local 65000
				remote 65001
			}
			router-id 1.2.3.4
			family {
				ipv4/unicast { prefix { maximum 10000; } }
			}
			capability {
				graceful-restart disable
			}
		}
		behavior {
			group-updates disable
		}
	}
}
EOF_CONF

cmd=background:seq=1:exec=ze-peer --port $PORT:stdin=source
cmd=foreground:seq=2:exec=ze -:stdin=ze-bgp:timeout=10s
expect=exit:code=0
reject=stderr:pattern=panic
reject=stderr:pattern=fatal error
reject=stderr:pattern=cache .* forward
reject=stderr:pattern=forward-cached failed
reject=stderr:pattern=release-cached failed
reject=stderr:pattern=BUG: ForwardUpdatesDirect
