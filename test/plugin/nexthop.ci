EOF_PEER

# Python plugin script
tmpfs=nexthop.run:mode=755:terminator=EOF_RUN
#!/usr/bin/env python3

import time

from ze_bgp_api import ready, send, wait_for_shutdown


def main() -> None:
    ready()

    send('neighbor 127.0.0.1 update text local-preference set 500 nhop set 2001::1 nlri ipv6/unicast add 2605::2/128')
    time.sleep(0.2)

    send('neighbor 127.0.0.1 update text local-preference set 500 nhop set 2001::2 nlri ipv6/unicast add 2605::2/128')
    time.sleep(0.2)

    send('neighbor 127.0.0.1 update text local-preference set 500 nhop set 2001::1 nlri ipv6/unicast add 2605::2/128')

    wait_for_shutdown()


if __name__ == '__main__':
    main()
EOF_RUN

# ze bgp configuration
stdin=ze-bgp:terminator=EOF_CONF
plugin {
	external announce-routes {
		run ./nexthop.run;
		encoder json;
	}
}
bgp {
	peer 127.0.0.1 {
		router-id 10.0.0.139;
		local-address 127.0.0.1;
		local-as 65512;
		peer-as 65512;
		hold-time 30;
	
		family {
			ipv6/unicast;
		}
		process announce-routes {
		}
	}
}
EOF_CONF

# Process orchestration
cmd=background:seq=1:exec=ze-peer --port $PORT:stdin=peer
cmd=foreground:seq=2:exec=ze bgp server -:stdin=ze-bgp:timeout=10s
