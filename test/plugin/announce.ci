stdin=peer:terminator=EOF_PEER
cmd:api:conn=1:seq=1:text=bgp peer * update text origin set igp local-preference set 100 nhop set 101.1.101.1 nlri ipv4/unicast add 1.1.0.0/24
expect:bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF0030020000001540010100400200400304650165014005040000006418010100
expect:json:conn=1:seq=1:json={"meta":{"version":"1.0.0","format":"ze-bgp"},"message":{"type":"update"},"peer":{"address":"127.0.0.1","asn":65533},"direction":"in","local-preference":100,"origin":"igp","ipv4/unicast":[{"action":"add","nlri":["1.1.0.0/24"],"next-hop":"101.1.101.1"}]}
cmd:api:conn=1:seq=1:text=bgp peer * update text nlri ipv4/unicast eor
expect:bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF00170200000000
cmd:api:conn=1:seq=1:text=bgp peer * update text origin set igp local-preference set 100 nhop set 101.1.101.1 nlri ipv4/unicast add 1.2.0.0/25
expect:bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF003102000000154001010040020040030465016501400504000000641901020000
expect:json:conn=1:seq=1:json={"meta":{"version":"1.0.0","format":"ze-bgp"},"message":{"type":"update"},"peer":{"address":"127.0.0.1","asn":65533},"direction":"in","local-preference":100,"origin":"igp","ipv4/unicast":[{"action":"add","nlri":["1.2.0.0/25"],"next-hop":"101.1.101.1"}]}
EOF_PEER

# Python plugin script
tmpfs=announce.run:mode=755:terminator=EOF_RUN
#!/usr/bin/env python3

from ze_bgp_api import ready, send, wait_for_ack, wait_for_shutdown


def main() -> None:
    ready()

    messages = [
        'bgp peer * update text nhop set 101.1.101.1 nlri ipv4/unicast add 1.1.0.0/24',
        'bgp peer * update text nhop set 101.1.101.1 nlri ipv4/unicast add 1.2.0.0/25',
    ]

    for message in messages:
        send(message)

    # Wait for ACKs (may be disabled in config)
    wait_for_ack(expected_count=2)

    # Wait for shutdown signal
    wait_for_shutdown()


if __name__ == '__main__':
    main()
EOF_RUN

# ze bgp configuration
stdin=ze-bgp:terminator=EOF_CONF
plugin {
	external add-remove {
		run ./announce.run;
		encoder json;
	}
}
bgp {
	peer 127.0.0.1 {
		router-id 1.2.3.4;
		local-address 127.0.0.1;
		local-as 1;
		peer-as 1;
		group-updates disable;
	
		family {
			ipv4/unicast;
		}
		capability {
			graceful-restart;
		}
		process add-remove {
		}
	}
}
EOF_CONF

# Process orchestration
cmd:background:seq=1:exec=ze-peer --port $PORT:stdin=peer
cmd:foreground:seq=2:exec=ze bgp server -:stdin=ze-bgp:timeout=10s
