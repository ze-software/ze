# Test: rpki-decorator graceful degradation when RPKI times out
# VALIDATES: AC-4: UPDATE emitted as update-rpki without rpki section on timeout
# VALIDATES: AC-7: rpki plugin not responding, decorator delivers UPDATE data only
# PREVENTS: Decorator blocking on missing rpki events, consumer never getting data

# ze-peer: send one route, no RTR server → rpki validation unavailable
stdin=peer:terminator=EOF_PEER
option=tcp_connections:value=1
option=timeout:value=20s
option=update:value=send-route:prefix=10.0.0.0/24:origin-as=65001:next-hop=10.0.0.1
# EOR from ze
expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF00170200000000
EOF_PEER

# Python test plugin: subscribes to update-rpki, verifies UPDATE data without rpki section
tmpfs=rpki-to-test.run:mode=755:terminator=EOF_RUN
#!/usr/bin/env python3
import json
import sys
import time
from ze_api import API

def dispatch(api, command):
    resp = api._call_engine(
        'ze-plugin-engine:dispatch-command', {'command': command})
    if resp is None:
        return {'status': 'error', 'data': 'engine call returned None'}
    return resp.get('result', {})

def main():
    api = API()
    api.declare_done()
    api.wait_for_config()
    api.capability_done()
    api.wait_for_registry()

    # Subscribe to update-rpki events
    api.ready()

    # Wait for UPDATE + decorator timeout (2s union timeout + margin)
    time.sleep(8.0)

    try:
        # Collect update-rpki events
        events = []
        for _ in range(20):
            event_str = api.read_line(timeout=0.5)
            if event_str is None:
                continue
            try:
                evt = json.loads(event_str)
            except (json.JSONDecodeError, TypeError):
                continue
            bgp = evt.get('bgp', {})
            msg = bgp.get('message', {})
            if msg.get('type') == 'update-rpki':
                events.append(evt)

        if len(events) == 0:
            print('FAIL: no update-rpki events received after timeout', file=sys.stderr)
            sys.exit(1)

        # Verify events have UPDATE data but no rpki section (timeout graceful degradation)
        for evt in events:
            bgp = evt.get('bgp', {})

            # Must have message type = update-rpki
            msg = bgp.get('message', {})
            if msg.get('type') != 'update-rpki':
                print(f'FAIL: wrong message type: {msg.get("type")}', file=sys.stderr)
                sys.exit(1)

            # Must have update section with route data
            update = bgp.get('update')
            if not isinstance(update, dict) or len(update) == 0:
                print(f'FAIL: update-rpki event missing update section: {json.dumps(evt)}', file=sys.stderr)
                sys.exit(1)

            # rpki section should be absent (no RTR server → no rpki events → timeout)
            if 'rpki' in bgp:
                print(f'WARNING: rpki section present despite no RTR (may be stale)', file=sys.stderr)

        print(f'OK: {len(events)} update-rpki events with UPDATE data, graceful timeout', file=sys.stderr)

    finally:
        dispatch(api, 'daemon shutdown')
        api.wait_for_shutdown()

if __name__ == '__main__':
    main()
EOF_RUN

stdin=ze-bgp:terminator=EOF_CONF
plugin {
	hub {
		server local {
			ip 127.0.0.1;
			port 0;
			secret rpki-timeout-test-secret-0123456789abcdef;
		}
	}
	external rpki-to-test {
		run ./rpki-to-test.run
		encoder json
	}
	external rpki-decorator {
		run "ze plugin bgp-rpki-decorator"
		encoder json
	}
	external adj-rib-in {
		run "ze plugin bgp-adj-rib-in"
		encoder json
	}
}

environment {
	tcp {
		attempts 3
	}
}

bgp {
	peer peer1 {
		connection {
			remote {
				ip 127.0.0.1
				accept false
			}
			local {
				ip 127.0.0.1
			}
		}
		session {
			asn {
				local 1
				remote 1
			}
			router-id 1.2.3.4
			family {
				ipv4/unicast { prefix { maximum 10000; } }
			}
			capability {
				graceful-restart disable
			}
		}
		behavior {
			group-updates disable
		}

		process rpki-to-test {
			receive [ update-rpki ]
		}
		process rpki-decorator {
			receive [ update ]
		}
		process adj-rib-in {
			receive [ update state ]
		}
	}
}
EOF_CONF

# No RTR mock -- rpki plugin not loaded, no rpki events
# Decorator receives UPDATEs only, emits after union timeout
cmd=background:seq=1:exec=ze-peer --port $PORT:stdin=peer
cmd=foreground:seq=2:exec=ze -:stdin=ze-bgp:timeout=30s
expect=exit:code=0
