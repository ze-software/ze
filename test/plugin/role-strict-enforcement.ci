# Test: role plugin strict mode sends NOTIFICATION to peer without role
# VALIDATES: role strict enforcement sends RFC 9234 Role Mismatch NOTIFICATION
# PREVENTS: strict mode silently accepting peers without role capability

# ze-peer expectations
stdin=peer:terminator=EOF_PEER
option=tcp_connections:value=1
option=timeout:value=10s
# Drop role capability (code 9) from ze-peer's OPEN response
option=open:value=drop-capability:code=9
# Expect NOTIFICATION: OPEN Message Error (code 2), Role Mismatch (subcode 11/0x0B, RFC 9234)
expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF001503020B
EOF_PEER

# ze bgp configuration with role strict at peer level
stdin=ze-bgp:terminator=EOF_CONF
bgp {
	peer peer1 {
		remote {
			ip 127.0.0.1
			as 1
		}
		local {
			as 1
			ip 127.0.0.1
		}
		router-id 1.2.3.4
		connection active

		family {
			ipv4/unicast
		}
		role {
			import customer
			strict true
		}
	}
}
EOF_CONF

# Process orchestration
cmd=background:seq=1:exec=ze-peer --port $PORT:stdin=peer
cmd=foreground:seq=2:exec=ze --plugin ze.role -:stdin=ze-bgp:timeout=10s
