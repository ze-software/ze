# Test: prefix-list filter composes in a multi-filter chain with itself
# VALIDATES: AC-11 -- composable in chain with other filters (chain-order proof)
# VALIDATES: Multiple chain refs dispatch in order; short-circuit on reject
# PREVENTS: Regression where a second named filter is silently skipped or
#   where chain order is not preserved.
#
# Flow:
# 1. Two named prefix-lists: ALLOW (permissive) and DENY (explicit reject)
# 2. Peer's import chain: [ bgp-filter-prefix:ALLOW bgp-filter-prefix:DENY ]
#    ALLOW runs first, accepts -> chain continues
#    DENY runs second, rejects -> chain short-circuits
# 3. ze-peer sends UPDATE: NLRI=10.0.0.0/24
# 4. Both filters fire and their Info logs appear in stderr in order
# 5. The final effect is reject (DENY wins by being second)

option=env:var=ze.log.bgp.filter.prefix:value=info

stdin=peer:terminator=EOF_PEER
option=tcp_connections:value=1
option=timeout:value=15s
action=send:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF002F02000000144001010040020602010000FDE940030401010101180A0000
EOF_PEER

# Observer: sleep briefly so both filters fire, then dispatch daemon shutdown.
tmpfs=test-chain.run:mode=755:terminator=EOF_RUN
#!/usr/bin/env python3
import time
from ze_api import API

def main():
    api = API()
    api.declare_done()
    api.wait_for_config()
    api.capability_done()
    api.wait_for_registry()
    api.ready()
    time.sleep(2.0)
    api._call_engine('ze-plugin-engine:dispatch-command', {'command': 'daemon shutdown'})
    api.wait_for_shutdown()

if __name__ == '__main__':
    main()
EOF_RUN

stdin=ze-bgp:terminator=EOF_CONF
plugin {
	external test-chain {
		run ./test-chain.run
		encoder json
	}
}
bgp {
	policy {
		prefix-list ALLOW {
			entry 10.0.0.0/8 {
				ge 16
				le 24
				action accept
			}
		}
		prefix-list DENY {
			entry 10.0.0.0/8 {
				ge 16
				le 24
				action reject
			}
		}
	}

	peer peer1 {
		connection {
			remote {
				ip 127.0.0.1
				accept false
			}
			local {
				ip 127.0.0.1
			}
		}
		session {
			asn {
				local 65000
				remote 65001
			}
			router-id 1.2.3.4
			family {
				ipv4/unicast { prefix { maximum 10000; } }
			}
		}

		filter {
			import [ bgp-filter-prefix:ALLOW bgp-filter-prefix:DENY ]
		}
	}
}
EOF_CONF

cmd=background:seq=1:exec=ze-peer --port $PORT:stdin=peer
cmd=foreground:seq=2:exec=ze --plugin ze.bgp-filter-prefix -:stdin=ze-bgp:timeout=15s
expect=exit:code=0
# ALLOW fires first (prefix-list accept with filter=ALLOW)
expect=stderr:pattern=prefix-list accept
expect=stderr:pattern=filter=ALLOW
# DENY fires second and rejects (prefix-list reject with filter=DENY)
expect=stderr:pattern=prefix-list reject
expect=stderr:pattern=filter=DENY
