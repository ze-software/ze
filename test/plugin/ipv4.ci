# Migrated from test/data/plugin/ipv4.*

# ze-peer expectations
stdin=peer:terminator=EOF_PEER
# Test: IPv4 unicast announce/withdraw with JSON format documentation
# JSON format: {"ipv4/unicast":[{"next-hop":"...","action":"add|del","nlri":["..."]}]}
cmd=api:conn=1:seq=1:text=peer * update text origin igp local-preference 200 nhop 10.0.1.254 nlri ipv4/unicast add 10.0.1.0/24
expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF00300200000015400101004002004003040A0001FE400504000000C8180A0001
expect=json:conn=1:seq=1:json={"meta":{"version":"1.0.0","format":"ze-bgp"},"message":{"type":"update"},"peer":{"address":"127.0.0.1","remote":{"as":65533}},"direction":"in","local-preference":200,"origin":"igp","ipv4/unicast":[{"action":"add","nlri":["10.0.1.0/24"],"next-hop":"10.0.1.254"}]}
cmd=api:conn=1:seq=2:text=peer * update text nlri ipv4/unicast eor
expect=bgp:conn=1:seq=2:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF00170200000000
cmd=api:conn=1:seq=3:text=peer * update text nlri ipv4/unicast del 10.0.1.0/24
expect=bgp:conn=1:seq=3:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF001B020004180A00010000
expect=json:conn=1:seq=3:json={"meta":{"version":"1.0.0","format":"ze-bgp"},"message":{"type":"update"},"peer":{"address":"127.0.0.1","remote":{"as":65533}},"direction":"in","ipv4/unicast":[{"action":"del","nlri":["10.0.1.0/24"]}]}
EOF_PEER

# Python plugin script
tmpfs=ipv4.run:mode=755:terminator=EOF_RUN
#!/usr/bin/env python3

import time

from ze_api import ready, send, wait_for_ack, wait_for_shutdown


def main() -> None:
    ready()

    # Test unicast functionality using update text syntax (Step 5: bgp peer prefix required)
    announce_unicast = 'peer * update text origin igp local-preference 200 nhop 10.0.1.254 nlri ipv4/unicast add 10.0.1.0/24'
    withdraw_unicast = 'peer * update text nlri ipv4/unicast del 10.0.1.0/24'

    messages = [
        announce_unicast,
        withdraw_unicast,
    ]

    for message in messages:
        send(message)
        time.sleep(0.2)

    wait_for_ack(expected_count=2)
    wait_for_shutdown()


if __name__ == '__main__':
    main()
EOF_RUN

# ze bgp configuration
stdin=ze-bgp:terminator=EOF_CONF
plugin {
	external announce-routes {
		run ./ipv4.run
		encoder json
	}
}
bgp {
	peer peer1 {
		connection {
			remote {
				ip 127.0.0.1
			}
			local {
				ip 127.0.0.1
				accept false
			}
		}
		session {
			asn {
				local 65000
				remote 65000
			}
			router-id 10.0.0.1
			family {
				ipv4/unicast { prefix { maximum 10000; } }
			}
			capability {
				graceful-restart
			}
		}
		behavior {
			group-updates disable
		}
	
		process announce-routes {
		}
	}
}
EOF_CONF

# Process orchestration
cmd=background:seq=1:exec=ze-peer --port $PORT:stdin=peer
cmd=foreground:seq=2:exec=ze -:stdin=ze-bgp:timeout=10s
