# Test: redistribute-l2tp -- L2TP route-change add event becomes a BGP UPDATE.
# VALIDATES: AC-6 -- with redistribute import l2tp configured, peer receives
#            UPDATE with /32 NLRI + NEXT_HOP=127.0.0.1 + origin=incomplete.
# VALIDATES: AC-1 -- IPCP-up emits (l2tp, route-change) batch (fakel2tp
#            drives the same typed handle the real observer uses).
# PREVENTS: L2TP route-change events not reaching bgp-redistribute, or
#           auto-load regression silently dropping the egress path.

# ze-peer expectations
stdin=peer:terminator=EOF_PEER
option=tcp_connections:value=1
option=timeout:value=15s
# UPDATE for 10.0.0.1/32 with NEXT_HOP=127.0.0.1 (peer's local session address)
expect=json:conn=1:seq=1:json={"meta":{"version":"1.0.0","format":"ze-bgp"},"message":{"type":"update"},"peer":{"address":"127.0.0.1","remote":{"as":65533}},"direction":"in","origin":"incomplete","ipv4/unicast":[{"action":"add","nlri":["10.0.0.1/32"],"next-hop":"127.0.0.1"}]}
EOF_PEER

# Python observer plugin: drive `fakel2tp emit add` via dispatch-command, then exit.
tmpfs=l2tp-announce-test.run:mode=755:terminator=EOF_RUN
#!/usr/bin/env python3
import time
from ze_api import API, runtime_fail


def dispatch(api, command):
    return api._call_engine('ze-plugin-engine:dispatch-command', {'command': command}) or {}


def main():
    api = API()
    api.declare_done()
    api.wait_for_config()
    api.capability_done()
    api.wait_for_registry()
    api.ready()

    # Wait for BGP session up so the UPDATE has a destination peer.
    time.sleep(2.0)

    resp = dispatch(api, 'fakel2tp emit add ipv4/unicast 10.0.0.1/32')
    result = resp.get('result', {})
    if result.get('status') != 'done':
        runtime_fail(f'fakel2tp emit failed: {result}')
        return

    # Give the consumer + reactor time to dispatch the UPDATE.
    time.sleep(2.0)
    dispatch(api, 'daemon shutdown')
    api.wait_for_shutdown()


if __name__ == '__main__':
    main()
EOF_RUN

# ze configuration
stdin=ze-bgp:terminator=EOF_CONF
plugin {
	external l2tp-announce-test {
		run ./l2tp-announce-test.run
		encoder json
	}
	external bgp-redistribute-egress {
		use bgp-redistribute-egress
		encoder json
	}
	external fakel2tp {
		use fakel2tp
		encoder json
	}
}

redistribute {
	import l2tp {
		family [ ipv4/unicast ];
	}
}

bgp {
	peer peer1 {
		connection {
			remote {
				ip 127.0.0.1
			}
			local {
				ip 127.0.0.1
				accept false
			}
		}
		session {
			asn {
				local 65533
				remote 65533
			}
			router-id 1.2.3.4
			family {
				ipv4/unicast { prefix { maximum 10000; } }
			}
			capability {
				graceful-restart disable
			}
		}
		behavior {
			group-updates disable
		}
	}
}
EOF_CONF

# Process orchestration
cmd=background:seq=1:exec=ze-peer --port $PORT:stdin=peer
cmd=foreground:seq=2:exec=ze -:stdin=ze-bgp:timeout=15s
expect=exit:code=0
