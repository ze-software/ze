# Test: reactor Bus subscription lifecycle — clean start/stop with Bus infrastructure
# VALIDATES: AC-6 — no handlers registered, no subscriptions, reactor starts and stops cleanly
# VALIDATES: Bus topic creation + publish (bgp/state on peer-up) + unsubscribe on shutdown
# PREVENTS: Bus lifecycle breaking reactor startup or shutdown

# ze-peer expectations
stdin=peer:terminator=EOF_PEER
option=tcp_connections:value=1
option=timeout:value=15s
expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF00170200000000
EOF_PEER

# Python test plugin: establishes session, sends EOR, triggers clean shutdown
tmpfs=bus-test.run:mode=755:terminator=EOF_RUN
#!/usr/bin/env python3
import sys
import time
from ze_api import API

def dispatch(api, command):
    resp = api._call_engine(
        'ze-plugin-engine:dispatch-command', {'command': command})
    if resp is None:
        return {'status': 'error', 'data': 'engine call returned None'}
    return resp.get('result', {})

def main():
    api = API()
    api.declare_done()
    api.wait_for_config()
    api.capability_done()
    api.wait_for_registry()
    api.ready()
    time.sleep(1.0)

    try:
        # Send EOR to exercise the full BGP session lifecycle,
        # which triggers Bus publish (bgp/state peer-up, bgp/negotiated).
        result = dispatch(api, 'peer * update text nlri ipv4/unicast eor')
        if result.get('status') != 'done':
            print(f'FAIL: EOR status={result.get("status")}', file=sys.stderr)
            sys.exit(1)

        print('OK: Bus lifecycle — session established, EOR sent', file=sys.stderr)
    finally:
        dispatch(api, 'daemon shutdown')
        api.wait_for_shutdown()

if __name__ == '__main__':
    main()
EOF_RUN

# ze bgp configuration
stdin=ze-bgp:terminator=EOF_CONF
plugin {
	external bus-test {
		run ./bus-test.run
		encoder json
	}
}

environment {
	tcp {
		attempts 3
	}
}

bgp {
	peer peer1 {
		remote {
			ip 127.0.0.1
			as 1
			accept false
		}
		local {
			as 1
			ip 127.0.0.1
		}
		router-id 1.2.3.4
		group-updates disable

		family {
			ipv4/unicast { prefix { maximum 10000; } }
		}
		capability {
			graceful-restart disable
		}
		process bus-test {
		}
	}
}
EOF_CONF

# Process orchestration
cmd=background:seq=1:exec=ze-peer --port $PORT:stdin=peer
cmd=foreground:seq=2:exec=ze -:stdin=ze-bgp:timeout=15s
expect=exit:code=0
