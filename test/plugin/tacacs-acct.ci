# Test: TACACS+ accounting sends START/STOP records for command execution
#
# Flow:
# 1. ze-test tacacs-mock logs every received packet (incl. ACCT START/STOP)
# 2. Daemon authenticates admin via TACACS+ and has accounting enabled
# 3. ze cli -c "summary" triggers the Dispatcher accounting hook
# 4. Mock log shows at least one "ACCT START" and one "ACCT STOP"
#
# VALIDATES: AC-8 -- TACACS+ accounting enabled, command executed => ACCT start+stop sent.
# PREVENTS: Accounting hook installed but never dispatching to the configured backend.

tmpfs=test-tacacs-acct.sh:mode=755:terminator=EOF_SH
#!/bin/sh
set -e

touch daemon.ready

ze-test tacacs-mock --port 0 --key ze-mock-key \
	--user admin:testpass:15 --addr-file mock.addr 2>mock.log &
MOCK_PID=$!
trap 'kill $MOCK_PID 2>/dev/null || true; wait $MOCK_PID 2>/dev/null || true' EXIT

MOCK_ADDR=""
for i in $(seq 1 30); do
	if [ -s mock.addr ]; then
		MOCK_ADDR=$(cat mock.addr)
		break
	fi
	sleep 0.1
done
if [ -z "$MOCK_ADDR" ]; then
	echo "FAIL: mock did not report address" >&2
	cat mock.log >&2
	exit 1
fi
MOCK_IP=$(echo "$MOCK_ADDR" | cut -d: -f1)
MOCK_PORT=$(echo "$MOCK_ADDR" | cut -d: -f2)
echo "mock at $MOCK_ADDR" >&2

cat > tacacs-acct.conf <<ZECONF
bgp {
	peer peer1 {
		connection {
			remote { ip 127.0.0.1; accept false; }
			local  { ip 127.0.0.1; }
		}
		session { asn { local 65533; remote 65533; } }
	}
}

system {
	authentication {
		tacacs {
			server ${MOCK_IP} { port ${MOCK_PORT}; key "ze-mock-key"; }
			timeout 2;
			accounting true;
		}
		tacacs-profile 15 { profile [ admin ]; }
	}
	authorization {
		profile admin { run { default-action allow; } edit { default-action allow; } }
	}
}

environment {
	ssh {
		enabled true
		server main { ip 127.0.0.1; port 0; }
	}
}
ZECONF

export ze_bgp_tcp_port=$((10000 + ($$ % 50000)))

ze tacacs-acct.conf 2>daemon.log &
DAEMON_PID=$!
trap 'kill $DAEMON_PID 2>/dev/null || true; wait $DAEMON_PID 2>/dev/null || true; kill $MOCK_PID 2>/dev/null || true; wait $MOCK_PID 2>/dev/null || true' EXIT

SSH_PORT=""
for i in $(seq 1 50); do
	SSH_PORT=$(grep -o '127\.0\.0\.1:[0-9]*' daemon.log 2>/dev/null | head -1 | cut -d: -f2 || true)
	if [ -n "$SSH_PORT" ]; then
		break
	fi
	sleep 0.2
done
if [ -z "$SSH_PORT" ]; then
	echo "FAIL: SSH server did not start" >&2
	cat daemon.log >&2
	exit 1
fi
echo "ssh on :$SSH_PORT" >&2

sleep 0.5

ADMIN_DIR=$(mktemp -d)
trap 'rm -rf "$ADMIN_DIR"; kill $DAEMON_PID 2>/dev/null || true; wait $DAEMON_PID 2>/dev/null || true; kill $MOCK_PID 2>/dev/null || true; wait $MOCK_PID 2>/dev/null || true' EXIT
printf 'admin\ntestpass\n127.0.0.1\n%s\n' "$SSH_PORT" | ZE_CONFIG_DIR="$ADMIN_DIR" ze init >/dev/null

OUTPUT=$(ZE_CONFIG_DIR="$ADMIN_DIR" ZE_SSH_PASSWORD="testpass" ze cli -c "summary" 2>&1) || {
	echo "FAIL: 'summary' via TACACS+ auth" >&2
	echo "OUTPUT: $OUTPUT" >&2
	echo "--- daemon log ---" >&2
	cat daemon.log >&2
	exit 1
}
echo "OK: summary ran via TACACS+ auth" >&2

# Give the accounting worker time to send both START and STOP over its
# buffered channel before we assert.
sleep 0.8

# Replay mock log so the .ci runner's expect=stderr:pattern can see it.
cat mock.log >&2

exit 0
EOF_SH

cmd=foreground:seq=1:exec=./test-tacacs-acct.sh:timeout=20s
expect=exit:code=0
# Mock logs "tacacs-mock: ACCT START" on receiving a START flag packet, and
# "tacacs-mock: ACCT STOP" on the matching STOP flag. Both MUST appear.
expect=stderr:pattern=tacacs-mock: ACCT START
expect=stderr:pattern=tacacs-mock: ACCT STOP
