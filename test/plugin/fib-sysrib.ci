# Test: System RIB selects best route across protocols by admin distance
#
# Flow:
# 1. Inject routes via rib inject (simulating BGP routes)
# 2. Dispatch "sysrib show" to verify system RIB received events
# 3. Verify correct protocol and priority in output
#
# VALIDATES: AC-4 -- System RIB receives and selects by priority
# VALIDATES: AC-18 -- ze show rib shows system RIB best routes
# PREVENTS: sysrib plugin not wired into Bus

# ze-peer expectations
stdin=peer:terminator=EOF_PEER
option=tcp_connections:value=1
option=timeout:value=15s
expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF00170200000000
EOF_PEER

# Python test plugin
tmpfs=fib-sysrib-test.run:mode=755:terminator=EOF_RUN
#!/usr/bin/env python3
"""Test: System RIB receives BGP best-path events via Bus."""

import json
import sys
import time

from ze_api import API


failures = 0


def dispatch(api, command):
    resp = api._call_engine(
        'ze-plugin-engine:dispatch-command', {'command': command})
    if resp is None:
        return {'status': 'error', 'data': 'engine call returned None'}
    return resp.get('result', {})


def check(label, result, expected_status):
    global failures
    actual = result.get('status')
    if actual != expected_status:
        print(f'FAIL {label}: expected status={expected_status}, got={actual}', file=sys.stderr)
        print(f'  data: {result.get("data", "")[:200]}', file=sys.stderr)
        failures += 1
    else:
        print(f'OK {label}: status={actual}', file=sys.stderr)


def wait_for_rib(api):
    for _ in range(20):
        r = dispatch(api, 'rib status')
        if r.get('status') == 'done':
            return True
        time.sleep(0.5)
    return False


def main():
    global failures
    api = API()
    api.declare_done()
    api.wait_for_config()
    api.capability_done()
    api.wait_for_registry()
    api.ready()

    time.sleep(1.0)
    if not wait_for_rib(api):
        print('FAIL: rib plugin did not become ready', file=sys.stderr)
        sys.exit(1)

    # Inject a route to trigger best-path tracking and Bus event.
    r = dispatch(api, 'rib inject 10.0.0.1 ipv4/unicast 10.20.0.0/24 origin igp')
    check('inject-route', r, 'done')

    # Wait for Bus event propagation to sysrib.
    time.sleep(2.0)

    # Query sysrib.
    r = dispatch(api, 'sysrib show')
    check('sysrib-show', r, 'done')
    data_str = r.get('data', '')
    try:
        entries = json.loads(data_str)
        if not isinstance(entries, list):
            entries = []
        found = any(e.get('prefix') == '10.20.0.0/24' for e in entries)
        if not found:
            print(f'FAIL sysrib-entry: 10.20.0.0/24 not in sysrib output: {data_str[:300]}', file=sys.stderr)
            failures += 1
        else:
            print('OK sysrib-entry: 10.20.0.0/24 found in system RIB', file=sys.stderr)
    except (json.JSONDecodeError, TypeError):
        print(f'FAIL sysrib-parse: {data_str[:200]}', file=sys.stderr)
        failures += 1

    # Shutdown
    if failures > 0:
        print(f'\n{failures} failures', file=sys.stderr)
    dispatch(api, 'daemon shutdown')
    api.wait_for_shutdown()

    if failures > 0:
        sys.exit(1)


if __name__ == '__main__':
    main()
EOF_RUN

# ze bgp configuration
stdin=ze-bgp:terminator=EOF_CONF
plugin {
	external fib-sysrib-test {
		run ./fib-sysrib-test.run
		encoder json
	}
	external rib {
		run "ze plugin bgp-rib"
		encoder json
	}
	external sysrib {
		run "ze plugin sysrib"
		encoder json
	}
}

environment {
	tcp {
		attempts 3
	}
}

bgp {
	peer peer1 {
		connection {
			remote {
				ip 127.0.0.1
				accept false
			}
			local {
				ip 127.0.0.1
			}
		}
		session {
			asn {
				local 1
				remote 1
			}
			router-id 1.2.3.4
			family {
				ipv4/unicast { prefix { maximum 10000; } }
			}
			capability {
				graceful-restart disable
			}
		}
		behavior {
			group-updates disable
		}

		process fib-sysrib-test {
		}
		process rib {
		}
		process sysrib {
		}
	}
}
EOF_CONF

cmd=background:seq=1:exec=ze-peer --port $PORT:stdin=peer
cmd=foreground:seq=2:exec=ze -:stdin=ze-bgp:timeout=15s
expect=exit:code=0
