# Test: rib inject inserts route into Adj-RIB-In
# VALIDATES: rib inject dispatches through engine to bgp-rib plugin and route is queryable
# PREVENTS: rib inject proxy handler broken or not reaching plugin

# ze-peer expectations
stdin=peer:terminator=EOF_PEER
option=tcp_connections:value=1
option=timeout:value=15s
expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF00170200000000
EOF_PEER

# Python test plugin: exercises dispatch-command for rib inject + rib show
tmpfs=rib-inject-test.run:mode=755:terminator=EOF_RUN
#!/usr/bin/env python3
import sys
import json
import time
from ze_api import API

def dispatch(api, command):
    resp = api._call_engine(
        'ze-plugin-engine:dispatch-command', {'command': command})
    if resp is None:
        return {'status': 'error', 'data': 'engine call returned None'}
    return resp.get('result', {})

def main():
    api = API()
    api.declare_done()
    api.wait_for_config()
    api.capability_done()
    api.wait_for_registry()
    api.ready()
    time.sleep(1.0)

    try:
        # Inject a route
        result = dispatch(api, 'bgp rib inject 10.0.0.99 ipv4/unicast 192.168.1.0/24 origin igp aspath 64500,64501')
        if result.get('status') != 'done':
            print(f'FAIL: rib inject status={result.get("status")} data={result.get("data")}', file=sys.stderr)
            sys.exit(1)

        data = result.get('data', '')
        if '192.168.1.0/24' not in data:
            print(f'FAIL: inject response missing prefix: {data}', file=sys.stderr)
            sys.exit(1)

        # Verify route appears in rib show
        result = dispatch(api, 'bgp rib show received')
        if result.get('status') != 'done':
            print(f'FAIL: rib show status={result.get("status")}', file=sys.stderr)
            sys.exit(1)

        show_data = result.get('data', '')
        if '192.168.1.0/24' not in show_data:
            print(f'FAIL: injected route not in rib show: {show_data[:200]}', file=sys.stderr)
            sys.exit(1)

        print('OK: rib inject + show verified', file=sys.stderr)
    finally:
        dispatch(api, 'daemon shutdown')
        api.wait_for_shutdown()

if __name__ == '__main__':
    main()
EOF_RUN

# ze bgp configuration
stdin=ze-bgp:terminator=EOF_CONF
plugin {
	external rib-inject-test {
		run ./rib-inject-test.run
		encoder json
	}
	external bgp-rib {
		use bgp-rib
		encoder json
	}
}

bgp {
	peer peer1 {
		connection {
			remote {
				ip 127.0.0.1
			}
			local {
				ip 127.0.0.1
				accept false
			}
		}
		session {
			asn {
				local 1
				remote 1
			}
			router-id 1.2.3.4
			family {
				ipv4/unicast { prefix { maximum 10000; } }
			}
			capability {
				graceful-restart disable
			}
		}
		behavior {
			group-updates disable
		}

		process rib-inject-test {
		}
		process bgp-rib {
			receive [ state ]
			send [ update ]
		}
	}
}
EOF_CONF

# Process orchestration
cmd=background:seq=1:exec=ze-peer --port $PORT:stdin=peer
cmd=foreground:seq=2:exec=ze -:stdin=ze-bgp:timeout=15s
expect=exit:code=0
