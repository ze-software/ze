# Test: prefix-list filter chain refs in short forms (type prefix, plain name)
# VALIDATES: ISSUE 6 fix -- users can write `prefix-list:NAME` or plain `NAME`
#   instead of the full `bgp-filter-prefix:NAME` plugin-process form.
# VALIDATES: Framework's FilterTypes resolver canonicalizes refs at parse time.
# PREVENTS: Regression where the canonicalizer drops a form or resolves to the
#   wrong plugin.
#
# Flow:
# 1. Config defines one prefix-list CUSTOMERS.
# 2. Two peers share the list via different ref forms:
#    - peer1 uses `prefix-list:CUSTOMERS` (filter-type prefix form)
#    - peer2 uses `CUSTOMERS` (plain, no prefix)
# 3. ze-peer sends UPDATE: NLRI=10.0.0.0/24 to both peers.
# 4. Both peers should invoke bgp-filter-prefix with filter=CUSTOMERS and accept.
# 5. Two "prefix-list accept" Info logs must appear in stderr (one per peer).

option=env:var=ze.log.bgp.filter.prefix:value=info

stdin=peer:terminator=EOF_PEER
option=tcp_connections:value=1
option=timeout:value=15s
action=send:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF002F02000000144001010040020602010000FDE940030401010101180A0000
EOF_PEER

# Observer: sleep briefly so the filter fires, then dispatch daemon shutdown.
tmpfs=test-shortform.run:mode=755:terminator=EOF_RUN
#!/usr/bin/env python3
import time
from ze_api import API

def main():
    api = API()
    api.declare_done()
    api.wait_for_config()
    api.capability_done()
    api.wait_for_registry()
    api.ready()
    time.sleep(2.0)
    api._call_engine('ze-plugin-engine:dispatch-command', {'command': 'daemon shutdown'})
    api.wait_for_shutdown()

if __name__ == '__main__':
    main()
EOF_RUN

stdin=ze-bgp:terminator=EOF_CONF
plugin {
	external test-shortform {
		run ./test-shortform.run
		encoder json
	}
}
bgp {
	policy {
		prefix-list CUSTOMERS {
			entry 10.0.0.0/8 {
				ge 16
				le 24
				action accept
			}
		}
	}

	peer peer1 {
		connection {
			remote {
				ip 127.0.0.1
				accept false
			}
			local {
				ip 127.0.0.1
			}
		}
		session {
			asn {
				local 65000
				remote 65001
			}
			router-id 1.2.3.4
			family {
				ipv4/unicast { prefix { maximum 10000; } }
			}
		}

		# Filter-type prefix form: `prefix-list` resolves to bgp-filter-prefix.
		filter {
			import [ prefix-list:CUSTOMERS ]
		}
	}
}
EOF_CONF

cmd=background:seq=1:exec=ze-peer --port $PORT:stdin=peer
cmd=foreground:seq=2:exec=ze --plugin ze.bgp-filter-prefix -:stdin=ze-bgp:timeout=15s
expect=exit:code=0
# The filter-type-prefix form dispatched to the prefix filter plugin.
expect=stderr:pattern=prefix-list accept
expect=stderr:pattern=filter=CUSTOMERS
reject=stderr:pattern=unknown plugin
