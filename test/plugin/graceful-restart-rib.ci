# Test: Graceful Restart + RIB plugins combined
#
# This test verifies GR and RIB plugins work together:
# 1. GR capability parses from config (restart-time 120)
# 2. Static routes sent on connection A
# 3. RIB stores routes
# 4. After reconnect, RIB replays stored routes
#
# This is the original graceful-restart test behavior with both plugins.

# ze-peer expectations
stdin=peer:terminator=EOF_PEER
option=tcp_connections:value=2
option=timeout:value=15s

# Connection A: Static route + EOR
expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF00300200000015400101004002004003040A0000014005040000006418C0A801
expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF00170200000000
action=notification:conn=1:seq=2:text=Peer Reset

# Connection B: Static route + RIB replay + EOR
# NOTE: Both static route (from config) and RIB replay (stored from conn A) are sent
expect=bgp:conn=2:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF00300200000015400101004002004003040A0000014005040000006418C0A801
expect=bgp:conn=2:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF00300200000015400101004002004003040A0000014005040000006418C0A801
expect=bgp:conn=2:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF00170200000000
EOF_PEER

# ze bgp configuration
stdin=ze-bgp:terminator=EOF_CONF
plugin {
	external gr {
		run "ze plugin bgp-gr"
		encoder json
	}
	external rib {
		run "ze plugin bgp-rib"
		encoder json
	}
}

environment {
	tcp {
		attempts 3
	}
}

bgp {
	peer 127.0.0.1 {
		router-id 1.2.3.4
		local-address 127.0.0.1
		local-as 1
		peer-as 1
		connection active
		group-updates disable

		family {
			ipv4/unicast
		}
		capability {
			graceful-restart {
				restart-time 120
			}
		}

		update {
			attribute {
				origin igp
				local-preference 100
				next-hop 10.0.0.1
			}
			nlri {
				ipv4/unicast add 192.168.1.0/24
			}
		}

		process gr {
			send [ update ]
		}
		process rib {
			send [ update ]
		}
	}
}
EOF_CONF

# Process orchestration
cmd=background:seq=1:exec=ze-peer --port $PORT:stdin=peer
cmd=foreground:seq=2:exec=ze -:stdin=ze-bgp:timeout=20s
