# Test: bgp peer remove dynamically removes a peer
# VALIDATES: peer add then remove, verified absent by subsequent peer list
# PREVENTS: peer remove silently failing or leaving stale entries

# ze-peer expectations
stdin=peer:terminator=EOF_PEER
option=tcp_connections:value=1
option=timeout:value=15s
expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF00170200000000
EOF_PEER

# Python test plugin: exercises dispatch-command for peer add+remove
tmpfs=peer-remove-test.run:mode=755:terminator=EOF_RUN
#!/usr/bin/env python3
import json
import sys
import time
from ze_api import API

def dispatch(api, command):
    resp = api._call_engine(
        'ze-plugin-engine:dispatch-command', {'command': command})
    if resp is None:
        return {'status': 'error', 'data': 'engine call returned None'}
    return resp.get('result', {})

def main():
    api = API()
    api.declare_done()
    api.wait_for_config()
    api.capability_done()
    api.wait_for_registry()
    api.ready()
    time.sleep(1.0)

    try:
        result = dispatch(api, 'peer 10.0.0.99 add asn 2 local-as 1')
        if result.get('status') != 'done':
            print(f'FAIL: add status={result.get("status")}', file=sys.stderr)
            sys.exit(1)
        time.sleep(0.5)

        result = dispatch(api, 'peer 10.0.0.99 remove')
        if result.get('status') != 'done':
            print(f'FAIL: remove status={result.get("status")}', file=sys.stderr)
            sys.exit(1)

        # Verify the peer is gone
        result = dispatch(api, 'peer * list')
        data = result.get('data', {})
        if isinstance(data, str):
            data = json.loads(data)
        peers = data.get('peers', {})
        if '10.0.0.99' in peers:
            print(f'FAIL: 10.0.0.99 still in peers after remove', file=sys.stderr)
            sys.exit(1)

        print('OK: peer add+remove verified', file=sys.stderr)
    finally:
        dispatch(api, 'daemon shutdown')
        api.wait_for_shutdown()

if __name__ == '__main__':
    main()
EOF_RUN

# ze bgp configuration
stdin=ze-bgp:terminator=EOF_CONF
plugin {
	external peer-remove-test {
		run ./peer-remove-test.run
		encoder json
	}
}

environment {
	tcp {
		attempts 3
	}
}

bgp {
	peer peer1 {
		remote {
			ip 127.0.0.1
			as 1
		}
		local {
			as 1
			ip 127.0.0.1
		}
		router-id 1.2.3.4
		connection active
		group-updates disable

		family {
			ipv4/unicast { prefix { maximum 10000; } }
		}
		capability {
			graceful-restart disable
		}
		process peer-remove-test {
		}
	}
}
EOF_CONF

# Process orchestration
cmd=background:seq=1:exec=ze-peer --port $PORT:stdin=peer
cmd=foreground:seq=2:exec=ze -:stdin=ze-bgp:timeout=15s
expect=exit:code=0
