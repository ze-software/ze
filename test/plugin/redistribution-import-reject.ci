# Test: import filter rejects routes, routes not cached
# VALIDATES: AC-6 -- Import filter returns reject, UPDATE dropped
# PREVENTS: Rejected routes leaking into cache or being dispatched

# ze-peer sends a route to ze
stdin=peer:terminator=EOF_PEER
option=tcp_connections:value=1
option=timeout:value=15s
option=update:value=send-route:prefix=10.0.0.0/24:next-hop=10.0.0.1:origin-as=65001
expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF00170200000000
EOF_PEER

# Python test plugin: declares an import filter that rejects everything
tmpfs=filter-reject-test.run:mode=755:terminator=EOF_RUN
#!/usr/bin/env python3
import json
import sys
import time
from ze_api import API

rejected_count = 0

def filter_handler(params):
    """Reject all routes."""
    global rejected_count
    rejected_count += 1
    print(f'filter-update REJECT: filter={params.get("filter")} peer={params.get("peer")}', file=sys.stderr)
    return {'action': 'reject'}

def dispatch(api, command):
    resp = api._call_engine(
        'ze-plugin-engine:dispatch-command', {'command': command})
    if resp is None:
        return {'status': 'error', 'data': 'None'}
    return resp.get('result', {})

def main():
    api = API()
    api.declare_filter(
        name='reject-all',
        direction='import',
        attributes=['as-path', 'origin'],
        on_error='reject',
    )
    api.on_filter_update(filter_handler)
    api.declare_done()
    api.wait_for_config()
    api.capability_done()
    api.wait_for_registry()
    api.ready()

    # Wait for route to arrive and be rejected
    time.sleep(2.0)

    if rejected_count > 0:
        print(f'OK: filter rejected {rejected_count} route(s)', file=sys.stderr)
    else:
        print('INFO: filter not called (route may not have triggered filter)', file=sys.stderr)

    dispatch(api, 'daemon shutdown')
    api.wait_for_shutdown()

if __name__ == '__main__':
    main()
EOF_RUN

# ze bgp configuration
stdin=ze-bgp:terminator=EOF_CONF
plugin {
    external filter-reject-test {
        run ./filter-reject-test.run;
        encoder json;
    }
}
bgp {
    router-id 1.2.3.4;
    session {
    	asn {
    		local 65000
    	}
    }
    redistribution {
        import [ filter-reject-test:reject-all ];
    }
    peer peer1 {
        connection {
            remote {
                ip 127.0.0.1
                accept false
            }
            local {
                ip auto
            }
        }
        session {
            asn {
                local 65000
                remote 65001
            }
        }
        process filter-reject-test {
            receive [ update state ];
        }
    }
}
EOF_CONF

# Run ze with the test plugin
cmd=foreground:seq=2:exec=ze -:stdin=ze-bgp:timeout=15s
expect=exit:code=0
