# ze-peer expectations
stdin=peer:terminator=EOF_PEER
cmd=api:conn=1:seq=1:text=bgp peer * update text nlri ipv4/unicast eor
expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF00170200000000
cmd=api:conn=1:seq=1:text=bgp peer * update text origin igp local-preference 100 nhop 101.1.101.1 nlri ipv4/unicast add 1.1.0.0/24
expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF0030020000001540010100400200400304650165014005040000006418010100
cmd=api:conn=1:seq=1:text=bgp peer * update text origin igp local-preference 100 nhop 101.1.101.1 nlri ipv4/unicast add 1.1.0.0/25
expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF003102000000154001010040020040030465016501400504000000641901010000
cmd=api:conn=1:seq=1:text=bgp peer * update text nlri ipv4/unicast del 1.1.0.0/24
expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF001B020004180101000000
cmd=api:conn=1:seq=1:text=bgp peer * update text nlri ipv4/unicast del 1.1.0.0/25
expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF001C02000519010100000000
EOF_PEER

# Python plugin script
tmpfs=add-remove.run:mode=755:terminator=EOF_RUN
#!/usr/bin/env python3

import time

from ze_api import ready, send, wait_for_ack, wait_for_shutdown


def main() -> None:
    ready()

    messages = [
        'bgp peer * update text nhop 101.1.101.1 nlri ipv4/unicast add 1.1.0.0/24',
        'bgp peer * update text nhop 101.1.101.1 nlri ipv4/unicast add 1.1.0.0/25',
        'sleep',
        'bgp peer * update text nlri ipv4/unicast del 1.1.0.0/24',
        'bgp peer * update text nlri ipv4/unicast del 1.1.0.0/25',
    ]

    for message in messages:
        if message == 'sleep':
            time.sleep(0.2)
            continue
        send(message)

    wait_for_ack(expected_count=4)
    wait_for_shutdown()


if __name__ == '__main__':
    main()
EOF_RUN

# ze bgp configuration
stdin=ze-bgp:terminator=EOF_CONF
plugin {
	external add-remove {
		run ./add-remove.run
		encoder json
	}
}
bgp {
	peer 127.0.0.1 {
		router-id 1.2.3.4
		local-address 127.0.0.1
		local-as 1
		peer-as 1
		connection active
		group-updates disable
	
		family {
			ipv4/unicast
		}
		capability {
			graceful-restart
		}
		process add-remove {
		}
	}
}
EOF_CONF

# Process orchestration
cmd=background:seq=1:exec=ze-peer --port $PORT:stdin=peer
cmd=foreground:seq=2:exec=ze -:stdin=ze-bgp:timeout=10s
