# Test: fib-vpp plugin auto-loads and falls back to a noop backend when
#       the VPP subsystem is present but disabled.
#
# VALIDATES: fib-vpp is wired into the config-driven auto-load pipeline
#            (ConfigRoots: ["fib.vpp"]); the mockBackend fallback in
#            runFibVPPPlugin OnStarted runs when GetActiveConnector() is
#            nil; the plugin subscribes to (system-rib, best-change)
#            without panicking.
# PREVENTS:  fib-vpp becoming library-only dead code (the "feature not
#            wired" mistake from memory). If the ConfigRoot changes, the
#            auto-loader path breaks, or the mock fallback is deleted,
#            this test catches it.
#
# Method: spawn ze with a minimal bgp + fib.vpp config; assert the
# plugin's lifecycle log lines appear on stderr within the deadline.
# Follows the bfd-config-load.ci orchestration pattern (subprocess,
# readline loop, SIGTERM on completion).
#
# The vpp subsystem loads (its config block is present) but stays inert
# because vpp.enabled is false; GetActiveConnector() therefore returns
# nil and fib-vpp logs the documented warn line before entering its
# event loop with a mockBackend.

tmpfs=test-fib-vpp-load.py:mode=755:terminator=EOF_PY
#!/usr/bin/env python3
"""Drive ze with a fib.vpp config and assert plugin lifecycle log lines."""

import os
import signal
import subprocess
import sys
import time

REQUIRED = [
    "VPP connector not available, using noop backend",
    "fib-vpp: running",
]

CONFIG = """environment {
}

bgp {
\trouter-id 10.0.0.1;
\tsession { asn { local 65533; } }
}

vpp {
\tenabled false;
}

fib {
\tvpp {
\t\tenabled true;
\t}
}
"""


def main() -> int:
    env = os.environ.copy()
    env["ze.log.fib.vpp"] = "debug"
    env["ze.log.vpp"] = "info"

    proc = subprocess.Popen(
        ["ze", "-"],
        stdin=subprocess.PIPE,
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
        text=True,
        env=env,
    )
    assert proc.stdin is not None
    proc.stdin.write(CONFIG)
    proc.stdin.close()

    deadline = time.time() + 10.0
    captured = ""
    matched: set[str] = set()
    while time.time() < deadline:
        if proc.stderr is None:
            break
        line = proc.stderr.readline()
        if not line:
            if proc.poll() is not None:
                break
            time.sleep(0.05)
            continue
        captured += line
        sys.stderr.write(line)
        sys.stderr.flush()
        for needle in REQUIRED:
            if needle in line:
                matched.add(needle)
        if len(matched) == len(REQUIRED):
            break

    if proc.poll() is None:
        proc.send_signal(signal.SIGTERM)
        try:
            proc.wait(timeout=3.0)
        except subprocess.TimeoutExpired:
            proc.kill()
            proc.wait(timeout=2.0)

    if proc.stderr is not None:
        try:
            tail = proc.stderr.read()
        except (ValueError, OSError):
            tail = ""
        if tail:
            captured += tail
            sys.stderr.write(tail)
            sys.stderr.flush()

    missing = [needle for needle in REQUIRED if needle not in captured]
    if missing:
        sys.stderr.write(f"FAIL: missing required patterns: {missing}\n")
        return 1

    sys.stderr.write("OK: all fib-vpp lifecycle patterns observed\n")
    return 0


if __name__ == "__main__":
    sys.exit(main())
EOF_PY

cmd=foreground:seq=1:exec=python3 ./test-fib-vpp-load.py:timeout=15s
expect=exit:code=0
expect=stderr:pattern=VPP connector not available, using noop backend
expect=stderr:pattern=fib-vpp: running
