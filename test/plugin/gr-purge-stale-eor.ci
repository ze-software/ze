# Test: GR purge-stale on EOR after reconnect
#
# Flow:
# 1. Connection 1: ze sends static route + EOR
# 2. ze-peer sends route to ze (populates ribInPool)
# 3. action=close → TCP drops → GR activates → retain-routes → mark-stale
#    (route from ze-peer is now stale in ribInPool)
# 4. Connection 2: ze reconnects → ribOut replay (static route × 2 + EOR)
# 5. ze-peer sends fresh route + EOR to ze
# 6. ze receives EOR → GR plugin fires purge-stale → old stale routes purged
#
# VALIDATES: AC-7 — GR session down → mark-stale → reconnect → fresh UPDATE → EOR → purge-stale.
# PREVENTS: Stale routes surviving after EOR received from restarting peer.

# ze-peer expectations
stdin=peer:terminator=EOF_PEER
option=tcp_connections:value=2
option=timeout:value=15s

# Connection 1: Static route + EOR from ze
expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF00300200000015400101004002004003040A0000014005040000006418C0A801
expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF00170200000000
# Send a route to ze (populates ribInPool) then close TCP
# Route: 10.0.0.0/24, origin=igp, as-path=[], nhop=10.0.0.2, local-pref=100
action=send:conn=1:seq=2:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF00300200000015400101004002004003040A00000240050400000064180A0000
action=close:conn=1:seq=2

# Connection 2: ribOut replay — static route (config + RIB replay) + EOR
expect=bgp:conn=2:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF00300200000015400101004002004003040A0000014005040000006418C0A801
expect=bgp:conn=2:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF00170200000000
# Send fresh route + EOR (triggers purge-stale for ipv4/unicast)
# Fresh route: 172.16.0.0/24, origin=igp, as-path=[], nhop=10.0.0.2, local-pref=100
action=send:conn=2:seq=2:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF00300200000015400101004002004003040A0000024005040000006418AC1000
# EOR (empty UPDATE) → GR plugin receives eor event → dispatches purge-stale
action=send:conn=2:seq=2:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF00170200000000
EOF_PEER

# ze bgp configuration
stdin=ze-bgp:terminator=EOF_CONF
plugin {
	external gr {
		use bgp-gr
		encoder json
	}
	external bgp-rib {
		use bgp-rib
		encoder json
	}
}

bgp {
	peer peer1 {
		connection {
			remote {
				ip 127.0.0.1
			}
			local {
				ip 127.0.0.1
				accept false
			}
		}
		session {
			asn {
				local 1
				remote 1
			}
			router-id 1.2.3.4
			family {
				ipv4/unicast { prefix { maximum 10000; } }
			}
			capability {
				graceful-restart {
					restart-time 120
				}
			}
		}
		behavior {
			group-updates disable
		}
		timer { connect-retry 5; }


		update {
			attribute {
				origin igp
				local-preference 100
				next-hop 10.0.0.1
			}
			nlri {
				ipv4/unicast add 192.168.1.0/24
			}
		}

		process gr {
			send [ update ]
		}
		process bgp-rib {
			send [ update ]
		}
	}
}
EOF_CONF

# Process orchestration
cmd=background:seq=1:exec=ze-peer --port $PORT:stdin=peer
cmd=foreground:seq=2:exec=ze -:stdin=ze-bgp:timeout=20s
