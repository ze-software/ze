# Test: Family-based auto-load prevention (NOT name-based)
#
# CRITICAL TEST: Verifies auto-load uses FAMILY claims, not plugin names.
#
# Scenario:
# - Config has `family { ipv4/flow; }` which would normally auto-load ze.bgp-nlri-flowspec
# - Config has plugin named "acme-traffic-filter" (unrelated name)
# - Plugin declares `declare family ipv4 flow decode` (claims the family)
# - Expected: Only "acme-traffic-filter" runs, internal flowspec NOT loaded
#
# Why this matters:
# - If name-based: "acme-traffic-filter" != "flowspec" → BOTH load → conflict error
# - If family-based: family claimed → auto-load skipped → success
#
# The plugin name is INFORMATIONAL ONLY. Only family declarations matter.

# ze-peer expectations
stdin=peer:terminator=EOF_PEER
option=open:value=inspect-open-message
# Expect OPEN with ipv4/flow + ipv4/unicast capabilities (bundled in single type-2 param, RFC 5492)
expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF003101040001005A01020304140212010400010085010400010001410400000001
# Expect marker UPDATE from custom plugin: 77.77.77.0/24
# This proves our custom plugin is active (internal flowspec wouldn't send this)
expect=bgp:conn=1:seq=2:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF00300200000015400101004002004003040102030440050400000064184d4d4d
EOF_PEER

# Custom plugin with UNRELATED name that claims flowspec families
tmpfs=acme-traffic-filter.run:mode=755:terminator=EOF_RUN
#!/usr/bin/env python3
"""Custom plugin with unrelated name - proves only family claims matter."""

import sys
import time
from ze_api import API

def main() -> None:
    api = API()

    # Stage 1: Claim flowspec families (this is what prevents auto-load)
    api.declare_family('ipv4', 'flow', mode='decode')
    api.declare_family('ipv6', 'flow', mode='decode')
    api.declare_family('ipv4', 'flow-vpn', mode='decode')
    api.declare_family('ipv6', 'flow-vpn', mode='decode')
    api.declare_family('ipv4', 'unicast')  # For sending marker
    api.declare_done()

    # Stage 2: Receive config
    api.wait_for_config(timeout=5.0)

    # Stage 3: No capabilities
    api.capability_done()

    # Stage 4: Receive registry
    api.wait_for_registry(timeout=5.0)

    # Stage 5: Ready
    api.ready()

    # Send marker UPDATE to prove we're the active plugin
    # Prefix 77.77.77.0/24 (0x4d4d4d) is unique to this plugin
    time.sleep(0.2)
    api.send('peer * update text origin igp local-preference 100 nhop 1.2.3.4 nlri ipv4/unicast add 77.77.77.0/24')
    time.sleep(0.3)

    api.wait_for_shutdown()

if __name__ == '__main__':
    main()
EOF_RUN

# ze bgp configuration
# Plugin name "acme-traffic-filter" has NO relation to "flowspec"
# Only the family declaration matters for auto-load prevention
stdin=ze-bgp:terminator=EOF_CONF
plugin {
    external acme-traffic-filter {
        run ./acme-traffic-filter.run
        encoder json
    }
}
bgp {
    peer peer1 {
    	connection {
    		remote {
    			ip 127.0.0.1
    		}
    		local {
    			ip 127.0.0.1
    			accept false
    		}
    	}
    	session {
    		asn {
    			local 1
    			remote 1
    		}
    		router-id 1.2.3.4
    		family {
    		    ipv4/flow { prefix { maximum 10000; } }
    		    ipv4/unicast { prefix { maximum 10000; } }
    		}
    	}


        process acme-traffic-filter {
            send [ update ]
        }
    }
}
EOF_CONF

# Process orchestration
cmd=background:seq=1:exec=ze-peer --port $PORT:stdin=peer
cmd=foreground:seq=2:exec=ze -:stdin=ze-bgp:timeout=10s
