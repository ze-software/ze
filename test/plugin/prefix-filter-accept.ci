# Test: prefix-list filter accepts matching routes
# VALIDATES: AC-1 -- prefix within ge/le range matches and is accepted
# VALIDATES: AC-9 -- IPv4 prefix matching end-to-end through filter chain
# VALIDATES: AC-11 -- chain reference bgp-filter-prefix:NAME wired correctly
# PREVENTS: Route silently dropped when prefix-list should allow it
#
# Flow:
# 1. ze-peer sends UPDATE: ORIGIN=IGP, AS_PATH=[65001], NEXT_HOP=1.1.1.1, NLRI=10.0.0.0/24
# 2. Filter chain calls bgp-filter-prefix:CUSTOMERS
# 3. prefix-list CUSTOMERS allows 10.0.0.0/8 with ge=16 le=24 -> 10.0.0.0/24 matches -> accept
# 4. Plugin emits Info log "prefix-list accept ... filter=CUSTOMERS"; observer verifies
#    route reached adj-rib-in (count >= 1).

# Enable the bgp.filter.prefix subsystem at Info level so the "prefix-list
# accept" / "prefix-list reject" decision logs are visible in stderr (default
# level is warn).
option=env:var=ze.log.bgp.filter.prefix:value=info

# Source peer sends one matching route
stdin=peer:terminator=EOF_PEER
option=tcp_connections:value=1
option=timeout:value=15s
# Marker(16) + Len=002F(47) + Type=02 + WdLen=0000 + AttrLen=0014(20)
#   ORIGIN: 40010100 (IGP)
#   AS_PATH: 40020602010000FDE9 (AS_SEQ [65001])
#   NEXT_HOP: 40030401010101
#   NLRI: 180A0000 (10.0.0.0/24)
action=send:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF002F02000000144001010040020602010000FDE940030401010101180A0000
EOF_PEER

# Python observer plugin: query adj-rib-in for accepted route
tmpfs=test-prefix-accept.run:mode=755:terminator=EOF_RUN
#!/usr/bin/env python3
"""Verify prefix-list filter accept: matching route lands in adj-rib-in."""
import json
import sys
import time
from ze_api import API

def dispatch(api, command):
    resp = api._call_engine('ze-plugin-engine:dispatch-command', {'command': command})
    return resp.get('result', {})

def main():
    api = API()
    api.declare_done()
    api.wait_for_config()
    api.capability_done()
    api.wait_for_registry()
    api.ready()

    # Wait for session establishment and route processing.
    time.sleep(3.0)

    result = dispatch(api, 'adj-rib-in status')
    data = json.loads(result.get('data', '{}'))
    total = data.get('total-routes', -1)

    if total < 1:
        print(f'FAIL: expected >=1 accepted route, got {total}', file=sys.stderr)
        dispatch(api, 'daemon shutdown')
        api.wait_for_shutdown()
        sys.exit(1)

    print(f'OK: {total} matching route(s) accepted by prefix-list', file=sys.stderr)
    dispatch(api, 'daemon shutdown')
    api.wait_for_shutdown()

if __name__ == '__main__':
    main()
EOF_RUN

# ze configuration: prefix-list + chain reference
stdin=ze-bgp:terminator=EOF_CONF
plugin {
	external test-prefix-accept {
		run ./test-prefix-accept.run
		encoder json
	}
}
bgp {
	policy {
		prefix-list CUSTOMERS {
			entry 10.0.0.0/8 {
				ge 16
				le 24
				action accept
			}
		}
	}

	peer peer1 {
		connection {
			remote {
				ip 127.0.0.1
				accept false
			}
			local {
				ip 127.0.0.1
			}
		}
		session {
			asn {
				local 65000
				remote 65001
			}
			router-id 1.2.3.4
			family {
				ipv4/unicast { prefix { maximum 10000; } }
			}
		}

		filter {
			import [ bgp-filter-prefix:CUSTOMERS ]
		}

		process test-prefix-accept {
			receive [ update state ]
		}
	}
}
EOF_CONF

# Process orchestration
cmd=background:seq=1:exec=ze-peer --port $PORT:stdin=peer
cmd=foreground:seq=2:exec=ze --plugin ze.bgp-filter-prefix --plugin ze.bgp-adj-rib-in -:stdin=ze-bgp:timeout=15s
expect=exit:code=0
# The filter must have been invoked and must have accepted the matching prefix.
# Asserts both the decision path (not just "filter was called") and the specific
# list name used. A bug that skipped dispatch, rejected instead of accepted, or
# dispatched to the wrong filter would all break one of these.
expect=stderr:pattern=prefix-list accept
expect=stderr:pattern=filter=CUSTOMERS
reject=stderr:pattern=prefix-list reject
