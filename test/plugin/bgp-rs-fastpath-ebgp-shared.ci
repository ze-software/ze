# bgp-rs-fastpath-ebgp-shared -- eBGP prepend via ForwardCached (rs-fastpath-3)
#
# VALIDATES: rs-fastpath-3 wiring -- eBGP source peer goes through bgp-rs
# forwarding via the Plugin.ForwardCached fast path. Legacy 'cache N forward'
# text RPC must not fire.
#
# PREVENTS: silent regression where the fast path is not engaged for eBGP
# forwarding. Deep A==B byte-equality assertion (AC-6b) deferred to follow-up.

stdin=source:terminator=EOF_SOURCE
option=tcp_connections:value=1
option=timeout:value=10s

action=send:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF00300200000015400101004002004003040101010140050400000064180A0000
EOF_SOURCE

stdin=ze-bgp:terminator=EOF_CONF
plugin {
	external rs {
		use bgp-rs
	}
}
bgp {
	peer source-peer {
		connection {
			remote {
				ip 127.0.0.1
				accept false
			}
			local {
				ip 127.0.0.1
			}
		}
		session {
			asn {
				local 65000
				remote 65001
			}
			router-id 1.2.3.4
			family {
				ipv4/unicast { prefix { maximum 10000; } }
			}
			capability {
				graceful-restart disable
			}
		}
		behavior {
			group-updates disable
		}
	}
}
EOF_CONF

cmd=background:seq=1:exec=ze-peer --port $PORT:stdin=source
cmd=foreground:seq=2:exec=ze -:stdin=ze-bgp:timeout=10s
expect=exit:code=0
reject=stderr:pattern=panic
reject=stderr:pattern=fatal error
reject=stderr:pattern=cache .* forward
reject=stderr:pattern=forward-cached failed
reject=stderr:pattern=release-cached failed
reject=stderr:pattern=BUG: ForwardUpdatesDirect
