# bgp-rs-fastpath-ebgp-shared -- eBGP prepend via ForwardCached (rs-fastpath-3)
#
# VALIDATES: rs-fastpath-3 wiring only -- eBGP source peer goes through bgp-rs
# forwarding via the Plugin.ForwardCached fast path, proven here by clean EOR
# delivery and absence of legacy 'cache N forward' text-RPC fallback.
#
# PREVENTS: silent regression where the fast path is not engaged for eBGP
# forwarding.
# STATUS: partial -- this file does not compare forwarded UPDATE bytes; deep
# A==B byte-equality assertion (AC-6b) remains deferred.

stdin=source:terminator=EOF_SOURCE
option=tcp_connections:value=1
option=timeout:value=15s

action=send:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF00300200000015400101004002004003040101010140050400000064180A0000
# Hold the connection open until rs's replayForPeer goroutine reaches sendEOR.
# Without this expect, ze-peer closes immediately after the send above and the
# session transitions ESTABLISHED -> IDLE before rs can deliver EOR, causing
# AnnounceEOR to fail with "no established peers to send to".
expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF00170200000000
EOF_SOURCE

# Observer plugin: after the peer has received the EOR (verified above via
# the bgp expect rule on conn=1), issue `daemon shutdown` so ze exits cleanly
# with code 0 instead of being killed by the foreground cmd timeout (which
# the runner treats as StateTimeout).
tmpfs=shutdown-after-up.run:mode=755:terminator=EOF_RUN
#!/usr/bin/env python3
import time
from ze_api import API

def main():
    api = API()
    api.declare_done()
    api.wait_for_config()
    api.capability_done()
    api.wait_for_registry()
    api.ready()
    # Allow rs's replayForPeer goroutine and the subsequent EOR send to
    # finish before tearing ze down. 2s is generous on dev machines.
    time.sleep(2.0)
    api._call_engine('ze-plugin-engine:dispatch-command', {'command': 'daemon shutdown'})
    api.wait_for_shutdown()

if __name__ == '__main__':
    main()
EOF_RUN

stdin=ze-bgp:terminator=EOF_CONF
plugin {
	external rs {
		use bgp-rs
	}
	external shutdown-after-up {
		run ./shutdown-after-up.run
		encoder json
	}
}
bgp {
	peer source-peer {
		connection {
			remote {
				ip 127.0.0.1
			}
			local {
				ip 127.0.0.1
				accept false
			}
		}
		session {
			asn {
				local 65000
				remote 65001
			}
			router-id 1.2.3.4
			family {
				ipv4/unicast { prefix { maximum 10000; } }
			}
			capability {
				graceful-restart disable
			}
		}
		behavior {
			group-updates disable
		}
	}
}
EOF_CONF

cmd=background:seq=1:exec=ze-peer --port $PORT:stdin=source
cmd=foreground:seq=2:exec=ze -:stdin=ze-bgp:timeout=10s
expect=exit:code=0
reject=stderr:pattern=panic
reject=stderr:pattern=fatal error
reject=stderr:pattern=cache .* forward
reject=stderr:pattern=forward-cached failed
reject=stderr:pattern=release-cached failed
reject=stderr:pattern=BUG: ForwardUpdatesDirect
