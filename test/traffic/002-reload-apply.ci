traffic-control {
}
EOF_CONF2

option=env:var=ze.log.traffic:value=debug

cmd=background:seq=1:exec=python3 reload.py
cmd=foreground:seq=2:exec=ze -:stdin=ze-bgp:timeout=15s
expect=exit:code=0
expect=stderr:contains=traffic-control config reloaded
