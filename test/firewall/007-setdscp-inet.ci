# Test: `dscp-set ef` action in an inet table verifies and programs a
# TOS rewrite on the IPv4 header.
# VALIDATES: spec-fw-10 AC-5 -- validateAction accepts FamilyInet for
#            SetDSCP (previously only FamilyIP was allowed, blocking
#            the common inet table shape); lowerSetDSCP emits the
#            payload write + Bitwise clear-and-OR into the kernel
#            rule.
# PREVENTS: a regression re-tightening the family check or dropping
#           the payload write.
#
# Requires CAP_NET_ADMIN.

tmpfs=driver.py:mode=755:terminator=EOF_PY
#!/usr/bin/env python3
import os, signal, subprocess, sys, time

for _ in range(200):
    if os.path.exists("daemon.pid") and os.path.exists("daemon.ready"):
        break
    time.sleep(0.05)
else:
    sys.exit("daemon readiness files missing")

with open("daemon.pid") as f:
    pid = int(f.read().strip())

time.sleep(0.5)
out = subprocess.check_output(["nft", "list", "table", "inet", "ze_fw10_007"], text=True)
sys.stdout.write(out)
os.kill(pid, signal.SIGTERM)
EOF_PY

stdin=ze-bgp:terminator=EOF_CONF
firewall {
	backend nft;
	table fw10_007 {
		family inet;
		chain forward {
			type filter;
			hook forward;
			priority 0;
			policy accept;
			term voip {
				from { destination-port 5060; }
				then { dscp-set ef; }
			}
		}
	}
}
EOF_CONF

option=env:var=ze.log.firewall:value=info

cmd=background:seq=1:exec=ze -:stdin=ze-bgp
cmd=foreground:seq=2:exec=python3 driver.py:timeout=10s
expect=exit:code=0
expect=stderr:contains=firewall config applied
expect=stdout:contains=tcp dport 5060
expect=stdout:contains=ip dscp set
