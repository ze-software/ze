#!/usr/bin/env python3
"""
ExaBGP compatibility wrapper for ZeBGP.

This script pretends to be ExaBGP but actually:
1. Converts ExaBGP config to Ze format using `ze exabgp migrate`
2. Runs `ze` with the migrated config
3. Bridges ExaBGP processes (e.g., watchdog) via Ze's SSH exec interface

Usage:
    ./exabgp config.conf [options]

Environment variables (ExaBGP compatible):
    exabgp.tcp.port / exabgp_tcp_port - TCP port to listen on
    exabgp.tcp.bind / exabgp_tcp_bind - Address to bind to
"""

import argparse
import os
import subprocess
import sys
import tempfile
import threading
import time
from pathlib import Path

# SSH credentials injected into migrated configs for process bridging.
# The bcrypt hash matches password "ze-test" (cost=4 for test speed).
_SSH_USER = 'ze-test'
_SSH_PASS = 'ze-test'
_SSH_HASH = '$2a$04$7an2xuyUkE94D4FwxauYPOILpSYl08/IR3nqLIWWfprP5pcplMviu'


def find_ze_binary() -> str:
    """Find the ze binary."""
    # Check relative to this script first (development mode - local build takes priority)
    script_dir = Path(__file__).parent.parent.parent.parent
    ze_path = script_dir / 'ze'
    if ze_path.exists():
        return str(ze_path)

    # Check bin/ directory (make build output)
    bin_path = script_dir / 'bin' / 'ze'
    if bin_path.exists():
        return str(bin_path)

    # Fallback: check if ze is in PATH
    result = subprocess.run(['which', 'ze'], capture_output=True, text=True)
    if result.returncode == 0:
        return result.stdout.strip()

    # Try to build it
    print("Building ze...", file=sys.stderr)
    result = subprocess.run(
        ['go', 'build', '-o', str(ze_path), './cmd/ze'],
        cwd=script_dir,
        capture_output=True,
        text=True
    )
    if result.returncode == 0 and ze_path.exists():
        return str(ze_path)

    print(f"Error: Cannot find or build ze binary", file=sys.stderr)
    print(f"  Tried: {ze_path}", file=sys.stderr)
    if result.stderr:
        print(f"  Build error: {result.stderr}", file=sys.stderr)
    sys.exit(1)


def migrate_config(ze_binary: str, config_path: str) -> tuple:
    """Migrate ExaBGP config to Ze format.

    Returns (config_text, external_processes) where external_processes
    is a list of (name, run_cmd) tuples for processes the wrapper must handle.
    """
    result = subprocess.run(
        [ze_binary, 'exabgp', 'migrate', config_path],
        capture_output=True,
        text=True
    )

    if result.returncode != 0:
        print(f"Error migrating config: {result.stderr}", file=sys.stderr)
        sys.exit(1)

    # Parse external process info from stderr (format: "process:name:cmd")
    processes = []
    for line in result.stderr.splitlines():
        if line.startswith('process:'):
            parts = line.split(':', 2)
            if len(parts) == 3:
                processes.append((parts[1], parts[2]))
        else:
            # Pass through other stderr (warnings, info)
            print(line, file=sys.stderr)

    return result.stdout, processes


def get_exabgp_env_vars() -> dict:
    """Extract environment variables for Ze port override."""
    env_vars = {}

    # TCP port - check Ze native var first, then ExaBGP compat vars
    port = (os.environ.get('ze_bgp_tcp_port') or
            os.environ.get('exabgp.tcp.port') or
            os.environ.get('exabgp_tcp_port'))
    if port:
        env_vars['port'] = port

    return env_vars


def inject_ssh_config(config_text: str, ssh_port: int) -> str:
    """Inject SSH server config into migrated Ze config for process bridging.

    Adds a system block with SSH credentials so the process bridge can
    send commands (e.g., watchdog announce/withdraw) to the running daemon.
    """
    ssh_block = f"""
system {{
\tauthentication {{
\t\tuser {_SSH_USER} {{
\t\t\tpassword "{_SSH_HASH}"
\t\t}}
\t}}
\tssh {{
\t\tlisten 127.0.0.1:{ssh_port}
\t}}
}}
"""
    return ssh_block + config_text


def wait_for_ssh(host: str, port: int, timeout: float = 15.0) -> bool:
    """Wait for SSH server to accept connections."""
    import socket as sock_mod
    start = time.time()
    while time.time() - start < timeout:
        try:
            s = sock_mod.create_connection((host, port), timeout=1.0)
            # Read the SSH banner to confirm it's actually SSH
            data = s.recv(256)
            s.close()
            if data.startswith(b'SSH-'):
                return True
        except (ConnectionRefusedError, OSError, TimeoutError):
            pass
        time.sleep(0.1)
    return False


def send_ssh_command(host: str, port: int, command: str, debug: bool = False) -> str:
    """Send a command to ze daemon via SSH exec."""
    import paramiko
    client = paramiko.SSHClient()
    client.set_missing_host_key_policy(paramiko.AutoAddPolicy())
    try:
        client.connect(host, port=port, username=_SSH_USER, password=_SSH_PASS,
                       timeout=5.0, look_for_keys=False, allow_agent=False)
        _, stdout, stderr = client.exec_command(command)
        out = stdout.read().decode('utf-8', errors='replace').strip()
        err = stderr.read().decode('utf-8', errors='replace').strip()
        if debug:
            if out:
                print(f"  SSH response: {out}", file=sys.stderr)
            if err:
                print(f"  SSH error: {err}", file=sys.stderr)
        return out
    finally:
        client.close()


def run_process_bridge(config_dir: str, run_cmd: str, ssh_host: str, ssh_port: int,
                       ze_process: subprocess.Popen, debug: bool = False):
    """Run an ExaBGP process and bridge its commands to Ze via SSH.

    Translates ExaBGP stdout commands to Ze CLI commands over SSH exec:
    - "announce watchdog <name>" -> "watchdog announce <name>"
    - "withdraw watchdog <name>" -> "watchdog withdraw <name>"
    """
    # Wait for SSH server to be ready
    if not wait_for_ssh(ssh_host, ssh_port):
        if debug:
            print(f"Warning: SSH server not ready at {ssh_host}:{ssh_port}", file=sys.stderr)
        return

    if debug:
        print(f"SSH bridge connected to {ssh_host}:{ssh_port}", file=sys.stderr)

    try:
        # Resolve the run command relative to config directory
        cmd_path = os.path.join(config_dir, run_cmd)
        cmd_dir = os.path.dirname(cmd_path)

        if debug:
            print(f"Starting process bridge: {cmd_path} (cwd={cmd_dir})", file=sys.stderr)

        # Start the ExaBGP process
        proc = subprocess.Popen(
            [sys.executable, cmd_path],
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
            cwd=cmd_dir,
        )

        try:
            # Read process stdout and translate commands
            for raw_line in proc.stdout:
                # Check if Ze is still running
                if ze_process.poll() is not None:
                    break

                line = raw_line.decode('utf-8', errors='replace').strip()
                if not line:
                    continue

                if debug:
                    print(f"Process bridge: {line}", file=sys.stderr)

                if line.startswith('announce watchdog '):
                    group = line.split(None, 2)[2]
                    send_ssh_command(ssh_host, ssh_port,
                                    'watchdog announce ' + group, debug)
                elif line.startswith('withdraw watchdog '):
                    group = line.split(None, 2)[2]
                    send_ssh_command(ssh_host, ssh_port,
                                    'watchdog withdraw ' + group, debug)
                # Other ExaBGP commands could be translated here in the future

        finally:
            proc.terminate()
            try:
                proc.wait(timeout=2)
            except subprocess.TimeoutExpired:
                proc.kill()
                proc.wait()
    except Exception as e:
        if debug:
            print(f"Process bridge error: {e}", file=sys.stderr)


def main():
    parser = argparse.ArgumentParser(
        description='ExaBGP compatibility wrapper for ZeBGP',
        formatter_class=argparse.RawDescriptionHelpFormatter
    )
    parser.add_argument('config', help='ExaBGP configuration file')
    parser.add_argument('-d', '--debug', action='store_true', help='Enable debug output')
    parser.add_argument('--dry-run', action='store_true', help='Show migrated config without running')
    parser.add_argument('--once', action='store_true', help='Exit after first peer disconnects')

    # Capture remaining args to pass through
    args, remaining = parser.parse_known_args()

    ze_binary = find_ze_binary()

    if args.debug:
        print(f"Using ze binary: {ze_binary}", file=sys.stderr)

    # Migrate the config
    if args.debug:
        print(f"Migrating config: {args.config}", file=sys.stderr)

    migrated_config, external_processes = migrate_config(ze_binary, args.config)

    if args.dry_run:
        print(migrated_config)
        return 0

    # If external processes need bridging, inject SSH config for command dispatch.
    # Derive SSH port from BGP port to avoid collisions between parallel tests.
    ssh_port = 0
    if external_processes:
        env_vars = get_exabgp_env_vars()
        bgp_port = int(env_vars.get('port', '0'))
        ssh_port = bgp_port + 20000 if bgp_port > 0 else 22222
        migrated_config = inject_ssh_config(migrated_config, ssh_port)

    # Write migrated config to temp file
    with tempfile.NamedTemporaryFile(mode='w', suffix='.conf', delete=False) as f:
        f.write(migrated_config)
        temp_config = f.name

    if args.debug:
        print(f"Migrated config written to: {temp_config}", file=sys.stderr)
        print("--- Migrated config ---", file=sys.stderr)
        print(migrated_config, file=sys.stderr)
        print("--- End config ---", file=sys.stderr)

    try:
        # Build ze command
        # Always load capability plugins that ExaBGP supports:
        # - ze.bgp-hostname: FQDN capability (code 73)
        # - ze.bgp-llnh: Link-local next-hop capability (code 77)
        # - ze.bgp-softver: Software version capability (code 75)
        cmd = [ze_binary, '--plugin', 'ze.bgp-hostname', '--plugin', 'ze.bgp-llnh', '--plugin', 'ze.bgp-softver', '--plugin', 'ze.bgp-watchdog', temp_config]

        # Add environment-based options
        env_vars = get_exabgp_env_vars()
        if env_vars.get('port'):
            # Ze reads ze_bgp_tcp_port to override peer port (see loader.go:388)
            os.environ['ze_bgp_tcp_port'] = env_vars['port']

        # For tests: exit after first session so test can complete
        # (Ze doesn't know it's in a test and would otherwise keep running)
        os.environ['ze_bgp_tcp_attempts'] = '1'

        # For tests: only dial out, never bind/listen (Ze default is "both")
        os.environ['ze_bgp_bgp_connection'] = 'active'

        if args.debug:
            print(f"Running: {' '.join(cmd)}", file=sys.stderr)

        # Start ze (in background if we have processes to bridge)
        if external_processes:
            ze_proc = subprocess.Popen(cmd)

            # Start process bridges in background threads using SSH
            config_dir = os.path.dirname(os.path.abspath(args.config))
            bridge_threads = []
            for name, run_cmd in external_processes:
                if args.debug:
                    print(f"Bridging process: {name} -> {run_cmd}", file=sys.stderr)
                t = threading.Thread(
                    target=run_process_bridge,
                    args=(config_dir, run_cmd, '127.0.0.1', ssh_port, ze_proc, args.debug),
                    daemon=True,
                )
                t.start()
                bridge_threads.append(t)

            # Wait for Ze to exit
            ze_proc.wait()
            return ze_proc.returncode
        else:
            # No processes to bridge - simple run
            result = subprocess.run(cmd)
            return result.returncode

    finally:
        # Cleanup temp file
        try:
            os.unlink(temp_config)
        except OSError:
            pass


if __name__ == '__main__':
    sys.exit(main() or 0)
