# Test: full edit, review, commit flow persists value
# VALIDATES: edit field, review diff, confirm commit saves value to config
# PREVENTS: commit not applying changes, diff modal commit button broken

option=timeout:value=30s

action=open:path=/config/edit/bgp/
action=fill:text=router-id:value=10.0.0.4
action=wait:ms=500
expect=element:text=pending change

action=click:text=Review
action=wait:ms=500
expect=element:text=Confirm Commit

action=click:text=Confirm Commit
action=wait:ms=1000
expect=element:not-text=pending change
