# Test: CLI set then discard clears pending changes
# VALIDATES: set command creates pending change, discard clears it
# PREVENTS: discard not clearing editor state

option=timeout:value=30s

action=open:path=/show/bgp/
expect=element:id=cli-input

action=fill:id=cli-input:value=set router-id 10.99.99.99
action=press:key=Enter
action=wait:ms=1000

action=fill:id=cli-input:value=discard
action=press:key=Enter
action=wait:ms=1000
expect=element:not-text=10.99.99.99
