# Test: create multiple BGP peers via CLI, verify all appear in table after commit
# VALIDATES: multiple peers tracked in editor, all visible in peer table after commit
# PREVENTS: second peer overwriting first, table not showing all entries after commit

option=timeout:value=60s

action=open:path=/show/bgp/peer/
action=wait:ms=1000

# Create first peer (ISP transit)
action=fill:id=cli-input:value=set bgp peer multi-isp connection remote ip 198.51.100.1
action=press:key=Enter
action=wait:ms=1000
action=fill:id=cli-input:value=set bgp peer multi-isp session asn remote 64496
action=press:key=Enter
action=wait:ms=1000

# Create second peer (customer)
action=fill:id=cli-input:value=set bgp peer multi-cust connection remote ip 172.16.1.2
action=press:key=Enter
action=wait:ms=1000
action=fill:id=cli-input:value=set bgp peer multi-cust session asn remote 65100
action=press:key=Enter
action=wait:ms=1000

# Navigate to peer table and verify both appear
action=open:path=/show/bgp/peer/
action=wait:ms=1000
expect=element:text=multi-isp
expect=element:text=multi-cust

# Commit
action=fill:id=cli-input:value=commit
action=press:key=Enter
action=wait:ms=2000

# Both still visible after commit
action=open:path=/show/bgp/peer/
action=wait:ms=1000
expect=element:text=multi-isp
expect=element:text=multi-cust
