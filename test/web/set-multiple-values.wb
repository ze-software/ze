# Test: setting two fields both persist after navigation
# VALIDATES: editor tree tracks multiple field changes across navigation
# PREVENTS: second set overwriting first, editor losing state

option=timeout:value=30s

action=open:path=/show/bgp/
action=fill:text=BGP Router ID:value=10.0.0.9
action=wait:ms=2000

action=open:path=/show/environment/daemon/
action=fill:text=PID file path:value=/var/run/ze.pid
action=wait:ms=2000

action=open:path=/show/bgp/
expect=element:text=10.0.0.9

action=open:path=/show/environment/daemon/
expect=element:text=/var/run/ze.pid
