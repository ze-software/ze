# Test: CLI bar executes show command via Enter key
# VALIDATES: filling CLI bar and pressing Enter dispatches command
# PREVENTS: CLI bar not submitting on Enter, show verb broken

option=timeout:value=30s

action=open:path=/show/bgp/
expect=element:text=type a command

action=fill:text=type a command:value=show
action=press:key=Enter
action=wait:ms=1000
expect=element:text=bgp
