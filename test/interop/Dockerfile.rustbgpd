# rustbgpd daemon for performance testing.
# Builds from GitHub source.

FROM rust:1.88-bookworm AS builder

RUN apt-get update && apt-get install -y protobuf-compiler && rm -rf /var/lib/apt/lists/*

WORKDIR /src
RUN git clone --depth 1 --branch v0.7.0 https://github.com/lance0/rustbgpd.git . && \
    cargo build --release

FROM debian:bookworm-slim

RUN apt-get update && apt-get install -y --no-install-recommends tini && rm -rf /var/lib/apt/lists/*

COPY --from=builder /src/target/release/rustbgpd /usr/local/bin/rustbgpd
COPY --from=builder /src/target/release/rustbgpctl /usr/local/bin/rustbgpctl

ENTRYPOINT ["tini", "--", "rustbgpd"]
CMD ["/etc/rustbgpd/config.toml"]
