# FRR daemons file — shared across all interop scenarios.
# zebra (routing table), bgpd (BGP), and bfdd (BFD for scenario
# 33-bfd-frr). bfdd is lightweight and idle when no scenario
# configures BFD, so enabling it globally keeps the scenario
# runner simple.
zebra=yes
bgpd=yes
ospfd=no
ospf6d=no
ripd=no
ripngd=no
isisd=no
pimd=no
pim6d=no
ldpd=no
nhrpd=no
eigrpd=no
babeld=no
sharpd=no
pbrd=no
bfdd=yes
fabricd=no
vrrpd=no
pathd=no
