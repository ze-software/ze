option:file:group-limit.conf
# EOR
1:cmd:announce eor ipv4/unicast
1:raw:FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF:0017:02:00000000
1:cmd:announce eor ipv6/unicast
1:raw:FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF:001E:02:00000007900F0003000201

# Two IPv4
1:cmd:update text origin set igp local-preference set 100 nhop set 10.0.0.1 nlri ipv4/unicast add 193.0.2.1/32 193.0.2.2/32
1:raw:FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF:0036:02:00000015400101004002004003040A0000014005040000006420C100020120C1000202
