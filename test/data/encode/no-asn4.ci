# zebgp-peer expectations
stdin=peer:terminator=EOF_PEER
cmd=api:conn=1:seq=1:text=update text origin set igp as-path set [100] local-preference set 100 nhop set 10.0.255.254 nlri ipv4/unicast add 10.0.1.0/24
expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF0034020000001940010100400204020100644003040A00FFFE40050400000064180A0001
EOF_PEER

# zebgp configuration
stdin=zebgp:terminator=EOF_CONF
peer 127.0.0.1 {
	router-id 127.0.0.1;
	local-address 127.0.0.1;
	local-as 65533;
	peer-as 65533;
	hold-time 180;
	capability {
		asn4 disable;
	}
	announce {
		ipv4 {
			unicast 10.0.1.0/24 next-hop 10.0.255.254 as-path 100;
		}
	}
}
EOF_CONF

# Process orchestration
cmd=background:seq=1:exec=zebgp-peer --port $PORT:stdin=peer
cmd=foreground:seq=2:exec=zebgp server -:stdin=zebgp:timeout=10s
