option=file:path=attributes.conf
# Empty UPDATE (EOR for IPv4 unicast)
cmd=api:conn=1:seq=1:text=announce eor ipv4/unicast
expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF00170200000000
# MP_UNREACH EOR for IPv4 unicast
cmd=api:conn=1:seq=1:text=announce eor ipv6/unicast
expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF001E0200000007900F0003000201
# UPDATE with large-community attribute
cmd=api:conn=1:seq=1:text=update text origin set igp local-preference set 100 large-community set [1:2:3 10:11:12] nhop set 255.255.255.255 nlri ipv4/unicast add 10.0.0.7/32
expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF004C020000003040010100400200400304FFFFFFFF40050400000064C020180000000100000002000000030000000A0000000B0000000C200A000007
expect=json:conn=1:seq=1:json={"meta":{"version":"1.0.0","format":"zebgp"},"message":{"type":"update"},"peer":{"address":"127.0.0.1","asn":65533},"direction":"in","local-preference":100,"origin":"igp","ipv4/unicast":[{"action":"add","nlri":["10.0.0.7/32"],"next-hop":"255.255.255.255"}]}
