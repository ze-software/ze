#!/usr/bin/env python3

import time

from zebgp_api import ready, send, wait_for_ack, wait_for_shutdown


def main() -> None:
    ready()

    messages = [
        'update text nhop set 127.0.0.1 nlri ipv4/unicast add 1.1.1.1/32',
        'update text nhop set 127.0.0.1 nlri ipv4/unicast add 3.3.3.3/32',
    ]

    for message in messages:
        send(message)
        time.sleep(0.2)

    wait_for_ack(expected_count=2)
    wait_for_shutdown()


if __name__ == '__main__':
    main()
