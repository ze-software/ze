#!/usr/bin/env python3

import time

from zebgp_api import ready, send, wait_for_ack, wait_for_shutdown


def main() -> None:
    ready()

    messages = [
        'announce eor',
        'announce eor ipv6/unicast',
        'announce eor ipv4/unicast',
    ]

    for message in messages:
        send(message)
        time.sleep(0.1)

    wait_for_ack(expected_count=2)
    wait_for_shutdown()


if __name__ == '__main__':
    main()
