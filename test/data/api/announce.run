#!/usr/bin/env python3

from exabgp_api import ready, send, wait_for_ack, wait_for_shutdown


def main() -> None:
    ready()

    messages = [
        'update text nhop set 101.1.101.1 nlri ipv4/unicast add 1.1.0.0/24',
        'update text nhop set 101.1.101.1 nlri ipv4/unicast add 1.2.0.0/25',
    ]

    for message in messages:
        send(message)

    # Wait for ACKs (may be disabled in config)
    wait_for_ack(expected_count=2)

    # Wait for shutdown signal
    wait_for_shutdown()


if __name__ == '__main__':
    main()
