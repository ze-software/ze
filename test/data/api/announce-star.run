#!/usr/bin/env python3

import time

from zebgp_api import ready, send, wait_for_ack, wait_for_shutdown


def main() -> None:
    ready()

    messages = [
        'neighbor * update text nhop set 101.1.101.1 nlri ipv4/unicast add 1.1.0.0/24',
        'neighbor * update text nhop set 101.1.101.1 nlri ipv4/unicast add 1.2.0.0/25',
    ]

    for message in messages:
        send(message)
        time.sleep(0.1)

    wait_for_ack(expected_count=2)
    wait_for_shutdown()


if __name__ == '__main__':
    main()
