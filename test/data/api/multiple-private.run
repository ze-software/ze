#!/usr/bin/env python3

import time

from exabgp_api import ready, send, wait_for_ack, wait_for_shutdown


def main() -> None:
    ready()

    messages = [
        'update text nhop set 127.0.0.1 nlri ipv4/unicast add 2.2.2.2/32',
        'shutdown',
    ]

    for message in messages:
        send(message)
        time.sleep(1)

    wait_for_ack(expected_count=2)
    wait_for_shutdown()


if __name__ == '__main__':
    main()
