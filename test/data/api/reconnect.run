#!/usr/bin/env python3
"""
Test: ZeBGP reconnects after peer sends NOTIFICATION

Flow:
1. ZeBGP connects to test peer
2. This script sends route1 via API
3. Test peer receives route1 + EOR, sends NOTIFICATION
4. ZeBGP reconnects
5. Test peer sends "done" route to ZeBGP (test completes)
"""

import time

from zebgp_api import ready, send, wait_for_ack, wait_for_shutdown


def main() -> None:
    ready()

    # Send one route - triggers connection A
    send('update text nhop set 1.1.1.1 nlri ipv4/unicast add 1.1.0.0/16')
    time.sleep(0.5)

    # Wait for ACK
    wait_for_ack(expected_count=1)

    # Test peer will send NOTIFICATION after receiving route1 + EOR
    # ZeBGP will reconnect, test peer will send "done" route
    # Wait for shutdown signal from test harness
    wait_for_shutdown()


if __name__ == '__main__':
    main()
