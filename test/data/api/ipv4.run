#!/usr/bin/env python3

import time

from exabgp_api import ready, send, wait_for_ack, wait_for_shutdown


def main() -> None:
    ready()

    # Simplified test: unicast only (no MUP)
    announce_unicast = 'announce ipv4/unicast 10.0.1.0/24 next-hop 10.0.1.254 local-preference 200'
    withdraw_unicast = 'withdraw ipv4/unicast 10.0.1.0/24'

    messages = [
        announce_unicast,
        withdraw_unicast,
    ]

    for message in messages:
        send(message)
        time.sleep(0.2)

    wait_for_ack(expected_count=2)
    wait_for_shutdown()


if __name__ == '__main__':
    main()
