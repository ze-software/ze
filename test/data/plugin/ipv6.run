#!/usr/bin/env python3

import time

from zebgp_api import ready, send, wait_for_ack, wait_for_shutdown


def main() -> None:
    ready()

    # Simplified test: unicast only (no MUP)
    announce_unicast = 'announce ipv6/unicast fc00:1::/64 next-hop 2001::11 local-preference 200'
    withdraw_unicast = 'withdraw ipv6/unicast fc00:1::/64'

    messages = [
        announce_unicast,
        withdraw_unicast,
    ]

    for message in messages:
        send(message)
        time.sleep(0.2)

    wait_for_ack(expected_count=2)
    wait_for_shutdown()


if __name__ == '__main__':
    main()
