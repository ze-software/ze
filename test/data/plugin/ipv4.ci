# Test: IPv4 unicast announce/withdraw with JSON format documentation
# JSON format: {"ipv4/unicast":[{"next-hop":"...","action":"add|del","nlri":["..."]}]}
option:file:ipv4.conf
1:cmd:update text origin set igp local-preference set 200 nhop set 10.0.1.254 nlri ipv4/unicast add 10.0.1.0/24
1:raw:FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF:0030:02:00000015400101004002004003040A0001FE400504000000C8180A0001
1:json:{"message":{"type":"update"},"direction":"in","peer":{"address":"127.0.0.1","asn":65000},"origin":"igp","local-preference":200,"ipv4/unicast":[{"next-hop":"10.0.1.254","action":"add","nlri":["10.0.1.0/24"]}]}
2:cmd:announce eor ipv4/unicast
2:raw:FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF:0017:02:00000000
3:cmd:update text nlri ipv4/unicast del 10.0.1.0/24
3:raw:FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF:001B:02:0004180A00010000
3:json:{"message":{"type":"update"},"direction":"in","peer":{"address":"127.0.0.1","asn":65000},"ipv4/unicast":[{"action":"del","nlri":["10.0.1.0/24"]}]}
