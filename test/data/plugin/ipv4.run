#!/usr/bin/env python3

import time

from zebgp_api import ready, send, wait_for_ack, wait_for_shutdown


def main() -> None:
    ready()

    # Test unicast functionality using update text syntax
    announce_unicast = 'update text origin set igp local-preference set 200 nhop set 10.0.1.254 nlri ipv4/unicast add 10.0.1.0/24'
    withdraw_unicast = 'update text nlri ipv4/unicast del 10.0.1.0/24'

    messages = [
        announce_unicast,
        withdraw_unicast,
    ]

    for message in messages:
        send(message)
        time.sleep(0.2)

    wait_for_ack(expected_count=2)
    wait_for_shutdown()


if __name__ == '__main__':
    main()
