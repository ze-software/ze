#!/usr/bin/env python3

from zebgp_api import ready, send, wait_for_ack, wait_for_shutdown


def main() -> None:
    ready()

    # Send a route first
    send('update text nhop set 1.1.1.1 nlri ipv4/unicast add 1.1.0.0/16')

    # Wait for route to be processed
    wait_for_ack(expected_count=1)

    # Send teardown command - ZeBGP should send NOTIFICATION to peer
    send('neighbor 127.0.0.1 teardown 4')

    # The connection will close after teardown, script exits
    try:
        wait_for_shutdown()
    except IOError:
        # Expected - connection closed by teardown
        pass


if __name__ == '__main__':
    main()
