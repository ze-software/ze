option:file:refresh.conf
option:timeout:10s

# Step 1: Receive initial route announcement and EoR from zebgp
1:raw:FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF:0030:02:00000015400101004002004003040A0000014005040000006418C0A801
1:raw:FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF:0017:02:00000000

# Step 2: Send ROUTE-REFRESH (type 5) for IPv4/unicast (AFI=1, Subtype=0, SAFI=1)
# Wire format: AFI(2) + Subtype(1) + SAFI(1) = 00010001
2:send:raw:FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF:0017:05:00010001

# Step 3: Expect BoRR, route re-announcement, EoRR
# BoRR: ROUTE-REFRESH with Subtype=1 (RFC 7313)
3:raw:FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF:0017:05:00010101
# Route re-announcement (same as step 1)
3:raw:FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF:0030:02:00000015400101004002004003040A0000014005040000006418C0A801
# EoRR: ROUTE-REFRESH with Subtype=2 (RFC 7313)
3:raw:FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF:0017:05:00010201
