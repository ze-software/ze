option:file:logging-level-filter.conf
option:timeout:10s

# Set server logging to INFO level (should filter out DEBUG)
option:env:zebgp.log.server=info

# Test: Level filtering
# Verifies zebgp.log.server=info filters out DEBUG messages

# Static route UPDATE
1:raw:FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF:0030:02:00000015400101004002004003040A0000014005040000006418C0A801
# EOR
1:raw:FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF:0017:02:00000000

# DEBUG messages should NOT appear (server subsystem logs at DEBUG level)
reject:stderr:level=DEBUG
