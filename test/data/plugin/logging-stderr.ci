option=file:path=logging-stderr.conf
option=timeout:value=10s

# Enable server subsystem logging
option=env:var=zebgp.log.server:value=debug

# Test: Engine subsystem logging to stderr
# Verifies zebgp.log.server=debug produces server logs in stderr

# Static route UPDATE
expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF00300200000015400101004002004003040A0000014005040000006418C0A801
# EOR
expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF00170200000000

# Verify server subsystem logs appear in stderr
expect=stderr:pattern=subsystem=server
expect=stderr:pattern=stageTransition|deliverConfig|handleRegistrationLine
