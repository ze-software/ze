#!/usr/bin/env python3

from zebgp_api import ready, send, wait_for_ack, wait_for_shutdown


def main() -> None:
    ready()

    # Announce a route that can be refreshed
    send('update text nhop set 10.0.0.1 nlri ipv4/unicast add 192.168.1.0/24')
    wait_for_ack()

    # Wait for shutdown signal
    wait_for_shutdown()


if __name__ == '__main__':
    main()
