#!/usr/bin/env python3

from zebgp_api import ready, send, wait_for_ack


def main() -> None:
    ready()

    messages = [
        'update text nhop set 11.11.11.11 nlri ipv4/unicast add 1.1.1.1/32',
    ]

    message = messages.pop(0)
    send(message)
    wait_for_ack()
    # Exits immediately after ACK - no wait_for_shutdown


if __name__ == '__main__':
    main()
