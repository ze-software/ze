#!/usr/bin/env python3

import time

from zebgp_api import ready, send, wait_for_ack, wait_for_shutdown


def main() -> None:
    ready()

    # Test EOR for both IPv4 and IPv6 families
    send('update text nlri ipv4/unicast eor')
    time.sleep(0.2)
    send('update text nlri ipv6/unicast eor')
    time.sleep(0.2)

    wait_for_ack(expected_count=2)
    wait_for_shutdown()


if __name__ == '__main__':
    main()
