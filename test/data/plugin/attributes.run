#!/usr/bin/env python3

from zebgp_api import ready, send, wait_for_ack, wait_for_shutdown


def main() -> None:
    ready()

    messages = [
        'update text origin set igp local-preference set 100 med set 100 nhop set 101.1.101.1 nlri ipv4/unicast add 1.0.0.1/32',
        'update text origin set igp local-preference set 100 med set 100 nhop set 101.1.101.1 nlri ipv4/unicast add 1.0.0.2/32',
        'update text origin set igp as-path set [1 2 3 4] local-preference set 200 nhop set 202.2.202.2 nlri ipv4/unicast add 2.0.0.1/32',
        'update text origin set igp as-path set [1 2 3 4] local-preference set 200 nhop set 202.2.202.2 nlri ipv4/unicast add 2.0.0.2/32',
    ]

    for message in messages:
        send(message)

    wait_for_ack(expected_count=4)
    wait_for_shutdown()


if __name__ == '__main__':
    main()
