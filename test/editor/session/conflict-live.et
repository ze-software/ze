# Test: Live disagreement conflict blocks commit
# VALIDATES: AC-7 -- commit when another active session has different value at same path
# PREVENTS: Two sessions silently overwriting each other's changes

tmpfs=test.conf:terminator=EOF_CONF
bgp {
  router-id 1.2.3.4;
  local {
  	as 65000
  }
}
EOF_CONF

option=file:path=test.conf
option=timeout:value=10s

# Alice sets local as to 65001
session=alice:user=alice,origin=ssh
input=type:text=set bgp local as 65001
input=enter
expect=status:contains=Set
expect=dirty:true

# Bob sets local as to 65002 (different value, same path)
session=bob:user=bob,origin=ssh
input=type:text=set bgp local as 65002
input=enter
expect=status:contains=Set
expect=dirty:true

# Bob tries to commit -- should be blocked by live conflict
input=type:text=commit
input=enter
expect=status:contains=conflict
expect=viewport:contains=LIVE
