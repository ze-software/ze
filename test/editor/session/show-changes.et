# Test: show changes displays session-scoped pending changes
# VALIDATES: AC-17 -- show changes displays current session's pending changes
# VALIDATES: AC-18 -- show changes all displays all sessions' pending changes
# PREVENTS: Changes from other sessions leaking into default show changes view

tmpfs=test.conf:terminator=EOF_CONF
bgp {
  router-id 1.2.3.4;
  local {
  	as 65000
  }
}
EOF_CONF

option=file:path=test.conf
option=timeout:value=10s

# Alice sets local as
session=alice:user=alice,origin=ssh
input=type:text=set bgp local as 65001
input=enter
expect=status:contains=set

# Bob sets router-id
session=bob:user=bob,origin=ssh
input=type:text=set bgp router-id 5.6.7.8
input=enter
expect=status:contains=set

# Bob checks his own changes (should see tree with router-id)
session=bob
input=type:text=option changes
input=enter
expect=status:contains=1 pending change
expect=viewport:contains=router-id
expect=error:none

# Bob checks all sessions' changes summary
input=type:text=option changes all
input=enter
expect=status:contains=2 pending changes across 2 sessions
expect=viewport:contains=router-id
expect=error:none
