# Test: Write-through creates per-user change file with session metadata
# VALIDATES: spec-per-user-drafts AC-1: set writes to change file immediately
# VALIDATES: Change file contains session identity (user@origin)
# PREVENTS: Set accumulates in memory without persisting to disk

tmpfs=test.conf:terminator=EOF_CONF
bgp {
  local {
  	as 65000
  }
  router-id 1.2.3.4;
}
EOF_CONF

option=file:path=test.conf
option=timeout:value=10s
option=session:user=thomas:origin=local

# Initial state not dirty
expect=dirty:false

# Set a value -- should write through to per-user change file
input=type:text=set bgp local as 65001
input=enter
expect=dirty:true
expect=error:none

# Verify change file exists with session metadata (not draft)
expect=file:path=test.conf.change.thomas:contains=#thomas @local
