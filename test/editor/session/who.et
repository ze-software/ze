# Test: who command lists active editing sessions
# VALIDATES: AC-28 -- who lists all active/orphaned sessions with change counts
# PREVENTS: Sessions invisible to other editors

tmpfs=test.conf:terminator=EOF_CONF
bgp {
  router-id 1.2.3.4;
  local {
  	as 65000
  }
}
EOF_CONF

option=file:path=test.conf
option=timeout:value=10s

# Alice makes a change
session=alice:user=alice,origin=ssh
input=type:text=set bgp local as 65001
input=enter
expect=status:contains=set

# Bob makes a change
session=bob:user=bob,origin=ssh
input=type:text=set bgp router-id 5.6.7.8
input=enter
expect=status:contains=set

# Bob asks who is editing (Bob has latest draft state in memory)
session=bob
input=type:text=who
input=enter
expect=viewport:contains=alice@ssh
expect=viewport:contains=bob@ssh
expect=viewport:contains=pending
expect=error:none
