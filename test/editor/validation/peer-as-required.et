# Test: Peer-as is required
# VALIDATES: Missing peer-as generates error
# PREVENTS: Incomplete peer config being accepted

tmpfs=test.conf:terminator=EOF_CONF
bgp {
  router-id 1.2.3.4;
  local-as 65000;
  peer 1.1.1.1 {
    hold-time 90;
  }
}
EOF_CONF

option=file:path=test.conf
option=timeout:value=10s

# Should have validation error for missing peer-as
expect=errors:contains=peer-as
