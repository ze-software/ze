# Test: Hold-time above maximum (65536)
# VALIDATES: receive-hold-time 65536 is invalid (exceeds uint16)
# BOUNDARY: First invalid value above valid range
# RFC 4271: Hold Time is a 2-octet unsigned integer (max 65535)

tmpfs=test.conf:terminator=EOF_CONF
bgp {
  router-id 1.2.3.4;
  peer peer1 {
  	remote {
  		ip 1.1.1.1
  		as 65001;
  	}
    timer { receive-hold-time 65536; }
  }
}
EOF_CONF

option=file:path=test.conf
option=timeout:value=10s

# Hold-time 65536 should be invalid (exceeds uint16 max)
expect=errors:count=1
