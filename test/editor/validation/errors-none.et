# Test: Valid config has no validation errors
# VALIDATES: Errors command shows "no issues" for valid config

tmpfs=test.conf:terminator=EOF_CONF
bgp {
  router-id 1.2.3.4;
  session {
  	asn {
  		local 65000
  	}
  }
  peer peer1 {
  	connection {
  		remote {
  			ip 1.1.1.1
  		}
  		local {
  			ip auto
  		}
  	}
  	session {
  		asn {
  			remote 65001
  		}
  	}
    timer { receive-hold-time 90; }
  }
}
EOF_CONF

option=file:path=test.conf
option=timeout:value=10s

# Should have no errors
expect=errors:count=0

# Errors command output is visible
input=type:text=errors
input=enter
expect=error:none
