# Test: Validation errors display
# VALIDATES: Errors command shows validation issues
# PREVENTS: User unable to see validation problems

tmpfs=test.conf:terminator=EOF_CONF
bgp {
  router-id 1.2.3.4;
  peer peer1 {
  	remote {
  		ip 1.1.1.1
  		as 65001;
  	}
    timer { receive-hold-time 1; }
  }
}
EOF_CONF

option=file:path=test.conf
option=timeout:value=10s

# Should have validation error for receive-hold-time 1 (RFC 4271)
expect=errors:count=1

# Errors command should show the issue
input=type:text=errors
input=enter
expect=content:contains=receive-hold-time
