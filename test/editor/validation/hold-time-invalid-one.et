# Test: Hold-time 1 is invalid per RFC 4271
# VALIDATES: receive-hold-time 1 triggers validation error
# RFC 4271 Section 4.2: Values 1-2 are invalid

tmpfs=invalid-one.conf:terminator=EOF_ONE
bgp {
  router-id 1.2.3.4;
  peer peer1 {
  	remote {
  		ip 1.1.1.1
  		as 65001;
  	}
    timer { receive-hold-time 1; }
  }
}
EOF_ONE

option=file:path=invalid-one.conf
option=timeout:value=10s

# Hold-time 1 should be invalid
expect=errors:count=1
expect=errors:contains=receive-hold-time
