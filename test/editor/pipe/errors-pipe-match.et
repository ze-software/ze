# Test: Errors with match filter
# VALIDATES: Pipe match filters error output
# VALIDATES: Can search for specific error messages
# PREVENTS: Pipe with errors command broken

tmpfs=test.conf:terminator=EOF_CONF
bgp {
  router-id 1.2.3.4;
  peer peer1 {
  	remote {
  		ip 1.1.1.1
  		as 65001;
  	}
    timer { receive-hold-time 1; }
  }
  peer peer2 {
  	remote {
  		ip 2.2.2.2
  		as 65002;
  	}
    timer { receive-hold-time 2; }
  }
}
EOF_CONF

option=file:path=test.conf
option=timeout:value=10s

# Should have validation errors for both peers
expect=errors:count=2

# Errors with match for specific peer name
input=type:text=errors | match peer1
input=enter
expect=error:none

# Should show error for peer1
expect=viewport:contains=peer1

# Should NOT show error for peer2
expect=viewport:not-contains=peer2
