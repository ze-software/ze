# Test: Chained pipe filters
# VALIDATES: Multiple pipes work together
# VALIDATES: match filters content, head limits lines
# PREVENTS: Pipe chain broken

tmpfs=test.conf:terminator=EOF_CONF
bgp {
  router-id 1.2.3.4;
  local {
  	as 65000
  }
  peer peer1 {
  	remote {
  		ip 1.1.1.1
  		as 65001;
  	}
  }
  peer peer2 {
  	remote {
  		ip 2.2.2.2
  		as 65002;
  	}
  }
  peer peer3 {
  	remote {
  		ip 3.3.3.3
  		as 65003;
  	}
  }
}
EOF_CONF

option=file:path=test.conf
option=timeout:value=10s

# Show with chained filters: match for peer, limit to 2 lines
input=type:text=show | match peer | head 2
input=enter

# Should apply both filters
expect=viewport:contains=peer
expect=viewport:not-contains=router-id
expect=viewport:not-contains=local
expect=error:none
