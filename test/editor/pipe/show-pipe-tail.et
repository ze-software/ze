# Test: Show with tail filter
# VALIDATES: Pipe to tail shows last N lines
# VALIDATES: Earlier content is excluded
# PREVENTS: Tail filter broken

tmpfs=test.conf:terminator=EOF_CONF
bgp {
  router-id 1.2.3.4;
  local {
  	as 65000
  }
  peer peer1 {
  	remote {
  		ip 1.1.1.1
  		as 65001;
  	}
    timer { hold-time 90; }
  }
  peer peer2 {
  	remote {
  		ip 2.2.2.2
  		as 65002;
  	}
    timer { hold-time 180; }
  }
}
EOF_CONF

option=file:path=test.conf
option=timeout:value=10s

# Show with tail 3 - should show last 3 lines only
input=type:text=show | tail 3
input=enter
expect=error:none

# Last line content (closing braces) should be present
expect=viewport:contains=}

# Earlier content should be excluded (local-as and first peer are early in serialized output)
expect=viewport:not-contains=local
expect=viewport:not-contains=as 65001
