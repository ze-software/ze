# Test: Show with head filter
# VALIDATES: Pipe head limits output to first N lines
# VALIDATES: Content from beginning is shown
# VALIDATES: Content beyond limit is excluded

tmpfs=test.conf:terminator=EOF_CONF
bgp {
  router-id 1.2.3.4;
  session {
  	asn {
  		local 65000
  	}
  }
  peer peer1 {
  	connection {
  		remote {
  			ip 1.1.1.1
  		}
  	}
  	session {
  		asn {
  			remote 65001
  		}
  	}
  }
  peer peer2 {
  	connection {
  		remote {
  			ip 2.2.2.2
  		}
  	}
  	session {
  		asn {
  			remote 65002
  		}
  	}
  }
  peer peer3 {
  	connection {
  		remote {
  			ip 3.3.3.3
  		}
  	}
  	session {
  		asn {
  			remote 65003
  		}
  	}
  }
}
EOF_CONF

option=file:path=test.conf
option=timeout:value=10s

# Show with head 3 - should show first 3 lines only
input=type:text=show | head 3
input=enter
expect=error:none

# First line content (bgp {) should be present
expect=viewport:contains=bgp

# Later content should be excluded (peer peer3 is line 11+)
expect=viewport:not-contains=3.3.3.3
expect=viewport:not-contains=65003
