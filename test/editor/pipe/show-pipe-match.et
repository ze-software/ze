# Test: Show with match filter
# VALIDATES: Pipe match filters output to matching lines
# VALIDATES: Non-matching content excluded

tmpfs=test.conf:terminator=EOF_CONF
bgp {
  router-id 1.2.3.4;
  session {
  	asn {
  		local 65000
  	}
  }
  peer peer1 {
  	connection {
  		remote {
  			ip 1.1.1.1
  		}
  	}
  	session {
  		asn {
  			remote 65001
  		}
  	}
  }
  peer peer2 {
  	connection {
  		remote {
  			ip 2.2.2.2
  		}
  	}
  	session {
  		asn {
  			remote 65002
  		}
  	}
  }
}
EOF_CONF

option=file:path=test.conf
option=timeout:value=10s

# Show with match to filter for specific peer
input=type:text=show | match 1.1.1.1
input=enter
expect=viewport:contains=1.1.1.1
expect=viewport:not-contains=2.2.2.2
expect=viewport:not-contains=router-id
expect=error:none
