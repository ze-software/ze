# Test: Edit nested block (peer inside bgp)
# VALIDATES: Edit finds nested blocks with hierarchical path
# VALIDATES: Context path includes parent (bgp.peer.peer1)

tmpfs=test.conf:terminator=EOF_CONF
bgp {
  router-id 1.2.3.4;
  local {
  	as 65000
  }
  peer peer1 {
  	remote {
  		ip 1.1.1.1
  		as 65001;
  	}
    timer { hold-time 90; }
  }
}
EOF_CONF

option=file:path=test.conf
option=timeout:value=10s

# Start at root
expect=context:root

# Edit peer - should find it inside bgp
input=type:text=edit bgp peer peer1
input=enter
expect=context:path=bgp.peer.peer1
expect=error:none

# Viewport shows peer content
expect=viewport:contains=remote
expect=viewport:contains=hold-time
