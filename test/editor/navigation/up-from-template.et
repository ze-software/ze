# Test: Up from bgp context returns to root
# VALIDATES: Up command from bgp goes to root
# VALIDATES: Navigation works for tree-based paths

tmpfs=test.conf:terminator=EOF_CONF
bgp {
  router-id 1.2.3.4;
  local-as 65000;
  peer 1.1.1.1 {
    peer-as 65001;
  }
}
EOF_CONF

option=file:path=test.conf
option=timeout:value=10s

# Navigate into bgp
input=type:text=edit bgp
input=enter
expect=context:path=bgp
expect=error:none

# Go up should return to root
input=type:text=up
input=enter
expect=context:root
expect=error:none
