# Test: Up command goes up one level
# VALIDATES: Up from peer goes to bgp
# VALIDATES: Context path updated correctly

tmpfs=test.conf:terminator=EOF_CONF
bgp {
  router-id 1.2.3.4;
  peer 1.1.1.1 {
    peer-as 65001;
  }
}
EOF_CONF

option=file:path=test.conf
option=timeout:value=10s

# Navigate to peer first
input=type:text=edit bgp peer 1.1.1.1
input=enter
expect=context:path=bgp.peer.1.1.1.1

# Go up one level
input=type:text=up
input=enter
expect=context:path=bgp
expect=error:none
