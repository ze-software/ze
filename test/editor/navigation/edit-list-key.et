# Test: Edit list entry by key
# VALIDATES: Edit command enters a specific list entry
# VALIDATES: Shows correct peer content, not other peers
# PREVENTS: List navigation broken when selecting by key value

tmpfs=test.conf:terminator=EOF_CONF
bgp {
  router-id 1.2.3.4;
  local {
  	as 65000
  }
  peer peer1 {
  	remote {
  		ip 1.1.1.1
  		as 65001;
  	}
    hold-time 90;
  }
  peer peer2 {
  	remote {
  		ip 2.2.2.2
  		as 65002;
  	}
    hold-time 180;
  }
}
EOF_CONF

option=file:path=test.conf
option=timeout:value=10s

# Verify initial state at root
expect=context:root
expect=dirty:false

# Enter specific peer by IP address (list key)
input=type:text=edit bgp peer peer1
input=enter
expect=context:path=bgp.peer.peer1
expect=error:none

# Should show the selected peer's content (65001, 90)
expect=viewport:contains=as 65001
expect=viewport:contains=hold-time 90
