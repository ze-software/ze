# Test: Edit list entry by key
# VALIDATES: Edit command enters a specific list entry
# VALIDATES: Shows correct peer content, not other peers
# PREVENTS: List navigation broken when selecting by key value

tmpfs=test.conf:terminator=EOF_CONF
bgp {
  router-id 1.2.3.4;
  local-as 65000;
  peer 1.1.1.1 {
    peer-as 65001;
    hold-time 90;
  }
  peer 2.2.2.2 {
    peer-as 65002;
    hold-time 180;
  }
}
EOF_CONF

option=file:path=test.conf
option=timeout:value=10s

# Verify initial state at root
expect=context:root
expect=dirty:false

# Enter specific peer by IP address (list key)
input=type:text=edit peer 1.1.1.1
input=enter
expect=context:path=bgp.peer.1.1.1.1
expect=error:none

# Should show the selected peer's content (65001, 90)
expect=content:contains=peer-as 65001
expect=content:contains=hold-time 90

# Should NOT show the other peer's content (check viewport, not full working content)
expect=viewport:not-contains=65002
expect=viewport:not-contains=180
expect=viewport:not-contains=2.2.2.2
