# Test: Edit with wildcard returns error (template mode deferred)
# VALIDATES: "edit peer *" returns error since template mode is not yet supported
# PREVENTS: Silent failure when using deferred features

tmpfs=test.conf:terminator=EOF_CONF
bgp {
  router-id 1.2.3.4;
  peer peer1 {
  	connection {
  		remote {
  			ip 1.1.1.1
  		}
  	}
  	session {
  		asn {
  			remote 65001
  		}
  	}
  }
  peer peer2 {
  	connection {
  		remote {
  			ip 2.2.2.2
  		}
  	}
  	session {
  		asn {
  			remote 65002
  		}
  	}
  }
}
EOF_CONF

option=file:path=test.conf
option=timeout:value=10s

# Edit with wildcard should return error (template mode deferred)
input=type:text=edit bgp peer *
input=enter
expect=error:contains=not yet supported
