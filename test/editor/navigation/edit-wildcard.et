# Test: Edit with wildcard enters template mode
# VALIDATES: "edit peer *" creates template context
# VALIDATES: Template mode flag is set

tmpfs=test.conf:terminator=EOF_CONF
bgp {
  router-id 1.2.3.4;
  peer 1.1.1.1 {
    peer-as 65001;
  }
  peer 2.2.2.2 {
    peer-as 65002;
  }
}
EOF_CONF

option=file:path=test.conf
option=timeout:value=10s

# Edit with wildcard
input=type:text=edit peer *
input=enter
expect=template:true
expect=context:path=bgp.peer.*
expect=error:none
