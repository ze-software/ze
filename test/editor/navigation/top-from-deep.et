# Test: Top returns to root from deep context
# VALIDATES: Top command clears context path completely
# VALIDATES: Works from any depth

tmpfs=test.conf:terminator=EOF_CONF
bgp {
  router-id 1.2.3.4;
  peer peer1 {
  	connection {
  		remote {
  			ip 1.1.1.1
  		}
  	}
  	session {
  		asn {
  			remote 65001
  		}
  	}
  }
}
EOF_CONF

option=file:path=test.conf
option=timeout:value=10s

# Navigate deep
input=type:text=edit bgp peer peer1
input=enter
expect=context:path=bgp.peer.peer1

# Top returns to root
input=type:text=top
input=enter
expect=context:root
expect=error:none
expect=viewport:contains=bgp
