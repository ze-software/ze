# Test: Delete leaf — remove hold-time, verify removed
# VALIDATES: spec-editor-4: leaf deletion workflow
# PREVENTS: Leaf deletion leaving stale state

tmpfs=test.conf:terminator=EOF_CONF
bgp {
  router-id 1.2.3.4;
  local-as 65000;
  peer 1.1.1.1 {
    peer-as 65001;
    hold-time 90;
  }
}
EOF_CONF

option=file:path=test.conf
option=timeout:value=10s

# Delete a leaf value from inside a peer
input=type:text=delete bgp peer 1.1.1.1 hold-time
input=enter
expect=status:contains=Deleted
expect=dirty:true
expect=error:none

# Commit
input=type:text=commit
input=enter
expect=status:contains=committed
expect=dirty:false
