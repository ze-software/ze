# Test: Delete leaf — remove receive-hold-time, verify removed
# VALIDATES: spec-editor-4: leaf deletion workflow
# PREVENTS: Leaf deletion leaving stale state

tmpfs=test.conf:terminator=EOF_CONF
bgp {
  router-id 1.2.3.4;
  session {
  	asn {
  		local 65000
  	}
  }
  peer peer1 {
  	connection {
  		remote {
  			ip 1.1.1.1
  		}
  		local {
  			ip auto
  		}
  	}
  	session {
  		asn {
  			remote 65001
  		}
  	}
    timer { receive-hold-time 90; }
  }
}
EOF_CONF

option=file:path=test.conf
option=timeout:value=10s

# Delete a leaf value from inside a peer
input=type:text=delete bgp peer peer1 timer receive-hold-time
input=enter
expect=status:contains=Deleted
expect=dirty:true
expect=error:none

# Commit
input=type:text=commit
input=enter
expect=status:contains=committed
expect=dirty:false
