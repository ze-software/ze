# Test: Set container leaf — change router-id at container level, commit
# VALIDATES: spec-editor-4 AC-4: container leaf workflow
# PREVENTS: Simple leaf set regression

tmpfs=test.conf:terminator=EOF_CONF
bgp {
  router-id 1.2.3.4;
  local-as 65000;
}
EOF_CONF

option=file:path=test.conf
option=timeout:value=10s

# Set router-id at root level
input=type:text=set bgp router-id 5.6.7.8
input=enter
expect=status:contains=Set
expect=dirty:true
expect=error:none

# Commit
input=type:text=commit
input=enter
expect=status:contains=committed
expect=dirty:false

# Verify
input=type:text=show
input=enter
expect=viewport:contains=5.6.7.8
