# Test: Errors command with valid config
# VALIDATES: Errors shows "no issues" for valid config
# PREVENTS: Confusing output for valid config

tmpfs=test.conf:terminator=EOF_CONF
bgp {
  router-id 1.2.3.4;
  session {
  	asn {
  		local 65000
  	}
  }
  peer peer1 {
  	connection {
  		remote {
  			ip 1.1.1.1
  		}
  		local {
  			ip auto
  		}
  	}
  	session {
  		asn {
  			remote 65001
  		}
  	}
    timer { receive-hold-time 90; }
  }
}
EOF_CONF

option=file:path=test.conf
option=timeout:value=10s

# Check errors
input=type:text=errors
input=enter

# Should show no issues
expect=content:contains=No validation issues
expect=errors:count=0
expect=error:none
