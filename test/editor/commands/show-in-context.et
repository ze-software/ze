# Test: Show in context
# VALIDATES: Show displays filtered view when in context
# VALIDATES: Parent-level content is excluded
# PREVENTS: Wrong content shown in edit context

tmpfs=test.conf:terminator=EOF_CONF
bgp {
  router-id 1.2.3.4;
  local-as 65000;
  peer 1.1.1.1 {
    peer-as 65001;
    hold-time 90;
  }
}
EOF_CONF

option=file:path=test.conf
option=timeout:value=10s

# Enter peer context
input=type:text=edit bgp peer 1.1.1.1
input=enter
expect=context:path=bgp.peer.1.1.1.1

# Show in context
input=type:text=show
input=enter

# Should show peer content only
expect=content:contains=peer-as
expect=content:contains=hold-time

expect=error:none
