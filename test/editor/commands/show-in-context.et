# Test: Show in context
# VALIDATES: Show displays filtered view when in context
# VALIDATES: Parent-level content is excluded
# PREVENTS: Wrong content shown in edit context

tmpfs=test.conf:terminator=EOF_CONF
bgp {
  router-id 1.2.3.4;
  session {
  	asn {
  		local 65000
  	}
  }
  peer peer1 {
  	connection {
  		remote {
  			ip 1.1.1.1
  		}
  	}
  	session {
  		asn {
  			remote 65001
  		}
  	}
    timer { receive-hold-time 90; }
  }
}
EOF_CONF

option=file:path=test.conf
option=timeout:value=10s

# Enter peer context
input=type:text=edit bgp peer peer1
input=enter
expect=context:path=bgp/peer/peer1

# Show in context
input=type:text=show
input=enter

# Should show peer content only
expect=content:contains=remote
expect=content:contains=receive-hold-time

expect=error:none
