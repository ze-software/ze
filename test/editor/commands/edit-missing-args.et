# Test: Edit command requires path
# VALIDATES: edit without arguments shows error
# PREVENTS: Incomplete edit command being accepted

tmpfs=test.conf:terminator=EOF_CONF
bgp {
  router-id 1.2.3.4;
}
EOF_CONF

option=file:path=test.conf
option=timeout:value=10s

# Edit without arguments
input=type:text=edit
input=enter
expect=error:contains=usage
