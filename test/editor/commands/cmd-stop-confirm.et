# Test: stop command shows confirmation prompt, Esc cancels
# VALIDATES: AC-11 -- interactive CLI stop with confirmation prompt.
# PREVENTS: stop command missing from CLI dispatch or skipping confirmation.

tmpfs=test.conf:terminator=EOF_CONF
bgp {
  router-id 1.2.3.4;
  local { as 65000; }
  peer peer1 {
    remote { ip 1.1.1.1; as 65001; }
    timer { receive-hold-time 90; }
  }
}
EOF_CONF

option=file:path=test.conf
option=timeout:value=10s
option=lifecycle:mode=wired

# Type stop -- should show confirmation prompt
input=type:text=stop
input=enter
expect=status:contains=shut down the daemon
expect=input:empty

# Press Esc -- should cancel (clears status, does not quit)
input=esc
expect=status:empty
