# Test: Set command works through list paths from root
# VALIDATES: spec-editor-2 AC-1: set bgp peer <ip> timer hold-time <value> works from root
# VALIDATES: spec-editor-2 AC-6: set bgp peer <ip> description <value> works from root
# PREVENTS: List key being treated as leaf name instead of key value

tmpfs=test.conf:terminator=EOF_CONF
bgp {
  router-id 1.2.3.4;
  local {
  	as 65000
  }
  peer peer1 {
  	remote {
  		ip 1.1.1.1
  		as 65001;
  	}
  }
}
EOF_CONF

option=file:path=test.conf
option=timeout:value=10s

# Set hold-time through list from root context
input=type:text=set bgp peer peer1 timer hold-time 120
input=enter
expect=status:contains=set
expect=dirty:true
expect=error:none

# Set description through list from root context
input=type:text=set bgp peer peer1 description "my peer"
input=enter
expect=status:contains=set
expect=error:none
