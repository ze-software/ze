# Test: Delete leaf value command
# VALIDATES: Delete command removes configuration value
# PREVENTS: Delete command broken

tmpfs=test.conf:terminator=EOF_CONF
bgp {
  router-id 1.2.3.4;
  session {
  	asn {
  		local 65000
  	}
  }
  peer peer1 {
    connection {
      remote {
        ip 1.1.1.1;
      }
    }
    session {
      asn {
        remote 65001;
      }
    }
    description "test router";
  }
}
EOF_CONF

option=file:path=test.conf
option=timeout:value=10s

# Initially not dirty
expect=dirty:false

# Delete a value
input=type:text=delete bgp peer peer1 description
input=enter
expect=dirty:true
expect=error:none
expect=status:contains=Deleted
