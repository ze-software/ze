# Test: Load command requires proper keywords
# VALIDATES: load without keywords shows usage error
# PREVENTS: Incomplete load command being accepted

tmpfs=test.conf:terminator=EOF_CONF
bgp {
  router-id 1.2.3.4;
}
EOF_CONF

option=file:path=test.conf
option=timeout:value=10s

# Load without keywords - should show usage
input=type:text=load
input=enter
expect=error:contains=source
