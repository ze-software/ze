# Test: History shows backup list
# VALIDATES: History command lists backups after commit
# VALIDATES: Output format shows filename and date
# PREVENTS: User can't see available backups

tmpfs=test.conf:terminator=EOF_CONF
bgp {
  router-id 1.2.3.4;
  local-as 65000;
  peer 1.1.1.1 {
    peer-as 65001;
    local-address auto;
    hold-time 90;
  }
}
EOF_CONF

option=file:path=test.conf
option=timeout:value=10s

# Initially no backups
input=type:text=history
input=enter
expect=viewport:contains=No backups
expect=error:none

# Create a backup by committing a change
input=type:text=set bgp router-id 5.6.7.8
input=enter
expect=dirty:true

input=type:text=commit
input=enter
expect=dirty:false
expect=status:contains=committed

# Now history should show backup
input=type:text=history
input=enter
expect=viewport:not-contains=No backups
expect=viewport:contains=test
expect=error:none
