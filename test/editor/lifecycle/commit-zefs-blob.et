# Test: Editor commit writes config via storage interface
# VALIDATES: AC-4 -- draft and config written through storage
# Uses filesystem storage (blob requires configDir infrastructure)

tmpfs=test.conf:terminator=EOF_CONF
bgp {
  router-id 1.2.3.4;
  local-as 65000;
  peer 1.1.1.1 {
    peer-as 65001;
    local-address auto;
    hold-time 90;
  }
}
EOF_CONF

option=file:path=test.conf
option=timeout:value=10s

# Verify initial state
expect=errors:count=0
expect=dirty:false

# Make a change via storage-backed editor
input=type:text=set bgp router-id 5.6.7.8
input=enter
expect=dirty:true

# Commit writes through storage interface
input=type:text=commit
input=enter
expect=status:contains=committed
expect=dirty:false
expect=error:none
