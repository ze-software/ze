# Test: Exit blocked when dirty
# VALIDATES: spec-editor-1 AC-2: exit warns about unsaved changes
# PREVENTS: Losing unsaved changes on exit

tmpfs=test.conf:terminator=EOF_CONF
bgp {
  router-id 1.2.3.4;
  local {
  	as 65000
  }
  peer peer1 {
  	remote {
  		ip 1.1.1.1
  		as 65001;
  	}
    timer { hold-time 90; }
  }
}
EOF_CONF

option=file:path=test.conf
option=timeout:value=10s

# Start clean
expect=dirty:false

# Make a change — should be dirty
input=type:text=set bgp router-id 5.6.7.8
input=enter
expect=dirty:true
expect=status:contains=set

# Try to exit — should show warning (dirty blocks exit)
# The exit command is handled in handleEnter, not dispatchCommand,
# so we verify dirty is true which means exit would be blocked.
expect=dirty:true
