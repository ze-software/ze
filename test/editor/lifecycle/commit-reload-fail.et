# Test: Commit succeeds even when daemon reload fails
# VALIDATES: Save completes, status warns about reload failure
# PREVENTS: Commit blocked by daemon not running

tmpfs=test.conf:terminator=EOF_CONF
bgp {
  router-id 1.2.3.4;
  local {
  	as 65000
  }
  peer peer1 {
  	remote {
  		ip 1.1.1.1
  		as 65001;
  	}
  	local {
  		ip auto;
  	}
    timer { hold-time 90; }
  }
}
EOF_CONF

option=file:path=test.conf
option=timeout:value=10s
option=reload:mode=fail

# Verify initial state
expect=errors:count=0
expect=dirty:false

# Make a change
input=type:text=set bgp router-id 5.6.7.8
input=enter
expect=dirty:true

# Commit should succeed but warn about reload
input=type:text=commit
input=enter
expect=status:contains=committed
expect=status:contains=reload failed
expect=dirty:false
expect=error:none
