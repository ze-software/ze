# Test: Commit confirm rejects invalid seconds (3601)
# VALIDATES: commit confirmed 3601 is invalid (must be <= 3600)
# BOUNDARY: First invalid above valid range

tmpfs=test.conf:terminator=EOF_CONF
bgp {
  router-id 1.2.3.4;
  local {
  	as 65000
  }
  peer peer1 {
  	remote {
  		ip 1.1.1.1
  		as 65001;
  	}
    hold-time 90;
  }
}
EOF_CONF

option=file:path=test.conf
option=timeout:value=10s

# Make a change
input=type:text=set bgp router-id 5.6.7.8
input=enter
expect=dirty:true

# Commit confirm 3601 should fail
input=type:text=commit confirmed 3601
input=enter
expect=error:contains=seconds
