# Test: Load shows error for missing file
# VALIDATES: Load fails gracefully for nonexistent file
# VALIDATES: Error message mentions cannot read

tmpfs=test.conf:terminator=EOF_CONF
bgp {
  router-id 1.2.3.4;
}
EOF_CONF

option=file:path=test.conf
option=timeout:value=10s

# Try to load nonexistent file with new syntax
input=type:text=load file absolute replace nonexistent.conf
input=enter
expect=error:contains=cannot read
