# Test: Commit confirm requires seconds argument
# VALIDATES: "commit confirmed" without number fails
# PREVENTS: Ambiguous command being accepted

tmpfs=test.conf:terminator=EOF_CONF
bgp {
  router-id 1.2.3.4;
  local {
  	as 65000
  }
  peer peer1 {
  	remote {
  		ip 1.1.1.1
  		as 65001;
  	}
    hold-time 90;
  }
}
EOF_CONF

option=file:path=test.conf
option=timeout:value=10s

# Make a change
input=type:text=set bgp router-id 5.6.7.8
input=enter
expect=dirty:true

# Commit confirm without seconds should fail
input=type:text=commit confirmed
input=enter
expect=error:contains=usage
