# Test: Exit works after set + discard
# VALIDATES: spec-editor-1 AC-3: discard clears dirty, enabling exit
# PREVENTS: Dirty stuck true after discard

tmpfs=test.conf:terminator=EOF_CONF
bgp {
  router-id 1.2.3.4;
  local {
  	as 65000
  }
  peer peer1 {
  	remote {
  		ip 1.1.1.1
  		as 65001;
  	}
    hold-time 90;
  }
}
EOF_CONF

option=file:path=test.conf
option=timeout:value=10s

# Start clean
expect=dirty:false

# Make a change
input=type:text=set bgp router-id 5.6.7.8
input=enter
expect=dirty:true
expect=status:contains=Set

# Discard — should clear dirty
input=type:text=discard
input=enter
expect=dirty:false
expect=status:contains=discarded
expect=error:none
