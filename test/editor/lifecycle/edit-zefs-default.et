# Test: Editor opens ze.conf as the default config name
# VALIDATES: AC-5 -- ze.conf is the default config name
# Tests that ze.conf works as a standard config file name

tmpfs=ze.conf:terminator=EOF_CONF
bgp {
  router-id 1.2.3.4;
  local {
  	as 65000
  }
  peer peer1 {
  	remote {
  		ip 1.1.1.1
  		as 65001;
  	}
  	local {
  		ip auto;
  	}
    timer { hold-time 90; }
  }
}
EOF_CONF

option=file:path=ze.conf
option=timeout:value=10s

# Verify the editor opens successfully with ze.conf
expect=errors:count=0
expect=dirty:false

# Verify config content is loaded
input=type:text=show
input=enter
expect=viewport:contains=router-id
expect=viewport:contains=local
expect=error:none
