# Test: Commit confirm accepts maximum valid seconds (3600)
# VALIDATES: commit confirmed 3600 is valid (maximum)
# BOUNDARY: Last valid at upper boundary

tmpfs=test.conf:terminator=EOF_CONF
bgp {
  router-id 1.2.3.4;
  session {
  	asn {
  		local 65000
  	}
  }
  peer peer1 {
  	connection {
  		remote {
  			ip 1.1.1.1
  		}
  		local {
  			ip auto
  		}
  	}
  	session {
  		asn {
  			remote 65001
  		}
  	}
    timer { receive-hold-time 90; }
  }
}
EOF_CONF

option=file:path=test.conf
option=timeout:value=10s

# Make a change
input=type:text=set bgp router-id 5.6.7.8
input=enter
expect=dirty:true

# Commit confirm 3600 should succeed
input=type:text=commit confirmed 3600
input=enter
expect=status:contains=Confirm within
expect=error:none
