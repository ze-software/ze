# Test: Commit blocked when validation errors exist
# VALIDATES: Commit fails with validation errors
# VALIDATES: Error message mentions validation

tmpfs=test.conf:terminator=EOF_CONF
bgp {
  router-id 1.2.3.4;
  peer 1.1.1.1 {
    peer-as 65001;
    hold-time 1;
  }
}
EOF_CONF

option=file:path=test.conf
option=timeout:value=10s

# Config has validation error (hold-time 1 is invalid per RFC 4271)
expect=errors:count=1

# Try to commit — issues shown in viewport, not as error
input=type:text=commit
input=enter
expect=viewport:contains=hold-time
expect=status:contains=blocked
