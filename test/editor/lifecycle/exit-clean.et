# Test: Exit works on clean editor (no changes)
# VALIDATES: spec-editor-1 AC-1: editor not dirty after open
# PREVENTS: False dirty on open blocking exit

tmpfs=test.conf:terminator=EOF_CONF
bgp {
  router-id 1.2.3.4;
  session {
  	asn {
  		local 65000
  	}
  }
  peer peer1 {
  	connection {
  		remote {
  			ip 1.1.1.1
  		}
  	}
  	session {
  		asn {
  			remote 65001
  		}
  	}
    timer { receive-hold-time 90; }
  }
}
EOF_CONF

option=file:path=test.conf
option=timeout:value=10s

# Verify editor starts clean — exit should work
expect=dirty:false
expect=error:none
