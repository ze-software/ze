# Test: Commit works in standalone mode (no daemon)
# VALIDATES: No reload notifier → status says "committed" (not "reloaded")
# PREVENTS: False "reloaded" message when no daemon configured

tmpfs=test.conf:terminator=EOF_CONF
bgp {
  router-id 1.2.3.4;
  session {
  	asn {
  		local 65000
  	}
  }
  peer peer1 {
  	connection {
  		remote {
  			ip 1.1.1.1
  		}
  		local {
  			ip auto
  		}
  	}
  	session {
  		asn {
  			remote 65001
  		}
  	}
    timer { receive-hold-time 90; }
  }
}
EOF_CONF

option=file:path=test.conf
option=timeout:value=10s

# No option=reload — standalone mode

# Make a change
input=type:text=set bgp router-id 5.6.7.8
input=enter
expect=dirty:true

# Commit should succeed without mentioning reload
input=type:text=commit
input=enter
expect=status:contains=committed
expect=dirty:false
expect=error:none
