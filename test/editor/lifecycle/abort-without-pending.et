# Test: Abort without pending commit confirm
# VALIDATES: abort command when no timer is active shows message
# PREVENTS: Unexpected behavior for out-of-sequence command

tmpfs=test.conf:terminator=EOF_CONF
bgp {
  router-id 1.2.3.4;
  local {
  	as 65000
  }
  peer peer1 {
  	remote {
  		ip 1.1.1.1
  		as 65001;
  	}
    hold-time 90;
  }
}
EOF_CONF

option=file:path=test.conf
option=timeout:value=10s

# Abort without prior commit confirm
input=type:text=abort
input=enter
expect=error:contains=pending
