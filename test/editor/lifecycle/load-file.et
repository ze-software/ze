# Test: Load replaces config content
# VALIDATES: Load command reads file and replaces content
# VALIDATES: Marks config as dirty after load

tmpfs=test.conf:terminator=EOF_CONF
bgp {
  router-id 1.2.3.4;
}
EOF_CONF

tmpfs=other.conf:terminator=EOF_OTHER
bgp {
  router-id 5.6.7.8;
  local-as 65000;
}
EOF_OTHER

option=file:path=test.conf
option=timeout:value=10s

# Load different config
input=type:text=load other.conf
input=enter
expect=dirty:true
expect=viewport:contains=5.6.7.8
expect=viewport:contains=local-as
expect=error:none
