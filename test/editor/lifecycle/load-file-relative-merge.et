# Test: Load file relative merge - merges at current context
# VALIDATES: Relative merge adds content at context position
# VALIDATES: Original context content preserved

tmpfs=test.conf:terminator=EOF_CONF
bgp {
  router-id 1.2.3.4;
  peer peer1 {
  	connection {
  		remote {
  			ip 1.1.1.1
  		}
  	}
  	session {
  		asn {
  			remote 65001
  		}
  	}
  }
}
EOF_CONF

tmpfs=extra.conf:terminator=EOF_EXTRA
description "merged peer";
timer { receive-hold-time 180; }
EOF_EXTRA

option=file:path=test.conf
option=timeout:value=10s

# Enter peer context
input=type:text=edit bgp peer peer1
input=enter
expect=context:path=bgp.peer.peer1

# Load relative merge
input=type:text=load file relative merge extra.conf
input=enter

# Original peer content preserved
expect=content:contains=remote 65001

# Merged content added
expect=content:contains=description
expect=content:contains=receive-hold-time

expect=dirty:true
expect=error:none
