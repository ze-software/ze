# Test: Commit confirm with confirmation
# VALIDATES: Commit confirm followed by confirm makes permanent
# PREVENTS: Confirmed changes being rolled back
# NOTE: Timer state not tracked in headless mode - check status messages instead

tmpfs=test.conf:terminator=EOF_CONF
bgp {
  router-id 1.2.3.4;
  session {
  	asn {
  		local 65000
  	}
  }
  peer peer1 {
  	connection {
  		remote {
  			ip 1.1.1.1
  		}
  		local {
  			ip auto
  		}
  	}
  	session {
  		asn {
  			remote 65001
  		}
  	}
    timer { receive-hold-time 90; }
  }
}
EOF_CONF

option=file:path=test.conf
option=timeout:value=10s

# Make a change
input=type:text=set bgp router-id 5.6.7.8
input=enter
expect=dirty:true

# Commit with confirm
input=type:text=commit confirmed 60
input=enter
expect=status:contains=Confirm within

# Confirm the commit
input=type:text=confirm
input=enter
expect=status:contains=confirmed
expect=error:none
