# Test: Commit triggers daemon reload on success
# VALIDATES: After save, daemon is notified and status says "reloaded"
# PREVENTS: Config saved but daemon not notified

tmpfs=test.conf:terminator=EOF_CONF
bgp {
  router-id 1.2.3.4;
  local-as 65000;
  peer 1.1.1.1 {
    peer-as 65001;
    local-address auto;
    hold-time 90;
  }
}
EOF_CONF

option=file:path=test.conf
option=timeout:value=10s
option=reload:mode=success

# Verify initial state
expect=errors:count=0
expect=dirty:false

# Make a change
input=type:text=set bgp router-id 5.6.7.8
input=enter
expect=dirty:true

# Commit should succeed and reload
input=type:text=commit
input=enter
expect=status:contains=committed and reloaded
expect=dirty:false
expect=error:none
