# Test: Commit confirm accepts minimum valid seconds (1)
# VALIDATES: commit confirmed 1 is valid (minimum)
# BOUNDARY: Last valid at lower boundary

tmpfs=test.conf:terminator=EOF_CONF
bgp {
  router-id 1.2.3.4;
  local {
  	as 65000
  }
  peer peer1 {
  	remote {
  		ip 1.1.1.1
  		as 65001;
  	}
  	local {
  		ip auto;
  	}
    hold-time 90;
  }
}
EOF_CONF

option=file:path=test.conf
option=timeout:value=10s

# Make a change
input=type:text=set bgp router-id 5.6.7.8
input=enter
expect=dirty:true

# Commit confirm 1 should succeed
input=type:text=commit confirmed 1
input=enter
expect=status:contains=Confirm within
expect=error:none
