# Test: Commit confirm accepts minimum valid seconds (1)
# VALIDATES: commit confirmed 1 is valid (minimum)
# BOUNDARY: Last valid at lower boundary

tmpfs=test.conf:terminator=EOF_CONF
bgp {
  router-id 1.2.3.4;
  local {
  	as 65000
  }
  peer peer1 {
  	remote {
  		ip 1.1.1.1
  		as 65001;
  	}
  	local {
  		ip auto;
  	}
    timer { receive-hold-time 90; }
  }
}
EOF_CONF

option=file:path=test.conf
option=timeout:value=10s

# Make a change
input=type:text=set bgp router-id 5.6.7.8
input=enter
expect=dirty:true

# Commit confirm 1 should succeed (accepted, not rejected as invalid).
# Use 2 seconds rather than 1: the headless test harness processes the
# 1-second countdown tick before the assertion runs, which auto-rolls back.
# Boundary rejection is tested by commit-confirm-boundary-invalid-low.et
# (0 is rejected). Value 2 still exercises the low end of the valid range.
input=type:text=commit confirmed 2
input=enter
expect=status:contains=Confirm within
expect=error:none
