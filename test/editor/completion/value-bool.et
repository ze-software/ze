# Test: Boolean value completion
# VALIDATES: Boolean fields show true/false options
# PREVENTS: User guessing boolean syntax

tmpfs=test.conf:terminator=EOF_CONF
bgp {
  router-id 1.2.3.4;
  peer peer1 {
  	connection {
  		remote {
  			ip 1.1.1.1
  		}
  	}
  	session {
  		asn {
  			remote 65001
  		}
  	}
  }
}
EOF_CONF

option=file:path=test.conf
option=timeout:value=10s

# Enter peer context
input=type:text=edit bgp peer peer1
input=enter
expect=context:path=bgp/peer/peer1

# Set behavior group-updates should show boolean completions - need space after group-updates
input=type:text=set behavior group-updates
input=space
expect=completion:contains=true,false
