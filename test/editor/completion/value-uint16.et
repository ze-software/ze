# Test: uint16 value hint completion
# VALIDATES: uint16 fields show appropriate range hint
# PREVENTS: User guessing valid ranges

tmpfs=test.conf:terminator=EOF_CONF
bgp {
  router-id 1.2.3.4;
  peer peer1 {
  	connection {
  		remote {
  			ip 1.1.1.1
  		}
  	}
  	session {
  		asn {
  			remote 65001
  		}
  	}
  }
}
EOF_CONF

option=file:path=test.conf
option=timeout:value=10s

# Navigate to peer context
input=type:text=edit bgp peer peer1
input=enter
expect=context:path=bgp/peer/peer1

# Set timer receive-hold-time should show uint16 hint (0-65535)
input=type:text=set timer receive-hold-time
input=space
expect=completion:contains=<0-65535>
