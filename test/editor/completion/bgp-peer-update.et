# Test: BGP peer update block completion
# VALIDATES: Completion shows update configuration options
# PREVENTS: Native route syntax not discoverable

tmpfs=test.conf:terminator=EOF_CONF
bgp {
  router-id 1.2.3.4;
  peer 1.1.1.1 {
    peer-as 65001;
    update {
      attribute {
        origin igp;
      }
      nlri {
      }
    }
  }
}
EOF_CONF

option=file:path=test.conf
option=timeout:value=10s

# Navigate to peer context
input=type:text=edit peer 1.1.1.1
input=enter
expect=context:path=bgp.peer.1.1.1.1

# Edit targets should include update
input=type:text=edit
input=space
expect=completion:contains=capability,update,process,rib
