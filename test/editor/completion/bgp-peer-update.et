# Test: BGP peer update block completion
# VALIDATES: Completion shows update configuration options
# PREVENTS: Native route syntax not discoverable

tmpfs=test.conf:terminator=EOF_CONF
bgp {
  router-id 1.2.3.4;
  peer peer1 {
  	connection {
  		remote {
  			ip 1.1.1.1
  		}
  	}
  	session {
  		asn {
  			remote 65001
  		}
  	}
    update {
      attribute {
        origin igp;
      }
      nlri {
      }
    }
  }
}
EOF_CONF

option=file:path=test.conf
option=timeout:value=10s

# Navigate to peer context
input=type:text=edit bgp peer peer1
input=enter
expect=context:path=bgp/peer/peer1

# Edit targets should include update
input=type:text=edit
input=space
expect=completion:contains=session,update,process,rib
