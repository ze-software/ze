# Test: BGP peer capability add-path completion
# VALIDATES: Completion shows add-path settings (send/receive)
# PREVENTS: ADD-PATH configuration not discoverable

tmpfs=test.conf:terminator=EOF_CONF
bgp {
  router-id 1.2.3.4;
  peer 1.1.1.1 {
    peer-as 65001;
    capability {
      add-path {
      }
    }
  }
}
EOF_CONF

option=file:path=test.conf
option=timeout:value=10s

# Navigate to capability.add-path context
input=type:text=edit bgp peer 1.1.1.1
input=enter
input=type:text=edit capability
input=enter
input=type:text=edit add-path
input=enter
expect=context:path=bgp.peer.1.1.1.1.capability.add-path

# Completions should show add-path settings
input=type:text=set
input=space
expect=completion:contains=send,receive
