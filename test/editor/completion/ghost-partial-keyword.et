# Test: Ghost text for partial keyword match
# VALIDATES: Partial keyword shows completion suffix as ghost text
# VALIDATES: Single match produces ghost text

tmpfs=test.conf:terminator=EOF_CONF
bgp {
  router-id 1.2.3.4;
}
EOF_CONF

option=file:path=test.conf
option=timeout:value=10s

# Type partial command - "disca" uniquely matches "discard"
# (note: "disc" matches both "discard" and "disconnect")
input=type:text=disca
expect=ghost:text=rd
