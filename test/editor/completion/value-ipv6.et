# Test: IPv6 address completion
# VALIDATES: IPv6 peer addresses work
# PREVENTS: IPv6 configuration broken

tmpfs=test.conf:terminator=EOF_CONF
bgp {
  router-id 1.2.3.4;
  peer peer-v6-1 {
  	remote {
  		ip 2001:db8::1
  		as 65001;
  	}
  }
}
EOF_CONF

option=file:path=test.conf
option=timeout:value=10s

# Verify IPv6 peer is navigable
input=type:text=edit bgp peer peer-v6-1
input=enter
expect=context:path=bgp.peer.peer-v6-1
expect=error:none

# Completions should work in IPv6 peer context
input=type:text=set
input=space
expect=completion:contains=remote,local,timer
