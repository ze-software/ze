# Test: ASN value completion
# VALIDATES: ASN fields show numeric range hint
# PREVENTS: User doesn't know valid range

tmpfs=test.conf:terminator=EOF_CONF
bgp {
  router-id 1.2.3.4;
}
EOF_CONF

option=file:path=test.conf
option=timeout:value=10s

# At bgp context
input=type:text=edit bgp
input=enter
expect=context:path=bgp

# After "set session asn local " should show value type hint (uint32 range)
input=type:text=set session asn local
input=space
expect=completion:contains=<0-4294967295>
expect=error:none
