# Test: BGP peer capability completions
# VALIDATES: Capability container shows capability children
# VALIDATES: YANG-defined capabilities appear
# PREVENTS: User can't configure capabilities

tmpfs=test.conf:terminator=EOF_CONF
bgp {
  router-id 1.2.3.4;
  session {
  	asn {
  		local 65000
  	}
  }
  peer peer1 {
  	connection {
  		remote {
  			ip 1.1.1.1
  		}
  	}
  	session {
  		asn {
  			remote 65001
  		}
  	}
  }
}
EOF_CONF

option=file:path=test.conf
option=timeout:value=10s

# Enter peer context
input=type:text=edit bgp peer peer1
input=enter
expect=context:path=bgp.peer.peer1

# "set session capability " should show capability children from YANG
input=type:text=set session capability
input=space
expect=completion:contains=asn4,add-path
expect=error:none
