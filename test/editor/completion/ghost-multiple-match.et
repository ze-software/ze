# Test: Ghost text with multiple matching completions
# VALIDATES: Common prefix shown when multiple matches
# VALIDATES: Ghost text shows common prefix extension beyond typed text
# PREVENTS: Wrong completion shown with multiple options

tmpfs=test.conf:terminator=EOF_CONF
bgp {
  router-id 1.2.3.4;
}
EOF_CONF

option=file:path=test.conf
option=timeout:value=10s

# Type "de" which matches "deactivate" and "delete" (common prefix "de")
# With only "de" typed, the common prefix is "de" itself, so no ghost extension.
# Type "del" to get a unique match ("delete") with ghost "ete".
# But we want multiple matches: use "ro" -> "rollback" (common prefix "ro")
# Actually use "re" -> "rename" only. Use "hi" -> "history" only.
# Use "set " which gives config path completions.
# Simplest: "com" matches "commit" and "compare" (common prefix "com").
input=type:text=com
expect=completion:contains=commit,compare

# Ghost text is empty: "commit" and "compare" diverge at index 3 ("com").
# Typed "com" = common prefix, no further extension.
expect=ghost:empty
