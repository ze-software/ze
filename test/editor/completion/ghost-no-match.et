# Test: Ghost text with no matching completion
# VALIDATES: No ghost text when no completions match
# VALIDATES: Partial word with no prefix match shows nothing
# PREVENTS: Random ghost text appearing

tmpfs=test.conf:terminator=EOF_CONF
bgp {
  router-id 1.2.3.4;
}
EOF_CONF

option=file:path=test.conf
option=timeout:value=10s

# Type something that doesn't match any command
input=type:text=xyz
expect=ghost:empty
expect=completion:empty
