# Test: BGP peer field completions
# VALIDATES: Tab completion shows peer-level fields
# PREVENTS: Missing completion for peer configuration

tmpfs=test.conf:terminator=EOF_CONF
bgp {
  router-id 1.2.3.4;
  peer peer1 {
  	connection {
  		remote {
  			ip 1.1.1.1
  		}
  	}
  	session {
  		asn {
  			remote 65001
  		}
  	}
  }
}
EOF_CONF

option=file:path=test.conf
option=timeout:value=10s

# Enter peer context
input=type:text=edit bgp peer peer1
input=enter
expect=context:path=bgp/peer/peer1

# Check set completions - should show connection and session containers
input=type:text=set c
expect=completion:contains=connection
