# Test: BGP group block completion
# VALIDATES: Completion shows bgp.group children
# PREVENTS: Group structure not navigable

tmpfs=test.conf:terminator=EOF_CONF
bgp {
  router-id 1.2.3.4;
  group internal {
    peer-as 65000;
    hold-time 90;
  }
}
EOF_CONF

option=file:path=test.conf
option=timeout:value=10s

# Enter bgp context
input=type:text=edit bgp
input=enter
expect=context:path=bgp
expect=error:none

# Completions in bgp context should include group
input=type:text=edit
input=space
expect=completion:contains=group,peer
