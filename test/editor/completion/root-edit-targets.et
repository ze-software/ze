# Test: Edit command shows containers/lists at root
# VALIDATES: Edit completions show navigable targets
# VALIDATES: Only containers/lists shown (not leaves)
# PREVENTS: Edit suggesting leaf fields that can't be entered

tmpfs=test.conf:terminator=EOF_CONF
bgp {
  router-id 1.2.3.4;
  session {
  	asn {
  		local 65000
  	}
  }
  peer peer1 {
  	connection {
  		remote {
  			ip 1.1.1.1
  		}
  	}
  	session {
  		asn {
  			remote 65001
  		}
  	}
  }
}
EOF_CONF

option=file:path=test.conf
option=timeout:value=10s

# At root, "edit " should show containers
input=type:text=edit
input=space
expect=completion:contains=bgp
expect=error:none
