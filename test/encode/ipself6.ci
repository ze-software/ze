# ze-peer expectations
stdin=peer:terminator=EOF_PEER
option=bind:value=ipv6
cmd=api:conn=1:seq=1:text=announce ipv6/unicast 2a04:6d80::1/128 next-hop ::1 origin igp local-preference 100
expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF004E02000000374001010040020040050400000064800E26000201100000000000000000000000000000000100802A046D80000000000000000000000001
cmd=api:conn=1:seq=1:text=announce eor ipv6/unicast
expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF001E0200000007900F0003000201
EOF_PEER

# ze bgp configuration
stdin=ze-bgp:terminator=EOF_CONF
bgp {
	peer ::1 {
		router-id 127.0.0.2;
		local-address ::1;
		local-as 12345;
		peer-as 12345;

		family {
			ipv6/unicast;
		}
		announce {
			ipv6 {
				unicast 2a04:6d80::1/128 next-hop self;
			}
		}
	}
}
EOF_CONF

# Process orchestration
cmd=background:seq=1:exec=ze-peer --port $PORT:stdin=peer
cmd=foreground:seq=2:exec=ze bgp server -:stdin=ze-bgp:timeout=10s
