# ze-peer expectations
stdin=peer:terminator=EOF_PEER
option=bind:value=ipv6
cmd=api:conn=1:seq=1:text=peer * update text origin igp local-preference 100 nhop ::1 nlri ipv6/unicast add 2a04:6d80::1/128
expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF004E02000000374001010040020040050400000064800E26000201100000000000000000000000000000000100802A046D80000000000000000000000001
cmd=api:conn=1:seq=1:text=peer * update text nlri ipv6/unicast eor
expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF001E0200000007900F0003000201
EOF_PEER

# ze bgp configuration
stdin=ze-bgp:terminator=EOF_CONF
bgp {
	group default {
		peer peer-v6-1 {
			remote {
				ip ::1
				as 12345
			}
			local {
				as 12345
				ip ::1
			}
			router-id 127.0.0.2
			connection active

			family {
				ipv6/unicast { prefix { maximum 10000; } }
			}
			update {
				attribute {
					origin igp
					next-hop self
				}
				nlri {
					ipv6/unicast add 2a04:6d80::1/128
				}
			}
		}
	}
}
EOF_CONF

# Process orchestration
cmd=background:seq=1:exec=ze-peer --port $PORT:stdin=peer
cmd=foreground:seq=2:exec=ze -:stdin=ze-bgp:timeout=10s
