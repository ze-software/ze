# watchdog script (needs to be on disk)
tmpfs=watchdog.run:terminator=EOF_RUN
#!/usr/bin/env python3

import os
import time

from ze_api import ready, send


def main() -> None:
    ready()

    # Wait for BGP session to establish and config routes to be sent.
    # Without this, watchdog commands may arrive before the session is up,
    # setting state to "announced" prematurely — causing the route to be
    # sent with the initial config batch instead of as a separate UPDATE.
    time.sleep(1)

    while os.getppid() != 1:
        send('watchdog announce dnsr')
        time.sleep(0.2)

        send('watchdog withdraw dnsr')
        time.sleep(0.2)

    time.sleep(1)  # time for configuration routes to pass


if __name__ == '__main__':
    main()
EOF_RUN

# ze-peer expectations
stdin=peer:terminator=EOF_PEER
cmd=api:conn=1:seq=1:text=peer * update text nlri ipv4/unicast eor
expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF00170200000000
