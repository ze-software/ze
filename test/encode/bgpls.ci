# BGP-LS family test - verifies capability negotiation and EOR
# ze-peer expectations
stdin=peer:terminator=EOF_PEER
option=asn:value=1
cmd=api:conn=1:seq=1:text=peer * update text nlri bgp-ls/bgp-ls eor
expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF001E0200000007900F0003400447
EOF_PEER

# ze bgp configuration
stdin=ze-bgp:terminator=EOF_CONF
bgp {
	group default {
		peer peer1 {
			connection {
				remote {
					ip 127.0.0.1
				}
				local {
					ip 127.0.0.1
					accept false
				}
			}
			session {
				asn {
					local 1
					remote 1
				}
				router-id 1.2.3.4
				family {
					bgp-ls/bgp-ls { prefix { maximum 10000; } }
				}
			}

		}
	}
}
EOF_CONF

# Process orchestration
cmd=background:seq=1:exec=ze-peer --port $PORT:stdin=peer
cmd=foreground:seq=2:exec=ze -:stdin=ze-bgp:timeout=10s
