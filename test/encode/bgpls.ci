# BGP-LS family test - verifies capability negotiation and EOR
# zebgp-peer expectations
stdin=peer:terminator=EOF_PEER
option=asn:value=1
cmd=api:conn=1:seq=1:text=announce eor bgp-ls/bgp-ls
expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF001E0200000007900F0003400447
EOF_PEER

# zebgp configuration
stdin=zebgp:terminator=EOF_CONF
peer 127.0.0.1 {
	router-id 1.2.3.4;
	local-address 127.0.0.1;
	local-as 1;
	peer-as 1;

	family {
		bgp-ls/bgp-ls;
	}
}
EOF_CONF

# Process orchestration
cmd=background:seq=1:exec=zebgp-peer --port $PORT:stdin=peer
cmd=foreground:seq=2:exec=zebgp server -:stdin=zebgp:timeout=10s
