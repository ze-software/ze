# ze bgp configuration
stdin=ze-bgp:terminator=EOF_CONF
bgp {
	group test {
		local {
			as 65533
		}
		remote {
			as 65533
		}
		connection active
		timer {
			hold-time 180
		}
		group-updates disable

		family {
			ipv4/unicast { prefix { maximum 10000; } }
		}
		capability {
			graceful-restart 1200
		}
		update {
			attribute {
				origin igp
				next-hop 1.1.1.1
			}
			nlri {
				ipv4/unicast add 1.0.0.0/8
			}
		}

		peer peer1 {
			remote {
				ip 127.0.0.1
			}
			local {
				ip 127.0.0.1
			}
			description "router 2 with two routes from inheritance"
			router-id 127.0.0.0
			update {
				attribute {
					origin igp
					next-hop 1.1.1.1
				}
				nlri {
					ipv4/unicast add 2.0.0.0/8
				}
			}
			update {
				attribute {
					origin igp
					next-hop 1.2.3.4
				}
				nlri {
					ipv4/unicast add 3.0.0.0/8
				}
			}
			update {
				attribute {
					origin igp
					next-hop 2.2.2.2
				}
				nlri {
					ipv4/unicast add 4.0.0.0/8
				}
			}
		}
	}
}
EOF_CONF

# Process orchestration
cmd=background:seq=1:exec=ze-peer --port $PORT:stdin=peer
cmd=foreground:seq=2:exec=ze -:stdin=ze-bgp:timeout=10s
