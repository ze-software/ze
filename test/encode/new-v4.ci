# ze bgp configuration
stdin=ze-bgp:terminator=EOF_CONF
bgp {
	group a-few-routes {
		update {
			attribute {
				origin igp
				next-hop 10.0.255.254
				community [ 0:0 ]
			}
			nlri {
				ipv4/unicast add 10.0.1.0/24
			}
		}
		update {
			attribute {
				origin igp
				next-hop 10.0.255.254
				community [ 30740:30740 ]
			}
			nlri {
				ipv4/unicast add 10.0.2.0/24
			}
		}
		update {
			attribute {
				origin igp
				next-hop 10.0.255.254
				community [ 30740:30740 30740:0 ]
			}
			nlri {
				ipv4/unicast add 10.0.3.0/24
			}
		}

		peer peer1 {
			remote {
				ip 127.0.0.1
				as 65533
			}
			local {
				as 65533
				ip 127.0.0.1
			}
			description "a simple test for the new configuration format name"
			router-id 10.0.0.2
			connection active
			timer {
				receive-hold-time 180
			}

			family {
				ipv4/unicast { prefix { maximum 10000; } }
			}
			update {
				attribute {
					origin igp
					next-hop 10.0.255.254
					local-preference 200
				}
				nlri {
					ipv4/unicast add 10.0.4.0/24 10.0.5.0/24
				}
			}
			update {
				attribute {
					origin igp
					next-hop 10.0.255.254
					community [ 30740:30740 ]
				}
				nlri {
					ipv4/unicast add 10.0.6.0/24
				}
			}
			update {
				attribute {
					origin igp
					next-hop 10.0.255.254
					local-preference 200
					community [ 30740:30740 ]
				}
				nlri {
					ipv4/unicast add 10.0.7.0/24 10.0.8.0/24
				}
			}
		}
	}
}
EOF_CONF

# Process orchestration
cmd=background:seq=1:exec=ze-peer --port $PORT:stdin=peer
cmd=foreground:seq=2:exec=ze -:stdin=ze-bgp:timeout=10s
