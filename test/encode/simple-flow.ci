# ze-peer expectations
stdin=peer:terminator=EOF_PEER
# single flow test
cmd=api:conn=1:seq=1:text=bgp peer * update text extended-community set [copy-to-nexthop] nhop set 1.2.3.4 nlri ipv4/flow add source-ipv4 10.0.0.2/32
expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF0043020000002C4001010040020040050400000064C010080800000000000001800E100001850401020304000602200A000002
expect=json:conn=1:seq=1:json={"meta":{"version":"1.0.0","format":"ze-bgp"},"message":{"type":"update"},"origin":"igp","local-preference":100,"extended-community":[{"string":"0x0800:000000000001","value":576460752303423489}],"ipv4/flow":[{"action":"add","nlri":{"source":[["10.0.0.2/32/0"]],"next-hop":"1.2.3.4"}}]}
cmd=api:conn=1:seq=2:text=bgp peer * update text nlri ipv4/flow eor
expect=bgp:conn=1:seq=2:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF001E0200000007900F0003000185
EOF_PEER

# ze bgp configuration
stdin=ze-bgp:terminator=EOF_CONF
bgp {
	peer 127.0.0.1 {
		router-id 1.2.3.4;
		local-address 127.0.0.1;
		local-as 1;
		peer-as 1;
		group-updates disable;

		family {
			ipv4/flow;
		}

		update {
			attribute {
				next-hop 1.2.3.4;
				extended-community [copy-to-nexthop];
			}
			nlri {
				ipv4/flow source-ipv4 10.0.0.2/32;
			}
		}
	}
}
EOF_CONF

# Process orchestration
cmd=background:seq=1:exec=ze-peer --port $PORT:stdin=peer
cmd=foreground:seq=2:exec=ze bgp server -:stdin=ze-bgp:timeout=10s
