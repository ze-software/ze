# ze bgp configuration using native update syntax
stdin=ze-bgp:terminator=EOF_CONF
bgp {
	group default {
		peer peer1 {
			connection {
				remote {
					ip 127.0.0.1
					accept false
				}
				local {
					ip 127.0.0.1
				}
			}
			session {
				asn {
					local 1
					remote 1
				}
				router-id 1.2.3.4
				family {
					ipv6/mpls-vpn { prefix { maximum 10000; } }
				}
			}

			update {
				attribute {
					origin igp
					as-path "25186 65000 64512"
					local-preference 100
					next-hop "::ffff:81.52.17.146"
					community 65000:33
					extended-community "target:10283:4.249.92.120"
					originator-id 57.35.2.240
				}
				nlri {
					ipv6/mpls-vpn add rd 3215:583457597 label 926 2001:4b50:20c0::/48 2001:4b50:20d0::/48
				}
			}
		}
	}
}
EOF_CONF

# Process orchestration
cmd=background:seq=1:exec=ze-peer --port $PORT:stdin=peer
cmd=foreground:seq=2:exec=ze -:stdin=ze-bgp:timeout=10s
