EOF_PEER

# ze bgp configuration
stdin=ze-bgp:terminator=EOF_CONF
bgp {
	peer 127.0.0.1 {
		router-id 10.0.0.10;
		local-address 127.0.0.1;
		local-as 65533;
		peer-as 65533;
		group-updates disable;

		family {
			ipv4/unicast;
		}
		update {
			attribute {
				origin igp;
				next-hop 192.168.1.100;
				med 100;
			}
			nlri {
				ipv4/unicast 100.100.100.100/32;
			}
		}
		update {
			attribute {
				origin igp;
				next-hop 192.168.1.100;
				attribute "0x99 0x60 0x00000064";
			}
			nlri {
				ipv4/unicast 101.101.101.101/32;
			}
		}
		update {
			attribute {
				origin igp;
				next-hop 192.168.1.100;
				attribute "0x99 0x70 0x00000064";
			}
			nlri {
				ipv4/unicast 111.111.111.111/32;
			}
		}
	}
}
EOF_CONF

# Process orchestration
cmd:background:seq=1:exec=ze-peer --port $PORT:stdin=peer
cmd:foreground:seq=2:exec=ze -:stdin=ze-bgp:timeout=10s
