# ze-peer expectations
# Config-based MVPN routes are grouped by AFI: all IPv4 first, then all IPv6
stdin=peer:terminator=EOF_PEER
# Message 1: IPv4 shared-join + source-join
expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF0073020000005C400101004002004003040A0A060340050400000064C010080102C0A85E0C0005800E39000105040A0A06030006160000FDE80001869F0000FDE8200A63C70120EFFBFFE407160000FDE80001869F0000FDE8200A630C0220EFFBFFE4
# Message 2: IPv4 source-ad
expect=bgp:conn=1:seq=2:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF00570200000040400101004002004003040A0A060440050400000064C010080002FDE80001869F800E1D000105040A0A06040005120000FDE80001869F200A630C0420EFFBFFE4
# Message 3: IPv6 shared-join + source-join
expect=bgp:conn=1:seq=3:
# Message 4: IPv6 source-ad
expect=bgp:conn=1:seq=4:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF006F0200000058400101004002004003040A0A060440050400000064C010080002FDE80001869F800E35000205040A0A060400052A0000FDE80001869F80FD12000000000000000000000000000480FF0E0000000000000000000000000001
# Message 5: IPv4 EOR
expect=bgp:conn=1:seq=5:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF001E0200000007900F0003000105
# Message 6: IPv6 EOR
expect=bgp:conn=1:seq=6:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF001E0200000007900F0003000205
EOF_PEER

# ze bgp configuration
stdin=ze-bgp:terminator=EOF_CONF
bgp {
	peer peer1 {
		connection {
			remote {
				ip 127.0.0.1
			}
			local {
				ip 127.0.0.1
				accept false
			}
		}
		session {
			asn {
				local 65000
				remote 65000
			}
			router-id 32.32.32.32
			family {
				ipv4/mvpn { prefix { maximum 10000; } }
				ipv6/mvpn { prefix { maximum 10000; } }
			}
		}
		behavior {
			group-updates enable
			auto-flush enable
		}


		# Route 1: IPv4 shared-join and source-join (grouped)
		update {
			attribute {
				next-hop 10.10.6.3
				extended-community [target:192.168.94.12:5]
			}
			nlri {
				ipv4/mvpn add shared-join rp 10.99.199.1 group 239.251.255.228 rd 65000:99999 source-as 65000
				ipv4/mvpn add source-join source 10.99.12.2 group 239.251.255.228 rd 65000:99999 source-as 65000
			}
		}

		# Route 2: IPv6 shared-join and source-join (grouped)
		update {
			attribute {
				next-hop 10.10.6.3
				extended-community [target:192.168.94.12:5]
			}
			nlri {
				ipv6/mvpn add shared-join rp fd00::1 group ff0e::1 rd 65000:99999 source-as 65000
				ipv6/mvpn add source-join source fd12::2 group ff0e::1 rd 65000:99999 source-as 65000
			}
		}

		# Route 3: IPv4 source-ad
		update {
			attribute {
				next-hop 10.10.6.4
				extended-community [target:65000:99999]
			}
			nlri {
				ipv4/mvpn add source-ad source 10.99.12.4 group 239.251.255.228 rd 65000:99999
			}
		}

		# Route 4: IPv6 source-ad
		update {
			attribute {
				next-hop 10.10.6.4
				extended-community [target:65000:99999]
			}
			nlri {
				ipv6/mvpn add source-ad source fd12::4 group ff0e::1 rd 65000:99999
			}
		}
	}
}
EOF_CONF

# Process orchestration
cmd=background:seq=1:exec=ze-peer --port $PORT:stdin=peer
cmd=foreground:seq=2:exec=ze -:stdin=ze-bgp:timeout=10s
