# zebgp configuration
stdin=zebgp:terminator=EOF_CONF
peer 127.0.0.1 {
	router-id 32.32.32.32;
	local-address 127.0.0.1;
	local-as 65000;
	peer-as 65000;
	group-updates enable;

	family {
		ipv4/mcast-vpn;
		ipv6/mcast-vpn;
	}
	auto-flush enable;
	announce {
		ipv4 {
			mcast-vpn shared-join rp 10.99.199.1 group 239.251.255.228 rd 65000:99999 source-as 65000 next-hop 10.10.6.3 extended-community target:192.168.94.12:5;
			mcast-vpn source-ad group 239.251.255.228 source 10.99.12.4 rd 65000:99999 next-hop 10.10.6.4 extended-community target:65000:99999;
			mcast-vpn source-join group 239.251.255.228 source 10.99.12.2 rd 65000:99999 source-as 65000 next-hop 10.10.6.3 extended-community target:192.168.94.12:5;
		}
		ipv6 {
			mcast-vpn shared-join rp fd00::1 group ff0e::1 rd 65000:99999 source-as 65000 next-hop 10.10.6.3 extended-community target:192.168.94.12:5;
			mcast-vpn source-ad group ff0e::1 source fd12::4 rd 65000:99999 next-hop 10.10.6.4 extended-community target:65000:99999;
			mcast-vpn source-join group ff0e::1 source fd12::2 rd 65000:99999 source-as 65000 next-hop 10.10.6.3 extended-community target:192.168.94.12:5;
		}
	}
}
EOF_CONF

# Process orchestration
cmd=background:seq=1:exec=zebgp-peer --port $PORT:stdin=peer
cmd=foreground:seq=2:exec=zebgp server -:stdin=zebgp:timeout=10s
