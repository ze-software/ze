# ze bgp configuration
stdin=ze-bgp:terminator=EOF_CONF
bgp {
	peer peer1 {
		remote {
			ip 127.0.0.1
			as 1
		}
		local {
			as 1
			ip 127.0.0.1
		}
		router-id 1.2.3.4
		connection active
		group-updates disable

		family {
			ipv4/mpls-vpn { prefix { maximum 10000; } }
			ipv4/unicast { prefix { maximum 10000; } }
			ipv6/unicast { prefix { maximum 10000; } }
		}
		capability {
			add-path send/receive
		}
		update {
			attribute {
				origin igp
				next-hop 10.0.0.1
				extended-community [ target:72:1 ]
				path-information 1.2.3.4
			}
			nlri {
				ipv4/unicast add 193.0.2.1/32
			}
		}
		update {
			attribute {
				origin igp
				next-hop 192.168.0.1
				local-preference 100
				extended-community [ target:0:0 target:1:1 ]
				path-information 10
			}
			nlri {
				ipv4/mpls-vpn add rd 100:100 label 20012 10.0.0.0/24
			}
		}
		add-path {
			ipv4/mpls-vpn
			ipv4/unicast
		}
	}
}
EOF_CONF

# Process orchestration
cmd=background:seq=1:exec=ze-peer --port $PORT:stdin=peer
cmd=foreground:seq=2:exec=ze -:stdin=ze-bgp:timeout=10s
