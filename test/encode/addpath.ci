expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF00400200000020400101004002004003040A00000140050400000064C0100800020048000000010102030420C1000201
expect=json:conn=1:seq=1:json={"meta":{"version":"1.0.0","format":"ze-bgp"},"message":{"type":"update"},"peer":{"address":"127.0.0.1","remote":{"as":65533}},"direction":"in","extended-community":[{"string":"target:72:1","value":563259191066625}],"local-preference":100,"origin":"igp","ipv4/unicast":[{"action":"add","nlri":["2.0.0.0/1","4.0.0.0/3","193.0.2.1/32"],"next-hop":"10.0.0.1"}]}
