# ze bgp configuration
stdin=ze-bgp:terminator=EOF_CONF
peer 127.0.0.1 {
	router-id 1.2.3.4;
	local-address 127.0.0.1;
	local-as 1;
	peer-as 1;
	group-updates disable;

	family {
		ipv4/mpls-vpn;
		ipv4/unicast;
		ipv6/unicast;
	}
	capability {
		add-path send/receive;
	}
	announce {
		ipv4 {
			unicast 193.0.2.1 next-hop 10.0.0.1 extended-community 72:0.0.0.1 path-information 1.2.3.4;
			mpls-vpn 10.0.0.0/24 next-hop 192.168.0.1 origin igp local-preference 100 extended-community "target:0:0 target:1:1" path-information 10 label 20012 rd 100:100;
		}
	}
	add-path {
		ipv4/mpls-vpn;
		ipv4/unicast;
	}
}
EOF_CONF

# Process orchestration
cmd=background:seq=1:exec=ze-peer --port $PORT:stdin=peer
cmd=foreground:seq=2:exec=ze bgp server -:stdin=ze-bgp:timeout=10s
