# ze bgp configuration
stdin=ze-bgp:terminator=EOF_CONF
bgp {
	peer peer1 {
		remote {
			ip 127.0.0.1
			as 1
		}
		local {
			as 1
			ip 127.0.0.1
		}
		router-id 1.2.3.4
		connection active

		family {
			ipv4/unicast { prefix { maximum 10000; } }
			ipv6/unicast { prefix { maximum 10000; } }
		}
		update {
			attribute {
				origin igp
				next-hop 10.0.0.1
			}
			nlri {
				ipv4/unicast add 193.0.2.1/32 193.0.2.2/32
			}
		}
		update {
			attribute {
				origin igp
				next-hop 2A02:B80:1::1
			}
			nlri {
				ipv6/unicast add 2A02:B80:0:1::1/128
			}
		}
		update {
			attribute {
				origin igp
				next-hop 2A02:B80:1::1
			}
			nlri {
				ipv6/unicast add 2A02:B80:0:2::2/128
			}
		}
	}
}
EOF_CONF

# Process orchestration
cmd=background:seq=1:exec=ze-peer --port $PORT:stdin=peer
cmd=foreground:seq=2:exec=ze -:stdin=ze-bgp:timeout=10s
