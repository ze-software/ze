# ze-peer expectations
stdin=peer:terminator=EOF_PEER
cmd=api:conn=1:seq=1:text=peer * update text origin igp as-path [57821 6939] local-preference 100 atomic-aggregate aggregator 18144:219.118.225.189 nhop 192.168.1.254 nlri ipv4/unicast add 1.0.64.0/18
expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF0048020000002D4001010040020A02020000E1DD00001B1B400304C0A801FE40050400000064400600C00708000046E0DB76E1BD12010040
EOF_PEER

# ze bgp configuration
stdin=ze-bgp:terminator=EOF_CONF
bgp {
	group default {
		peer peer1 {
			remote {
				ip 127.0.0.1
				as 65533
			}
			local {
				as 65533
				ip 127.0.0.1
			}
			description "a quagga test peer"
			router-id 10.0.0.2
			connection active
			timer {
				receive-hold-time 180
			}
			update {
				attribute {
					origin igp
					next-hop 192.168.1.254
					as-path [ 57821 6939 ]
					aggregator 18144:219.118.225.189
					atomic-aggregate true
				}
				nlri {
					ipv4/unicast add 1.0.64.0/18
				}
			}
		}
	}
}
EOF_CONF

# Process orchestration
cmd=background:seq=1:exec=ze-peer --port $PORT:stdin=peer
cmd=foreground:seq=2:exec=ze -:stdin=ze-bgp:timeout=10s
