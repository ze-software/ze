# ze-peer expectations
stdin=peer:terminator=EOF_PEER
cmd=api:conn=1:seq=1:text=update text origin set igp as-path set [57821 6939] local-preference set 100 atomic-aggregate aggregator 18144:219.118.225.189 nhop set 192.168.1.254 nlri ipv4/unicast add 1.0.64.0/18
expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF0048020000002D4001010040020A02020000E1DD00001B1B400304C0A801FE40050400000064400600C00708000046E0DB76E1BD12010040
EOF_PEER

# ze bgp configuration
stdin=ze-bgp:terminator=EOF_CONF
peer 127.0.0.1 {
	description "a quagga test peer";
	router-id 10.0.0.2;
	local-address 127.0.0.1;
	local-as 65533;
	peer-as 65533;
	hold-time 180;
	announce {
		ipv4 {
			unicast 1.0.64.0/18 next-hop 192.168.1.254 as-path "57821 6939" aggregator 18144:219.118.225.189 atomic-aggregate true;
		}
	}
}
EOF_CONF

# Process orchestration
cmd=background:seq=1:exec=ze-peer --port $PORT:stdin=peer
cmd=foreground:seq=2:exec=ze bgp server -:stdin=ze-bgp:timeout=10s
