expect=bgp:conn=1:seq=1:
cmd=api:conn=1:seq=2:text=bgp peer * update text origin set igp as-path set [30740 30740 30740 30740 30740 30740 30740] local-preference set 1 med set 2000 community set [54591:123] extended-community set [target:54591:6 l2info:19:0:1500:111] originator-id set 192.168.22.1 cluster-list set [3.3.3.3 192.168.201.1] nhop set 192.168.201.1 nlri l2vpn/vpls add rd 192.168.201.1:124 ve-id 5 ve-block-offset 1 ve-block-size 8 label-base 10732
