# ze-peer expectations
stdin=peer:terminator=EOF_PEER
option=asn:value=65000
expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF001304
EOF_PEER

# ze bgp configuration
stdin=ze-bgp:terminator=EOF_CONF
bgp {
	group default {
		peer peer1 {
			connection {
				remote {
					ip 127.0.0.1
				}
				local {
					ip 127.0.0.1
					accept false
				}
			}
			session {
				asn {
					local 65533
					remote 65000
				}
				router-id 10.0.0.2
				family {
					ipv4/unicast { prefix { maximum 10000; } }
				}
			}
			timer {
				receive-hold-time 180
			}

		}
	}
}
EOF_CONF

# Process orchestration
cmd=background:seq=1:exec=ze-peer --port $PORT:stdin=peer
cmd=foreground:seq=2:exec=ze -:stdin=ze-bgp:timeout=10s
