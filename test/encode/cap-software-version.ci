# ze-peer expectations
stdin=peer:terminator=EOF_PEER
option=open:value=inspect-open-message
expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF00450104FFFD00B40A000002280206010400010001020641040000FFFD02164B14134578614247502F352E302E302D302B74657374
EOF_PEER

# ze bgp configuration
stdin=ze-bgp:terminator=EOF_CONF
peer 127.0.0.1 {
	router-id 10.0.0.2;
	local-address 127.0.0.1;
	local-as 65533;
	peer-as 65533;
	hold-time 180;

	family {
		ipv4/unicast;
	}
	capability {
		software-version enable;
	}
}
EOF_CONF

# Process orchestration
cmd=background:seq=1:exec=ze-peer --port $PORT:stdin=peer
cmd=foreground:seq=2:exec=ze bgp server -:stdin=ze-bgp:timeout=10s
