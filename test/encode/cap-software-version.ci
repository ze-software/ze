# ze-peer expectations
stdin=peer:terminator=EOF_PEER
option=open:value=inspect-open-message
expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF00360104FFFD00B40A00000219021701040001000141040000FFFD4B09085A652F302E312E30
EOF_PEER

# ze bgp configuration
stdin=ze-bgp:terminator=EOF_CONF
bgp {
	group default {
		peer peer1 {
			connection {
				remote {
					ip 127.0.0.1
				}
				local {
					ip 127.0.0.1
					accept false
				}
			}
			session {
				asn {
					local 65533
					remote 65533
				}
				router-id 10.0.0.2
				family {
					ipv4/unicast { prefix { maximum 10000; } }
				}
				capability {
					software-version { }
				}
			}
			timer {
				receive-hold-time 180
			}

		}
	}
}
EOF_CONF

# Process orchestration
cmd=background:seq=1:exec=ze-peer --port $PORT:stdin=peer
cmd=foreground:seq=2:exec=ze --plugin ze.bgp-softver -:stdin=ze-bgp:timeout=10s
