# ze-peer expectations
stdin=peer:terminator=EOF_PEER
option=open:value=inspect-open-message
expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF003A0104FFFD00B40A0000021D0206010400010001020641040000FFFD020B4B09085A652F302E312E30
EOF_PEER

# ze bgp configuration
stdin=ze-bgp:terminator=EOF_CONF
bgp {
	peer 127.0.0.1 {
		router-id 10.0.0.2
		local-address 127.0.0.1
		local-as 65533
		peer-as 65533
		connection active
		hold-time 180

		family {
			ipv4/unicast
		}
		capability {
			software-version { }
		}
	}
}
EOF_CONF

# Process orchestration
cmd=background:seq=1:exec=ze-peer --port $PORT:stdin=peer
cmd=foreground:seq=2:exec=ze --plugin ze.bgp-softver -:stdin=ze-bgp:timeout=10s
