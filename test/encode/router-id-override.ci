# Test: per-peer router-id overrides global router-id in OPEN
# VALIDATES: per-peer router-id config appears in OPEN message
# PREVENTS: per-peer router-id silently ignored, global used instead

# ze-peer expectations
stdin=peer:terminator=EOF_PEER
option=open:value=inspect-open-message
option=timeout:value=10s

# OPEN with router-id 10.20.30.40 (0A141E28):
# marker(16xFF) + len(002D=45) + type(01=OPEN) + ver(04) + ASN(0001) + hold(005A=90)
# + router-id(0A141E28) + opt-len(10=16)
# + MP ipv4/unicast: param(02) len(06) cap(01) len(04) AFI(0001) res(00) SAFI(01)
# + ASN4: param(02) len(06) cap(41) len(04) ASN(00000001)
expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF002D01040001005A0A141E281002060104000100010206410400000001
EOF_PEER

# ze bgp configuration with per-peer router-id
stdin=ze-bgp:terminator=EOF_CONF
bgp {
	peer peer1 {
		remote {
			ip 127.0.0.1
			as 1
		}
		local {
			as 1
			ip 127.0.0.1
		}
		router-id 10.20.30.40
		connection active
		family {
			ipv4/unicast { prefix { maximum 10000; } }
		}
	}
}
EOF_CONF

# Process orchestration
cmd=background:seq=1:exec=ze-peer --port $PORT:stdin=peer
cmd=foreground:seq=2:exec=ze -:stdin=ze-bgp:timeout=10s
