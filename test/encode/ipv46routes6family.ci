# ze-peer expectations
stdin=peer:terminator=EOF_PEER
cmd=api:conn=1:seq=1:text=peer * update text origin igp local-preference 200 community [30740:0 30740:30740] nhop 2a02:b80:0:2::1 nlri ipv6/unicast add 2a02:b80:0:1::1/128
expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF0059020000004240010100400200400504000000C8C008087814000078147814800E26000201102A020B8000000002000000000000000100802A020B80000000010000000000000001
cmd=api:conn=1:seq=1:text=peer * update text nlri ipv6/unicast eor
expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF001E0200000007900F0003000201
EOF_PEER

# ze bgp configuration
stdin=ze-bgp:terminator=EOF_CONF
bgp {
	group default {
		peer 127.0.0.1 {
			router-id 1.2.3.4
			local-address 127.0.0.1
			local-as 1
			peer-as 1
			connection active
			group-updates disable

			family {
				ipv6/unicast
			}
			update {
				attribute {
					origin igp
					next-hop 2A02:B80:0:2::1
					local-preference 200
					community [ 30740:0 30740:30740 ]
				}
				nlri {
					ipv6/unicast add 2A02:B80:0:1::1/128
				}
			}
		}
	}
}
EOF_CONF

# Process orchestration
cmd=background:seq=1:exec=ze-peer --port $PORT:stdin=peer
cmd=foreground:seq=2:exec=ze -:stdin=ze-bgp:timeout=10s
