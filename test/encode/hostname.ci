# ze-peer expectations
stdin=peer:terminator=EOF_PEER
option=open:value=inspect-open-message
expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF00510104FFFD00B40A000002340206010400010001020641040000FFFD022249200C6D792D686F73742D6E616D65126D792D646F6D61696E2D6E616D652E636F6D
EOF_PEER

# ze bgp configuration
stdin=ze-bgp:terminator=EOF_CONF
bgp {
	peer 127.0.0.1 {
		router-id 10.0.0.2;
		local-address 127.0.0.1;
		local-as 65533;
		peer-as 65533;
		hold-time 180;

		family {
			ipv4/unicast;
		}
		host-name my-host-name;
		domain-name my-domain-name.com;
	}
}
EOF_CONF

# Process orchestration
cmd=background:seq=1:exec=ze-peer --port $PORT:stdin=peer
cmd=foreground:seq=2:exec=ze bgp server -:stdin=ze-bgp:timeout=10s
