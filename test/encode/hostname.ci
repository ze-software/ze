# ze-peer expectations
stdin=peer:terminator=EOF_PEER
option=open:value=inspect-open-message
expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF004D0104FFFD00B40A00000230022E01040001000141040000FFFD49200C6D792D686F73742D6E616D65126D792D646F6D61696E2D6E616D652E636F6D
EOF_PEER

# ze bgp configuration
stdin=ze-bgp:terminator=EOF_CONF
bgp {
	group default {
		peer peer1 {
			connection {
				remote {
					ip 127.0.0.1
				}
				local {
					ip 127.0.0.1
					accept false
				}
			}
			session {
				asn {
					local 65533
					remote 65533
				}
				router-id 10.0.0.2
				family {
					ipv4/unicast { prefix { maximum 10000; } }
				}
				capability {
					hostname {
						host my-host-name
						domain my-domain-name.com
					}
				}
			}
			timer {
				receive-hold-time 180
			}

		}
	}
}
EOF_CONF

# Process orchestration
cmd=background:seq=1:exec=ze-peer --port $PORT:stdin=peer
cmd=foreground:seq=2:exec=ze --plugin ze.bgp-hostname -:stdin=ze-bgp:timeout=10s
