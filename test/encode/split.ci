# ze bgp configuration
stdin=ze-bgp:terminator=EOF_CONF
bgp {
	peer 127.0.0.1 {
		description "will announce 4 /24";
		router-id 198.111.227.39;
		local-address 127.0.0.1;
		local-as 65533;
		peer-as 65533;
		group-updates disable;

		family {
			ipv4/unicast;
		}
		announce {
			ipv4 {
				unicast 172.10.0.0/22 next-hop 192.0.2.1 med 200 community 174:666 split /24;
				unicast 172.10.4.0/22 next-hop 192.0.2.1 med 200 community 174:666 split /24;
			}
		}
	}
}
EOF_CONF

# Process orchestration
cmd=background:seq=1:exec=ze-peer --port $PORT:stdin=peer
cmd=foreground:seq=2:exec=ze bgp server -:stdin=ze-bgp:timeout=10s
