# ze bgp configuration
stdin=ze-bgp:terminator=EOF_CONF
bgp {
	peer peer1 {
		connection {
			remote {
				ip 127.0.0.1
				accept false
			}
			local {
				ip 127.0.0.1
			}
		}
		session {
			asn {
				local 12345
				remote 12345
			}
			router-id 127.0.0.2
			family {
				ipv4/mpls-vpn { prefix { maximum 10000; } }
				ipv4/unicast { prefix { maximum 10000; } }
				ipv6/mpls-vpn { prefix { maximum 10000; } }
				ipv6/unicast { prefix { maximum 10000; } }
			}
			capability {
				nexthop {
					ipv4/mpls-vpn ipv6
					ipv4/unicast ipv6
					ipv6/unicast ipv4
				}
			}
		}
		behavior {
			group-updates disable
		}

		update {
			attribute {
				origin igp
				next-hop BAD:CAFE:BAD:CAFE:BAD:CAFE:BAD:CAFE
			}
			nlri {
				ipv4/unicast add 153.153.153.153/32
			}
		}
		update {
			attribute {
				origin igp
				next-hop 170.170.170.170
			}
			nlri {
				ipv6/unicast add DEAD:BEEF:DEAD:BEEF:DEAD:BEEF:DEAD:BEEF/128
			}
		}
	}
}
EOF_CONF

# Process orchestration
cmd=background:seq=1:exec=ze-peer --port $PORT:stdin=peer
cmd=foreground:seq=2:exec=ze -:stdin=ze-bgp:timeout=10s
