# ze-peer expectations
stdin=peer:terminator=EOF_PEER
cmd=api:conn=1:seq=1:text=bgp peer * update text origin set igp as-path set [100] local-preference set 100 nhop set 10.0.255.254 nlri ipv4/unicast add 10.0.1.0/24
expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF0034020000001940010100400204020100644003040A00FFFE40050400000064180A0001
EOF_PEER

# ze bgp configuration
stdin=ze-bgp:terminator=EOF_CONF
bgp {
	peer 127.0.0.1 {
		router-id 127.0.0.1;
		local-address 127.0.0.1;
		local-as 65533;
		peer-as 65533;
		hold-time 180;
		capability {
			asn4 disable;
		}
		announce {
			ipv4 {
				unicast 10.0.1.0/24 next-hop 10.0.255.254 as-path 100;
			}
		}
	}
}
EOF_CONF

# Process orchestration
cmd=background:seq=1:exec=ze-peer --port $PORT:stdin=peer
cmd=foreground:seq=2:exec=ze bgp server -:stdin=ze-bgp:timeout=10s
