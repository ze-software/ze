# ze-peer expectations
stdin=peer:terminator=EOF_PEER
cmd=api:conn=1:seq=1:text=peer * update text origin igp as-path [100] local-preference 100 nhop 10.0.255.254 nlri ipv4/unicast add 10.0.1.0/24
expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF0034020000001940010100400204020100644003040A00FFFE40050400000064180A0001
EOF_PEER

# ze bgp configuration
stdin=ze-bgp:terminator=EOF_CONF
bgp {
	group default {
		peer 127.0.0.1 {
			router-id 127.0.0.1
			local-address 127.0.0.1
			local-as 65533
			peer-as 65533
			connection active
			hold-time 180
			capability {
				asn4 disable
			}
			update {
				attribute {
					origin igp
					next-hop 10.0.255.254
					as-path [ 100 ]
				}
				nlri {
					ipv4/unicast add 10.0.1.0/24
				}
			}
		}
	}
}
EOF_CONF

# Process orchestration
cmd=background:seq=1:exec=ze-peer --port $PORT:stdin=peer
cmd=foreground:seq=2:exec=ze -:stdin=ze-bgp:timeout=10s
