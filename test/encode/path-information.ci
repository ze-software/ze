# ze bgp configuration
stdin=ze-bgp:terminator=EOF_CONF
bgp {
	peer 127.0.0.1 {
		router-id 127.0.0.1
		local-address 127.0.0.1
		local-as 55219
		peer-as 55219
		connection active

		family {
			ipv4/unicast
		}
		capability {
			add-path send/receive
		}
		update {
			attribute {
				origin igp
				next-hop 10.10.1.1
				path-information 0.0.0.1
			}
			nlri {
				ipv4/unicast add 10.0.0.10/32
			}
		}
		update {
			attribute {
				origin igp
				next-hop 10.10.1.2
				path-information 0.0.0.2
			}
			nlri {
				ipv4/unicast add 10.0.0.10/32
			}
		}
		update {
			attribute {
				origin igp
				next-hop 10.10.1.3
				path-information 0.0.0.3
			}
			nlri {
				ipv4/unicast add 10.1.0.10/32
			}
		}
	}
}
EOF_CONF

# Process orchestration
cmd=background:seq=1:exec=ze-peer --port $PORT:stdin=peer
cmd=foreground:seq=2:exec=ze -:stdin=ze-bgp:timeout=10s
