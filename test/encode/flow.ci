# ze bgp configuration
stdin=ze-bgp:terminator=EOF_CONF
bgp {
	peer 127.0.0.1 {
		router-id 1.2.3.4;
		local-address 127.0.0.1;
		local-as 1;
		peer-as 1;
		group-updates disable;

		family {
			ipv4/flow;
			ipv4/flow-vpn;
			ipv6/flow;
		}

		# Route 1: flow source-ipv4 10.0.0.1/32 rd 65535:65536 extended-community discard
		update {
			attribute {
				extended-community [rate-limit:0];
			}
			nlri {
				ipv4/flow-vpn rd 65535:65536 source-ipv4 10.0.0.1/32;
			}
		}

		# Route 2: flow source-ipv4 10.0.0.2/32 next-hop 1.2.3.4 extended-community copy-to-nexthop
		update {
			attribute {
				next-hop 1.2.3.4;
				extended-community [copy-to-nexthop];
			}
			nlri {
				ipv4/flow source-ipv4 10.0.0.2/32;
			}
		}

		# Route 3: flow with community and extended-community
		update {
			attribute {
				community [30740:0 30740:30740];
				extended-community [rate-limit:0];
			}
			nlri {
				ipv4/flow destination-ipv4 10.0.0.2/32 source-ipv4 10.0.0.1/32 protocol =tcp destination-port =3128;
			}
		}

		# Route 4: fragment action
		update {
			attribute {
				extended-community [action sample-terminal];
			}
			nlri {
				ipv4/flow fragment last-fragment;
			}
		}

		# Route 5: rate-limit 9600
		update {
			attribute {
				extended-community [rate-limit:9600];
			}
			nlri {
				ipv4/flow source-ipv4 10.0.0.0/24 protocol =tcp destination-port =3128;
			}
		}

		# Route 6: IPv6 flow
		update {
			attribute {
				extended-community [rate-limit:0];
			}
			nlri {
				ipv6/flow destination-ipv6 2a02:b80:15:0:7aca:39ff:feae:a87a/128/0 source-ipv6 ::1/128/120 next-header =udp traffic-class =101 flow-label =2013;
			}
		}

		# Route 7: packet-length ranges
		update {
			attribute {
				extended-community [mark 10];
			}
			nlri {
				ipv4/flow packet-length [ >200&<300 >400&<500 ];
			}
		}

		# Route 8: flow-vpn with redirect-to-nexthop
		update {
			attribute {
				next-hop 5.6.7.8;
				extended-community [redirect-to-nexthop];
			}
			nlri {
				ipv4/flow-vpn rd 65535:65536 source-ipv4 10.0.0.3/32;
			}
		}

		# Route 9: redirect-to-nexthop
		update {
			attribute {
				next-hop 1.2.3.4;
				extended-community [redirect-to-nexthop];
			}
			nlri {
				ipv4/flow destination-ipv4 192.168.0.1/32;
			}
		}

		# Route 10: complex flow with redirect
		update {
			attribute {
				extended-community [redirect:258:33756718];
			}
			nlri {
				ipv4/flow destination-ipv4 192.168.0.1/32 source-ipv4 10.0.0.2/32 protocol [ =udp =tcp ] port [ =80 =8080 ] destination-port [ >8080&<8088 =3128 ] source-port >1024;
			}
		}

		# Route 11: redirect 65500:12345
		update {
			attribute {
				extended-community [redirect:65500:12345];
			}
			nlri {
				ipv4/flow destination-ipv4 192.168.0.1/32 source-ipv4 10.0.0.9/32 protocol [ =udp =tcp ] port [ =80 =8080 ] destination-port [ >8080&<8088 =3128 ] source-port >1024;
			}
		}

		# Route 12: negation operators
		update {
			attribute {
				extended-community [rate-limit:0];
			}
			nlri {
				ipv4/flow destination-ipv4 192.168.0.1/32 source-ipv4 10.0.0.10/32 protocol !=tcp port !=0 destination-port !=443 source-port [ !=80 !=8080 ];
			}
		}

		# Route 13: tcp-flags
		update {
			attribute {
				extended-community [rate-limit:0];
			}
			nlri {
				ipv4/flow destination-ipv4 10.0.0.2/32 source-ipv4 10.0.0.1/32 protocol =tcp destination-port =3128 tcp-flags [ syn rst&fin&!=push ];
			}
		}
	}
}
EOF_CONF

# Process orchestration
# flowspec plugin auto-loaded because ipv4/flow family is configured
cmd=background:seq=1:exec=ze-peer --port $PORT:stdin=peer
cmd=foreground:seq=2:exec=ze -:stdin=ze-bgp:timeout=10s
