# ze bgp configuration
stdin=ze-bgp:terminator=EOF_CONF
bgp {
	peer peer1 {
		remote {
			ip 127.0.0.1
			as 65000
			accept false
		}
		local {
			as 65000
			ip 127.0.0.1
		}
		router-id 10.0.0.1

		family {
			ipv4/mup { prefix { maximum 10000; } }
			ipv6/mup { prefix { maximum 10000; } }
		}

		# Route 1: mup-t1st IPv4 with source
		update {
			attribute {
				next-hop 10.0.0.2
				extended-community [target:10:10]
			}
			nlri {
				ipv4/mup add mup-t1st 192.168.0.2/32 rd 100:100 teid 12345 qfi 9 endpoint 10.0.0.1 source 10.0.1.1
			}
		}

		# Route 2: mup-t1st IPv6 with source
		update {
			attribute {
				next-hop ::ffff:10.0.0.2
				extended-community [target:10:10]
			}
			nlri {
				ipv6/mup add mup-t1st 2001:db8:1:1::2/128 rd 100:100 teid 12345 qfi 9 endpoint 2001::1 source 2002::2
			}
		}
	}
}
EOF_CONF

# Process orchestration
cmd=background:seq=1:exec=ze-peer --port $PORT:stdin=peer
cmd=foreground:seq=2:exec=ze -:stdin=ze-bgp:timeout=10s
