# ze-peer expectations (what peer expects to receive)
stdin=peer:terminator=EOF_PEER
option=asn:value=65000
expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF002F02000000144001010040020602010000FFFD4003040A0001FE180A0000
expect=bgp:conn=1:seq=2:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF00170200000000
EOF_PEER

# ze bgp configuration
stdin=ze-bgp:terminator=EOF_CONF
bgp {
	group default {
		peer peer1 {
			remote {
				ip 127.0.0.1
				as 65000
			}
			local {
				as 65533
				ip 127.0.0.1
			}
			router-id 10.0.0.2
			connection active
			timer {
				receive-hold-time 180
			}

			family {
				ipv4/unicast { prefix { maximum 10000; } }
			}
			update {
				attribute {
					origin igp
					next-hop 10.0.1.254
					local-preference 200
				}
				nlri {
					ipv4/unicast add 10.0.0.0/24
				}
			}
		}
	}
}
EOF_CONF

# Process orchestration
cmd=background:seq=1:exec=ze-peer --port $PORT:stdin=peer
cmd=foreground:seq=2:exec=ze -:stdin=ze-bgp:timeout=10s
