# ze bgp configuration
stdin=ze-bgp:terminator=EOF_CONF
bgp {
	peer 127.0.0.1 {
		router-id 10.0.0.1
		local-address 127.0.0.1
		local-as 65000
		peer-as 65000
		connection active

		family {
			ipv4/mup
			ipv6/mup
		}

		# Route 1: mup-isd IPv4
		update {
			attribute {
				next-hop 2001::1
				extended-community [target:10:10]
				bgp-prefix-sid-srv6 ( l3-service 2001:db8:1:1:: 0x48 [64,24,16,0,0,0] )
			}
			nlri {
				ipv4/mup add mup-isd 10.0.1.0/24 rd 100:100
			}
		}

		# Route 2: mup-dsd IPv4
		update {
			attribute {
				next-hop 2001::2
				extended-community [target:10:10 mup:10:10]
				bgp-prefix-sid-srv6 ( l3-service 2001:db8:1:1:: 0x13 [64,24,16,0,0,0] )
			}
			nlri {
				ipv4/mup add mup-dsd 10.0.0.1 rd 100:100
			}
		}

		# Route 3: mup-t1st IPv4
		update {
			attribute {
				next-hop 10.0.0.2
				extended-community [target:10:10]
			}
			nlri {
				ipv4/mup add mup-t1st 192.168.0.1/32 rd 100:100 teid 12345 qfi 9 endpoint 10.0.0.1
			}
		}

		# Route 4: mup-t2st IPv4 teid/32
		update {
			attribute {
				next-hop 10.0.0.2
				extended-community [target:10:10 mup:10:10]
			}
			nlri {
				ipv4/mup add mup-t2st 10.0.0.1 rd 100:100 teid 12345/32
			}
		}

		# Route 5: mup-t2st IPv4 teid/23
		update {
			attribute {
				next-hop 10.0.0.2
				extended-community [target:10:10 mup:10:10]
			}
			nlri {
				ipv4/mup add mup-t2st 10.0.0.1 rd 100:100 teid 12345/23
			}
		}

		# Route 6: mup-t2st IPv4 teid 0/0
		update {
			attribute {
				next-hop 10.0.0.2
				extended-community [target:10:10 mup:10:10]
			}
			nlri {
				ipv4/mup add mup-t2st 10.0.0.1 rd 100:100 teid 0/0
			}
		}

		# Route 7: mup-isd IPv6
		update {
			attribute {
				next-hop 2001::2
				extended-community [target:10:10]
				bgp-prefix-sid-srv6 ( l3-service 2001:db8:1:1:: 0x47 [64,24,16,0,0,0] )
			}
			nlri {
				ipv6/mup add mup-isd 2001::/64 rd 100:100
			}
		}

		# Route 8: mup-dsd IPv6
		update {
			attribute {
				next-hop 2001::2
				extended-community [target:10:10 mup:10:10]
				bgp-prefix-sid-srv6 ( l3-service 2001:db8:2:2:: 0x18 [64,24,16,0,0,0] )
			}
			nlri {
				ipv6/mup add mup-dsd 2001::1 rd 100:100
			}
		}

		# Route 9: mup-t1st IPv6
		update {
			attribute {
				next-hop ::ffff:10.0.0.2
				extended-community [target:10:10]
			}
			nlri {
				ipv6/mup add mup-t1st 2001:db8:1:1::1/128 rd 100:100 teid 12345 qfi 9 endpoint 2001::1
			}
		}

		# Route 10: mup-t2st IPv6
		update {
			attribute {
				next-hop ::ffff:10.0.0.2
				extended-community [target:10:10 mup:10:10]
			}
			nlri {
				ipv6/mup add mup-t2st 2001::1 rd 100:100 teid 12345/32
			}
		}
	}
}
EOF_CONF

# Process orchestration
cmd=background:seq=1:exec=ze-peer --port $PORT:stdin=peer
cmd=foreground:seq=2:exec=ze -:stdin=ze-bgp:timeout=10s
