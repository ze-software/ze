# Group defaults produce correct wire output: receive-hold-time inherited from group
stdin=peer:terminator=EOF_PEER
option=open:value=inspect-open-message
expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF002B0104FFFD001E0A0000020E020C01040001000141040000FFFD
EOF_PEER

# ze bgp configuration -- receive-hold-time set at group level, inherited by peer
stdin=ze-bgp:terminator=EOF_CONF
bgp {
	group test {
		connection {
			remote {
			}
			local {
				accept false
			}
		}
		session {
			asn {
				local 65533
				remote 65533
			}
			family {
				ipv4/unicast { prefix { maximum 10000; } }
			}
		}
		timer {
			receive-hold-time 30
		}
		peer peer1 {
			connection {
				remote {
					ip 127.0.0.1
				}
				local {
					ip 127.0.0.1
				}
			}
			session {
				router-id 10.0.0.2
			}
		}
	}
}
EOF_CONF

# Process orchestration
cmd=background:seq=1:exec=ze-peer --port $PORT:stdin=peer
cmd=foreground:seq=2:exec=ze -:stdin=ze-bgp:timeout=10s
