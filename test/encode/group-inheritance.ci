# Group defaults produce correct wire output: hold-time inherited from group
stdin=peer:terminator=EOF_PEER
option=open:value=inspect-open-message
expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF002D0104FFFD001E0A000002100206010400010001020641040000FFFD
EOF_PEER

# ze bgp configuration -- hold-time set at group level, inherited by peer
stdin=ze-bgp:terminator=EOF_CONF
bgp {
	group test {
		local {
			as 65533
		}
		remote {
			as 65533
		}
		timer {
			hold-time 30
		}
		connection active
		family {
			ipv4/unicast { prefix { maximum 10000; } }
		}
		peer peer1 {
			remote {
				ip 127.0.0.1
			}
			local {
				ip 127.0.0.1
			}
			router-id 10.0.0.2
		}
	}
}
EOF_CONF

# Process orchestration
cmd=background:seq=1:exec=ze-peer --port $PORT:stdin=peer
cmd=foreground:seq=2:exec=ze -:stdin=ze-bgp:timeout=10s
