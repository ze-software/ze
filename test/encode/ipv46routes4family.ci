# ze-peer expectations
stdin=peer:terminator=EOF_PEER
cmd=api:conn=1:seq=1:text=peer * update text origin igp local-preference 100 extended-community [target:72:1] nhop 10.0.0.1 nlri ipv4/unicast add 193.0.2.1/32
expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF003C0200000020400101004002004003040A00000140050400000064C01008000200480000000120C1000201
EOF_PEER

# ze bgp configuration
stdin=ze-bgp:terminator=EOF_CONF
bgp {
	group default {
		peer peer1 {
			connection {
				remote {
					ip 127.0.0.1
				}
				local {
					ip 127.0.0.1
					accept false
				}
			}
			session {
				asn {
					local 1
					remote 1
				}
				router-id 1.2.3.4
				family {
					ipv4/unicast { prefix { maximum 10000; } }
				}
			}
			behavior {
				group-updates disable
			}

			update {
				attribute {
					origin igp
					next-hop 10.0.0.1
					extended-community [ target:72:1 ]
				}
				nlri {
					ipv4/unicast add 193.0.2.1/32
				}
			}
		}
	}
}
EOF_CONF

# Process orchestration
cmd=background:seq=1:exec=ze-peer --port $PORT:stdin=peer
cmd=foreground:seq=2:exec=ze -:stdin=ze-bgp:timeout=10s
