# ze-peer expectations
stdin=peer:terminator=EOF_PEER
cmd=api:conn=1:seq=1:text=bgp peer * update text origin set igp local-preference set 100 extended-community set [target:72:1] nhop set 10.0.0.1 nlri ipv4/unicast add 193.0.2.1/32
expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF003C0200000020400101004002004003040A00000140050400000064C01008000200480000000120C1000201
EOF_PEER

# ze bgp configuration
stdin=ze-bgp:terminator=EOF_CONF
bgp {
	peer 127.0.0.1 {
		router-id 1.2.3.4;
		local-address 127.0.0.1;
		local-as 1;
		peer-as 1;
		group-updates disable;

		family {
			ipv4/unicast;
		}
		update {
			attribute {
				origin igp;
				next-hop 10.0.0.1;
				extended-community [ target:72:1 ];
			}
			nlri {
				ipv4/unicast 193.0.2.1/32;
			}
		}
	}
}
EOF_CONF

# Process orchestration
cmd=background:seq=1:exec=ze-peer --port $PORT:stdin=peer
cmd=foreground:seq=2:exec=ze bgp server -:stdin=ze-bgp:timeout=10s
