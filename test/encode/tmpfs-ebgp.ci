# tmpfs-based encoding test - embeds config directly in .ci file
tmpfs=tmpfs-ebgp.conf:terminator=EOF_CONF
bgp {
	peer peer1 {
		connection {
			remote {
				ip 127.0.0.1
				accept false
			}
			local {
				ip 127.0.0.1
			}
		}
		session {
			asn {
				local 65533
				remote 65000
			}
			router-id 10.0.0.2
			family {
				ipv4/unicast { prefix { maximum 10000; } }
			}
		}
		timer {
			receive-hold-time 180
		}

		update {
			attribute {
				origin igp
				next-hop 10.0.1.254
				local-preference 200
			}
			nlri {
				ipv4/unicast add 10.0.0.0/24
			}
		}
	}
}
EOF_CONF

option=file:path=tmpfs-ebgp.conf
option=asn:value=65000
cmd=api:conn=1:seq=1:text=peer * update text origin igp as-path [65533] nhop 10.0.1.254 nlri ipv4/unicast add 10.0.0.0/24
expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF002F02000000144001010040020602010000FFFD4003040A0001FE180A0000
expect=json:conn=1:seq=1:json={"meta":{"version":"1.0.0","format":"ze-bgp"},"message":{"type":"update"},"as-path":[65533],"origin":"igp","ipv4/unicast":[{"action":"add","nlri":["10.0.0.0/24"],"next-hop":"10.0.1.254"}]}
cmd=api:conn=1:seq=1:text=peer * update text nlri ipv4/unicast eor
expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF00170200000000
