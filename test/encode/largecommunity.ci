# ze bgp configuration
stdin=ze-bgp:terminator=EOF_CONF
bgp {
	group default {
		peer 127.0.0.1 {
			router-id 1.2.3.4
			local-address 127.0.0.1
			local-as 65000
			peer-as 65000
			connection active
			group-updates disable

			family {
				ipv4/unicast
			}
			update {
				attribute {
					origin igp
					next-hop 192.0.2.1
					large-community [ 2914:0:666 2914:3320:123 ]
				}
				nlri {
					ipv4/unicast add 8.8.8.10/32
				}
			}
			update {
				attribute {
					origin igp
					next-hop 192.0.2.1
					large-community [ 2914:0:666 2914:3320:123 ]
				}
				nlri {
					ipv4/unicast add 9.9.9.10/32
				}
			}
		}
	}
}
EOF_CONF

# Process orchestration
cmd=background:seq=1:exec=ze-peer --port $PORT:stdin=peer
cmd=foreground:seq=2:exec=ze -:stdin=ze-bgp:timeout=10s
