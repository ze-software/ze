# ze-peer expectations
stdin=peer:terminator=EOF_PEER
option:open:value=send-unknown-message
expect:bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF004003010063616E206E6F74206465636F646520757064617465206D657373616765206F662074797065202232353522
EOF_PEER

# ze bgp configuration
stdin=ze-bgp:terminator=EOF_CONF
bgp {
	peer 127.0.0.1 {
		router-id 1.2.3.4;
		local-address 127.0.0.1;
		local-as 1;
		peer-as 1;

		family {
			ipv4/unicast;
		}
	}
}
EOF_CONF

# Process orchestration
cmd:background:seq=1:exec=ze-peer --port $PORT:stdin=peer
cmd:foreground:seq=2:exec=ze -:stdin=ze-bgp:timeout=10s
