# ze-peer expectations
stdin=peer:terminator=EOF_PEER
cmd=api:conn=1:seq=1:text=bgp peer * update text label 800001 origin set igp local-preference set 100 bgp-prefix-sid [ 777 ] nhop set 198.51.100.1 nlri ipv4/unicast add 198.51.100.100/32
expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF004D020000003640010100400200400304C633640140050400000064800E1100010404C63364010038C35011C6336464C0280A01000700000000000309
cmd=api:conn=1:seq=1:text=bgp peer * update text label 800002 origin set igp local-preference set 100 bgp-prefix-sid [ 300, [ ( 800000,4096 ) ( 1000000,5000 ) ] ] nhop set 198.51.100.2 nlri ipv4/unicast add 198.51.100.101/32
expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF005E020000004740010100400200400304C633640240050400000064800E1100010404C63364020038C35021C6336465C0281B0100070000000000012C03000E00000C35000010000F4240001388
EOF_PEER

# ze bgp configuration
stdin=ze-bgp:terminator=EOF_CONF
bgp {
	peer 127.0.0.1 {
		router-id 198.51.100.200;
		local-address 127.0.0.1;
		local-as 65000;
		peer-as 65000;
		group-updates disable;

		family {
			ipv4/nlri-mpls;
			ipv4/unicast;
		}
		announce {
			ipv4 {
				nlri-mpls 198.51.100.100/32 next-hop 198.51.100.1 label 800001 bgp-prefix-sid 777;
				nlri-mpls 198.51.100.101/32 next-hop 198.51.100.2 label 800002 bgp-prefix-sid "300, [( 800000,4096) ,( 1000000,5000)]";
			}
		}
	}
}
EOF_CONF

# Process orchestration
cmd=background:seq=1:exec=ze-peer --port $PORT:stdin=peer
cmd=foreground:seq=2:exec=ze bgp server -:stdin=ze-bgp:timeout=10s
