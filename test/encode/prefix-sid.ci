# ze bgp configuration
stdin=ze-bgp:terminator=EOF_CONF
bgp {
	peer 127.0.0.1 {
		router-id 198.51.100.200;
		local-address 127.0.0.1;
		local-as 65000;
		peer-as 65000;
		connection active;
		group-updates disable;

		family {
			ipv4/mpls;
			ipv4/unicast;
		}
		update {
			attribute {
				origin igp;
				next-hop 198.51.100.1;
				label 800001;
				bgp-prefix-sid "[ 777 ]";
			}
			nlri {
				ipv4/mpls add 198.51.100.100/32;
			}
		}
		update {
			attribute {
				origin igp;
				next-hop 198.51.100.2;
				label 800002;
				bgp-prefix-sid "[ 300, [ ( 800000,4096 ) ( 1000000,5000 ) ] ]";
			}
			nlri {
				ipv4/mpls add 198.51.100.101/32;
			}
		}
	}
}
EOF_CONF

# Process orchestration
cmd=background:seq=1:exec=ze-peer --port $PORT:stdin=peer
cmd=foreground:seq=2:exec=ze -:stdin=ze-bgp:timeout=10s
