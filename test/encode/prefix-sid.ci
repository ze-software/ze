expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF005E020000004740010100400200400304C633640240050400000064C0281B0100070000000000012C03000E00000C35000010000F4240001388800E1100010404C63364020038C35021C6336465
