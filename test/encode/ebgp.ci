# ze-peer expectations
stdin=peer:terminator=EOF_PEER
option=asn:value=65000
cmd=api:conn=1:seq=1:text=bgp peer * update text origin set igp as-path set [65533] nhop set 10.0.1.254 nlri ipv4/unicast add 10.0.0.0/24
expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF002F02000000144001010040020602010000FFFD4003040A0001FE180A0000
expect=json:conn=1:seq=1:json={"meta":{"version":"1.0.0","format":"ze-bgp"},"message":{"type":"update"},"peer":{"address":"127.0.0.1","asn":65533},"direction":"in","as-path":{"0":{"element":"as-sequence","value":[65533]}},"origin":"igp","ipv4/unicast":[{"action":"add","nlri":["10.0.0.0/24"],"next-hop":"10.0.1.254"}]}
cmd=api:conn=1:seq=1:text=bgp peer * update text nlri ipv4/unicast eor
expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF00170200000000
EOF_PEER

# ze bgp configuration
stdin=ze-bgp:terminator=EOF_CONF
bgp {
	peer 127.0.0.1 {
		router-id 10.0.0.2;
		local-address 127.0.0.1;
		local-as 65533;
		peer-as 65000;
		hold-time 180;

		family {
			ipv4/unicast;
		}
		announce {
			ipv4 {
				unicast 10.0.0.0/24 next-hop 10.0.1.254 local-preference 200;
			}
		}
	}
}
EOF_CONF

# Process orchestration
cmd=background:seq=1:exec=ze-peer --port $PORT:stdin=peer
cmd=foreground:seq=2:exec=ze bgp server -:stdin=ze-bgp:timeout=10s
