# ze-peer expectations
stdin=peer:terminator=EOF_PEER
cmd=api:conn=1:seq=1:text=update text origin set igp local-preference set 100 nhop set 127.0.0.1 nlri ipv4/unicast add 10.0.0.0/32
expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF00310200000015400101004002004003047F00000140050400000064200A000000
expect=json:conn=1:seq=1:json={"meta":{"version":"1.0.0","format":"ze-bgp"},"message":{"type":"update"},"peer":{"address":"127.0.0.1","asn":65533},"direction":"in","local-preference":100,"origin":"igp","ipv4/unicast":[{"action":"add","nlri":["10.0.0.0/32"],"next-hop":"127.0.0.1"}]}
cmd=api:conn=1:seq=1:text=announce eor ipv4/unicast
expect=bgp:conn=1:seq=1:hex=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF00170200000000
EOF_PEER

# ze bgp configuration
stdin=ze-bgp:terminator=EOF_CONF
bgp {
	peer 127.0.0.1 {
		router-id 127.0.0.2;
		local-address 127.0.0.1;
		local-as 12345;
		peer-as 12345;

		family {
			ipv4/unicast;
		}
		announce {
			ipv4 {
				unicast 10.0.0.0/32 next-hop self;
			}
		}
	}
}
EOF_CONF

# Process orchestration
cmd=background:seq=1:exec=ze-peer --port $PORT:stdin=peer
cmd=foreground:seq=2:exec=ze bgp server -:stdin=ze-bgp:timeout=10s
