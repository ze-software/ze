# Test: ze config completion — option command targets
# VALIDATES: "option " shows display setting subcommands

tmpfs=test.conf:terminator=EOF_CONF
bgp {
	router-id 1.2.3.4
	session {
		asn {
			local 65000
		}
	}
}
EOF_CONF

cmd=foreground:seq=1:exec=ze config completion --context bgp --input option+ test.conf
expect=exit:code=0
expect=stdout:contains=blame
expect=stdout:contains=changes
expect=stdout:contains=author
expect=stdout:contains=date
expect=stdout:contains=source
expect=stdout:contains=all
expect=stdout:contains=none
