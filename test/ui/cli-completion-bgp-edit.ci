# Test: ze config completion — bgp level edit targets
# VALIDATES: "edit " in bgp context shows children including leaves

tmpfs=test.conf:terminator=EOF_CONF
bgp {
	router-id 1.2.3.4
	local-as 65000
}
EOF_CONF

cmd=foreground:seq=1:exec=ze config completion --context bgp --input edit+ test.conf
expect=exit:code=0
expect=stdout:contains=peer
expect=stdout:contains=rib
