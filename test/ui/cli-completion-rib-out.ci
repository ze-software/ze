# Test: ze config completion — rib out fields
# VALIDATES: RIB out container shows group-updates, auto-commit-delay, max-batch-size

tmpfs=test.conf:terminator=EOF_CONF
bgp {
	router-id 1.2.3.4;
	local-as 65000;
	peer 1.1.1.1 {
		peer-as 65001;
		local-address 127.0.0.1;
	}
}
EOF_CONF

cmd=foreground:seq=1:exec=ze config completion --context bgp/peer/1.1.1.1/rib/out --input set+ test.conf
expect=exit:code=0
expect=stdout:contains=group-updates
expect=stdout:contains=auto-commit-delay
expect=stdout:contains=max-batch-size
