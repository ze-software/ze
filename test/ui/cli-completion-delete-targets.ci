# Test: ze config completion — delete command targets
# VALIDATES: "delete " shows same targets as set (all children)

tmpfs=test.conf:terminator=EOF_CONF
bgp {
	router-id 1.2.3.4
	local {
		as 65000
	}
}
EOF_CONF

cmd=foreground:seq=1:exec=ze config completion --context bgp --input delete+ test.conf
expect=exit:code=0
expect=stdout:contains=router-id
expect=stdout:contains=local
expect=stdout:contains=peer
expect=stdout:contains=listen
