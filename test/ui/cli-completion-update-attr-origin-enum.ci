# Test: ze config completion — update attribute origin enum values
# VALIDATES: Origin leaf shows igp/egp/incomplete enum values

tmpfs=test.conf:terminator=EOF_CONF
bgp {
	router-id 1.2.3.4
	session {
		asn {
			local 65000
		}
	}
	peer peer1 {
		connection {
			remote {
				ip 1.1.1.1
			}
			local {
				ip 127.0.0.1
			}
		}
		session {
			asn {
				remote 65001
			}
		}
	}
}
EOF_CONF

cmd=foreground:seq=1:exec=ze config completion --context bgp/peer/peer1/update/attribute --input set+origin+ test.conf
expect=exit:code=0
expect=stdout:contains=igp
expect=stdout:contains=egp
expect=stdout:contains=incomplete
