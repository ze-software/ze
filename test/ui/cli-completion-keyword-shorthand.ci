# Test: ze config completion — keyword shorthand (set prefix suggested)
# VALIDATES: Typing a keyword prefix suggests "set <keyword>"

tmpfs=test.conf:terminator=EOF_CONF
bgp {
	router-id 1.2.3.4
	local {
		as 65000
	}
}
EOF_CONF

cmd=foreground:seq=1:exec=ze config completion --context bgp --input ro test.conf
expect=exit:code=0
expect=stdout:contains=set router-id
expect=stdout:contains=rollback
