# Test: ze config completion — environment debug fields
# VALIDATES: Debug container shows its leaf children

tmpfs=test.conf:terminator=EOF_CONF
bgp {
	router-id 1.2.3.4
	session {
		asn {
			local 65000
		}
	}
}
EOF_CONF

cmd=foreground:seq=1:exec=ze config completion --context environment/debug --input set+ test.conf
expect=exit:code=0
expect=stdout:contains=pdb
expect=stdout:contains=memory
expect=stdout:contains=pprof
expect=stdout:contains=defensive
