# Test: ze config completion — environment top-level leaves (post spec-env-cleanup)
# VALIDATES: Top-level `environment/pprof` leaf is reachable via completion.
# Note: The old `environment/debug` container was retired along with every
# ExaBGP-compat debug flag. `pprof` is now a direct leaf under environment.

tmpfs=test.conf:terminator=EOF_CONF
bgp {
	router-id 1.2.3.4
	session {
		asn {
			local 65000
		}
	}
}
EOF_CONF

cmd=foreground:seq=1:exec=ze config completion --context environment --input set+ test.conf
expect=exit:code=0
expect=stdout:contains=pprof
