# Test: ze config completion — environment children (post spec-env-cleanup)
# VALIDATES: Environment container shows surviving sub-containers.
# Retired (spec-env-cleanup 2026-04): tcp, cache, api, debug.

tmpfs=test.conf:terminator=EOF_CONF
bgp {
	router-id 1.2.3.4
	session {
		asn {
			local 65000
		}
	}
}
EOF_CONF

cmd=foreground:seq=1:exec=ze config completion --context environment --input set+ test.conf
expect=exit:code=0
expect=stdout:contains=daemon
expect=stdout:contains=log
expect=stdout:contains=bgp
expect=stdout:contains=reactor
expect=stdout:contains=chaos
expect=stdout:contains=exabgp
expect=stdout:contains=pprof
