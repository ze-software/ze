# Test: ze config completion -- role container children and enum values
# VALIDATES: Role plugin augment provides container children and enum completions

tmpfs=test.conf:terminator=EOF_CONF
bgp {
	router-id 1.2.3.4
	session {
		asn {
			local 65000
		}
	}
	peer peer1 {
		connection {
			remote {
				ip 1.1.1.1
			}
			local {
				ip 127.0.0.1
			}
		}
		session {
			asn {
				remote 65001
			}
		}
	}
}
EOF_CONF

# Role container should show import, export, and strict children
cmd=foreground:seq=1:exec=ze config completion --context bgp/peer/peer1/role --input set+ test.conf
expect=exit:code=0
expect=stdout:contains=import
expect=stdout:contains=strict

# Role import should show enum values
cmd=foreground:seq=2:exec=ze config completion --context bgp/peer/peer1/role --input set+import+ test.conf
expect=exit:code=0
expect=stdout:contains=provider
expect=stdout:contains=customer
expect=stdout:contains=peer
expect=stdout:contains=rs
expect=stdout:contains=rs-client
