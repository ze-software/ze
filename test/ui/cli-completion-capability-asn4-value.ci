# Test: ze config completion — capability asn4 boolean value
# VALIDATES: asn4 is a boolean leaf with true/false completions

tmpfs=test.conf:terminator=EOF_CONF
bgp {
	router-id 1.2.3.4;
	local-as 65000;
	peer 1.1.1.1 {
		peer-as 65001;
		local-address 127.0.0.1;
	}
}
EOF_CONF

cmd=foreground:seq=1:exec=ze config completion --context bgp/peer/1.1.1.1/capability --input set+asn4+ test.conf
expect=exit:code=0
expect=stdout:contains=true
expect=stdout:contains=false
