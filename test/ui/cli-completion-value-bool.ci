# Test: ze config completion — boolean value hints
# VALIDATES: Boolean leaf shows true/false completions

tmpfs=test.conf:terminator=EOF_CONF
bgp {
	router-id 1.2.3.4
	session {
		asn {
			local 65000
		}
	}
	peer peer1 {
		connection {
			remote {
				ip 1.1.1.1
			}
			local {
				ip 127.0.0.1
			}
		}
		session {
			asn {
				remote 65001
			}
		}
	}
}
EOF_CONF

cmd=foreground:seq=1:exec=ze config completion --context bgp/peer/peer1/rib/adj --input set+in+ test.conf
expect=exit:code=0
expect=stdout:contains=true
expect=stdout:contains=false
