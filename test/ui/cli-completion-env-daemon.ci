# Test: ze config completion — environment daemon fields
# VALIDATES: Daemon container shows its leaf children

tmpfs=test.conf:terminator=EOF_CONF
bgp {
	router-id 1.2.3.4
	local-as 65000
}
EOF_CONF

cmd=foreground:seq=1:exec=ze config completion --context environment/daemon --input set+ test.conf
expect=exit:code=0
expect=stdout:contains=pid
expect=stdout:contains=user
expect=stdout:contains=daemonize
expect=stdout:contains=drop
