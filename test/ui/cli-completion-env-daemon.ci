# Test: ze config completion — environment daemon fields (post spec-env-cleanup)
# VALIDATES: Daemon container shows its surviving leaves (pid, user).
# Retired (spec-env-cleanup): daemonize, drop, umask.

tmpfs=test.conf:terminator=EOF_CONF
bgp {
	router-id 1.2.3.4
	session {
		asn {
			local 65000
		}
	}
}
EOF_CONF

cmd=foreground:seq=1:exec=ze config completion --context environment/daemon --input set+ test.conf
expect=exit:code=0
expect=stdout:contains=pid
expect=stdout:contains=user
