# Test: ze config completion — environment exabgp/api fields (post spec-env-cleanup)
# VALIDATES: exabgp.api.ack completion inside the new `environment/exabgp/api` container
# Note: The ExaBGP-style `environment/api` container was retired; Ze's runtime
# exposes only exabgp.api.ack for the bridge compat surface.

tmpfs=test.conf:terminator=EOF_CONF
bgp {
	router-id 1.2.3.4
	session {
		asn {
			local 65000
		}
	}
}
EOF_CONF

cmd=foreground:seq=1:exec=ze config completion --context environment/exabgp/api --input set+ test.conf
expect=exit:code=0
expect=stdout:contains=ack
