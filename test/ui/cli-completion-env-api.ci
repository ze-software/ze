# Test: ze config completion — environment api fields (plugin augment)
# VALIDATES: API container from plugin-conf augment shows its fields

tmpfs=test.conf:terminator=EOF_CONF
bgp {
	router-id 1.2.3.4
	local-as 65000
}
EOF_CONF

cmd=foreground:seq=1:exec=ze config completion --context environment/api --input set+ test.conf
expect=exit:code=0
expect=stdout:contains=encoder
expect=stdout:contains=compact
expect=stdout:contains=respawn
expect=stdout:contains=cli
