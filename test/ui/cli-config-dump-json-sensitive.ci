# Test: ze config dump --json masks sensitive values with $9$ encoding
stdin=config:terminator=EOF_CONF
bgp {
	router-id 10.0.0.1
	session {
		asn {
			local 65533
		}
	}
	peer peer3 {
		connection {
			remote {
				ip 10.0.0.3
			}
			md5 {
				password abc123
			}
		}
		session {
			asn {
				remote 65534
			}
		}
	}
}
EOF_CONF

tmpfs=test.conf:terminator=EOF_FILE
bgp {
	router-id 10.0.0.1
	session {
		asn {
			local 65533
		}
	}
	peer peer3 {
		connection {
			remote {
				ip 10.0.0.3
			}
			md5 {
				password abc123
			}
		}
		session {
			asn {
				remote 65534
			}
		}
	}
}
EOF_FILE

cmd=foreground:seq=1:exec=ze config dump --json test.conf
expect=exit:code=0
expect=stdout:contains=$9$
