# Test: ze config completion — bgp level set targets
# VALIDATES: "set " in bgp context shows all bgp children

tmpfs=test.conf:terminator=EOF_CONF
bgp {
	router-id 1.2.3.4
	local-as 65000
}
EOF_CONF

cmd=foreground:seq=1:exec=ze config completion --context bgp --input set+ test.conf
expect=exit:code=0
expect=stdout:contains=router-id
expect=stdout:contains=local-as
expect=stdout:contains=listen
expect=stdout:contains=peer
