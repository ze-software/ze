# Test: ze config completion -- list keys with partial match
# VALIDATES: Partial key "peer1" filters to matching peers only

tmpfs=test.conf:terminator=EOF_CONF
bgp {
	router-id 1.2.3.4
	session {
		asn {
			local 65000
		}
	}
	peer peer1 {
		connection {
			remote {
				ip 1.1.1.1
			}
			local {
				ip 127.0.0.1
			}
		}
		session {
			asn {
				remote 65001
			}
		}
	}
	peer peer2 {
		connection {
			remote {
				ip 2.2.2.2
			}
			local {
				ip 127.0.0.1
			}
		}
		session {
			asn {
				remote 65002
			}
		}
	}
}
EOF_CONF

cmd=foreground:seq=1:exec=ze config completion --context bgp --input edit+peer+peer1 test.conf
expect=exit:code=0
expect=stdout:contains=peer1
