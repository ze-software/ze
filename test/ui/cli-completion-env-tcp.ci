# Test: ze config completion — environment tcp fields (bgp augment)
# VALIDATES: TCP container from bgp-conf augment shows its fields

tmpfs=test.conf:terminator=EOF_CONF
bgp {
	router-id 1.2.3.4
	local {
		as 65000
	}
}
EOF_CONF

cmd=foreground:seq=1:exec=ze config completion --context environment/tcp --input set+ test.conf
expect=exit:code=0
expect=stdout:contains=port
expect=stdout:contains=delay
expect=stdout:contains=acl
