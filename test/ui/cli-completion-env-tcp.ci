# Test: ze config completion — environment bgp fields (post spec-env-cleanup)
# VALIDATES: bgp container (from bgp-conf augment) shows openwait + announce-delay
# Note: `tcp` container retired -- ze has no global ExaBGP-style listen port.

tmpfs=test.conf:terminator=EOF_CONF
bgp {
	router-id 1.2.3.4
	session {
		asn {
			local 65000
		}
	}
}
EOF_CONF

cmd=foreground:seq=1:exec=ze config completion --context environment/bgp --input set+ test.conf
expect=exit:code=0
expect=stdout:contains=openwait
expect=stdout:contains=announce-delay
