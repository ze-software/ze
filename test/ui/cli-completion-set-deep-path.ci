# Test: ze config completion — set navigating through list key
# VALIDATES: "set bgp peer <key> " shows peer children when navigating via set path

tmpfs=test.conf:terminator=EOF_CONF
bgp {
	router-id 1.2.3.4
	session {
		asn {
			local 65000
		}
	}
	peer peer1 {
		connection {
			remote {
				ip 1.1.1.1
			}
			local {
				ip 127.0.0.1
			}
		}
		session {
			asn {
				remote 65001
			}
		}
	}
}
EOF_CONF

cmd=foreground:seq=1:exec=ze config completion --input set+bgp+peer+1.1.1.1+ test.conf
expect=exit:code=0
expect=stdout:contains=connection
expect=stdout:contains=session
expect=stdout:contains=behavior
