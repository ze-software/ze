# Test: ze config completion — full config with multiple sections
# VALIDATES: Completion works with a comprehensive config across all sections

tmpfs=test.conf:terminator=EOF_CONF
environment {
	log {
		level info
	}
	tcp {
		attempts 3
	}
}
bgp {
	router-id 10.0.0.1
	session {
		asn {
			local 65000
		}
	}
	peer peer1 {
		connection {
			remote {
				ip 192.168.1.1
			}
			local {
				ip 192.168.1.254
				connect false
			}
		}
		session {
			asn {
				remote 65001
			}
			capability {
				asn4 true
				graceful-restart {
					restart-time 120
				}
			}
			family ipv4/unicast {
				mode enable
				prefix { maximum 10000; }
			}
		}
		timer {
			receive-hold-time 90
		}
		role {
			import customer
		}
	}
	peer peer1-2 {
		connection {
			remote {
				ip 192.168.2.1
			}
			local {
				ip 192.168.2.254
			}
		}
		session {
			asn {
				remote 65002
			}
		}
		role {
			import provider
		}
	}
}
EOF_CONF

# Root level — verify all top-level sections visible with full config
cmd=foreground:seq=1:exec=ze config completion --input set+ test.conf
expect=exit:code=0
expect=stdout:contains=bgp
expect=stdout:contains=environment
