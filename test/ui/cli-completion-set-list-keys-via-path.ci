# Test: ze config completion — set path reaching a list shows keys
# VALIDATES: "set bgp peer " shows list key completions, not schema children

tmpfs=test.conf:terminator=EOF_CONF
bgp {
	router-id 1.2.3.4
	session {
		asn {
			local 65000
		}
	}
	peer peer1 {
		connection {
			remote {
				ip 1.1.1.1
			}
			local {
				ip 127.0.0.1
			}
		}
		session {
			asn {
				remote 65001
			}
		}
	}
	peer peer2 {
		connection {
			remote {
				ip 2.2.2.2
			}
			local {
				ip 127.0.0.1
			}
		}
		session {
			asn {
				remote 65002
			}
		}
	}
}
EOF_CONF

cmd=foreground:seq=1:exec=ze config completion --input set+bgp+peer+ test.conf
expect=exit:code=0
expect=stdout:contains=*
expect=stdout:contains=peer1
expect=stdout:contains=peer2
