# Test: ze config completion — nonexistent context path
# VALIDATES: Invalid context path returns empty completions gracefully

tmpfs=test.conf:terminator=EOF_CONF
bgp {
	router-id 1.2.3.4
	session {
		asn {
			local 65000
		}
	}
}
EOF_CONF

cmd=foreground:seq=1:exec=ze config completion --context nonexistent/path --input set+ test.conf
expect=exit:code=0
