# Test: ze config completion -- bgp group level children
# VALIDATES: BGP container shows group as a completable entry

tmpfs=test.conf:terminator=EOF_CONF
bgp {
	router-id 1.2.3.4
	local-as 65000
}
EOF_CONF

cmd=foreground:seq=1:exec=ze config completion --context bgp --input edit+ test.conf
expect=exit:code=0
expect=stdout:contains=group
