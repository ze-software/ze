# Test: ze config completion — capability add-path children
# VALIDATES: add-path sub-container shows send/receive

tmpfs=test.conf:terminator=EOF_CONF
bgp {
	router-id 1.2.3.4
	local {
		as 65000
	}
	peer peer1 {
		remote {
			ip 1.1.1.1
			as 65001
		}
		local {
			ip 127.0.0.1
		}
	}
}
EOF_CONF

cmd=foreground:seq=1:exec=ze config completion --context bgp/peer/peer1/capability/add-path --input set+ test.conf
expect=exit:code=0
expect=stdout:contains=send
expect=stdout:contains=receive
