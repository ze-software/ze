# Test: ze config completion — config from stdin
# VALIDATES: Using - reads config from stdin

stdin=config:terminator=EOF_CONF
bgp {
	router-id 1.2.3.4;
	local-as 65000;
	peer 1.1.1.1 {
		peer-as 65001;
		local-address 127.0.0.1;
	}
}
EOF_CONF

cmd=foreground:seq=1:exec=ze config completion --context bgp --input set+ -:stdin=config
expect=exit:code=0
expect=stdout:contains=router-id
expect=stdout:contains=peer
