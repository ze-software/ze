# Test: ze config completion — environment reactor fields (bgp augment)
# VALIDATES: Reactor container from bgp-conf augment shows its fields

tmpfs=test.conf:terminator=EOF_CONF
bgp {
	router-id 1.2.3.4
	session {
		asn {
			local 65000
		}
	}
}
EOF_CONF

cmd=foreground:seq=1:exec=ze config completion --context environment/reactor --input set+ test.conf
expect=exit:code=0
expect=stdout:contains=speed
expect=stdout:contains=cache-ttl
expect=stdout:contains=cache-max
