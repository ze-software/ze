# Test: ze config completion — show command targets
# VALIDATES: "show " shows all children including leaves

tmpfs=test.conf:terminator=EOF_CONF
bgp {
	router-id 1.2.3.4;
	local-as 65000;
}
EOF_CONF

cmd=foreground:seq=1:exec=ze config completion --context bgp --input show+ test.conf
expect=exit:code=0
expect=stdout:contains=peer
expect=stdout:contains=rib
