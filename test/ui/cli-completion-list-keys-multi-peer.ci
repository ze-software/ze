# Test: ze config completion — list keys with multiple entries
# VALIDATES: Multiple peers listed as completion keys

tmpfs=test.conf:terminator=EOF_CONF
bgp {
	router-id 1.2.3.4
	local-as 65000
	peer 1.1.1.1 {
		peer-as 65001
		local-address 127.0.0.1
	}
	peer 2.2.2.2 {
		peer-as 65002
		local-address 127.0.0.1
	}
	peer 3.3.3.3 {
		peer-as 65003
		local-address 127.0.0.1
	}
}
EOF_CONF

cmd=foreground:seq=1:exec=ze config completion --context bgp --input edit+peer+ test.conf
expect=exit:code=0
expect=stdout:contains=1.1.1.1
expect=stdout:contains=2.2.2.2
expect=stdout:contains=3.3.3.3
expect=stdout:contains=*
