# Test: ze config completion — capability level all fields
# VALIDATES: All capability fields including plugin augments

tmpfs=test.conf:terminator=EOF_CONF
bgp {
	router-id 1.2.3.4
	local-as 65000
	peer 1.1.1.1 {
		peer-as 65001
		local-address 127.0.0.1
	}
}
EOF_CONF

cmd=foreground:seq=1:exec=ze config completion --context bgp/peer/1.1.1.1/capability --input set+ test.conf
expect=exit:code=0
# Base capabilities
expect=stdout:contains=asn4
expect=stdout:contains=add-path
expect=stdout:contains=extended-message
expect=stdout:contains=nexthop
expect=stdout:contains=route-refresh
# Plugin augments
expect=stdout:contains=graceful-restart
expect=stdout:contains=hostname
expect=stdout:contains=link-local-nexthop
expect=stdout:contains=software-version
