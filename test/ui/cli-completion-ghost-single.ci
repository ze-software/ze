# Test: ze config completion — ghost text single match
# VALIDATES: Ghost text returns suffix for unique match

tmpfs=test.conf:terminator=EOF_CONF
bgp {
	router-id 1.2.3.4
	session {
		asn {
			local 65000
		}
	}
}
EOF_CONF

cmd=foreground:seq=1:exec=ze config completion --ghost --context bgp --input set+router test.conf
expect=exit:code=0
expect=stdout:contains=-id
