# Test: ze config completion — IPv4 address value hint
# VALIDATES: IPv4 address leaf shows value type hint

tmpfs=test.conf:terminator=EOF_CONF
bgp {
	router-id 1.2.3.4
	local-as 65000
}
EOF_CONF

cmd=foreground:seq=1:exec=ze config completion --context bgp --input set+router-id+ test.conf
expect=exit:code=0
expect=stdout:contains=value
