# Test: ze config completion — peer partial keyword
# VALIDATES: Partial keyword "p" inside peer filters to peer-* and process/port

tmpfs=test.conf:terminator=EOF_CONF
bgp {
	router-id 1.2.3.4
	local-as 65000
	peer 1.1.1.1 {
		peer-as 65001
		local-address 127.0.0.1
	}
}
EOF_CONF

cmd=foreground:seq=1:exec=ze config completion --context bgp/peer/1.1.1.1 --input set+p test.conf
expect=exit:code=0
expect=stdout:contains=peer-as
expect=stdout:contains=port
expect=stdout:contains=process
