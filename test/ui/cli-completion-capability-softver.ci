# Test: ze config completion — software-version capability (plugin augment)
# VALIDATES: Software-version plugin augments capability

tmpfs=test.conf:terminator=EOF_CONF
bgp {
	router-id 1.2.3.4
	local-as 65000
	peer 1.1.1.1 {
		peer-as 65001
		local-address 127.0.0.1
	}
}
EOF_CONF

cmd=foreground:seq=1:exec=ze config completion --context bgp/peer/1.1.1.1/capability/software-version --input set+ test.conf
expect=exit:code=0
expect=stdout:contains=mode
