# Test: ze config set --dry-run with filesystem override
# VALIDATES: ZE_STORAGE_BLOB=false forces filesystem storage (AC-4)

tmpfs=test.conf:terminator=EOF_CONF
bgp {
	router-id 1.2.3.4
	session {
		asn {
			local 65000
		}
	}
	peer peer1 {
		connection {
			remote {
				ip 1.1.1.1
			}
			local {
				ip 127.0.0.1
			}
		}
		session {
			asn {
				remote 65001
			}
		}
	}
}
EOF_CONF

option=env:var=ZE_STORAGE_BLOB:value=false
cmd=foreground:seq=1:exec=ze config set --dry-run --no-reload test.conf bgp session asn local 65001
expect=exit:code=0
expect=stderr:contains=dry-run: would set
