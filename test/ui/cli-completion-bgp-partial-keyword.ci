# Test: ze config completion — bgp partial keyword match
# VALIDATES: Partial keyword in bgp context filters correctly

tmpfs=test.conf:terminator=EOF_CONF
bgp {
	router-id 1.2.3.4;
	local-as 65000;
}
EOF_CONF

cmd=foreground:seq=1:exec=ze config completion --context bgp --input set+local test.conf
expect=exit:code=0
expect=stdout:contains=local-as
