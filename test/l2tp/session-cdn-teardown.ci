# Test: CDN tears down an established session.
# VALIDATES: AC-7 -- CDN destroys established session.

tmpfs=session-cdn-teardown.py:mode=755:terminator=EOF_PY
#!/usr/bin/env python3
"""Establish tunnel + session, then send CDN to tear down the session."""
import hashlib
import os
import socket
import struct
import sys
import time

if len(sys.argv) < 2:
    print("usage: session-cdn-teardown.py <port>", file=sys.stderr)
    sys.exit(2)

TARGET = ("127.0.0.1", int(sys.argv[1]))
SECRET = os.environ.get("TEST_SECRET", "s3cr3t").encode("utf-8")
PEER_TID = 0x0123
PEER_SID = 500
PEER_CHALLENGE = bytes.fromhex("00112233445566778899aabbccddeeff")


def avp(mandatory, attr_type, value, vendor=0):
    flags = 0x8000 if mandatory else 0
    return struct.pack("!HHH", flags | (6 + len(value)), vendor, attr_type) + value


def l2tp_ctrl(dest_tid, dest_sid, ns, nr, body):
    total = 12 + len(body)
    hdr = struct.pack("!HHHHHH", 0xC802, total, dest_tid, dest_sid, ns, nr)
    return hdr + body


def parse_avps(body):
    out = {}
    off = 0
    while off + 6 <= len(body):
        word, vendor, atype = struct.unpack("!HHH", body[off:off+6])
        length = word & 0x03FF
        if length < 6 or off + length > len(body):
            break
        if vendor == 0:
            out[atype] = body[off+6:off+length]
        off += length
    return out


def recv_msg(sock, expect_type=None):
    data, _ = sock.recvfrom(1500)
    if len(data) < 12:
        return None, None
    _, length, tid, sid, ns, nr = struct.unpack("!HHHHHH", data[:12])
    avps = parse_avps(data[12:length])
    if expect_type is not None:
        mt = struct.unpack("!H", avps[0])[0] if 0 in avps else 0
        if mt != expect_type:
            print(f"ERROR: expected msg type {expect_type}, got {mt}", file=sys.stderr)
            return None, None
    return avps, {"tid": tid, "sid": sid, "ns": ns, "nr": nr}


def drain(sock):
    try:
        sock.recvfrom(1500)
    except (socket.timeout, OSError):
        pass


def main():
    sock = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
    sock.bind(("127.0.0.1", 0))
    sock.settimeout(0.25)
    time.sleep(0.05)

    # --- Tunnel handshake (SCCRQ/SCCRP/SCCCN) ---
    sccrq_body = b""
    sccrq_body += avp(True, 0, struct.pack("!H", 1))
    sccrq_body += avp(True, 2, b"\x01\x00")
    sccrq_body += avp(True, 3, struct.pack("!I", 3))
    sccrq_body += avp(True, 4, struct.pack("!I", 0))
    sccrq_body += avp(True, 7, b"py-peer")
    sccrq_body += avp(True, 9, struct.pack("!H", PEER_TID))
    sccrq_body += avp(True, 10, struct.pack("!H", 8))
    sccrq_body += avp(True, 11, PEER_CHALLENGE)
    sccrq = l2tp_ctrl(0, 0, 0, 0, sccrq_body)

    sccrp_avps = None
    for _ in range(20):
        try:
            sock.sendto(sccrq, TARGET)
            sccrp_avps, _ = recv_msg(sock, expect_type=2)
            if sccrp_avps is not None:
                break
        except (socket.timeout, ConnectionRefusedError, OSError):
            continue
    if sccrp_avps is None:
        print("ERROR: no SCCRP", file=sys.stderr)
        return 1
    local_tid = struct.unpack("!H", sccrp_avps[9])[0]
    digest = hashlib.md5(bytes([3]) + SECRET + sccrp_avps[11]).digest()
    sock.settimeout(1.0)
    scccn_body = avp(True, 0, struct.pack("!H", 3)) + avp(True, 13, digest)
    sock.sendto(l2tp_ctrl(local_tid, 0, 1, 1, scccn_body), TARGET)
    drain(sock)

    # --- Session: ICRQ -> ICRP -> ICCN ---
    time.sleep(0.05)
    icrq_body = b""
    icrq_body += avp(True, 0, struct.pack("!H", 10))
    icrq_body += avp(True, 14, struct.pack("!H", PEER_SID))
    icrq_body += avp(True, 15, struct.pack("!I", 42))
    sock.sendto(l2tp_ctrl(local_tid, 0, 2, 1, icrq_body), TARGET)
    icrp_avps, _ = recv_msg(sock, expect_type=11)
    if icrp_avps is None:
        print("ERROR: no ICRP", file=sys.stderr)
        return 1
    ze_sid = struct.unpack("!H", icrp_avps[14])[0]
    drain(sock)

    iccn_body = b""
    iccn_body += avp(True, 0, struct.pack("!H", 12))
    iccn_body += avp(True, 24, struct.pack("!I", 10000000))
    iccn_body += avp(True, 19, struct.pack("!I", 2))
    sock.sendto(l2tp_ctrl(local_tid, ze_sid, 3, 2, iccn_body), TARGET)
    drain(sock)
    time.sleep(0.05)

    # --- CDN to tear down the session ---
    cdn_body = b""
    cdn_body += avp(True, 0, struct.pack("!H", 14))          # Message Type = CDN
    cdn_body += avp(True, 1, struct.pack("!HH", 1, 0))       # Result Code (1=disconnect)
    cdn_body += avp(True, 14, struct.pack("!H", PEER_SID))   # Assigned Session ID (sender's)
    sock.sendto(l2tp_ctrl(local_tid, ze_sid, 4, 3, cdn_body), TARGET)
    drain(sock)

    print("OK: CDN sent for established session")
    return 0


if __name__ == "__main__":
    sys.exit(main())
EOF_PY

stdin=config:terminator=EOF_CONF
l2tp {
    enabled true
    shared-secret s3cr3t
}
environment {
    l2tp {
        server main {
            ip 127.0.0.1
            port $PORT
        }
    }
}
EOF_CONF

option=env:var=ze.log.l2tp:value=debug
option=env:var=ze.l2tp.skip-kernel-probe:value=true
option=env:var=TEST_SECRET:value=s3cr3t

cmd=background:seq=1:exec=ze -:stdin=config
cmd=foreground:seq=2:exec=python3 session-cdn-teardown.py $PORT:timeout=10s
expect=exit:code=0
expect=stdout:contains=OK: CDN sent
expect=stderr:contains=session destroyed
