# Test: RADIUS rejects credentials; L2TP tunnel still establishes (auth is per-session).
# VALIDATES: spec-l2tp-8b AC-4 -- RADIUS Access-Reject handled correctly.
# The mock RADIUS server returns Access-Reject for all requests.
# The tunnel itself establishes (tunnel auth uses shared secret, not RADIUS).

tmpfs=mock-radius-reject.py:mode=755:terminator=EOF_RADIUS
#!/usr/bin/env python3
"""Mock RADIUS server: rejects all Access-Requests."""
import hashlib
import os
import socket
import struct
import sys

RADIUS_PORT = int(os.environ.get("RADIUS_PORT", "11813"))
SHARED_KEY = os.environ.get("RADIUS_KEY", "testing123").encode()

def response_auth(code, ident, length, req_auth, attrs, secret):
    h = hashlib.md5()
    h.update(bytes([code, ident]))
    h.update(struct.pack("!H", length))
    h.update(req_auth)
    h.update(attrs)
    h.update(secret)
    return h.digest()

def main():
    sock = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
    sock.bind(("127.0.0.1", RADIUS_PORT))
    sock.settimeout(30.0)
    print(f"RADIUS reject mock on 127.0.0.1:{RADIUS_PORT}", flush=True)

    while True:
        try:
            data, addr = sock.recvfrom(4096)
        except socket.timeout:
            break
        if len(data) < 20 or data[0] != 1:
            continue
        ident = data[1]
        req_auth = data[4:20]

        # Reply-Message attribute: type=18, "bad credentials"
        reply_msg = b"bad credentials"
        attr = bytes([18, 2 + len(reply_msg)]) + reply_msg
        resp_len = 20 + len(attr)
        resp = bytearray(resp_len)
        resp[0] = 3  # Access-Reject
        resp[1] = ident
        struct.pack_into("!H", resp, 2, resp_len)
        resp[20:] = attr
        auth = response_auth(3, ident, resp_len, req_auth, attr, SHARED_KEY)
        resp[4:20] = auth
        sock.sendto(bytes(resp), addr)
        print(f"RADIUS: Access-Reject sent to {addr}", flush=True)

if __name__ == "__main__":
    sys.exit(main())
EOF_RADIUS

tmpfs=l2tp-peer-reject.py:mode=755:terminator=EOF_PEER
#!/usr/bin/env python3
"""L2TP peer: verify tunnel establishes even when RADIUS rejects sessions."""
import hashlib
import os
import socket
import struct
import sys
import time

TARGET = ("127.0.0.1", int(sys.argv[1]))
SECRET = os.environ.get("TEST_SECRET", "s3cr3t").encode("utf-8")
PEER_TID = 0x0600
PEER_CHALLENGE = bytes.fromhex("aabbccddeeff00112233445566778899")

def avp(mandatory, attr_type, value):
    flags = 0x8000 if mandatory else 0
    return struct.pack("!HHH", flags | (6 + len(value)), 0, attr_type) + value

def build_sccrq():
    body = b""
    body += avp(True, 0, struct.pack("!H", 1))
    body += avp(True, 2, b"\x01\x00")
    body += avp(True, 3, struct.pack("!I", 0x3))
    body += avp(True, 4, struct.pack("!I", 0x0))
    body += avp(True, 7, b"py-reject")
    body += avp(True, 9, struct.pack("!H", PEER_TID))
    body += avp(True, 10, struct.pack("!H", 8))
    body += avp(True, 11, PEER_CHALLENGE)
    total = 12 + len(body)
    hdr = struct.pack("!HHHHHH", 0xC802, total, 0, 0, 0, 0)
    return hdr + body

def build_scccn(dest_tid, ns, nr, response):
    body = b""
    body += avp(True, 0, struct.pack("!H", 3))
    body += avp(True, 13, response)
    total = 12 + len(body)
    hdr = struct.pack("!HHHHHH", 0xC802, total, dest_tid, 0, ns, nr)
    return hdr + body

def parse_avps(body):
    out = {}
    off = 0
    while off + 6 <= len(body):
        word, vendor, atype = struct.unpack("!HHH", body[off:off+6])
        length = word & 0x03FF
        if length < 6 or off + length > len(body):
            break
        if vendor == 0:
            out[atype] = body[off+6:off+length]
        off += length
    return out

def main():
    sock = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
    sock.bind(("127.0.0.1", 0))
    sock.settimeout(0.25)
    time.sleep(0.1)
    sccrq = build_sccrq()
    sccrp = None
    for _ in range(20):
        try:
            sock.sendto(sccrq, TARGET)
            data, _ = sock.recvfrom(1500)
            sccrp = data
            break
        except (socket.timeout, ConnectionRefusedError, OSError):
            continue
    if sccrp is None:
        print("ERROR: no SCCRP received", file=sys.stderr)
        return 1
    _, length, _, _, _, _ = struct.unpack("!HHHHHH", sccrp[:12])
    avps = parse_avps(sccrp[12:length])
    our_challenge = avps.get(11)
    tid_bytes = avps.get(9)
    if our_challenge is None or tid_bytes is None:
        print("ERROR: SCCRP missing fields", file=sys.stderr)
        return 1
    local_tid = struct.unpack("!H", tid_bytes)[0]
    digest = hashlib.md5(bytes([3]) + SECRET + our_challenge).digest()
    sock.settimeout(1.0)
    sock.sendto(build_scccn(local_tid, 1, 1, digest), TARGET)
    try:
        sock.recvfrom(1500)
    except (socket.timeout, OSError):
        pass
    print("OK: tunnel established with RADIUS reject config")
    return 0

if __name__ == "__main__":
    sys.exit(main())
EOF_PEER

stdin=config:terminator=EOF_CONF
l2tp {
    enabled true
    shared-secret s3cr3t
    auth {
        radius {
            server radius1 {
                address 127.0.0.1
                port $RADIUS_PORT
                shared-key testing123
            }
            timeout 3
            retries 1
        }
    }
}
environment {
    l2tp {
        server main {
            ip 127.0.0.1
            port $PORT
        }
    }
}
EOF_CONF

option=env:var=ze.log.l2tp:value=debug
option=env:var=ze.l2tp.skip-kernel-probe:value=true
