# Test: L2TP session with PAP auth via RADIUS (mock server).
# VALIDATES: spec-l2tp-8b AC-1 -- PAP auth with RADIUS Access-Accept.
# The mock RADIUS server accepts all credentials and returns Access-Accept.
# The L2TP peer establishes a tunnel and verifies the auth handler is wired.

tmpfs=mock-radius.py:mode=755:terminator=EOF_RADIUS
#!/usr/bin/env python3
"""Mock RADIUS server: accepts all Access-Requests with Access-Accept."""
import hashlib
import os
import socket
import struct
import sys

RADIUS_PORT = int(os.environ.get("RADIUS_PORT", "11812"))
SHARED_KEY = os.environ.get("RADIUS_KEY", "testing123").encode()

def response_auth(code, ident, length, req_auth, attrs, secret):
    h = hashlib.md5()
    h.update(bytes([code, ident]))
    h.update(struct.pack("!H", length))
    h.update(req_auth)
    h.update(attrs)
    h.update(secret)
    return h.digest()

def main():
    sock = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
    sock.bind(("127.0.0.1", RADIUS_PORT))
    sock.settimeout(30.0)
    print(f"RADIUS mock listening on 127.0.0.1:{RADIUS_PORT}", flush=True)

    while True:
        try:
            data, addr = sock.recvfrom(4096)
        except socket.timeout:
            break
        if len(data) < 20:
            continue
        code = data[0]
        ident = data[1]
        req_auth = data[4:20]

        if code == 1:  # Access-Request
            resp = bytearray(20)
            resp[0] = 2  # Access-Accept
            resp[1] = ident
            struct.pack_into("!H", resp, 2, 20)
            auth = response_auth(2, ident, 20, req_auth, b"", SHARED_KEY)
            resp[4:20] = auth
            sock.sendto(bytes(resp), addr)
            print(f"RADIUS: Access-Accept sent to {addr}", flush=True)
        elif code == 4:  # Accounting-Request
            resp = bytearray(20)
            resp[0] = 5  # Accounting-Response
            resp[1] = ident
            struct.pack_into("!H", resp, 2, 20)
            auth = response_auth(5, ident, 20, req_auth, b"", SHARED_KEY)
            resp[4:20] = auth
            sock.sendto(bytes(resp), addr)

if __name__ == "__main__":
    sys.exit(main())
EOF_RADIUS

tmpfs=l2tp-peer.py:mode=755:terminator=EOF_PEER
#!/usr/bin/env python3
"""Minimal L2TP peer: establish tunnel to verify control plane works with RADIUS."""
import hashlib
import os
import socket
import struct
import sys
import time

if len(sys.argv) < 2:
    print("usage: l2tp-peer.py <port>", file=sys.stderr)
    sys.exit(2)

TARGET = ("127.0.0.1", int(sys.argv[1]))
SECRET = os.environ.get("TEST_SECRET", "s3cr3t").encode("utf-8")
PEER_TID = 0x0500
PEER_CHALLENGE = bytes.fromhex("aabbccddeeff00112233445566778899")

def avp(mandatory, attr_type, value):
    flags = 0x8000 if mandatory else 0
    return struct.pack("!HHH", flags | (6 + len(value)), 0, attr_type) + value

def build_sccrq():
    body = b""
    body += avp(True, 0, struct.pack("!H", 1))
    body += avp(True, 2, b"\x01\x00")
    body += avp(True, 3, struct.pack("!I", 0x3))
    body += avp(True, 4, struct.pack("!I", 0x0))
    body += avp(True, 7, b"py-radius")
    body += avp(True, 9, struct.pack("!H", PEER_TID))
    body += avp(True, 10, struct.pack("!H", 8))
    body += avp(True, 11, PEER_CHALLENGE)
    total = 12 + len(body)
    hdr = struct.pack("!HHHHHH", 0xC802, total, 0, 0, 0, 0)
    return hdr + body

def build_scccn(dest_tid, ns, nr, response):
    body = b""
    body += avp(True, 0, struct.pack("!H", 3))
    body += avp(True, 13, response)
    total = 12 + len(body)
    hdr = struct.pack("!HHHHHH", 0xC802, total, dest_tid, 0, ns, nr)
    return hdr + body

def parse_avps(body):
    out = {}
    off = 0
    while off + 6 <= len(body):
        word, vendor, atype = struct.unpack("!HHH", body[off:off+6])
        length = word & 0x03FF
        if length < 6 or off + length > len(body):
            break
        if vendor == 0:
            out[atype] = body[off+6:off+length]
        off += length
    return out

def main():
    sock = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
    sock.bind(("127.0.0.1", 0))
    sock.settimeout(0.25)
    time.sleep(0.1)
    sccrq = build_sccrq()
    sccrp = None
    for _ in range(20):
        try:
            sock.sendto(sccrq, TARGET)
            data, _ = sock.recvfrom(1500)
            sccrp = data
            break
        except (socket.timeout, ConnectionRefusedError, OSError):
            continue
    if sccrp is None:
        print("ERROR: no SCCRP received", file=sys.stderr)
        return 1
    _, length, _, _, _, _ = struct.unpack("!HHHHHH", sccrp[:12])
    avps = parse_avps(sccrp[12:length])
    our_challenge = avps.get(11)
    tid_bytes = avps.get(9)
    if our_challenge is None or tid_bytes is None:
        print("ERROR: SCCRP missing Challenge or Assigned Tunnel ID", file=sys.stderr)
        return 1
    local_tid = struct.unpack("!H", tid_bytes)[0]
    digest = hashlib.md5(bytes([3]) + SECRET + our_challenge).digest()
    sock.settimeout(1.0)
    sock.sendto(build_scccn(local_tid, 1, 1, digest), TARGET)
    try:
        sock.recvfrom(1500)
    except (socket.timeout, OSError):
        pass
    print("OK: tunnel established with RADIUS auth config")
    return 0

if __name__ == "__main__":
    sys.exit(main())
EOF_PEER

stdin=config:terminator=EOF_CONF
l2tp {
    enabled true
    shared-secret s3cr3t
    auth {
        radius {
            server radius1 {
                address 127.0.0.1
                port $RADIUS_PORT
                shared-key testing123
            }
            timeout 5
            retries 2
        }
    }
}
environment {
    l2tp {
        server main {
            ip 127.0.0.1
            port $PORT
        }
    }
}
EOF_CONF

option=env:var=ze.log.l2tp:value=debug
