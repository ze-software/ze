option=env:var=TEST_SECRET:value=s3cr3t
option=env:var=RADIUS_PORT:value=11812
option=env:var=RADIUS_KEY:value=testing123

cmd=background:seq=1:exec=python3 mock-radius.py
cmd=background:seq=2:exec=ze -:stdin=config
