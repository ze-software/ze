# Test: ze config migrate --format flag controls output format
# VALIDATES: --format set produces flat set commands
# VALIDATES: --format hierarchical produces indented tree
# PREVENTS: Format flag ignored or broken

stdin=config:terminator=EOF_CONF
bgp {
	router-id 10.0.0.1
	local-as 65533
	peer 127.0.0.1 {
		local-address 127.0.0.1
		peer-as 65534
	}
}
EOF_CONF

tmpfs=test.conf:terminator=EOF_FILE
bgp {
	router-id 10.0.0.1
	local-as 65533
	peer 127.0.0.1 {
		local-address 127.0.0.1
		peer-as 65534
	}
}
EOF_FILE

cmd=foreground:seq=1:exec=ze config migrate --format set test.conf
expect=exit:code=0
expect=stdout:contains=set bgp router-id
expect=stdout:contains=set bgp peer 127.0.0.1 peer-as

cmd=foreground:seq=2:exec=ze config migrate --format hierarchical test.conf
expect=exit:code=0
expect=stdout:contains=bgp {
expect=stdout:contains=router-id
