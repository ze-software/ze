# Test: Unknown keyword inside telemetry prometheus rejected by YANG validation
# VALIDATES: AC-9 — telemetry { prometheus { bogus; } } fails YANG schema check
stdin=config:terminator=EOF_CONF
bgp {
	router-id 10.0.0.1
	local {
		as 65533
	}
	peer peer1 {
		remote {
			ip 127.0.0.1
			as 65534
		}
		local {
			ip 127.0.0.1
		}
	}
}
telemetry {
	prometheus {
		enabled true
		bogus true
	}
}
EOF_CONF

cmd=foreground:seq=1:exec=ze validate -:stdin=config
expect=exit:code=1
expect=stderr:contains=bogus
