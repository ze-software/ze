# Test: ze config set modifies a configuration value
# VALIDATES: set command changes value and saves file
# PREVENTS: set command silently failing to persist value
stdin=config:terminator=EOF_STDIN
bgp {
	peer peer1 {
		connection {
			remote {
				ip 127.0.0.1
			}
			local {
				ip 127.0.0.1
			}
		}
		session {
			asn {
				local 65533
				remote 65533
			}
		}
	}
}
EOF_STDIN

tmpfs=test.conf:terminator=EOF_CONF
bgp {
	router-id 10.0.0.1
	session {
		asn {
			local 65533
		}
	}
	peer peer1 {
		connection {
			remote {
				ip 127.0.0.1
			}
			local {
				ip 127.0.0.1
			}
		}
		session {
			asn {
				remote 65534
			}
		}
	}
}
EOF_CONF

option=env:var=ze.storage.blob:value=false

# Set the value
cmd=foreground:seq=1:exec=ze config set --no-reload test.conf bgp session asn local 65000
expect=exit:code=0

# Verify the value was actually changed by dumping the config
cmd=foreground:seq=2:exec=ze config dump test.conf
expect=exit:code=0
expect=stdout:contains=local: 65000
