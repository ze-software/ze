# Test: system { archive { <name> { ... } } } config parses successfully
# Validates that named archive blocks under system are accepted by the parser
stdin=config:terminator=EOF_CONF
system {
	host router1
	domain dc1.example.com
	archive local-backup {
		location file:///backups
		trigger commit
	}
	archive offsite {
		location https://server/archive
		trigger daily
		on-change true
	}
}
bgp {
	router-id 10.0.0.1
	local {
		as 65533
	}
	peer peer1 {
		remote {
			ip 127.0.0.1
			as 65534
		}
		local {
			ip 127.0.0.1
		}
	}
}
EOF_CONF

cmd=foreground:seq=1:exec=ze config check -
expect=exit:code=0
