# Dispatch test: ze config.conf with bgp {} block validates correctly
# This tests that config dispatch recognizes bgp {} and routes to BGP daemon
stdin=config:terminator=EOF_CONF
bgp {
	peer peer1 {
		connection {
			remote {
				ip 127.0.0.1
			}
			local {
				ip 127.0.0.1
			}
		}
		session {
			asn {
				local 65533
				remote 65533
			}
			router-id 10.0.0.2
			family {
				ipv4/unicast { prefix { maximum 10000; } }
			}
		}
		timer {
			receive-hold-time 180
		}
	}
}
EOF_CONF

# Use validate to test config parsing without starting daemon
cmd=foreground:seq=1:exec=ze config validate -:stdin=config
expect=exit:code=0
