# Valid config: healthcheck plugin
stdin=config:terminator=EOF_CONF
plugin {
	external service-nginx {
		run "python3 -m exabgp healthcheck -s --name nginx --cmd curl --fail --verbose --max-time 2 http://localhost --start-ip 0"
		encoder text
	}
}
bgp {
	peer peer3 {
		connection {
			remote {
				ip 10.0.0.3
			}
			local {
				ip 10.0.0.2
			}
		}
		session {
			asn {
				local 65533
				remote 65533
			}
			router-id 198.111.227.39
		}
		description "will announce a route to a service"
		process service-nginx {
		}
	}
}
EOF_CONF

cmd=foreground:seq=1:exec=ze config validate -:stdin=config
expect=exit:code=0
