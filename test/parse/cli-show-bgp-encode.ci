# Test: ze show bgp encode dispatches through YANG verb tree
# VALIDATES: show bgp encode is wired via local handler to bgp.Run
# PREVENTS: show bgp encode not reaching the encode handler
stdin=config:terminator=EOF_CONF
bgp {
	peer peer1 {
		connection {
			remote {
				ip 127.0.0.1
			}
			local {
				ip 127.0.0.1
			}
		}
		session {
			asn {
				local 65533
				remote 65533
			}
		}
	}
}
EOF_CONF

cmd=foreground:seq=1:exec=ze show bgp encode --help
expect=exit:code=0
expect=stderr:contains=Encode
