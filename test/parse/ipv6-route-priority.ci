# Valid config: route-priority on ethernet unit for IPv6 RA management
# AC-1: route-priority 5 on unit with IPv6 address triggers accept_ra_defrtr suppression.
# AC-3: unit without route-priority uses kernel default (no ze intervention).
stdin=config:terminator=EOF_CONF
interface {
    ethernet eth0 {
        unit 0 {
            route-priority 5
            address [ 2001:db8::1/64 ]
        }
        unit 1 {
            address [ 2001:db8:1::1/64 ]
        }
    }
}
EOF_CONF

cmd=foreground:seq=1:exec=ze config validate -:stdin=config
expect=exit:code=0
