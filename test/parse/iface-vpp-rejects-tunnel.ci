# Test: tunnel is rejected under backend vpp
# VALIDATES: spec-backend-feature-gate AC-2 -- commit-time feature gate
#            rejects a tunnel list entry when the active backend is vpp,
#            naming the /interface/tunnel YANG path.
# PREVENTS: vpp receiving an Apply call for tunnel creation that lands
#           on errNotSupported inside ifacevpp.CreateTunnel.
stdin=config:terminator=EOF_CONF
interface {
	backend vpp;
	tunnel t0 {
		encapsulation {
			gre {
				local { ip 192.0.2.1; }
				remote { ip 198.51.100.1; }
			}
		}
	}
}
EOF_CONF

cmd=foreground:seq=1:exec=ze config validate -:stdin=config
expect=exit:code=1
expect=stdout:contains=/interface/tunnel
expect=stdout:contains="vpp"
