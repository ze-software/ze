# Test: ze config set system authentication user X plaintext-password "secret"
# VALIDATES: AC-2 -- Junos-style plaintext->bcrypt rewrite at commit time.
# PREVENTS: plaintext password persisting on disk; canonical leaf left empty.
# After ze config set runs, the persisted file must contain a $2a$10$... hash
# under 'password' and must NOT contain the plaintext or the plaintext-password leaf.

stdin=config:terminator=EOF_STDIN
bgp {
	peer peer1 {
		connection {
			remote {
				ip 127.0.0.1
			}
			local {
				ip 127.0.0.1
			}
		}
		session {
			asn {
				local 65533
				remote 65533
			}
		}
	}
}
EOF_STDIN

tmpfs=test.conf:terminator=EOF_CONF
bgp {
	peer peer1 {
		connection {
			remote {
				ip 127.0.0.1
			}
			local {
				ip 127.0.0.1
			}
		}
		session {
			asn {
				local 65533
				remote 65533
			}
		}
	}
}

system {
	authentication {
		user alice {
		}
	}
}
EOF_CONF

# Set the plaintext password — commit hook must bcrypt it before write.
cmd=foreground:seq=1:exec=ze config set --no-reload test.conf system authentication user alice plaintext-password "secret"
expect=exit:code=0

# Verify the file: bcrypt prefix present, plaintext absent.
cmd=foreground:seq=2:exec=ze config dump test.conf
expect=exit:code=0
expect=stdout:contains=$2a$10$
reject=stdout:contains=plaintext-password
reject=stdout:contains=password: secret
