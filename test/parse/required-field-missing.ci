# Test: ze config validate skips peer missing required field
# A standalone peer without session/asn/remote is incomplete and skipped
# so the daemon can start for config editing with partial configs.
stdin=config:terminator=EOF_CONF
bgp {
    router-id 1.2.3.4
    session {
        asn {
            local 65000
        }
    }
    peer test_peer {
        connection {
            remote {
                ip 10.0.0.1
            }
        }
    }
}
EOF_CONF

cmd=foreground:seq=1:exec=ze config validate -:stdin=config
expect=exit:code=0
expect=stderr:contains=incomplete
