# Test: BGP route reflection and next-hop control config parsing
# Validates YANG leaves: route-reflector-client, cluster-id, next-hop
stdin=config:terminator=EOF_CONF
bgp {
	router-id 1.1.1.1
	session {
		asn {
			local 65000
		}
	}
	group IBGP {
		session {
			route-reflector-client true
			cluster-id 1.1.1.1
			next-hop self
		}
		peer client1 {
			connection {
				remote {
					ip 10.0.0.1
				}
				local {
					ip 10.0.0.100
				}
			}
			session {
				asn {
					remote 65000
				}
			}
		}
		peer client2 {
			connection {
				remote {
					ip 10.0.0.2
				}
				local {
					ip 10.0.0.100
				}
			}
			session {
				asn {
					remote 65000
				}
				next-hop unchanged
			}
		}
	}
	peer ebgp-upstream {
		connection {
			remote {
				ip 192.168.1.1
			}
			local {
				ip 192.168.1.2
			}
		}
		session {
			asn {
				remote 65001
			}
			next-hop 10.0.0.254
		}
	}
}
EOF_CONF

cmd=foreground:seq=1:exec=ze config validate -:stdin=config
expect=exit:code=0
expect=stdout:contains=configuration valid
