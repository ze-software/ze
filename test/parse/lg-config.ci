# Test: ze config validate with looking-glass config
# VALIDATES: LG YANG schema accepts environment.looking-glass block
# PREVENTS: LG config rejected by YANG parser
stdin=config:terminator=EOF_CONF
bgp {
	peer peer1 {
		remote {
			ip 127.0.0.1
			as 65533
		}
		local {
			as 65533
			ip 127.0.0.1
		}
	}
}

environment {
	looking-glass {
		host 0.0.0.0
		port 8443
	}
}
EOF_CONF

cmd=foreground:seq=1:exec=ze config validate -:stdin=config
expect=exit:code=0
expect=stdout:contains=configuration valid
