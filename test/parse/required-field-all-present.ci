# Test: ze config validate accepts peer with all required fields present
stdin=config:terminator=EOF_CONF
bgp {
    router-id 1.2.3.4
    session {
        asn {
            local 65000
        }
    }
    peer test_peer {
        connection {
            remote {
                ip 10.0.0.1
            }
            local {
                ip auto
            }
        }
        session {
            asn {
                remote 65001
            }
        }
    }
}
EOF_CONF

cmd=foreground:seq=1:exec=ze config validate -:stdin=config
expect=exit:code=0
expect=stdout:contains=configuration valid
