# Test: config with inactive peer parses successfully
# Verifies that the inactive leaf is accepted in peer config
# and that the inactive: prefix sugar is also valid.
stdin=config:terminator=EOF_CONF
bgp {
	session {
		asn {
			local 65000
		}
	}
	router-id 1.2.3.4
	peer active-peer {
		connection {
			remote {
				ip 10.0.0.1
			}
			local {
				ip auto
			}
		}
		session {
			asn {
				remote 65001
			}
		}
	}
	inactive: peer disabled-peer {
		connection {
			local {
				ip auto
			}
			remote {
				ip 10.0.0.2
			}
		}
		session {
			asn {
				remote 65002
			}
		}
	}
}
EOF_CONF

cmd=foreground:seq=1:exec=ze config validate -:stdin=config
expect=exit:code=0
expect=stdout:contains=configuration valid
