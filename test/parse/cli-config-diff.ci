# Test: ze config diff with changed peer-as and added peer
# VALIDATES: AC-10 — changed values appear in diff output
# VALIDATES: AC-11 — added peer subtree appears in diff output
stdin=config:terminator=EOF_CONF
bgp {
	router-id 1.1.1.1
	session {
		asn {
			local 65000
		}
	}
	peer peer1 {
		connection {
			remote {
				ip 10.0.0.1
			}
			local {
				ip 10.0.0.254
			}
		}
		session {
			asn {
				remote 65001
			}
		}
	}
}
EOF_CONF

tmpfs=old.conf:terminator=EOF_OLD
bgp {
	router-id 1.1.1.1
	session {
		asn {
			local 65000
		}
	}
	peer peer1 {
		connection {
			remote {
				ip 10.0.0.1
			}
			local {
				ip 10.0.0.254
			}
		}
		session {
			asn {
				remote 65001
			}
		}
	}
}
EOF_OLD

tmpfs=new.conf:terminator=EOF_NEW
bgp {
	router-id 1.1.1.1
	session {
		asn {
			local 65000
		}
	}
	peer peer1 {
		connection {
			remote {
				ip 10.0.0.1
			}
			local {
				ip 10.0.0.254
			}
		}
		session {
			asn {
				remote 65002
			}
		}
	}
	peer peer2 {
		connection {
			remote {
				ip 10.0.0.2
			}
			local {
				ip 10.0.0.254
			}
		}
		session {
			asn {
				remote 65003
			}
		}
	}
}
EOF_NEW

option=env:var=ze.storage.blob:value=false

cmd=foreground:seq=1:exec=ze config diff old.conf new.conf
expect=exit:code=0
expect=stdout:contains=remote
expect=stdout:contains=10.0.0.2
