# Test: ze validate with invalid SSH config (unknown field)
# Verifies that unknown fields in the ssh block are rejected
stdin=config:terminator=EOF_CONF
bgp {
	peer peer1 {
		remote {
			ip 127.0.0.1
			as 65533
		}
		local {
			as 65533
			ip 127.0.0.1
		}
	}
}

system {
	ssh {
		listen 0.0.0.0:2222
		unknown-field value
	}
}
EOF_CONF

cmd=foreground:seq=1:exec=ze validate -:stdin=config
expect=exit:code=1
expect=stderr:contains=unknown
