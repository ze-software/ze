# Test: ze exabgp migrate converts ExaBGP config to ze format
# VALIDATES: exabgp migrate translates neighbor to peer
# PREVENTS: migration dropping peer address or ASN values
stdin=config:terminator=EOF_STDIN
bgp {
	peer peer1 {
		remote {
			ip 127.0.0.1
			as 65533
		}
		local {
			as 65533
			ip 127.0.0.1
		}
	}
}
EOF_STDIN

tmpfs=exabgp.conf:terminator=EOF_CONF
neighbor 10.0.0.1 {
	router-id 1.1.1.1
	local-address 10.0.0.2
	local-as 65001
	peer-as 65002
	hold-time 180
}
EOF_CONF

cmd=foreground:seq=1:exec=ze exabgp migrate exabgp.conf
expect=exit:code=0
expect=stdout:contains=peer
expect=stdout:contains=remote
expect=stdout:contains=local
