# Test: ze config dump (new path, was ze bgp config-dump)
# This tests the moved config-dump as a subcommand of config
stdin=config:terminator=EOF_CONF
bgp {
	router-id 10.0.0.1
	session {
		asn {
			local 65533
		}
	}
	peer peer1 {
		connection {
			remote {
				ip 127.0.0.1
			}
			local {
				ip 127.0.0.1
			}
		}
		session {
			asn {
				remote 65534
			}
		}
	}
}
EOF_CONF

tmpfs=test.conf:terminator=EOF_FILE
bgp {
	router-id 10.0.0.1
	session {
		asn {
			local 65533
		}
	}
	peer peer1 {
		connection {
			remote {
				ip 127.0.0.1
			}
			local {
				ip 127.0.0.1
			}
		}
		session {
			asn {
				remote 65534
			}
		}
	}
}
EOF_FILE

cmd=foreground:seq=1:exec=ze config dump test.conf
expect=exit:code=0
expect=stdout:contains=router-id
expect=stdout:contains=local: 65533
