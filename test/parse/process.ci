# Valid config: process with group
stdin=config:terminator=EOF_CONF
plugin {
	external my-process {
		run ./syslog-1.py
		encoder json
	}
}
bgp {
	group default {
		process my-process {
			receive [ state ]
		}

		peer 10.0.0.3 {
			description "will pass received routes to the program"
			router-id 10.0.0.2
			local-address 10.0.0.2
			local-as 65533
			peer-as 65533
			hold-time 180
		}
	}
}
EOF_CONF

cmd=foreground:seq=1:exec=ze validate -:stdin=config
expect=exit:code=0
