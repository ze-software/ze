# Test: ExaBGP legacy flow block is rejected
# flow { route { match {} then {} } } is not supported — use update { nlri { } } instead
stdin=config:terminator=EOF_CONF
bgp {
	peer 10.0.0.3 {
		local-address 10.0.0.2
		local-as 65533
		peer-as 65533
		flow {
			route test {
				match {
					source-ipv4 10.0.0.1/32
				}
				then {
					discard
				}
			}
		}
	}
}
EOF_CONF

cmd=foreground:seq=1:exec=ze validate -:stdin=config
expect=exit:code=1
expect=stderr:contains=unknown field in
