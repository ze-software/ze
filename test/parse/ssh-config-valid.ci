# Test: ze config validate with valid SSH config block
# Verifies that the SSH server configuration is accepted by the YANG schema
stdin=config:terminator=EOF_CONF
bgp {
	peer peer1 {
		connection {
			remote {
				ip 127.0.0.1
			}
			local {
				ip 127.0.0.1
			}
		}
		session {
			asn {
				local 65533
				remote 65533
			}
		}
	}
}

system {
	authentication {
		user admin {
			password "$2a$10$abcdefghijklmnopqrstuuABCDEFGHIJKLMNOPQRSTUVWXYZ012"
		}
	}
}

environment {
	ssh {
		enabled true
		server main {
			ip 0.0.0.0
			port 2222
		}
		host-key /etc/ze/ssh_host_ed25519_key
		idle-timeout 600
		max-sessions 8
	}
}
EOF_CONF

cmd=foreground:seq=1:exec=ze config validate -:stdin=config
expect=exit:code=0
expect=stdout:contains=configuration valid
