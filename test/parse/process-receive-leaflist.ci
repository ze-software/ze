# Test: process receive with leaf-list bracket syntax
stdin=config:terminator=EOF_CONF
plugin {
	external my-process {
		run ./syslog-1.py
		encoder json
	}
}
bgp {
	peer peer3 {
		connection {
			remote {
				ip 10.0.0.3
			}
			local {
				ip 10.0.0.2
			}
		}
		session {
			asn {
				local 65533
				remote 65533
			}
		}
		process my-process {
			receive [ update state negotiated ]
		}
	}
}
EOF_CONF

cmd=foreground:seq=1:exec=ze config validate -:stdin=config
expect=exit:code=0
