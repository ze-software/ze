# Valid config: simple IPv4 peer with multiple routes
stdin=config:terminator=EOF_CONF
bgp {
	peer 127.0.0.1 {
		description "a quagga test peer"
		router-id 10.0.0.2
		local-address 127.0.0.1
		local-as 65533
		peer-as 65533
		hold-time 180
		update {
			attribute {
				origin igp
				next-hop 10.0.255.254
				community 0
			}
			nlri {
				ipv4/unicast add 10.0.1.0/24
			}
		}
		update {
			attribute {
				origin igp
				next-hop 10.0.255.254
				community 30740:30740
			}
			nlri {
				ipv4/unicast add 10.0.2.0/24
			}
		}
		update {
			attribute {
				origin igp
				next-hop 10.0.255.254
				community [ 30740:30740 30740:0 ]
			}
			nlri {
				ipv4/unicast add 10.0.3.0/24
			}
		}
		update {
			attribute {
				origin igp
				next-hop 10.0.255.254
				local-preference 200
			}
			nlri {
				ipv4/unicast add 10.0.4.0/24
				ipv4/unicast add 10.0.5.0/24
			}
		}
		update {
			attribute {
				origin igp
				next-hop 10.0.255.254
				community 30740:30740
			}
			nlri {
				ipv4/unicast add 10.0.6.0/24
			}
		}
		update {
			attribute {
				origin igp
				next-hop 10.0.255.254
				local-preference 200
				community 30740:30740
			}
			nlri {
				ipv4/unicast add 10.0.7.0/24
				ipv4/unicast add 10.0.8.0/24
			}
		}
		update {
			attribute {
				origin igp
				next-hop 10.0.255.254
				local-preference 200
				community [ 30740:0 30740:30740 ]
			}
			nlri {
				ipv4/unicast add 10.0.7.0/24
				ipv4/unicast add 10.0.8.0/24
			}
		}
	}
}
EOF_CONF

cmd=foreground:seq=1:exec=ze validate -:stdin=config
expect=exit:code=0
