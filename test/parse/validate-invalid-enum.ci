# Test: Invalid enum value rejected
# VALIDATES: AC-1 — connection invalid-value triggers validation error
stdin=config:terminator=EOF_CONF
bgp {
	router-id 1.2.3.4
	local {
		as 65000
	}
	peer peer1 {
		remote {
			ip 192.0.2.1
			as 65001
		}
		local {
			ip 192.0.2.2
		}
		connection invalid-value
	}
}
EOF_CONF

cmd=foreground:seq=1:exec=ze validate -:stdin=config
expect=exit:code=1
expect=stderr:contains=connection
