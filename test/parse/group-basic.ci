# Valid config: peer groups with inherited hold-time
stdin=config:terminator=EOF_CONF
bgp {
	router-id 1.2.3.4
	local {
		as 65000
	}
	group peering {
		timer {
			hold-time 180
		}
		peer peer1 {
			remote {
				ip 127.0.0.1
				as 65001
			}
			local {
				ip 127.0.0.1
			}
		}
	}
}
EOF_CONF

cmd=foreground:seq=1:exec=ze config validate -:stdin=config
expect=exit:code=0
