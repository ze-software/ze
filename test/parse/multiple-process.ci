# Valid config: multiple processes with group
stdin=config:terminator=EOF_CONF
plugin {
	external my-process {
		run ./syslog-1.py
		encoder json
	}
	external my-second-process {
		run ./stderr-1.py
		encoder json
	}
}
bgp {
	group test {
		process my-process {
			receive [ state ]
		}
		process my-second-process {
			receive [ state ]
		}

		peer peer3 {
			remote {
				ip 10.0.0.3
				as 65533
			}
			local {
				as 65533
				ip 10.0.0.2
			}
			description "will pass received routes to the program"
			router-id 10.0.0.2
			timer {
				hold-time 180
			}
		}
	}
}
EOF_CONF

cmd=foreground:seq=1:exec=ze config validate -:stdin=config
expect=exit:code=0
