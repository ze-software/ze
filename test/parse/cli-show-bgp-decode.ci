# Test: ze show bgp decode dispatches through YANG verb tree
# VALIDATES: show bgp decode is wired via local handler to bgp.Run
# PREVENTS: show bgp decode not reaching the decode handler
stdin=config:terminator=EOF_CONF
bgp {
	peer peer1 {
		remote {
			ip 127.0.0.1
			as 65533
		}
		local {
			as 65533
			ip 127.0.0.1
		}
	}
}
EOF_CONF

cmd=foreground:seq=1:exec=ze show bgp decode --help
expect=exit:code=0
expect=stdout:contains=Decode BGP message
expect=stdout:contains=hex-payload
