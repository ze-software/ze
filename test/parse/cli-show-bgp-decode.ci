# Test: ze show bgp decode dispatches through YANG verb tree
# VALIDATES: show bgp decode is wired via local handler to bgp.Run
# PREVENTS: show bgp decode not reaching the decode handler
stdin=config:terminator=EOF_CONF
bgp {
	peer peer1 {
		connection {
			remote {
				ip 127.0.0.1
			}
			local {
				ip 127.0.0.1
			}
		}
		session {
			asn {
				local 65533
				remote 65533
			}
		}
	}
}
EOF_CONF

cmd=foreground:seq=1:exec=ze bgp decode --help
expect=exit:code=0
expect=stderr:contains=Decode BGP message
expect=stderr:contains=hex
