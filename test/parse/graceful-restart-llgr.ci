# Valid config: graceful-restart with long-lived-stale-time (RFC 9494)
stdin=config:terminator=EOF_CONF
bgp {
	peer peer1 {
		connection {
			remote {
				ip 10.0.0.1
			}
			local {
				ip 192.0.2.1
			}
		}
		session {
			asn {
				local 65001
				remote 65002
			}
			router-id 1.2.3.4
			capability {
				graceful-restart {
					restart-time 120
					long-lived-stale-time 3600
				}
			}
		}
		process gr {
			send [ update ]
		}
	}
}
EOF_CONF

cmd=foreground:seq=1:exec=ze config validate -:stdin=config
expect=exit:code=0
