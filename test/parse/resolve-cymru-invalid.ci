# Test: ze resolve cymru asn-name with non-numeric ASN exits 1
# VALIDATES: AC-19 -- invalid ASN validation
# PREVENTS: panic on non-numeric ASN input
# Note: stderr assertion removed -- test runner doesn't capture stderr for standalone foreground commands.
# Full stderr validation in Go unit test TestCmdCymruInvalidASN.
stdin=config:terminator=EOF_CONF
bgp {
	peer peer1 {
		connection {
			remote {
				ip 127.0.0.1
			}
			local {
				ip 127.0.0.1
			}
		}
		session {
			asn {
				local 65533
				remote 65533
			}
		}
	}
}
EOF_CONF

cmd=foreground:seq=1:exec=ze resolve cymru asn-name abc
expect=exit:code=1
