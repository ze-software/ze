# Test: Valid complete config passes validation
# VALIDATES: AC-7 — valid complete config produces no errors
stdin=config:terminator=EOF_CONF
bgp {
	router-id 1.2.3.4
	local-as 65000
	peer 192.0.2.1 {
		local-address 192.0.2.2
		peer-as 65001
		hold-time 90
	}
}
EOF_CONF

cmd=foreground:seq=1:exec=ze validate -:stdin=config
expect=exit:code=0
expect=stdout:contains=configuration valid
