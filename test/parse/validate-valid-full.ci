# Test: Valid complete config passes validation
# VALIDATES: AC-7 — valid complete config produces no errors
stdin=config:terminator=EOF_CONF
bgp {
	router-id 1.2.3.4
	session {
		asn {
			local 65000
		}
	}
	peer peer1 {
		connection {
			remote {
				ip 192.0.2.1
			}
			local {
				ip 192.0.2.2
			}
		}
		session {
			asn {
				remote 65001
			}
		}
		timer {
			receive-hold-time 90
		}
	}
}
EOF_CONF

cmd=foreground:seq=1:exec=ze config validate -:stdin=config
expect=exit:code=0
expect=stdout:contains=configuration valid
