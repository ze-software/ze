# Valid config: extended community syntax
stdin=config:terminator=EOF_CONF
bgp {
	peer peer1 {
		connection {
			remote {
				ip 10.0.200.1
			}
			local {
				ip 3.3.3.3
			}
		}
		session {
			asn {
				local 65000
				remote 65000
			}
			router-id 1.2.3.4
		}
		behavior {
			group-updates disable
		}
		update {
			attribute {
				origin igp
				next-hop 192.0.2.1
				extended-community [ target:120000L:123 origin:130000:1234 ]
			}
			nlri {
				ipv4/unicast add 9.9.9.9/32
			}
		}
	}
}
EOF_CONF

cmd=foreground:seq=1:exec=ze config validate -:stdin=config
expect=exit:code=0
