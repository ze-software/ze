# Test: ze config validate accepts port 0 in L2TP server block
# Note: port 0 means "OS-assigned"; YANG range now allows 0..65535
stdin=config:terminator=EOF_CONF
l2tp {
	enabled true
}
environment {
	l2tp {
		server main {
			ip 127.0.0.1
			port 0
		}
	}
}
EOF_CONF

cmd=foreground:seq=1:exec=ze config validate -:stdin=config
expect=exit:code=0
