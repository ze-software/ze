# Test: ze config check on valid current config
# VALIDATES: config check reports current config needs no migration
# VALIDATES: config check with deprecated patterns returns exit 1
# PREVENTS: check command regression on migration detection
stdin=config:terminator=EOF_STDIN
bgp {
	peer peer1 {
		remote {
			ip 127.0.0.1
			as 65533
		}
		local {
			as 65533
			ip 127.0.0.1
		}
	}
}
EOF_STDIN

tmpfs=test.conf:terminator=EOF_CONF
bgp {
	router-id 10.0.0.1
	local {
		as 65533
	}
	peer peer1 {
		remote {
			ip 127.0.0.1
			as 65534
		}
		local {
			ip 127.0.0.1
		}
	}
}
EOF_CONF

cmd=foreground:seq=1:exec=ze config check test.conf
expect=exit:code=0
expect=stdout:contains=Config is current

# Deprecated config: uses "neighbor" keyword (ExaBGP legacy format)
tmpfs=old.conf:terminator=EOF_OLD
neighbor 127.0.0.1 {
	router-id 10.0.0.1
	local-as 65533
	peer-as 65534
}
EOF_OLD

cmd=foreground:seq=2:exec=ze config check old.conf
expect=exit:code=1
expect=stdout:contains=needs migration
