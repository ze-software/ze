# Test: ze config validate on valid current config
# VALIDATES: config validate reports valid config
# PREVENTS: validate command regression
stdin=config:terminator=EOF_STDIN
bgp {
	peer peer1 {
		connection {
			remote {
				ip 127.0.0.1
			}
			local {
				ip 127.0.0.1
			}
		}
		session {
			asn {
				local 65533
				remote 65533
			}
		}
	}
}
EOF_STDIN

tmpfs=test.conf:terminator=EOF_CONF
bgp {
	router-id 10.0.0.1
	session {
		asn {
			local 65533
		}
	}
	peer peer1 {
		connection {
			remote {
				ip 127.0.0.1
			}
			local {
				ip 127.0.0.1
			}
		}
		session {
			asn {
				remote 65534
			}
		}
	}
}
EOF_CONF

cmd=foreground:seq=1:exec=ze config validate test.conf
expect=exit:code=0
expect=stdout:contains=configuration valid
