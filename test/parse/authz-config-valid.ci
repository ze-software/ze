# Test: ze config validate with valid authorization profile config
# Verifies that the YANG schema accepts authorization profiles with run/edit sections
stdin=config:terminator=EOF_CONF
bgp {
	peer peer1 {
		connection {
			remote {
				ip 127.0.0.1
			}
			local {
				ip 127.0.0.1
			}
		}
		session {
			asn {
				local 65533
				remote 65533
			}
		}
	}
}

system {
	authorization {
		profile noc {
			run {
				default-action deny
				entry 10 {
					action allow
					match "peer show"
				}
				entry 20 {
					action allow
					match "peer summary"
				}
			}
			edit {
				default-action deny
			}
		}
		profile admin {
			run {
				default-action allow
			}
			edit {
				default-action allow
			}
		}
	}
}
EOF_CONF

cmd=foreground:seq=1:exec=ze config validate -:stdin=config
expect=exit:code=0
expect=stdout:contains=configuration valid
