# Test: ze resolve cymru with no args prints usage and exits 1
# VALIDATES: missing args shows cymru usage
# PREVENTS: panic on empty args
stdin=config:terminator=EOF_CONF
bgp {
	peer peer1 {
		connection {
			remote {
				ip 127.0.0.1
			}
			local {
				ip 127.0.0.1
			}
		}
		session {
			asn {
				local 65533
				remote 65533
			}
		}
	}
}
EOF_CONF

option=env:var=NO_COLOR:value=1
cmd=foreground:seq=1:exec=ze resolve cymru
expect=exit:code=1
expect=stdout:contains=Operations:
expect=stdout:contains=asn-name
