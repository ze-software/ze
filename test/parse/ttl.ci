# Valid config: outgoing TTL setting
stdin=config:terminator=EOF_CONF
bgp {
	peer 10.0.0.3 {
		description "will announce 256 /24"
		router-id 198.111.227.39
		local-address 10.0.0.2
		local-as 65533
		peer-as 65533
		hold-time 180
		outgoing-ttl 1
		update {
			attribute {
				origin igp
				next-hop 192.0.2.1
				med 200
				community 174:666
			}
			nlri {
				ipv4/unicast add 172.10.0.0/16
			}
		}
	}
}
EOF_CONF

cmd=foreground:seq=1:exec=ze validate -:stdin=config
expect=exit:code=0
