# Test: plugin hub config with listen and secret is valid
# VALIDATES: hub config block is accepted by YANG schema parser
# PREVENTS: hub config being rejected as unknown key

stdin=ze-bgp:terminator=EOF_CONF
plugin {
    hub {
        listen 127.0.0.1:12700;
        secret abcdefghijklmnopqrstuvwxyz012345;
    }
}
bgp {
    peer peer1 {
    	remote {
    		ip 127.0.0.1
    		as 1
    	}
    	local {
    		as 1
    		ip 127.0.0.1
    	}
        router-id 1.2.3.4
    }
}
EOF_CONF

cmd=foreground:seq=1:exec=ze bgp validate -:stdin=ze-bgp
expect=exit:code=0
