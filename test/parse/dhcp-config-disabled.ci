# Valid config: interface unit without DHCP (static address)
# AC-2: No dhcp block means no DHCP client, config valid.
stdin=config:terminator=EOF_CONF
interface {
    ethernet eth0 {
        unit 0 {
            address [10.0.0.1/24]
        }
    }
}
EOF_CONF

cmd=foreground:seq=1:exec=ze config validate -:stdin=config
expect=exit:code=0
