# Test: plugin hub config with multiple server blocks
# VALIDATES: list server accepts multiple named entries
# PREVENTS: Only first server being parsed

stdin=ze-bgp:terminator=EOF_CONF
plugin {
    hub {
        server local {
            host 127.0.0.1;
            port 12700;
            secret abcdefghijklmnopqrstuvwxyz012345;
        }
        server remote {
            host 192.168.1.1;
            port 12700;
            secret abcdefghijklmnopqrstuvwxyz012345;
        }
    }
}
bgp {
    peer peer1 {
    	remote {
    		ip 127.0.0.1
    		as 1
    	}
    	local {
    		as 1
    		ip 127.0.0.1
    	}
        router-id 1.2.3.4
    }
}
EOF_CONF

cmd=foreground:seq=1:exec=ze bgp validate -:stdin=ze-bgp
expect=exit:code=0
