# Test: ze config fmt outputs formatted config
# VALIDATES: fmt command normalizes config to stdout with proper structure
# PREVENTS: fmt command losing config structure or values
stdin=config:terminator=EOF_STDIN
bgp {
	peer peer1 {
		remote {
			ip 127.0.0.1
			as 65533
		}
		local {
			as 65533
			ip 127.0.0.1
		}
	}
}
EOF_STDIN

tmpfs=test.conf:terminator=EOF_CONF
bgp {
	router-id 10.0.0.1
	local {
		as 65533
	}
	peer peer1 {
		remote {
			ip 127.0.0.1
			as 65534
		}
		local {
			ip 127.0.0.1
		}
	}
}
EOF_CONF

cmd=foreground:seq=1:exec=ze config fmt test.conf
expect=exit:code=0
expect=stdout:contains=bgp {
expect=stdout:contains=peer peer1 {
expect=stdout:contains=remote 65534
