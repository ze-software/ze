# Test: Valid telemetry prometheus config parses
# VALIDATES: AC-1 — telemetry { prometheus { enabled true; } } accepted by YANG validation
stdin=config:terminator=EOF_CONF
bgp {
	router-id 10.0.0.1
	local {
		as 65533
	}
	peer peer1 {
		remote {
			ip 127.0.0.1
			as 65534
		}
		local {
			ip 127.0.0.1
		}
	}
}
telemetry {
	prometheus {
		enabled true
		address 127.0.0.1
		port 9273
		path /metrics
	}
}
EOF_CONF

cmd=foreground:seq=1:exec=ze config validate -:stdin=config
expect=exit:code=0
expect=stdout:contains=configuration valid
