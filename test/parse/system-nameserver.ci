# Test: ze config validate with static DNS name-servers
# VALIDATES: AC-1 -- YANG config specifies name-server leaf-list, accepted by schema
# VALIDATES: AC-5 -- resolv-conf-path under system dns accepted by schema
stdin=config:terminator=EOF_CONF
bgp {
	peer peer1 {
		connection {
			remote {
				ip 127.0.0.1
			}
			local {
				ip 127.0.0.1
			}
		}
		session {
			asn {
				local 65533
				remote 65533
			}
		}
	}
}

system {
	name-server [8.8.8.8 1.1.1.1]
	dns {
		resolv-conf-path /tmp/resolv.conf
	}
}
EOF_CONF

cmd=foreground:seq=1:exec=ze config validate -:stdin=config
expect=exit:code=0
expect=stdout:contains=configuration valid
