# Invalid config: route-refresh requires process with send [ update ]
stdin=config:terminator=EOF_CONF
bgp {
	peer peer1 {
		remote {
			ip 10.0.0.1
			as 65002
		}
		local {
			as 65001
			ip 192.0.2.1
		}
		router-id 1.2.3.4
		capability {
			route-refresh
		}
	}
}
EOF_CONF

cmd=foreground:seq=1:exec=ze validate -:stdin=config
expect=exit:code=1
expect=stderr:contains=route-refresh requires process with send [ update ]
