# Test: config with $9$-encoded md5-password parses and validates
stdin=config:terminator=EOF_CONF
bgp {
	router-id 10.0.0.1
	session {
		asn {
			local 65533
		}
	}
	peer peer3 {
		connection {
			remote {
				ip 10.0.0.3
			}
			local {
				ip 10.0.0.1
			}
			md5 {
				password $9$QI1cF39tpBEhrAtM87Nbw
			}
		}
		session {
			asn {
				remote 65534
			}
		}
	}
}
EOF_CONF
