# Test: pre-hashed bcrypt value on the canonical password leaf is accepted.
# VALIDATES: AC-1 -- canonical $2a$10$... stored verbatim, no $9$ decode.
# PREVENTS: regression where ze:bcrypt parser would mangle a real hash.

stdin=config:terminator=EOF_STDIN
bgp {
	peer peer1 {
		connection {
			remote {
				ip 127.0.0.1
			}
			local {
				ip 127.0.0.1
			}
		}
		session {
			asn {
				local 65533
				remote 65533
			}
		}
	}
}

system {
	authentication {
		user admin {
			password "$2a$10$abcdefghijklmnopqrstuuABCDEFGHIJKLMNOPQRSTUVWXYZ012"
		}
	}
}
EOF_STDIN

cmd=foreground:seq=1:exec=ze config validate -:stdin=config
expect=exit:code=0
expect=stdout:contains=configuration valid
