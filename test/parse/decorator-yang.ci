# Test: ze config validate with YANG leaves having ze:decorate extension
# VALIDATES: AC-7 -- ze:decorate extension does not break config parsing
# VALIDATES: AC-2 -- non-decorated leaves still parse correctly
stdin=config:terminator=EOF_CONF
bgp {
	session {
		asn {
			local 64500
		}
	}
	peer upstream {
		connection {
			remote {
				ip 192.168.1.1
			}
			local {
				ip 192.168.1.2
			}
		}
		session {
			asn {
				remote 13335
			}
		}
	}
}
EOF_CONF

cmd=foreground:seq=1:exec=ze config validate -:stdin=config
expect=exit:code=0
expect=stdout:contains=configuration valid
