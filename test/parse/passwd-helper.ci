# Test: ze passwd hashes piped plaintext to a valid bcrypt $2a$10$... on stdout.
# VALIDATES: AC-13 -- echo "secret" | ze passwd produces valid hash.

stdin=config:terminator=EOF_STDIN
bgp {
	peer peer1 {
		connection {
			remote {
				ip 127.0.0.1
			}
			local {
				ip 127.0.0.1
			}
		}
		session {
			asn {
				local 65533
				remote 65533
			}
		}
	}
}
EOF_STDIN

cmd=foreground:seq=1:exec=sh:args=-c,echo secret | ze passwd
expect=exit:code=0
expect=stdout:contains=$2a$10$
