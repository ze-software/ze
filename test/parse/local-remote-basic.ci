# Valid config: peer with nested local/remote containers and global local AS
# Exercises: peer keyed by name, remote {ip, as}, local {as, ip}, global local {as}
stdin=config:terminator=EOF_CONF
bgp {
	router-id 10.0.0.1
	session {
		asn {
			local 65000
		}
	}
	peer upstream-1 {
		connection {
			remote {
				ip 10.0.0.2
			}
			local {
				ip 10.0.0.1
			}
		}
		session {
			asn {
				remote 65002
			}
		}
	}
	peer upstream-2 {
		connection {
			remote {
				ip 10.0.0.3
			}
			local {
				ip 10.0.0.1
			}
		}
		session {
			asn {
				local 65100
				remote 65003
			}
		}
	}
}
EOF_CONF

cmd=foreground:seq=1:exec=ze config validate -:stdin=config
expect=exit:code=0
