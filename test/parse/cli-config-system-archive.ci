# Test: system { host; domain; archive { ... } } combined config parses
# Validates that system identity + archive blocks work together
stdin=config:terminator=EOF_CONF
system {
	host myrouter
	domain lab.example.com
	archive backup {
		location file:///var/backups/ze
		filename "{name}-{host}-{domain}-{date}"
		timeout 10s
		trigger manual
	}
}
bgp {
	router-id 10.0.0.1
	local {
		as 65533
	}
	peer peer1 {
		remote {
			ip 127.0.0.1
			as 65534
		}
		local {
			ip 127.0.0.1
		}
	}
}
EOF_CONF

cmd=foreground:seq=1:exec=ze config check -
expect=exit:code=0
