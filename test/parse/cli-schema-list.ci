# Test: ze schema list (new path, was ze bgp schema list)
# This tests the moved schema command at root level
# Note: schema list doesn't need config input, but test runner requires stdin
stdin=config:terminator=EOF_CONF
# Minimal valid config for test framework
bgp {
	peer 127.0.0.1 {
		local-address 127.0.0.1;
		local-as 65533;
		peer-as 65533;
	}
}
EOF_CONF

cmd=foreground:seq=1:exec=ze schema list
expect=exit:code=0
expect=stdout:contains=Registered schemas
expect=stdout:contains=ze-bgp
