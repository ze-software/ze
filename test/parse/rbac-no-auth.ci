# Test: config without authentication/authorization parses successfully
#
# VALIDATES: AC-5 — no authentication configured = backwards compatible.
# PREVENTS: Missing system block causes parse error or panic.

stdin=config:terminator=EOF_CONF
bgp {
	peer peer1 {
		remote {
			ip 127.0.0.1
			as 65533
		}
		local {
			as 65533
			ip 127.0.0.1
		}
	}
}
EOF_CONF

cmd=foreground:seq=1:exec=ze validate -:stdin=config
expect=exit:code=0
expect=stdout:contains=configuration valid
