# Valid config: IPv6 peer with IPv4 and IPv6 routes
stdin=config:terminator=EOF_CONF
bgp {
	peer peer-v6-1 {
		connection {
			remote {
				ip 2a02:b80::2
			}
			local {
				ip 2a02:b80::1
			}
		}
		session {
			asn {
				local 65533
				remote 65533
			}
			router-id 10.0.0.2
		}
		description "a quagga test peer over ipv6"
		update {
			attribute {
				origin igp
				next-hop 5.6.7.8
			}
			nlri {
				ipv4/unicast add 1.2.3.4/32
			}
		}
		update {
			attribute {
				origin igp
				next-hop 2A02:B80:0:2::1
				local-preference 200
				community [ 30740:0 30740:30740 ]
			}
			nlri {
				ipv6/unicast add 2A02:B80:0:1::/64
			}
		}
	}
}
EOF_CONF

cmd=foreground:seq=1:exec=ze config validate -:stdin=config
expect=exit:code=0
