# Test: peer without local-address is rejected
# local-address is mandatory — omitting it should produce a clear error
stdin=config:terminator=EOF_CONF
bgp {
	peer peer1 {
		remote {
			ip 192.0.2.1
			as 65001
		}
		local {
			as 65000
		}
	}
}
EOF_CONF

cmd=foreground:seq=1:exec=ze config validate -:stdin=config
expect=exit:code=1
expect=stderr:contains=local ip is required
