# Test: ze config archive without archive block fails
# This tests that config archive fails gracefully when no system.archive blocks exist
stdin=config:terminator=EOF_CONF
bgp {
	router-id 10.0.0.1
	local-as 65533
	peer 127.0.0.1 {
		local-address 127.0.0.1
		peer-as 65534
	}
}
EOF_CONF

tmpfs=test.conf:terminator=EOF_FILE
bgp {
	router-id 10.0.0.1
	local-as 65533
	peer 127.0.0.1 {
		local-address 127.0.0.1
		peer-as 65534
	}
}
EOF_FILE

cmd=foreground:seq=1:exec=ze config archive backup test.conf
expect=exit:code=2
