# Valid config: peer with display name inside group
stdin=config:terminator=EOF_CONF
bgp {
	router-id 1.2.3.4
	session {
		asn {
			local 65000
		}
	}
	group peering {
		peer router-east {
			connection {
				remote {
					ip 127.0.0.1
				}
				local {
					ip 127.0.0.1
				}
			}
			session {
				asn {
					remote 65001
				}
			}
		}
	}
}
EOF_CONF

cmd=foreground:seq=1:exec=ze config validate -:stdin=config
expect=exit:code=0
