# Valid config: peer with display name inside group
stdin=config:terminator=EOF_CONF
bgp {
	router-id 1.2.3.4
	local {
		as 65000
	}
	group peering {
		peer router-east {
			remote {
				ip 127.0.0.1
				as 65001
			}
			local {
				ip 127.0.0.1
			}
		}
	}
}
EOF_CONF

cmd=foreground:seq=1:exec=ze validate -:stdin=config
expect=exit:code=0
