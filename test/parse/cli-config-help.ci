# Test: ze config help shows all subcommands
# This tests that the consolidated config command has all subcommands
# Note: config help doesn't need config input, but test runner requires stdin
stdin=config:terminator=EOF_CONF
# Minimal valid config for test framework
bgp {
	peer peer1 {
		connection {
			remote {
				ip 127.0.0.1
			}
			local {
				ip 127.0.0.1
			}
		}
		session {
			asn {
				local 65533
				remote 65533
			}
		}
	}
}
EOF_CONF

cmd=foreground:seq=1:exec=ze config help
expect=exit:code=0
expect=stderr:contains=edit
expect=stderr:contains=validate
expect=stderr:contains=migrate
expect=stderr:contains=fmt
expect=stderr:contains=dump
expect=stderr:contains=archive
