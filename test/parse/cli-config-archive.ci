# Test: ze config archive with named block and file:// location
# This tests the config archive subcommand with a named archive destination
stdin=config:terminator=EOF_CONF
system {
	host testhost
	archive local {
		location file:///tmp/ze-ci-archive-test
	}
}
bgp {
	router-id 10.0.0.1
	session {
		asn {
			local 65533
		}
	}
	peer peer1 {
		connection {
			remote {
				ip 127.0.0.1
			}
			local {
				ip 127.0.0.1
			}
		}
		session {
			asn {
				remote 65534
			}
		}
	}
}
EOF_CONF

tmpfs=test.conf:terminator=EOF_FILE
system {
	host testhost
	archive local {
		location file:///tmp/ze-ci-archive-test
	}
}
bgp {
	router-id 10.0.0.1
	session {
		asn {
			local 65533
		}
	}
	peer peer1 {
		connection {
			remote {
				ip 127.0.0.1
			}
			local {
				ip 127.0.0.1
			}
		}
		session {
			asn {
				remote 65534
			}
		}
	}
}
EOF_FILE

option=env:var=ze.storage.blob:value=false

cmd=foreground:seq=1:exec=ze config archive local test.conf
expect=exit:code=0
