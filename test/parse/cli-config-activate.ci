# Test: `ze config activate` reverses a prior deactivate
# Demonstrates the round-trip: deactivate followed by activate restores
# the file to a state validate accepts identically to the original.
tmpfs=test.conf:terminator=EOF_FILE
bgp {
	router-id 10.0.0.1
	session {
		asn {
			local 65533
		}
	}
	peer peer1 {
		connection {
			remote {
				ip 127.0.0.1
			}
			local {
				ip 127.0.0.1
			}
		}
		session {
			asn {
				remote 65534
			}
		}
	}
}
EOF_FILE

option=env:var=ze.storage.blob:value=false

cmd=foreground:seq=1:exec=ze config deactivate --no-reload test.conf bgp router-id
expect=exit:code=0

cmd=foreground:seq=2:exec=ze config activate --no-reload test.conf bgp router-id
expect=exit:code=0

cmd=foreground:seq=3:exec=ze config validate test.conf
expect=exit:code=0
