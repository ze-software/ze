# Test: NLRI without operation keyword (add/del/eor) must fail
stdin=config:terminator=EOF_CONF
bgp {
	peer peer3 {
		connection {
			remote {
				ip 10.0.0.3
			}
			local {
				ip 10.0.0.2
			}
		}
		session {
			asn {
				local 65533
				remote 65533
			}
		}
		update {
			attribute {
				origin igp
				next-hop self
			}
			nlri {
				ipv4/unicast 10.0.0.0/24
			}
		}
	}
}
EOF_CONF

cmd=foreground:seq=1:exec=ze config validate -:stdin=config
expect=exit:code=1
expect=stdout:contains=missing operation keyword
