# Test: ze schema protocol shows protocol version info
# VALIDATES: schema protocol displays hub architecture details
# PREVENTS: protocol version or declaration format regression
stdin=config:terminator=EOF_CONF
bgp {
	peer peer1 {
		connection {
			remote {
				ip 127.0.0.1
			}
			local {
				ip 127.0.0.1
			}
		}
		session {
			asn {
				local 65533
				remote 65533
			}
		}
	}
}
EOF_CONF

cmd=foreground:seq=1:exec=ze schema protocol
expect=exit:code=0
expect=stdout:contains=Version: 1.0
expect=stdout:contains=Schema Declaration Format
expect=stdout:contains=Handler Routing
