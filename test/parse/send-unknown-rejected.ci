# Test: send [ unknown-type ] rejected when no plugin registers it
# VALIDATES: AC-2: Unregistered send types rejected at config parse time
stdin=config:terminator=EOF_CONF
plugin {
	external my-process {
		run ./test.py
		encoder json
	}
}
bgp {
	peer peer1 {
		connection {
			remote {
				ip 10.0.0.1
			}
			local {
				ip 10.0.0.2
			}
		}
		session {
			asn {
				local 65001
				remote 65001
			}
		}
		process my-process {
			send [ unknown-send-type ]
		}
	}
}
EOF_CONF

cmd=foreground:seq=1:exec=ze config validate -:stdin=config
expect=exit:code=1
expect=stdout:contains=unknown-send-type
