# Test: api-server.rest with two named server entries parses
# VALIDATES: spec-named-service-listeners AC-5 -- REST transport accepts
#            multiple list server entries after the container->list YANG
#            migration in chunk 2.
# PREVENTS: Legacy container-shaped server config leaking back in; silent
#           drop of extra REST listeners.
stdin=config:terminator=EOF_CONF
bgp {
	router-id 10.0.0.1;
	session { asn { local 65533; } }
	peer peer1 {
		connection {
			remote { ip 127.0.0.1; }
			local { ip auto; }
		}
		session { asn { remote 65534; } }
	}
}
environment {
	api-server {
		rest {
			enabled true;
			server public {
				ip 0.0.0.0;
				port 8081;
			}
			server admin {
				ip 127.0.0.1;
				port 18081;
			}
		}
	}
}
EOF_CONF

cmd=foreground:seq=1:exec=ze config validate -:stdin=config
expect=exit:code=0
expect=stdout:contains=configuration valid
