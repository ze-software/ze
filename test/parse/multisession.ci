# Valid config: IPv4 and IPv6 routes with multiple update blocks
stdin=config:terminator=EOF_CONF
plugin {
	external parsed-route-backend {
		run ./syslog-1.py
		encoder json
	}
}
bgp {
	peer peer3 {
		connection {
			remote {
				ip 10.0.0.3
			}
			local {
				ip 10.0.0.2
			}
		}
		session {
			asn {
				local 123456
				remote 123456
			}
			router-id 10.0.0.2
		}
		description "will pass received routes to the program"
		timer {
			receive-hold-time 180
		}
		update {
			attribute {
				origin igp
				next-hop 192.0.2.1
			}
			nlri {
				ipv4/unicast add 10.0.0.0/24
				ipv4/unicast add 10.0.1.0/24
				ipv4/unicast add 10.0.2.0/24
				ipv4/unicast add 10.0.3.0/24
			}
		}
		update {
			attribute {
				origin igp
				next-hop 2A02:B80:0:2::1
				local-preference 200
				community [ 30740:0 30740:30740 ]
			}
			nlri {
				ipv6/unicast add 2A02:B80:0:1::/64
			}
		}
		process parsed-route-backend {
		}
	}
}
EOF_CONF

cmd=foreground:seq=1:exec=ze config validate -:stdin=config
expect=exit:code=0
