# Test: Invalid range value rejected
# VALIDATES: AC-3 — hold-time 2 triggers range validation error
stdin=config:terminator=EOF_CONF
bgp {
	router-id 1.2.3.4;
	local-as 65000;
	peer 192.0.2.1 {
		local-address 192.0.2.2;
		peer-as 65001;
		hold-time 2;
	}
}
EOF_CONF

cmd=foreground:seq=1:exec=ze validate -:stdin=config
expect=exit:code=1
expect=stderr:contains=hold-time
