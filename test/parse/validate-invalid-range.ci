# Test: Invalid range value rejected
# VALIDATES: AC-3 — receive-hold-time 2 triggers range validation error
stdin=config:terminator=EOF_CONF
bgp {
	router-id 1.2.3.4
	session {
		asn {
			local 65000
		}
	}
	peer peer1 {
		connection {
			remote {
				ip 192.0.2.1
			}
			local {
				ip 192.0.2.2
			}
		}
		session {
			asn {
				remote 65001
			}
		}
		timer {
			receive-hold-time 2
		}
	}
}
EOF_CONF

cmd=foreground:seq=1:exec=ze config validate -:stdin=config
expect=exit:code=1
expect=stdout:contains=receive-hold-time
