# Test: ze config validate with environment-only config
# Config with only environment {} and no functional sections is valid YANG.
# BGP validation only runs when bgp {} is present.
stdin=config:terminator=EOF_CONF
environment {
	log {
		level info
	}
}
EOF_CONF

cmd=foreground:seq=1:exec=ze config validate -:stdin=config
expect=exit:code=0
