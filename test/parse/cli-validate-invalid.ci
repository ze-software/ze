# Test: ze validate (new path) with invalid config
# This tests error handling for the moved validate command
stdin=config:terminator=EOF_CONF
# Invalid: missing bgp block
environment {
	log {
		level info
	}
}
EOF_CONF

cmd=foreground:seq=1:exec=ze validate -:stdin=config
expect=exit:code=1
expect=stderr:contains=missing required bgp { } block
