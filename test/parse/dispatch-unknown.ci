# Parse test: config without bgp {} block is valid
# BGP validation only runs when bgp {} is present. An environment-only
# config is valid YANG (supports interface-only, fib-only deployments).
stdin=config:terminator=EOF_CONF
environment {
	log {
		level info
	}
}
EOF_CONF

cmd=foreground:seq=1:exec=ze config validate -:stdin=config
expect=exit:code=0
