# Test: web listener with named list pattern
# VALIDATES: AC-10 -- web config with named list entries parses correctly
# PREVENTS: regression in YANG listener list normalization
stdin=config:terminator=EOF_CONF
bgp {
	router-id 10.0.0.1;
	session { asn { local 65533; } }
	peer peer1 {
		connection {
			remote { ip 127.0.0.1; }
			local { ip auto; }
		}
		session { asn { remote 65534; } }
	}
}
environment {
	web {
		enabled true;
		server main {
			ip 0.0.0.0;
			port 3443;
		}
	}
}
EOF_CONF

cmd=foreground:seq=1:exec=ze config validate -:stdin=config
expect=exit:code=0
expect=stdout:contains=configuration valid
