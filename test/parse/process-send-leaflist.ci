# Test: process send with leaf-list bracket syntax
stdin=config:terminator=EOF_CONF
plugin {
	external my-process {
		run ./syslog-1.py
		encoder json
	}
}
bgp {
	peer peer3 {
		remote {
			ip 10.0.0.3
			as 65533
		}
		local {
			as 65533
			ip 10.0.0.2
		}
		process my-process {
			send [ update ]
		}
	}
}
EOF_CONF

cmd=foreground:seq=1:exec=ze validate -:stdin=config
expect=exit:code=0
