# Test: CLI commands read meta/ssh/* keys after ze init
#
# VALIDATES: AC-5 -- sshclient.ReadCredentials reads namespaced keys.
# PREVENTS: CLI commands failing because sshclient reads old ssh/* keys.

# This test verifies the init + db round-trip: init writes meta/ssh/*,
# db cat reads them back. Full SSH connectivity is tested by other .ci tests
# that start a daemon.

tmpfs=test-cli-meta-keys.sh:mode=755:terminator=EOF_SH
#!/bin/sh
set -e

touch daemon.ready

INIT_DIR=$(mktemp -d)
trap 'rm -rf "$INIT_DIR"' EXIT

# Init credentials
printf 'testuser\ntestpass\n10.0.0.1\n3333\n\n' | ZE_CONFIG_DIR="$INIT_DIR" ze init

# Read back via ze db cat (uses raw blob keys)
USERNAME=$(ZE_CONFIG_DIR="$INIT_DIR" ze db cat meta/ssh/username)
[ "$USERNAME" = "testuser" ] || { echo "FAIL: username expected 'testuser', got '$USERNAME'" >&2; exit 1; }

PASSWORD=$(ZE_CONFIG_DIR="$INIT_DIR" ze db cat meta/ssh/password)
[ "$PASSWORD" = "testpass" ] || { echo "FAIL: password mismatch" >&2; exit 1; }

HOST=$(ZE_CONFIG_DIR="$INIT_DIR" ze db cat meta/ssh/host)
[ "$HOST" = "10.0.0.1" ] || { echo "FAIL: host expected '10.0.0.1', got '$HOST'" >&2; exit 1; }

PORT=$(ZE_CONFIG_DIR="$INIT_DIR" ze db cat meta/ssh/port)
[ "$PORT" = "3333" ] || { echo "FAIL: port expected '3333', got '$PORT'" >&2; exit 1; }

echo "OK: CLI reads meta/ssh/* keys after init" >&2
exit 0
EOF_SH

cmd=foreground:seq=1:exec=./test-cli-meta-keys.sh:timeout=10s
expect=exit:code=0
