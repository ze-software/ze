# Test: ze data reads meta/* keys from blob store
#
# VALIDATES: AC-5 -- blob store supports meta/ namespace keys.
# PREVENTS: CLI commands failing to read namespaced keys.

tmpfs=test-cli-meta-keys.sh:mode=755:terminator=EOF_SH
#!/bin/sh
set -e

touch daemon.ready

INIT_DIR=$(mktemp -d)
DB="$INIT_DIR/database.zefs"

# Init with piped prompts
printf 'admin\nsecret123\n10.0.0.1\n3333\n\n' | ZE_CONFIG_DIR="$INIT_DIR" ze init

# Verify host and port
HOST=$(ze data --path "$DB" cat meta/ssh/host)
[ "$HOST" = "10.0.0.1" ] || { echo "FAIL: host expected '10.0.0.1', got '$HOST'" >&2; exit 1; }

PORT=$(ze data --path "$DB" cat meta/ssh/port)
[ "$PORT" = "3333" ] || { echo "FAIL: port expected '3333', got '$PORT'" >&2; exit 1; }

# Password is stored as bcrypt hash
PASSWORD=$(ze data --path "$DB" cat meta/ssh/password)
echo "$PASSWORD" | grep -q '^\$2' || { echo "FAIL: password expected bcrypt hash, got '$PASSWORD'" >&2; exit 1; }

rm -rf "$INIT_DIR"
echo "OK: ze data reads meta/ssh/* keys" >&2
exit 0
EOF_SH

cmd=foreground:seq=1:exec=./test-cli-meta-keys.sh:timeout=10s
expect=exit:code=0
