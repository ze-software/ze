# Test: managed client starts from cached config when hub unreachable
#
# VALIDATES: AC-5 -- client starts BGP from cached config during partition.
# PREVENTS: Managed client refusing to start when hub is down.

tmpfs=test-backup-start.sh:mode=755:terminator=EOF_SH
#!/bin/sh
set -e

touch daemon.ready

INIT_DIR=$(mktemp -d)
DB="$INIT_DIR/database.zefs"
trap 'rm -rf "$INIT_DIR"' EXIT

# Init with --managed flag
printf 'admin\nsecret123\n127.0.0.1\n2222\nedge-01\n' | ZE_CONFIG_DIR="$INIT_DIR" ze init --managed

# Verify managed flag is set
MANAGED=$(ze data --path "$DB" cat meta/instance/managed)
[ "$MANAGED" = "true" ] || { echo "FAIL: not managed" >&2; exit 1; }

# Write a cached config (simulating previous successful fetch)
cat > "$INIT_DIR/edge-01.conf" <<'CONF'
bgp {
    peer p1 {
        connection {
            remote {
                ip 127.0.0.1
            }
            local {
                ip 127.0.0.1
            }
        }
        session {
            asn {
                local 65000
                remote 65001
            }
            router-id 1.2.3.4
        }
    }
}
plugin {
    hub {
        server local {
            host 127.0.0.1;
            port 1790;
            secret "local-secret-that-is-at-least-32ch";
        }
        client edge-01 {
            host 10.0.0.1;
            port 1791;
            secret "client-token-that-is-at-least-32ch";
        }
    }
}
CONF
ze data --path "$DB" import "$INIT_DIR/edge-01.conf"

# Verify cached config exists
ze data --path "$DB" ls 2>&1 | grep -q "edge-01.conf" || {
    echo "FAIL: cached config not found" >&2
    exit 1
}

echo "OK: cached config written for managed client" >&2
exit 0
EOF_SH

cmd=foreground:seq=1:exec=./test-backup-start.sh:timeout=10s
expect=exit:code=0
