# Test: config-changed notification protocol types
#
# VALIDATES: AC-3 -- config-changed notification carries version hash.
# PREVENTS: Stale version in notification causing fetch loop.
#
# Note: This tests the protocol types and handler logic via a shell script
# that exercises ze's config validation with server+client blocks.

tmpfs=test-config-change.sh:mode=755:terminator=EOF_SH
#!/bin/sh
set -e

touch daemon.ready

INIT_DIR=$(mktemp -d)
trap 'rm -rf "$INIT_DIR"' EXIT

# Init database
printf 'admin\nsecret123\n127.0.0.1\n2222\nhub-01\n' | ZE_CONFIG_DIR="$INIT_DIR" ze init

# Write hub config with server block + client entries
ZE_CONFIG_DIR="$INIT_DIR" ze data write hub-01.conf <<'CONF'
plugin {
    hub {
        server central {
            host 0.0.0.0;
            port 1791;
            secret "central-secret-that-is-at-least32";
            client edge-01 {
                secret "edge01-secret-that-is-at-least-32";
            }
            client edge-02 {
                secret "edge02-secret-that-is-at-least-32";
            }
        }
    }
}
CONF

# Validate config parses with multiple clients
ZE_CONFIG_DIR="$INIT_DIR" ze config validate hub-01.conf 2>&1 || {
    echo "FAIL: hub config with client entries failed validation" >&2
    exit 1
}

echo "OK: hub config with per-client entries parses for notification" >&2
exit 0
EOF_SH

cmd=foreground:seq=1:exec=./test-config-change.sh:timeout=10s
expect=exit:code=0
