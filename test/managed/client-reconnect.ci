# Test: managed client config with hub-level client block for reconnect
#
# VALIDATES: AC-7, AC-14 -- client extracts name, address, token from client block.
# PREVENTS: Client unable to find hub connection info for reconnect.

tmpfs=test-reconnect.sh:mode=755:terminator=EOF_SH
#!/bin/sh
set -e

touch daemon.ready

INIT_DIR=$(mktemp -d)
trap 'rm -rf "$INIT_DIR"' EXIT

# Init with --managed
printf 'admin\nsecret123\n127.0.0.1\n2222\nedge-01\n' | ZE_CONFIG_DIR="$INIT_DIR" ze init --managed

# Write cached config with hub-level client block (connection info for reconnect)
ZE_CONFIG_DIR="$INIT_DIR" ze data write edge-01.conf <<'CONF'
bgp {
    peer 127.0.0.1 {
        router-id 1.2.3.4;
        local-address 127.0.0.1;
        local-as 65000;
        peer-as 65001;
        connect false;
    }
}
plugin {
    hub {
        server local {
            host 127.0.0.1;
            port 1790;
            secret "local-secret-that-is-at-least-32ch";
        }
        client edge-01 {
            host 10.0.0.1;
            port 1791;
            secret "client-token-that-is-at-least-32ch";
        }
    }
}
CONF

# Validate config with client block parses
ZE_CONFIG_DIR="$INIT_DIR" ze config validate edge-01.conf 2>&1 || {
    echo "FAIL: config with client block failed validation" >&2
    exit 1
}

echo "OK: config with hub client block valid for reconnect" >&2
exit 0
EOF_SH

cmd=foreground:seq=1:exec=./test-reconnect.sh:timeout=10s
expect=exit:code=0
