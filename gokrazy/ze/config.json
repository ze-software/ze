{
    "Hostname": "ze",
    "Update": {},
    "Environment": [
        "GOOS=linux"
    ],
    "Packages": [
        "github.com/gokrazy/serial-busybox",
        "codeberg.org/thomas-mangin/ze/cmd/ze"
    ],
    "GokrazyPackages": [
        "github.com/gokrazy/gokrazy/cmd/randomd",
        "github.com/gokrazy/gokrazy/cmd/heartbeat"
    ],
    "PackageConfig": {
        "github.com/gokrazy/gokrazy/cmd/randomd": {
            "ExtraFileContents": {
                "/etc/machine-id": "8c41122ccef146da873e644db09cde89\n"
            }
        },
        "codeberg.org/thomas-mangin/ze/cmd/ze": {
            "CommandLineFlags": [
                "start"
            ],
            "Environment": [
                "ze.config.dir=/perm/ze",
                "ze.bgp.api.socketpath=/tmp/ze.socket",
                "ze.bgp.daemon.drop=false",
                "ze.log=info",
                "ze.log.backend=kmsg,stderr",
                "ze.gokrazy.enabled=true"
            ]
        }
    },
    "SerialConsole": "ttyS0,115200",
    "KernelPackage": "github.com/rtr7/kernel",
    "FirmwarePackage": "",
    "EEPROMPackage": ""
}
