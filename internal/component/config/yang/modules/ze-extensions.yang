module ze-extensions {
    namespace "urn:ze:extensions";
    prefix ze;

    description "YANG extensions for ZeBGP config parsing syntax modes.
                 These extensions control how the config parser handles
                 nodes that need special syntax beyond standard YANG.";

    revision 2026-01-01 {
        description "Initial revision";
    }

    // Extension: listener
    // Marks a list entry as a network listener endpoint.
    // Used by port conflict detection (CollectListeners) to find all
    // services that bind to ip:port pairs. Applied to list nodes inside
    // service containers (e.g., web > server, ssh > server).
    extension listener {
        description "Marks a list entry as a network listener endpoint
                     for port conflict detection at config parse time.";
    }

    // Extension: syntax
    // Controls how the config parser handles this node.
    //
    // Values:
    //   flex           - accepts flag (;), value (word;), or block ({...})
    //   freeform       - accepts arbitrary words until ; or {}
    //   inline-list    - list with key + attributes on same line
    //   family-block   - special address family syntax (ipv4/unicast;)
    //   multi-leaf     - multiple space-separated values on one line
    //   bracket        - bracketed syntax [ a b c ] for leaf-list
    //   value-or-array - accepts either value; or [ a b c ];
    extension syntax {
        argument mode;
        description "Specifies the parsing syntax mode for this node.";
    }

    // Extension: key-type
    // For inline-list nodes, specifies the key type.
    //
    // Values: string, prefix, ip, uint32
    extension key-type {
        argument type;
        description "Specifies the key type for inline-list nodes.";
    }

    // Extension: route-attributes
    // Marker that this node accepts standard BGP route attributes.
    // Used on inline-list nodes for static/announce routes.
    extension route-attributes {
        description "Node accepts standard route attributes
                     (next-hop, origin, community, etc.)";
    }

    // Extension: allow-unknown-fields
    // Container accepts arbitrary key-value pairs beyond defined leaves.
    // Used for dynamic configuration like per-subsystem log levels.
    // Unknown fields are stored as key-value strings.
    extension allow-unknown-fields {
        description "Container accepts arbitrary unknown fields as strings.
                     Used for environment.log to allow subsystem paths
                     like 'bgp.routes debug;' for ze.log.bgp.routes=debug.";
    }

    // Extension: sensitive
    // Marks a leaf as containing sensitive data (passwords, keys).
    // Sensitive values are displayed as $9$-encoded in config output
    // and can be replaced with /* SECRET-DATA */ via --strip-private.
    extension sensitive {
        description "Marks a leaf as containing sensitive data.
                     Values are obfuscated in display output using
                     JunOS-compatible $9$ encoding.";
    }

    // Extension: validate
    // References a registered Go function for runtime validation and completion.
    // Used only when YANG native constraints (enum, pattern, range) are insufficient —
    // primarily for runtime-determined valid sets (e.g., address families from plugins).
    // The argument is the validator function name registered via ValidatorRegistry.
    extension validate {
        argument name;
        description "References a custom validator function for runtime validation.
                     The function provides both Validate(path, value) and Complete()
                     for CLI tab-completion of valid values.";
    }

    // Extension: command
    // Marks a config false container as an executable command and references
    // the handler's WireMethod for dispatch (e.g., "ze-bgp:peer-list").
    // Without this extension, a config false container is just a grouping node
    // in the command tree (navigable but not executable).
    // The argument is the WireMethod string used for handler dispatch.
    extension command {
        argument handler;
        description "Marks a config false container as an executable CLI command.
                     The argument is the WireMethod (module:rpc-name) used for
                     handler dispatch. The YANG tree path defines the CLI hierarchy;
                     the handler argument connects it to the registered handler.";
    }

    // Extension: edit-shortcut
    // Marks a command as available in edit mode as a shortcut.
    // When typed in edit mode, implicitly runs as 'run <command>'.
    // Replaces the hardcoded editModeCommands map in model_mode.go.
    extension edit-shortcut {
        description "Marks a command as an edit mode shortcut.
                     Commands with this extension appear in edit mode completions
                     and execute as operational commands without requiring the
                     'run' prefix.";
    }

    // Extension: display-key
    // Marks a leaf in a keyless list as the display label for UI navigation.
    // The web interface uses this leaf's value as the entry name in the finder,
    // and shows it as an optional input when creating new entries.
    // If the leaf is empty, the UI falls back to child list keys or the index.
    extension display-key {
        description "Marks a leaf as the display label for keyless list entries.
                     The web interface reads this extension to determine which
                     leaf to show in navigation and prompt for on creation.";
    }

    // Extension: os
    // Restricts a node to a specific operating system.
    // When the runtime OS does not match the argument, the node is excluded
    // from the schema -- it will not appear in config, CLI, or web UI.
    // The argument is a GOOS value. Valid values: linux, darwin, freebsd, openbsd, windows.
    // A typo silently hides the node on all platforms -- test after adding.
    extension os {
        argument goos;
        description "Restricts this node to the specified operating system.
                     Nodes with ze:os are excluded from the schema when
                     the runtime OS does not match.";
    }

    // Extension: cumulative
    // Marks a leaf-list as cumulative during config resolution.
    // Normal leaf-lists are replaced by more-specific config levels (peer > group > bgp).
    // Cumulative leaf-lists append values from all levels instead of replacing.
    // Used for filter tag/strip lists that must gather values across config hierarchy.
    extension cumulative {
        description "Marks a leaf-list as cumulative during config resolution.
                     Values from bgp, group, and peer levels are accumulated
                     (appended) instead of the most-specific level replacing others.";
    }

    // Extension: required
    // Declares a field path that must have a value in a list entry after
    // config inheritance resolution (bgp -> group -> peer merge).
    // Applied to list nodes. The argument is a slash-separated path
    // (e.g., "session/asn/remote"). Multiple ze:required statements
    // can appear on the same list.
    extension required {
        argument path;
        description "Declares a field that must have a value after config
                     inheritance resolution. Used for post-resolve validation
                     and to mark required fields in creation forms.";
    }

    // Extension: suggest
    // Declares a field path that should be shown in the creation dialog
    // but is not mandatory. Applied to list nodes. The argument is a
    // slash-separated path (e.g., "connection/local/ip").
    extension suggest {
        argument path;
        description "Declares a field to show in creation dialogs with
                     inherited defaults. Not mandatory -- the entry can
                     be created without it.";
    }

    // Extension: hidden
    // Marks a leaf as hidden from config display and the web editor.
    // Hidden leaves are stored in the config tree but not shown in the UI
    // or config output. Used for internal metadata fields (e.g., PeeringDB
    // update timestamps).
    extension hidden {
        argument value;
        description "Marks a leaf as hidden from config display and web editor.
                     The argument is a boolean string (true/false).";
    }

    // Extension: decorate
    // Attaches a display-time decorator to a leaf.
    // The argument names a registered decorator function (e.g., "asn-name").
    // When the web UI renders a decorated leaf, it calls the decorator to
    // obtain supplementary display text (e.g., AS number -> org name).
    extension decorate {
        argument name;
        description "Attaches a display-time decorator to a leaf.
                     The argument names a registered decorator function
                     that resolves supplementary display text for the value.";
    }
}
