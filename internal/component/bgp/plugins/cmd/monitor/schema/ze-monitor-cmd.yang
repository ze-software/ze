module ze-monitor-cmd {
    namespace "urn:ze:monitor:cmd";
    prefix moncmd;
    import ze-extensions { prefix ze; }
    description "BGP monitor command tree";
    revision 2026-03-17 { description "Initial revision"; }

    container bgp {
        config false;
        description "BGP operations";

        container monitor {
            config false;
            ze:command "ze-bgp:monitor";
            description "Stream live BGP events";
        }
    }
}
