module ze-sysrib-conf {
    namespace "urn:ze:sysrib:conf";
    prefix sysrib;

    description
        "System RIB internal module for Ze.
         The sysrib plugin is loaded as a dependency of FIB backends,
         not directly by user config. Admin distance settings are
         configured under fib { admin-distance { } } in ze-fib-conf.";

    revision 2026-04-04 {
        description "Initial revision. Internal module, no user-facing containers.";
    }
}
